# www.nigredo.ch - Apache Konfiguration
# Saubere URLs ohne .html Endung

Options -MultiViews -Indexes
RewriteEngine On

# Einheitliche Zeichensatzangabe auch auf HTTP-Header-Ebene
AddDefaultCharset UTF-8

# HTTPS erzwingen
# Einige Hoster terminieren SSL vor Apache. In dem Fall bleibt %{HTTPS} intern "off",
# obwohl der Browser bereits per HTTPS verbunden ist. X-Forwarded-Proto verhindert Redirect-Loops.
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Kanonische Domain erzwingen
RewriteCond %{HTTP_HOST} !^www\.nigredo\.ch$ [NC]
RewriteRule ^ https://www.nigredo.ch%{REQUEST_URI} [L,R=301]

# Entfernte SEO-Landingpages dauerhaft auf die beste kanonische Zielseite führen
RewriteRule ^faq-webdesign/?$ /haeufige-fragen/ [L,R=301]
RewriteRule ^lokale-seo/?$ /digitale-loesungen/ [L,R=301]
RewriteRule ^website-fuer-kmu-selbststaendige/?$ /digitale-loesungen/ [L,R=301]
RewriteRule ^website-technik-cms/?$ /digitale-loesungen/ [L,R=301]

# Kanonische Directory-URLs mit Trailing Slash
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.+[^/])$ /$1/ [L,R=301]

# Astro Directory-Build: /pfad -> /pfad/index.html
# Dadurch bleiben saubere URLs ohne Slash möglich, obwohl der Build Verzeichnisse erzeugt.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
RewriteRule ^(.+)$ /$1/index.html [L]

# 404 Fehlerseite
ErrorDocument 404 /404.html

# Sicherheitsheader
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=(), display-capture=(), interest-cohort=(), idle-detection=(), serial=(), ambient-light-sensor=(), battery=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-origin"
    Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; form-action 'self'; script-src 'self' https://cloud.umami.is 'sha256-Qix3JATzJhnAoy5h5hdKG3aimHHuJTAmtpyE1WqRKtw=' 'sha256-4oXEtvDVUGje1DzYKf+NPJrMZeQ2NVW5trg2DdLl6QY=' 'sha256-415FHitiDih1Xu9qT49w1y0SiGJrN84MWRNQPWNi5YE=' 'sha256-w4DK1IRs3SUk4cEQ9L7uL2PAlqnf/gPVsNNFATlXbCM=' 'sha256-SLhnYCTzxHKMfx5X+tdaMA0DlVQWQUl6naFs8Mies/8=' 'sha256-QUrMqAREyGy8RrckhQsFnvWl2Qh+Eih4paCiM0sZJng=' 'sha256-83aTr00Ac+ta6nNHgcQViWWIIZPpNRRwHem2rv9/y0g=' 'sha256-e/xK1KuEWXAOSYnlI+C/q5iLfulbG1lMvpyN/OG33eY=' 'sha256-HvS924qOhxKPsEjJiD7aaTgq4e/kE80q4Ajh/z9zAzo=' 'sha256-wXkPUIwmXg2Vodrv4DfgqfIHRHA4MPzWtXfUny3s/YY=' 'sha256-HWhMmAf+9MPgnUzeLeNfAk72SHbWiiQwARpw/Qm9oek=' 'sha256-1HuPBevNszlqLaUqVMr1rEyIpccQAYaMwl/bkTgPmOQ=' 'sha256-aG8eJ6dZS4EEp7P4il1weJL8WmsdZ3nhH9yFe0AuA10=' 'sha256-B9HKp+Hev8/IdEPCM2WgdAYjGEOeS/r2iR+1Jk6wXOQ=' 'sha256-ee7Ek+QrX7LWMLXELZKrd3elZSxJRiM3TdNuQrR6cxw='; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://cloud.umami.is; frame-ancestors 'none'"
    Header append Vary "Accept-Encoding"
    <FilesMatch "\.(?:avif|css|gif|ico|jpe?g|js|mjs|png|svg|webp|woff2?|ttf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(?:html|php)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
</IfModule>

# Brotli/GZIP Kompression
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript application/json image/svg+xml text/plain application/xml text/xml
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/plain application/xml text/xml
</IfModule>

# Browser Caching für statische Assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/avif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>
