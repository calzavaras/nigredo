# www.nigredo.ch - Apache Konfiguration
# Saubere URLs ohne .html Endung

Options -MultiViews -Indexes
RewriteEngine On

# Einheitliche Zeichensatzangabe auch auf HTTP-Header-Ebene
AddDefaultCharset UTF-8

# Kanonische Domain zuerst erzwingen, damit alle Varianten direkt auf www landen.
RewriteCond %{HTTP_HOST} !^www\.nigredo\.ch$ [NC]
RewriteRule ^ https://www.nigredo.ch%{REQUEST_URI} [L,R=301]

# HTTPS erzwingen
# Einige Hoster terminieren SSL vor Apache. In dem Fall bleibt %{HTTPS} intern "off",
# obwohl der Browser bereits per HTTPS verbunden ist. X-Forwarded-Proto verhindert Redirect-Loops.
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteRule ^ https://www.nigredo.ch%{REQUEST_URI} [L,R=301]

# Entfernte SEO-Landingpages dauerhaft auf die beste kanonische Zielseite führen
RewriteRule ^faq-webdesign/?$ /haeufige-fragen/ [L,R=301]
RewriteRule ^lokale-seo/?$ /digitale-loesungen/ [L,R=301]
RewriteRule ^website-fuer-kmu-selbststaendige/?$ /digitale-loesungen/ [L,R=301]
RewriteRule ^website-technik-cms/?$ /digitale-loesungen/ [L,R=301]

# Kanonische Directory-URLs mit Trailing Slash
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.+[^/])$ /$1/ [L,R=301]

# Astro Directory-Build: /pfad -> /pfad/index.html
# Dadurch bleiben saubere URLs ohne Slash möglich, obwohl der Build Verzeichnisse erzeugt.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
RewriteRule ^(.+)$ /$1/index.html [L]

# 404 Fehlerseite
ErrorDocument 404 /404.html

# Sicherheitsheader
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=(), display-capture=(), interest-cohort=(), idle-detection=(), serial=(), ambient-light-sensor=(), battery=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-origin"
    Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; form-action 'self'; script-src 'self' https://cloud.umami.is 'sha256-OK+dwxdOIqmRsEnLod7/mWX+mY1IxkaRL5C83Y6yGjk=' 'sha256-4oXEtvDVUGje1DzYKf+NPJrMZeQ2NVW5trg2DdLl6QY=' 'sha256-pNpHBnOF5uPR2QMg1lyDZhNdaxyj6oir9np1EQN2s48=' 'sha256-KzL/7vWMsGf6Ab/3+Vz6kckDi524AhIA63HCdtWxxpY=' 'sha256-jmn/2vz6lznnDL+Qu+nsKp276xf8NI4mKsypWUYojfs=' 'sha256-SndlS3XI3z0xII9tVc3xuQQPx1xbISwLToU2BiFWuDo=' 'sha256-X87DG7FlprKWXwJSVN5CcvvdChdoJtr0bruEC23LBmo=' 'sha256-QUrMqAREyGy8RrckhQsFnvWl2Qh+Eih4paCiM0sZJng=' 'sha256-4E9MzbsNlSblBwLK6A4+kjyToWJCJ+CBirMJHg+KZPE=' 'sha256-ry9hEBP2v1T8oXNx8jGz6RpAaDDS3sO3zQkDPMMXF8Q=' 'sha256-Hl01zZWNFOhulvP6XhwCsr/YjrDu/no3t6JaERdVWEY=' 'sha256-wXkPUIwmXg2Vodrv4DfgqfIHRHA4MPzWtXfUny3s/YY=' 'sha256-HWhMmAf+9MPgnUzeLeNfAk72SHbWiiQwARpw/Qm9oek=' 'sha256-LqB6R7RYeehwBbha6WmosczhjVaqwDWqUf60V4IHAxs=' 'sha256-aG8eJ6dZS4EEp7P4il1weJL8WmsdZ3nhH9yFe0AuA10=' 'sha256-giTlpJ4/YXGxgksVaX2mf5hEUDDEBzDmJlbSYI2E054=' 'sha256-ee7Ek+QrX7LWMLXELZKrd3elZSxJRiM3TdNuQrR6cxw='; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://cloud.umami.is; frame-ancestors 'none'"
    Header append Vary "Accept-Encoding"
    <FilesMatch "\.(?:avif|css|gif|ico|jpe?g|js|mjs|png|svg|webp|woff2?|ttf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(?:html|php)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
</IfModule>

# Brotli/GZIP Kompression
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript application/json image/svg+xml text/plain application/xml text/xml
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/plain application/xml text/xml
</IfModule>

# Browser Caching für statische Assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/avif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>
