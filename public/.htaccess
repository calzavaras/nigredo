# www.nigredo.ch - Apache Konfiguration
# Saubere URLs ohne .html Endung

Options -MultiViews -Indexes
RewriteEngine On

# Einheitliche Zeichensatzangabe auch auf HTTP-Header-Ebene
AddDefaultCharset UTF-8

# Kanonische Domain zuerst erzwingen, damit alle Varianten direkt auf www landen.
RewriteCond %{HTTP_HOST} !^www\.nigredo\.ch$ [NC]
RewriteRule ^ https://www.nigredo.ch%{REQUEST_URI} [L,R=301]

# HTTPS erzwingen
# Einige Hoster terminieren SSL vor Apache. In dem Fall bleibt %{HTTPS} intern "off",
# obwohl der Browser bereits per HTTPS verbunden ist. X-Forwarded-Proto verhindert Redirect-Loops.
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteRule ^ https://www.nigredo.ch%{REQUEST_URI} [L,R=301]

# Direkt aufgerufene Index-Dateien auf die kanonische Directory-URL führen.
# THE_REQUEST verhindert Redirect-Loops mit dem internen Astro-Rewrite auf index.html.
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [L,R=301]
RewriteCond %{THE_REQUEST} \s/+(.+)/index\.html[\s?] [NC]
RewriteRule ^(.+)/index\.html$ /$1/ [L,R=301]

# Entfernte SEO-Landingpages dauerhaft auf die beste kanonische Zielseite führen
RewriteRule ^faq-webdesign/?$ /haeufige-fragen/ [L,R=301]
RewriteRule ^lokale-seo/?$ /digitale-loesungen/ [L,R=301]
RewriteRule ^website-fuer-kmu-selbststaendige/?$ /digitale-loesungen/ [L,R=301]
RewriteRule ^website-technik-cms/?$ /digitale-loesungen/ [L,R=301]

# Kanonische Directory-URLs mit Trailing Slash
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.+[^/])$ /$1/ [L,R=301]

# Astro Directory-Build: /pfad -> /pfad/index.html
# Dadurch bleiben saubere URLs ohne Slash möglich, obwohl der Build Verzeichnisse erzeugt.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
RewriteRule ^(.+)$ /$1/index.html [L]

# 404 Fehlerseite
ErrorDocument 404 /404.html

# Sicherheitsheader
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=(), display-capture=(), interest-cohort=(), idle-detection=(), serial=(), ambient-light-sensor=(), battery=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-origin"
    Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; form-action 'self'; script-src 'self' https://cloud.umami.is 'sha256-r5zh2QbSLOXMzgYpuPbONKxkeBbZhRjeEnyZT7prnCM=' 'sha256-4oXEtvDVUGje1DzYKf+NPJrMZeQ2NVW5trg2DdLl6QY=' 'sha256-rBSmqzQAeFm9n6NcWJfXd7vnHeZ5le0bkNgHM2m1Mek=' 'sha256-5h6SW16YLILu/1MJR0sHmSwFQqErUeJQajgyC+4DYZQ=' 'sha256-UWEvoYljK5qNZFqVax7Xbg09Ug2VZpD37foX70CG2GA=' 'sha256-59hltD/Y+dv1u1JNghQy0Pqp1nSVofL8lJIi2RZPudE=' 'sha256-BcHYHXtM4Jo5iPhuiUlgomV1jd/PA+1ZfQYR+EJJhK8=' 'sha256-mdIXanX9+uPxbYyVFGBcFcRA9KH1uMtF4RFhWNdPwNA=' 'sha256-dpAKgzVH26PSLeban64mF8k9jBhCyl+pXO3npL0Cu7c=' 'sha256-lZzEw40xw+UypJDiSG6lbCDWy5/RnJt32haFU+Uae2Q=' 'sha256-UEY6z0gN2K20QH7OkrdykQODY0gAJa5ghY9MF1yrKgM=' 'sha256-QUrMqAREyGy8RrckhQsFnvWl2Qh+Eih4paCiM0sZJng=' 'sha256-1KQxB7+EU5mJdzKNg7yy0KMR8ypRn812t7RsovXtysA=' 'sha256-xrNbkGvbDPA8lO8EmS6TcHCCBaKpvv88flSLiHNrj6g=' 'sha256-VoTScYJV9IrzwchFmsdgHJWJcYVQBNvu6AwCEaxMayQ=' 'sha256-wXkPUIwmXg2Vodrv4DfgqfIHRHA4MPzWtXfUny3s/YY=' 'sha256-HWhMmAf+9MPgnUzeLeNfAk72SHbWiiQwARpw/Qm9oek=' 'sha256-U4MAlStjb0ZuFHYCq6RZkODKCp70TW3WLVIn3AwGyhU=' 'sha256-aG8eJ6dZS4EEp7P4il1weJL8WmsdZ3nhH9yFe0AuA10=' 'sha256-iil2bbWLKK9OCxgD1K8ppoBKyUb7gR2oMpv+gWiE5Xs=' 'sha256-L4jee1IL2NSWzCLLAFOU3NOMFlg8ZvrKSnNEahqzRdM=' 'sha256-HaFGJmMTLpcjJyHqRthhwvQvLO+1iRMJ06LQVcWZ5NE=' 'sha256-9fgntxoHOpDPu/YeK70YpydPDKS5FIgFDVAvcM99J3M=' 'sha256-ee7Ek+QrX7LWMLXELZKrd3elZSxJRiM3TdNuQrR6cxw='; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://cloud.umami.is; frame-ancestors 'none'"
    <Files "send-mail.php">
        Header set X-Robots-Tag "noindex, nofollow, noarchive"
    </Files>
    Header append Vary "Accept-Encoding"
    <FilesMatch "\.(?:avif|css|gif|ico|jpe?g|js|mjs|png|svg|webp|woff2?|ttf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(?:html|php)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
</IfModule>

# Brotli/GZIP Kompression
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript application/json image/svg+xml text/plain application/xml text/xml
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/plain application/xml text/xml
</IfModule>

# Browser Caching für statische Assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/avif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>
