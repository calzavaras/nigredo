# www.nigredo.ch - Apache Konfiguration
# Saubere URLs ohne .html Endung

Options -MultiViews -Indexes
RewriteEngine On

# Einheitliche Zeichensatzangabe auch auf HTTP-Header-Ebene
AddDefaultCharset UTF-8

# Kanonische Domain zuerst erzwingen, damit alle Varianten direkt auf www landen.
RewriteCond %{HTTP_HOST} !^www\.nigredo\.ch$ [NC]
RewriteRule ^ https://www.nigredo.ch%{REQUEST_URI} [L,R=301]

# HTTPS erzwingen
# Einige Hoster terminieren SSL vor Apache. In dem Fall bleibt %{HTTPS} intern "off",
# obwohl der Browser bereits per HTTPS verbunden ist. X-Forwarded-Proto verhindert Redirect-Loops.
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteRule ^ https://www.nigredo.ch%{REQUEST_URI} [L,R=301]

# Direkt aufgerufene Index-Dateien auf die kanonische Directory-URL führen.
# THE_REQUEST verhindert Redirect-Loops mit dem internen Astro-Rewrite auf index.html.
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [L,R=301]
RewriteCond %{THE_REQUEST} \s/+(.+)/index\.html[\s?] [NC]
RewriteRule ^(.+)/index\.html$ /$1/ [L,R=301]

# Entfernte SEO-Landingpages dauerhaft auf die beste kanonische Zielseite führen
RewriteRule ^faq-webdesign/?$ /haeufige-fragen/ [L,R=301]
RewriteRule ^lokale-seo/?$ /digitale-loesungen/ [L,R=301]
RewriteRule ^website-fuer-kmu-selbststaendige/?$ /digitale-loesungen/ [L,R=301]
RewriteRule ^website-technik-cms/?$ /digitale-loesungen/ [L,R=301]

# Kanonische Directory-URLs mit Trailing Slash
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.+[^/])$ /$1/ [L,R=301]

# Astro Directory-Build: /pfad -> /pfad/index.html
# Dadurch bleiben saubere URLs ohne Slash möglich, obwohl der Build Verzeichnisse erzeugt.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
RewriteRule ^(.+)$ /$1/index.html [L]

# 404 Fehlerseite
ErrorDocument 404 /404.html

# Sicherheitsheader
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=(), display-capture=(), interest-cohort=(), idle-detection=(), serial=(), ambient-light-sensor=(), battery=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-origin"
    Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; form-action 'self'; script-src 'self' https://cloud.umami.is 'sha256-UMcjKGH8NsKazZH5B3FzwnZU3v2+4cqF9shjpXr6Gxc=' 'sha256-2RKtJh2ZQzxpl1r3lXPQiXCM8k8DUhKQ678sxVjjT1k=' 'sha256-nDXbU2pqGzSCYa4PCGtU48QUfmYiRaXBf6CzhrB4Po0=' 'sha256-vP4GBadCHdwEkcmEfcK6MnZLQjr+n42Dn7mUci12AEY=' 'sha256-zBAVLXImJmg1f/k9q+kYVrf0pF86dX6Q5nf00KW7EpQ=' 'sha256-S58uYPfx+asnzK8NkiHJict8XGBLkQd2W1qcqyWRw/g=' 'sha256-rK4ukImasB0Aojdf4FXsEYmrTslBRiK5tmG8EdKf9o4=' 'sha256-+t6Or8VBccoV789lW/jGQdvQRpO6oPf4CCb1ugpE7dg=' 'sha256-1TrnoewRn7XuruQfHD63YiklJH/RCiTCSOQeNcsDrT4=' 'sha256-D+F+cKuFzS+XHjoS7d6+SdR9+zVNIiFRWCPTiN9GM+A=' 'sha256-yG7JE3zvrjHehIUVbt1WcGdLRUfFdUWLXcMbzmNtTzM=' 'sha256-QUrMqAREyGy8RrckhQsFnvWl2Qh+Eih4paCiM0sZJng=' 'sha256-G4lugb/cAfFjrMgnRKpOHkk3pgnjBYP5Xer6Qzu4x6o=' 'sha256-UiqBNX53Ba6B88h6wyyahwtZiTeqXKc6tXDdMfaTV/Q=' 'sha256-8m+V14H9GI7U/0kpPW9r+OjKQI7QPeeYONa6mVDxFQ4=' 'sha256-wXkPUIwmXg2Vodrv4DfgqfIHRHA4MPzWtXfUny3s/YY=' 'sha256-ndkE6E6px5JOVHRWbJWZlAOM8kxuoBjxsWqvAUZIp6k=' 'sha256-JjktpNP/uGuJhBEKze70pgHbGobCH+J1KwvmqsXChPk=' 'sha256-vuuEbSzr7wB9/D4W29X0ulcNiJxmCyZWBSq6Hi0kYMk=' 'sha256-Q9dxjvEGDtKCw8JWQFluOIhCqUEh5upqxjevsKhEEQo=' 'sha256-b9vJBIOdMkm0JISiRYaYc5HbZ4wR09ZafzFknQrN0uE=' 'sha256-/vuRwPAACkK7Cui+v8SffEndtuWcrVQVkoR0Mur/wCg=' 'sha256-22QHopD168c41GEsqWhzJCfezco/SygG1MvMlc10+Bc=' 'sha256-aoPYvjfSXUEJsFGy7bv3viE3aIl9tBFCDn3NMu+z15k=' 'sha256-/yzNRM+nlUQQ4gYtTbm2BwtFmPMdSR0gyv80U9tQGX0='; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://cloud.umami.is; frame-ancestors 'none'"
    <Files "send-mail.php">
        Header set X-Robots-Tag "noindex, nofollow, noarchive"
    </Files>
    Header append Vary "Accept-Encoding"
    <FilesMatch "\.(?:avif|css|gif|ico|jpe?g|js|mjs|png|svg|webp|woff2?|ttf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(?:html|php)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
</IfModule>

# Brotli/GZIP Kompression
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript application/json image/svg+xml text/plain application/xml text/xml
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/plain application/xml text/xml
</IfModule>

# Browser Caching für statische Assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/avif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>
