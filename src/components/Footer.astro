      <div class="footer-col footer-col--brand">
        <span class="footer-label">Aus St. Gallen</span>
        <div class="footer-stack">
          <p class="footer-intro">Nigredo</p>
          <address class="footer-address">
            Wildeggstrasse 37<br>
            9000 St. Gallen<br>
            Schweiz
          </address>
        </div>
      </div>
      <div class="footer-col">
        <span class="footer-label">Entdecken</span>
        <nav class="footer-menu" aria-label="Hauptseiten">
          <a href="/referenzen/">Referenzen</a>
          <a href="/digitale-loesungen/">Lösungen</a>
          <a href="/marco-calzavara/">Über mich</a>
          <a href="/haeufige-fragen/">Häufige Fragen</a>
        </nav>
      </div>
      <div class="footer-col">
        <span class="footer-label">Kontakt</span>
