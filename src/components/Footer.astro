---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-glow"></div>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col">
        <span class="footer-label">Adresse</span>
        <div class="footer-stack">
          <span class="footer-logo">Nigredo</span>
          <address class="footer-address">
            Wildeggstrasse 37<br>
            9000 St. Gallen<br>
            Schweiz
          </address>
        </div>
      </div>
      <div class="footer-col">
        <span class="footer-label">Information</span>
        <nav class="footer-menu" aria-label="Information">
          <a href="/haeufige-fragen/">Häufige Fragen</a>
        </nav>
      </div>
      <div class="footer-col">
        <span class="footer-label">Profile</span>
        <nav class="footer-menu" aria-label="Externe Profile">
          <a href="https://ch.linkedin.com/in/calzavara-marco" rel="me noopener" target="_blank">LinkedIn</a>
        </nav>
      </div>
      <div class="footer-col">
        <span class="footer-label">Rechtliches</span>
        <nav class="footer-menu" aria-label="Rechtliche Links">
          <a href="/impressum/">Impressum</a>
          <a href="/datenschutz/">Datenschutz</a>
        </nav>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="footer-divider"></div>
      <div class="footer-bottom-content">
        <span class="copyright">&copy; {year} Marco Calzavara. Alle Rechte vorbehalten.</span>
        <span class="swiss-made">Gebaut mit Anspruch.</span>
      </div>
    </div>
  </div>
</footer>
