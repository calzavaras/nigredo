---
import Breadcrumb from './Breadcrumb.astro';
import ReferenzVisual from './ReferenzVisual.astro';
import {
  getReferencePageHref,
  type ReferenceEntry,
} from '../data/references';

interface Props {
  pageNumber: number;
  pageCount: number;
  pageItems: ReferenceEntry[];
}

const { pageNumber, pageCount, pageItems } = Astro.props;
const prevHref = pageNumber > 1 ? getReferencePageHref(pageNumber - 1) : null;
const nextHref = pageNumber < pageCount ? getReferencePageHref(pageNumber + 1) : null;
const archiveImageSizes = '(max-width: 700px) calc(100vw - 44px), (max-width: 1024px) calc(50vw - 44px), 432px';
const breadcrumbItems = [
  { label: 'Start', href: '/' },
  { label: 'Referenzen', href: '/referenzen/' },
];

if (pageNumber > 1) {
  breadcrumbItems.push({ label: `Seite ${pageNumber}` });
}
---

<section class="section pt-sub refs-hero" aria-labelledby="referenzen-title">
  <div class="hero-glow"></div>
  <div class="container refs-hero__container">
    <Breadcrumb items={breadcrumbItems} />

    <div class="fade-up home-hero__inner refs-intro">

      <h1 id="referenzen-title" class="home-hero__title refs-hero__title">
        Echte Aufgaben.<br>
        <span class="gradient-text">Echte Ergebnisse.</span>
      </h1>
      <p class="hero-lead refs-hero__lead">
        Websites, KI-Anwendungen und digitale Werkzeuge für konkrete Anforderungen. Jede Referenz zeigt die Ausgangslage, den gewählten Weg und das Ergebnis.
      </p>
      {pageCount > 1 && (
        <p class="refs-page-kicker">Seite {pageNumber} von {pageCount}</p>
      )}
    </div>

    <div
      id="refs-grid"
      class="refs-grid"
    >
      {pageItems.map((reference, index) => (
        <article
          class={`ref-main-card${reference.linkCls === 'ref-main-link--ki' ? ' ref-main-card--ki' : ''}${reference.badge.cls === 'accent-cyan' ? ' ref-main-card--app' : ''}`}
        >
          <ReferenzVisual reference={reference} sizes={archiveImageSizes} priority={index === 0} />
          <div class="ref-main-card-body">
            <div class="ref-main-card-header">
              <h2 class="ref-main-card-title">{reference.listTitle}</h2>
              <span class="ref-main-card-year">{reference.year}</span>
            </div>
            <p class="ref-main-card-sub">{reference.sub}</p>
            <p class="ref-main-card-desc">{reference.listDesc}</p>
            <p class="ref-main-card-role"><span>Rolle:</span> {reference.rolle}</p>
            <div class="ref-main-card-footer">
              <a href={reference.href} class={`ref-main-link ref-main-link--stretched ${reference.linkCls}`.trim()} aria-label={reference.ariaLabel}>Details <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
              {reference.liveUrl ? (
                <a href={reference.liveUrl} class="ref-main-live-link" target="_blank" rel="noopener" aria-label={`${reference.listTitle} Website in neuem Tab öffnen`}>Website ansehen <span aria-hidden="true">↗</span></a>
              ) : (
                <span class="ref-main-live-note">{reference.liveNote}</span>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>

    {pageCount > 1 && (
      <nav class="refs-pagination" aria-label="Referenzen Seiten">
        {prevHref ? (
          <a href={prevHref} class="refs-page-link refs-page-link--edge">Zurück</a>
        ) : <span class="refs-page-link refs-page-link--edge is-disabled">Zurück</span>}

        <div class="refs-page-list">
          {Array.from({ length: pageCount }, (_, index) => {
            const targetPage = index + 1;
            const href = getReferencePageHref(targetPage);
            const isCurrent = targetPage === pageNumber;

            return isCurrent ? (
              <span class="refs-page-link is-current" aria-current="page">{targetPage}</span>
            ) : (
              <a href={href} class="refs-page-link">{targetPage}</a>
            );
          })}
        </div>

        {nextHref ? (
          <a href={nextHref} class="refs-page-link refs-page-link--edge">Weiter</a>
        ) : <span class="refs-page-link refs-page-link--edge is-disabled">Weiter</span>}
      </nav>
    )}

    <div class="section refs-final-section">
      <div class="section-cta refs-final-cta fade-up">
        <span class="cta-label">Der nächste Schritt</span>
        <h2>Dein Projekt soll hier stehen?<br><span>Erzähl mir davon.</span></h2>
        <div class="hero-cta-group" style="justify-content: center;">
          <a href="/kontakt/" class="btn btn-primary">Kontakt aufnehmen</a>
          <a href="/marco-calzavara/" class="btn btn-ghost">Über mich</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .refs-hero {
    --refs-a: var(--brand-cyan);
    --refs-b: var(--brand-violet);
    --refs-c: var(--brand-coral);
    animation: none;
  }

  .refs-hero {
    min-height: min(620px, 68vh);
    display: flex;
    align-items: center;
    padding-top: var(--hero-offset-top-breadcrumb);
    padding-bottom: var(--hero-offset-bottom);
  }

  .refs-hero__container {
    position: relative;
    width: 100%;
  }

  .refs-hero .home-hero__inner {
    width: 100%;
  }

  .refs-hero .breadcrumb {
    margin-bottom: 28px;
  }

  .refs-hero .badge {
    margin-bottom: 0.95rem;
    color: rgba(219, 253, 249, 0.94);
    border-color: color-mix(in srgb, var(--refs-b) 34%, rgba(255, 255, 255, 0.22));
    background: transparent;
    box-shadow: none;
  }

  .refs-hero__title {
    max-width: 940px;
    font-size: var(--hero-title-size);
    line-height: var(--hero-title-line-height);
    letter-spacing: -0.015em;
    margin-bottom: clamp(24px, 3vw, 30px);
  }

  .refs-hero .gradient-text {
    background: var(--brand-gradient-mixed);
    background-size: 100% auto;

    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    filter:
      drop-shadow(0 0 12px color-mix(in srgb, var(--refs-a) 22%, transparent))
      drop-shadow(0 0 18px color-mix(in srgb, var(--refs-c) 14%, transparent));
  }

  .refs-hero__lead {
    max-width: 620px;
    font-size: var(--lead-size);
    line-height: 1.65;
  }

  .refs-hero .hero-glow {
    background:
      radial-gradient(circle at 20% 36%, color-mix(in srgb, var(--refs-a) 18%, transparent) 0%, transparent 34%),
      radial-gradient(circle at 56% 46%, color-mix(in srgb, var(--refs-b) 17%, transparent) 0%, transparent 30%),
      radial-gradient(circle at 84% 30%, color-mix(in srgb, var(--refs-c) 16%, transparent) 0%, transparent 24%);
  }

  .refs-page-kicker {
    margin-top: 22px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  .refs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(24px, 3vw, 32px);
    margin-bottom: clamp(32px, 4vw, 40px);
    align-items: stretch;
  }

  .refs-intro {
    max-width: 940px;
    margin-bottom: clamp(60px, 7vw, 76px);
  }

  .ref-main-card {
    --card-accent: var(--neon-red);
    display: flex;
    flex-direction: column;
    height: 100%;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(10, 10, 12, 0.75);
    background-clip: padding-box;
    overflow: hidden;
    color: #fff;
    position: relative;
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1),
                border-color 0.4s ease,
                box-shadow 0.4s ease;
  }

  .ref-main-card--ki {
    --card-accent: var(--tertiary-accent);
  }

  .ref-main-card--app {
    --card-accent: var(--quaternary-accent);
  }

  @media (hover: hover) {
    .ref-main-card:hover {
      transform: translateY(-4px);
      border-color: rgba(255, 255, 255, 0.16);
      box-shadow: var(--shadow-card-hover);
    }
    .ref-main-card:hover .referenz-visual__image {
      transform: scale(1.04);
    }
  }

  .ref-main-card-body {
    padding: clamp(24px, 2.4vw, 32px) clamp(22px, 2.6vw, 28px);
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
  }

  .ref-main-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
  }

  .ref-main-card-year {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.3);
    white-space: nowrap;
    padding-top: 4px;
  }

  .ref-main-card-title {
    font-size: 1.22rem;
    font-weight: 700;
    margin: 0;
    color: #fff;
  }

  .ref-main-card-sub {
    font-size: 0.875rem;
    color: var(--secondary-accent);
    margin-bottom: 16px;
    font-weight: 500;
  }

  .ref-main-card--ki .ref-main-card-sub {
    color: #c69aff;
  }

  .ref-main-card--app .ref-main-card-sub {
    color: #62e6db;
  }

  .ref-main-card-desc {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .ref-main-card-role {
    margin: 18px 0 0;
    color: var(--text-faint);
    font-size: 0.78rem;
    line-height: 1.55;
  }

  .ref-main-card-role span {
    color: var(--text-soft);
    font-weight: 600;
  }

  .ref-main-card-footer {
    display: flex;
    align-items: center;
    gap: 12px 20px;
    flex-wrap: wrap;
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .ref-main-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
    transition: color 0.3s ease, gap 0.3s ease;
    text-decoration: none;
  }

  .ref-main-link--stretched::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: var(--radius-lg);
  }

  .ref-main-link--stretched:focus-visible {
    outline: none;
  }

  .ref-main-link--stretched:focus-visible::after {
    outline: 2px solid var(--card-accent);
    outline-offset: -3px;
  }

  .ref-main-live-link {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: var(--text-soft);
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .ref-main-live-link:hover {
    color: #fff;
  }

  .ref-main-live-link:focus-visible {
    outline: 2px solid var(--card-accent);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  .ref-main-live-note {
    color: var(--text-faint);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .ref-main-card:hover .ref-main-link {
    color: #fff;
    gap: 12px;
  }

  @media (prefers-reduced-motion: reduce) {
    .ref-main-card,
    .ref-main-link,
    .ref-main-live-link,
    .ref-main-card .referenz-visual__image {
      transition: none !important;
      transform: none !important;
    }
  }

  .refs-pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: clamp(36px, 5vw, 56px);
  }

  .refs-page-list {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .refs-page-link {
    min-width: 44px;
    height: 44px;
    padding: 0 16px;
    box-sizing: border-box;
    border-radius: var(--radius-pill);
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.03);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.78);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .refs-page-link.is-current {
    background: color-mix(in srgb, var(--refs-b) 16%, transparent);
    border-color: color-mix(in srgb, var(--refs-b) 34%, rgba(255, 255, 255, 0.18));
    color: #fff;
  }

  .refs-page-link.is-disabled {
    opacity: 0.4;
    pointer-events: none;
  }

  .refs-page-link--edge {
    min-width: 96px;
  }

  .refs-final-section {
    padding-top: var(--section-py-sm);
    padding-bottom: var(--section-py-md);
  }

  .refs-final-cta {
    max-width: 660px;
  }

  .refs-final-cta .cta-label {
    color: var(--text-faint);
  }

  .refs-final-cta h2 {
    color: #f5f5f7;
    font-size: var(--display-title);
    line-height: 1.04;
    letter-spacing: 0;
    margin-bottom: 0;
  }

  .refs-final-cta h2 span {
    color: var(--text-soft);
  }

  .refs-final-cta .hero-cta-group {
    margin-top: 34px;
  }

  .refs-final-cta .btn-ghost {
    background-image:
      linear-gradient(#050505, #050505),
      linear-gradient(rgba(255, 255, 255, 0.15), rgba(255, 255, 255, 0.15));
  }

  .refs-final-cta .btn-ghost:hover {
    animation: none;
    transform: translateY(-2px);
    background-image:
      linear-gradient(#0a0a0c, #0a0a0c),
      linear-gradient(rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0.3));
    box-shadow: 0 10px 26px rgba(255, 255, 255, 0.08);
  }

  .refs-final-cta .btn-primary:hover {
    box-shadow:
      inset 0 2px 4px rgba(255, 255, 255, 1),
      0 10px 26px rgba(255, 255, 255, 0.14);
  }

  @media (max-width: 860px) {
    .refs-hero {
      min-height: auto;
      padding-top: var(--hero-offset-top-breadcrumb-mobile);
      padding-bottom: 50px;
    }

    .refs-hero__title {
      font-size: var(--hero-title-size-tablet);
      line-height: var(--hero-title-line-height-mobile);
    }

    .refs-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .refs-intro {
      margin-bottom: 52px;
    }

    .refs-pagination {
      flex-direction: column;
      align-items: stretch;
    }

    .refs-page-link--edge {
      min-width: 0;
      width: 100%;
    }
  }

  @media (max-width: 520px) {
    .refs-hero__lead {
      font-size: var(--lead-size-mobile);
      line-height: 1.6;
    }

    .refs-hero__title {
      font-size: var(--hero-title-size-mobile);
      line-height: var(--hero-title-line-height-mobile);
    }

    .refs-intro {
      margin-bottom: 42px;
    }

    .refs-final-section {
      padding-top: 40px;
      padding-bottom: 72px;
    }

    .refs-final-cta h2 {
      font-size: var(--display-title);
    }
  }
</style>
