---
const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Start' },
  { href: '/referenzen/', label: 'Referenzen' },
  { href: '/digitale-loesungen/', label: 'Lösungen' },
  { href: '/marco-calzavara/', label: 'Über mich' },
  { href: '/kontakt/', label: 'Kontakt', mobileOnly: true, isContact: true },
];

function isActive(href: string): boolean {
  const normalizedPath = pathname === '/' ? '/' : pathname.replace(/\/?$/, '/');
  if (href === '/') return normalizedPath === '/';
  return normalizedPath === href || normalizedPath.startsWith(href);
}
---

<header class="floating-header">
  <div class="nav-container">
    <nav aria-label="Hauptnavigation">
      <a href="/" class="logo" aria-label="Nigredo Startseite">
        <picture class="logo-picture">
          <source srcset="/assets/nigredo-logo-header.webp" type="image/webp">
          <img src="/assets/nigredo-logo-header.png" alt="Nigredo - Websites, KI-Lösungen und Software aus St. Gallen" class="logo-img" width="448" height="143" loading="eager" decoding="async" fetchpriority="high">
        </picture>
      </a>
      <div class="nav-links" id="primary-navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              { active: isActive(link.href) },
              { 'nav-link--mobile-only': link.mobileOnly },
              { 'nav-link--contact': link.isContact },
            ]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </div>
      <div class="header-actions">
        <a href="/kontakt/" class="btn btn-primary header-cta" aria-label="Kontakt aufnehmen">Anfragen</a>
        <button class="menu-toggle" aria-label="Menü öffnen" aria-controls="primary-navigation" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </nav>
  </div>
</header>
