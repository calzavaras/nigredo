---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  canonical: string;
  robots?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogImageWidth?: string;
  ogImageHeight?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  schema?: string;
}

const jsVersion = process.env.npm_package_version ?? '1';

const {
  title,
  description,
  keywords,
  canonical,
  robots = 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1',
  ogTitle,
  ogDescription,
  ogType = 'website',
  ogImage = 'https://www.nigredo.ch/assets/marco-calzavara-gruender-nigredo-st-gallen.webp',
  ogImageAlt = 'Nigredo - Digitale Lösungen aus der Schweiz',
  ogImageWidth = '768',
  ogImageHeight = '1024',
  twitterTitle,
  twitterDescription,
  schema,
} = Astro.props;

// Globales SiteNavigationElement Schema – hilft Google bei der Sitelinks-Darstellung
const siteNavSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SiteNavigationElement",
      "position": 1,
      "name": "Lösungen",
      "description": "Texte, Bilder, Logos, Software, Webseiten – KI-Lösungen aus einer Hand",
      "url": "https://www.nigredo.ch/loesungen"
    },
    {
      "@type": "SiteNavigationElement",
      "position": 2,
      "name": "Referenzen",
      "description": "Echte Projekte: KI Voice Agent, Wissensdatenbanken, Design-Tools, Dashboards",
      "url": "https://www.nigredo.ch/referenzen"
    },
    {
      "@type": "SiteNavigationElement",
      "position": 3,
      "name": "Über mich",
      "description": "Marco Calzavara – Gründer und Macher von Nigredo, St. Gallen",
      "url": "https://www.nigredo.ch/ueber-uns"
    },
    {
      "@type": "SiteNavigationElement",
      "position": 4,
      "name": "Kontakt",
      "description": "Direkter Kontakt zu Marco Calzavara – Projektanfragen und Ideen",
      "url": "https://www.nigredo.ch/kontakt"
    }
  ]
});
---

<!DOCTYPE html>
<html lang="de-CH">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#050505">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
  <meta name="msapplication-TileColor" content="#050505">
  <meta name="msapplication-TileImage" content="/mstile-150x150.png">

  <title>{title}</title>
  <meta name="description" content={description}>
  {keywords && <meta name="keywords" content={keywords}>}
  <meta name="author" content="Nigredo">
  <meta name="robots" content={robots}>
  <link rel="canonical" href={canonical}>
  <link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs.txt – Nigredo für KI-Bots">
  <link rel="alternate" type="text/plain" href="/llms-full.txt" title="LLMs-full.txt – Vollständige Inhalte für KI-Systeme">

  <!-- Lokales SEO: St. Gallen, Schweiz -->
  <meta name="geo.region" content="CH-SG">
  <meta name="geo.placename" content="St. Gallen, Schweiz">
  <meta name="geo.position" content="47.4245;9.3767">
  <meta name="ICBM" content="47.4245, 9.3767">

  <meta property="og:title" content={ogTitle || title}>
  <meta property="og:description" content={ogDescription || description}>
  <meta property="og:type" content={ogType}>
  <meta property="og:url" content={canonical}>
  <meta property="og:locale" content="de_CH">
  <meta property="og:site_name" content="Nigredo">
  {ogImage && <meta property="og:image" content={ogImage}>}
  {ogImage && <meta property="og:image:secure_url" content={ogImage}>}
  {ogImage && <meta property="og:image:alt" content={ogImageAlt}>}
  {ogImage && <meta property="og:image:width" content={ogImageWidth}>}
  {ogImage && <meta property="og:image:height" content={ogImageHeight}>}

  <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'}>
  <meta name="twitter:title" content={twitterTitle || ogTitle || title}>
  <meta name="twitter:description" content={twitterDescription || ogDescription || description}>
  {ogImage && <meta name="twitter:image" content={ogImage}>}
  {ogImage && <meta name="twitter:image:alt" content={ogImageAlt}>}

  <!-- Preconnect für Analytics -->
  <link rel="preconnect" href="https://cloud.umami.is">
  <link rel="dns-prefetch" href="https://cloud.umami.is">

  <!-- LCP: Logo-Preload -->
  <link rel="preload" href="/assets/nigredo-logo.png" as="image" type="image/png" fetchpriority="high">

  <!-- Hreflang: Sprache deklarieren -->
  <link rel="alternate" hreflang="de-CH" href={canonical}>
  <link rel="alternate" hreflang="x-default" href={canonical}>

  <!-- Google Fonts: Inter & Plus Jakarta Sans (non-render-blocking) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap"></noscript>

  <script defer src="https://cloud.umami.is/script.js" data-website-id="84118d46-7fdb-4f47-be37-3914e0dad55f"></script>

  <!-- Globales Navigations-Schema (SiteNavigationElement) für Google Sitelinks -->
  <script type="application/ld+json" set:html={siteNavSchema} />
  {schema && <script type="application/ld+json" set:html={schema} />}
</head>
<body>

  <Header />

  <main id="main-content">
    <slot />
  </main>

  <Footer />

  <script src={`/main.min.js?v=${jsVersion}`} defer></script>

  <!-- Contact Form Modal -->
  <div id="contact-modal" class="cmodal" role="dialog" aria-modal="true" aria-labelledby="cmodal-title" aria-hidden="true">
    <div class="cmodal-backdrop"></div>
    <div class="cmodal-scroll">
      <div class="cmodal-panel">
        <div class="cmodal-panel-glow"></div>
        <button class="cmodal-close" aria-label="Schliessen">&times;</button>

        <div class="cmodal-header">
          <div class="cmodal-icon-wrap">
            <svg class="cmodal-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" fill="none" aria-hidden="true">
              <defs>
                <linearGradient id="cmodal-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#00D2FF"/>
                  <stop offset="50%" stop-color="#A64DFF"/>
                  <stop offset="100%" stop-color="#FF4D80"/>
                </linearGradient>
              </defs>
              <rect x="3" y="7" width="26" height="18" rx="3" stroke="url(#cmodal-grad)" stroke-width="1.8" fill="none"/>
              <path d="M3 10l13 9 13-9" stroke="url(#cmodal-grad)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </svg>
          </div>
          <div>
            <h2 id="cmodal-title" class="cmodal-title">Schreib mir.</h2>
            <p class="cmodal-subtitle">Landet direkt bei mir. Antwort meist noch heute.</p>
          </div>
        </div>
        <div class="cmodal-header-divider"></div>

        <form id="contact-form" class="cmodal-form" novalidate>
          <input type="text" name="website" class="cmodal-honeypot" tabindex="-1" autocomplete="off" aria-hidden="true">

          <div class="cmodal-row">
            <div class="cmodal-field">
              <label class="cmodal-label" for="cmodal-name">Name <span class="cmodal-required">*</span></label>
              <input class="cmodal-input" type="text" id="cmodal-name" name="name" placeholder="Dein Name" required autocomplete="name">
            </div>
            <div class="cmodal-field">
              <label class="cmodal-label" for="cmodal-email">E-Mail <span class="cmodal-required">*</span></label>
              <input class="cmodal-input" type="email" id="cmodal-email" name="email" placeholder="deine@email.ch" required autocomplete="email">
            </div>
          </div>

          <div class="cmodal-field">
            <label class="cmodal-label" for="cmodal-phone">Telefon</label>
            <input class="cmodal-input" type="tel" id="cmodal-phone" name="phone" placeholder="+41 79 000 00 00" autocomplete="tel" inputmode="tel">
          </div>

          <div class="cmodal-field">
            <label class="cmodal-label" for="cmodal-subject">Betreff</label>
            <input class="cmodal-input" type="text" id="cmodal-subject" name="subject" placeholder="Worum geht es?">
          </div>

          <div class="cmodal-field">
            <label class="cmodal-label" for="cmodal-message">Nachricht <span class="cmodal-required">*</span></label>
            <textarea class="cmodal-input cmodal-textarea" id="cmodal-message" name="message" placeholder="Erzähl mir von deinem Projekt oder deiner Idee…" required rows="5"></textarea>
          </div>

          <button type="submit" id="cmodal-submit" class="btn btn-primary cmodal-submit-btn">
            <span class="cmodal-btn-text">Nachricht senden</span>
            <span class="cmodal-btn-loading" aria-hidden="true">Wird gesendet…</span>
          </button>

          <div id="cmodal-feedback" class="cmodal-feedback" role="alert" aria-live="polite"></div>
        </form>

        <!-- Success State (shown after successful send) -->
        <div id="cmodal-success" class="cmodal-success" aria-live="polite">
          <div class="cmodal-success-glow"></div>
          <div class="cmodal-success-icon-wrap">
            <svg class="cmodal-success-svg" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <defs>
                <linearGradient id="check-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#FFC700"/>
                  <stop offset="100%" stop-color="#FF4D80"/>
                </linearGradient>
              </defs>
              <circle class="cmodal-check-circle" cx="32" cy="32" r="29" stroke="url(#check-grad)" stroke-width="1.5" fill="none"/>
              <path class="cmodal-check-mark" d="M20 32l9 9 16-16" stroke="url(#check-grad)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </svg>
          </div>
          <h3 class="cmodal-success-title"><span class="gradient-text">Nachricht gesendet.</span></h3>
          <p class="cmodal-success-text">Deine Anfrage ist angekommen. Ich melde mich persönlich — meistens noch am selben Tag.</p>
          <button class="btn btn-ghost cmodal-success-close">Schliessen</button>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    // System for Premium Spotlight & Random offset
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.card, .contact-card, .case-feature').forEach(function(card) {
        var randomAngle = Math.floor(Math.random() * 360) + 'deg';
        card.style.setProperty('--start-angle', randomAngle);
      });
    });

    document.addEventListener('mousemove', function(e) {
      document.querySelectorAll('.card, .contact-card, .case-feature').forEach(function(card) {
        var rect = card.getBoundingClientRect();
        var x = e.clientX - rect.left;
        var y = e.clientY - rect.top;
        card.style.setProperty('--mouse-x', x + 'px');
        card.style.setProperty('--mouse-y', y + 'px');
      });
    });
  </script>
</body>
</html>
