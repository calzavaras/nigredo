---
import '../styles/global.css';
import { readFileSync } from 'node:fs';
import { createHash } from 'node:crypto';
import { dirname, resolve } from 'node:path';
import { fileURLToPath } from 'node:url';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactModal from '../components/ContactModal.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  robots?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogImageWidth?: string;
  ogImageHeight?: string;
  ogImageType?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  schema?: string;
  preloadImage?: string;
  preloadImageType?: string;
  preloadImageSrcset?: string;
  preloadImageSizes?: string;
}

const layoutDir = dirname(fileURLToPath(import.meta.url));
const mainScriptPath = resolve(layoutDir, '../../static/main.min.js');

function getMainScriptVersion(): string {
  try {
    const script = readFileSync(mainScriptPath);
    return createHash('sha256').update(script).digest('hex').slice(0, 12);
  } catch {
    return process.env.npm_package_version ?? '1';
  }
}

const jsVersion = getMainScriptVersion();
const faviconVersion = '20260518';

const {
  title,
  description,
  canonical,
  robots = 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1',
  ogTitle,
  ogDescription,
  ogType = 'website',
  ogImage = 'https://www.nigredo.ch/android-chrome-512x512.png',
  ogImageAlt = 'Nigredo Icon',
  ogImageWidth = '512',
  ogImageHeight = '512',
  ogImageType,
  twitterTitle,
  twitterDescription,
  schema,
  preloadImage,
  preloadImageType,
  preloadImageSrcset,
  preloadImageSizes,
} = Astro.props;

function inferImageType(image: string | undefined): string | undefined {
  const path = image?.split('?')[0]?.toLowerCase();
  if (!path) return undefined;
  if (path.endsWith('.jpg') || path.endsWith('.jpeg')) return 'image/jpeg';
  if (path.endsWith('.png')) return 'image/png';
  if (path.endsWith('.webp')) return 'image/webp';
  if (path.endsWith('.avif')) return 'image/avif';
  return undefined;
}

const resolvedOgImageType = ogImageType ?? inferImageType(ogImage);
const canonicalUrl = canonical === 'https://www.nigredo.ch'
  ? 'https://www.nigredo.ch/'
  : (canonical.endsWith('/') ? canonical : `${canonical}/`);

