---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="404 | Nigredo"
  description="Diese Seite gibt es nicht. Aber alles andere schon. Zurück zu Nigredo."
  canonical="https://www.nigredo.ch/"
  robots="noindex, follow"
>
  <section class="section pt-sub not-found-page" aria-labelledby="not-found-title">
    <div class="hero-glow"></div>
    <div class="container not-found-page__inner fade-up">

      <span class="badge badge--pink">404</span>

      <h1 id="not-found-title" class="home-hero__title not-found-page__title">
        Hier baut<br>
        <span class="gradient-text">gerade niemand.</span>
      </h1>

      <p class="hero-lead not-found-page__lead">
        Diese Seite existiert nicht. Aber alles andere schon. Vielleicht findest du hier, was du suchst.
      </p>

      <div class="hero-cta-group">
        <a href="/" class="btn btn-primary">Zurück zum Start</a>
        <a href="/kontakt/" class="btn btn-ghost">Kontakt aufnehmen</a>
      </div>

      <div class="not-found-page__links" aria-label="Weitere Seiten">
        <span class="cta-label">Vielleicht meintest du</span>
        <nav>
          <a href="/digitale-loesungen/">Lösungen</a>
          <a href="/referenzen/">Referenzen</a>
          <a href="/marco-calzavara/">Über mich</a>
        </nav>
      </div>
    </div>
  </section>
</Layout>

<style>
  .not-found-page {
    --nf-accent: #ff4d80;
    min-height: min(620px, 68vh);
    display: flex;
    align-items: center;
    padding-top: var(--hero-offset-top);
    padding-bottom: clamp(92px, 9vw, 128px);
  }

  .not-found-page__inner {
    width: 100%;
  }

  .not-found-page .badge {
    margin-bottom: 0.95rem;
    color: rgba(255, 229, 236, 0.94);
    border-color: color-mix(in srgb, var(--nf-accent) 34%, rgba(255, 255, 255, 0.22));
    background: transparent;
    box-shadow: none;
  }

  .not-found-page .hero-glow {
    background: radial-gradient(circle at 50% 38%, color-mix(in srgb, var(--nf-accent) 18%, transparent) 0%, transparent 34%);
  }

  .not-found-page__title {
    max-width: 940px;
    font-size: var(--hero-title-size);
    line-height: var(--hero-title-line-height);
    letter-spacing: -0.02em;
    margin-bottom: clamp(24px, 3vw, 30px);
  }

  .not-found-page__lead {
    max-width: 620px;
    font-size: var(--lead-size);
    line-height: 1.65;
  }

  .not-found-page__links {
    margin-top: 56px;
  }

  .not-found-page__links nav {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
  }

  .not-found-page__links a {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.4;
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.18);
    text-underline-offset: 5px;
    transition: color 0.25s ease, text-decoration-color 0.25s ease;
  }

  .not-found-page__links a:hover {
    color: #ffffff;
    text-decoration-color: color-mix(in srgb, var(--nf-accent) 64%, transparent);
  }

  .not-found-page .btn-primary:hover {
    box-shadow:
      inset 0 2px 4px rgba(255, 255, 255, 1),
      0 10px 26px rgba(255, 255, 255, 0.14);
  }

  @media (max-width: 860px) {
    .not-found-page {
      min-height: auto;
      padding-top: var(--hero-offset-top-mobile);
      padding-bottom: 72px;
    }

    .not-found-page__title {
      font-size: var(--hero-title-size-tablet);
      line-height: var(--hero-title-line-height-mobile);
    }
  }

  @media (max-width: 520px) {
    .not-found-page {
      padding-bottom: 72px;
    }

    .not-found-page__title {
      font-size: var(--hero-title-size-mobile);
      line-height: var(--hero-title-line-height-mobile);
    }

    .not-found-page__lead {
      font-size: var(--lead-size-mobile);
      line-height: 1.6;
    }

    .not-found-page__links {
      margin-top: 48px;
    }
  }
</style>
