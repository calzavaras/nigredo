---
import Layout from '../layouts/Layout.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.nigredo.ch/#webpage",
      "url": "https://www.nigredo.ch/",
      "name": "Websites & KI-Lösungen aus St. Gallen | Nigredo",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "about": { "@id": "https://www.nigredo.ch/#organization" },
      "description": "Websites, KI-Lösungen und digitale Tools zum Fixpreis. Nigredo entwickelt aus St. Gallen für Schweizer KMU.",
      "inLanguage": "de-CH",
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", ".hero-lead"]
      }
    }
  ]
});
---

<Layout
  title="Websites & KI-Lösungen aus St. Gallen | Nigredo"
  description="Websites, KI-Lösungen und digitale Tools zum Fixpreis. Nigredo entwickelt aus St. Gallen für Schweizer KMU: persönlich, klar, ohne Baukasten."
  canonical="https://www.nigredo.ch/"
  ogTitle="Websites, KI-Lösungen und digitale Tools aus St. Gallen."
  ogDescription="Kein Baukasten, keine Kompromisse. Nigredo entwickelt digitale Produkte mit Substanz. Persönlich. Fixpreis. Aus St. Gallen."
  ogImageAlt="Nigredo - Exklusive Websites & Digitale Lösungen"
  twitterTitle="Websites & KI-Lösungen aus St. Gallen | Nigredo"
  twitterDescription="Websites, KI-Lösungen und digitale Tools für Schweizer KMU. Persönlich, klar und zum Fixpreis."
  schema={schema}
>
  <section class="section pt-hero home-hero" aria-labelledby="hero-title">
    <div class="hero-glow"></div>
    <div class="container home-hero__inner fade-up">

      <span class="badge badge--yellow">DIGITALE PRODUKTE. IM MASSANZUG.</span>

      <h1 id="hero-title" class="home-hero__title">
        Websites, KI-Lösungen<br class="hidden-mobile">
        <span class="gradient-text">und digitale Tools.</span>
      </h1>

      <p class="hero-lead">
        Aus St. Gallen für Schweizer KMU: Websites, Software, Tools und Texte mit Charakter. <br class="hidden-tablet">
        Durchdacht bis ins Detail und gemacht, um langfristig zu tragen.
      </p>

      <div class="hero-cta-group">
        <a href="/kontakt" class="btn btn-primary">Projekt starten</a>
        <a href="/referenzen" class="btn btn-ghost">Arbeiten ansehen</a>
      </div>
    </div>
  </section>

  <section class="section pt-compact home-values" aria-labelledby="values-title">
    <div class="container">
      <h2 id="values-title" class="visually-hidden">So arbeite ich</h2>
      <div class="grid-3">

        <article class="card value-card fade-up" style="--icon-gradient: linear-gradient(135deg, #00d2ff 0%, #a64dff 100%); --icon-shadow: rgba(0, 210, 255, 0.34);">
          <div class="card-icon" aria-hidden="true"><div class="gradient-icon" style="-webkit-mask-image: url('/assets/icons/icon-verstaendnis.svg'); mask-image: url('/assets/icons/icon-verstaendnis.svg');"></div></div>
          <span class="cta-label">VERSTÄNDNIS</span>
          <h3>Erst verstehen. Dann veredeln.</h3>
          <p>Ich denke mich in dein Vorhaben ein, erkenne, worauf es wirklich ankommt, und entwickle daraus eine Lösung mit klarer Richtung, Tiefe und Substanz.</p>
        </article>

        <article class="card value-card fade-up delay-100" style="--icon-gradient: linear-gradient(135deg, #ffc700 0%, #ff4d80 100%); --icon-shadow: rgba(196, 77, 255, 0.34);">
          <div class="card-icon" aria-hidden="true"><div class="gradient-icon" style="-webkit-mask-image: url('/assets/icons/icon-anspruch.svg'); mask-image: url('/assets/icons/icon-anspruch.svg');"></div></div>
          <span class="cta-label">ANSPRUCH</span>
          <h3>Gut genug ist nicht das Ziel.</h3>
          <p>Ich arbeite nicht für halbe Ergebnisse. Ich arbeite, bis Form, Funktion und Wirkung zusammenpassen und etwas entsteht, das langfristig trägt.</p>
        </article>

        <article class="card value-card fade-up delay-200" style="--icon-gradient: linear-gradient(135deg, #a64dff 0%, #ff4d80 100%); --icon-shadow: rgba(255, 77, 128, 0.32);">
          <div class="card-icon" aria-hidden="true"><div class="gradient-icon" style="-webkit-mask-image: url('/assets/icons/icon-zusammenarbeit.svg'); mask-image: url('/assets/icons/icon-zusammenarbeit.svg');"></div></div>
          <span class="cta-label">ZUSAMMENARBEIT</span>
          <h3>Klar im Denken. Direkt im Tun.</h3>
          <p>Keine Umwege, kein leeres Theater. Ich schätze klare Abmachungen, ehrlichen Austausch und eine Zusammenarbeit, die unkompliziert ist und trotzdem Tiefe hat.</p>
        </article>

      </div>
    </div>
  </section>

  <section class="section home-final-section" aria-labelledby="cta-title">
    <div class="container">
      <div class="section-cta home-final-cta fade-up">
        <span class="cta-label">NÄCHSTER SCHRITT</span>
        <h2 id="cta-title">Erzähl mir kurz,<br><span>was du vorhast.</span></h2>
        <div class="hero-cta-group" style="justify-content: center;">
          <a href="/kontakt" class="btn btn-primary">Gespräch starten</a>
          <a href="/referenzen" class="btn btn-ghost">Arbeiten ansehen</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Page specific overrides if any */
  :global(.floating-header) {
    padding-top: 48px;
  }

  .home-hero {
    min-height: min(570px, 64vh);
    display: flex;
    align-items: center;
    padding-top: 100px;
    padding-bottom: 48px;
  }

  .home-hero .badge {
    margin-bottom: 1rem;
  }

  .home-hero__inner {
    width: 100%;
  }

  .home-hero__title {
    max-width: 940px;
    font-size: clamp(2.9rem, 5.35vw, 4.85rem);
    line-height: var(--hero-title-line-height);
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }


  .home-hero .hero-lead {
    max-width: 620px;
    font-size: clamp(1.03rem, 1.15vw, 1.2rem);
    line-height: 1.65;
    color: rgba(245, 245, 247, 0.68);
  }

  .home-values {
    padding-top: 8px;
    padding-bottom: 86px;
  }

  .card p {
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.7;
    margin-bottom: 0;
  }

  .value-card {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.018)),
      #0a0a0c;
    isolation: isolate;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.035),
      0 18px 45px rgba(0, 0, 0, 0.22);
  }

  .value-card::before {
    display: none;
  }

  .value-card::after,
  .value-card:hover::after {
    opacity: 0;
  }

  .value-card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.16);
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.045),
        rgba(255, 255, 255, 0.022)
      ),
      #0b0b0d;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 28px 60px rgba(0, 0, 0, 0.32);
  }

  .value-card .card-icon {
    width: 3.15rem;
    height: 3.15rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    background: rgba(255, 255, 255, 0.03);
    position: relative;
  }

  .value-card:hover .card-icon {
    border-color: rgba(255, 255, 255, 0.16);
    background: color-mix(in srgb, var(--icon-shadow) 18%, rgba(255, 255, 255, 0.045));
    box-shadow:
      0 0 22px color-mix(in srgb, var(--icon-shadow) 76%, transparent),
      0 0 48px color-mix(in srgb, var(--icon-shadow) 46%, transparent),
      inset 0 0 18px rgba(255, 255, 255, 0.06);
    transform: translateY(-1px);
  }

  .value-card .gradient-icon {
    width: 1.95rem;
    height: 1.95rem;
    opacity: 1;
    background: var(--icon-gradient);
    filter: brightness(1.18) saturate(1.28) drop-shadow(0 0 12px var(--icon-shadow));
  }

  .value-card:hover .gradient-icon {
    opacity: 1;
    background: var(--icon-gradient);
    filter:
      brightness(1.7)
      saturate(2.1)
      contrast(1.08)
      drop-shadow(0 0 12px var(--icon-shadow))
      drop-shadow(0 0 28px var(--icon-shadow));
  }

  .home-final-section {
    padding-top: 52px;
    padding-bottom: 118px;
  }

  .home-final-cta {
    max-width: 660px;
  }

  .home-final-cta .cta-label {
    color: rgba(255, 255, 255, 0.42);
  }

  .home-final-cta h2 {
    color: #f5f5f7;
    font-size: clamp(2.25rem, 4.5vw, 3.7rem);
    line-height: 1.04;
    letter-spacing: 0;
    margin-bottom: 0;
  }

  .home-final-cta h2 span {
    color: rgba(255, 255, 255, 0.62);
  }

  .home-final-cta .hero-cta-group {
    margin-top: 34px;
  }

  .home-final-cta .btn-primary:hover {
    box-shadow:
      inset 0 2px 4px rgba(255, 255, 255, 1),
      0 10px 26px rgba(255, 255, 255, 0.14);
  }

  @media (max-width: 860px) {
    :global(.floating-header) {
      padding-top: 28px;
    }

    .home-hero {
      min-height: auto;
      padding-top: 96px;
      padding-bottom: 46px;
    }

    .home-hero__title {
      font-size: clamp(2.55rem, 10vw, 3.8rem);
      line-height: var(--hero-title-line-height-mobile);
    }
  }

  @media (max-width: 520px) {
    .home-hero {
      padding-top: 92px;
      padding-bottom: 40px;
    }

    .home-hero__title {
      font-size: clamp(2.35rem, 13vw, 3.25rem);
      line-height: var(--hero-title-line-height-mobile);
      margin-bottom: 20px;
    }

    .home-hero .hero-lead {
      font-size: 1.02rem;
      line-height: 1.6;
    }

    .home-values {
      padding-top: 14px;
    }

    .home-values {
      padding-bottom: 72px;
    }

    .home-final-section {
      padding-top: 40px;
      padding-bottom: 88px;
    }

    .home-final-cta h2 {
      font-size: clamp(1.8rem, 11vw, 2.5rem);
    }
  }

</style>
