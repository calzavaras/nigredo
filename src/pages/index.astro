---
import Layout from '../layouts/Layout.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["WebPage", "HomePage"],
      "@id": "https://www.nigredo.ch/#webpage",
      "url": "https://www.nigredo.ch/",
      "name": "Nigredo | Websites, KI-Lösungen und digitale Tools aus St. Gallen",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "about": { "@id": "https://www.nigredo.ch/#organization" },
      "mainEntity": { "@id": "https://www.nigredo.ch/#organization" },
      "publisher": { "@id": "https://www.nigredo.ch/#organization" },
      "primaryImageOfPage": { "@id": "https://www.nigredo.ch/#logo" },
      "significantLink": [
        "https://www.nigredo.ch/digitale-loesungen/",
        "https://www.nigredo.ch/referenzen/",
        "https://www.nigredo.ch/marco-calzavara/",
        "https://www.nigredo.ch/kontakt/",
        "https://www.nigredo.ch/haeufige-fragen/"
      ],
      "description": "Nigredo entwickelt Websites, KI-Lösungen, digitale Tools und Texte für Selbstständige, KMU und Organisationen, die online klar verstanden werden möchten.",
      "datePublished": "2025-06-01",
      "dateModified": "2026-05-18",
      "inLanguage": "de-CH"
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.nigredo.ch/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" }
      ]
    }
  ]
});
---

<Layout
  title="Nigredo | Websites, KI-Lösungen & digitale Tools aus St. Gallen"
  description="Nigredo entwickelt Websites, KI-Lösungen, digitale Tools und Texte für Selbstständige, KMU und Organisationen, die online klar verstanden werden möchten."
  canonical="https://www.nigredo.ch/"
  ogTitle="Ich arbeite weiter, wo andere aufhören."
  ogDescription="Websites, KI-Lösungen, digitale Tools und Texte für Selbstständige, KMU und Organisationen, die online klar verstanden werden möchten."
  ogImageAlt="Nigredo - Websites, KI-Lösungen und digitale Tools aus St. Gallen"
  twitterTitle="Nigredo | Websites, KI-Lösungen & digitale Tools"
  twitterDescription="Persönlich aus St. Gallen. Durchdacht bis ins Detail und umgesetzt mit klarer Strategie, sauberer Technik und ohne Baukasten."
  schema={schema}
>
  <section class="section pt-hero home-hero" aria-labelledby="hero-title">
    <div class="hero-glow"></div>
    <div class="container home-hero__inner fade-up">
      <!-- Höhen-Spacer: identisch mit Breadcrumb-Höhe anderer Seiten (kein nav/BreadcrumbList im DOM) -->
      <div class="home-breadcrumb-spacer" aria-hidden="true" role="presentation"></div>

      <span class="badge badge--yellow">DIGITALE PRODUKTE. IM MASSANZUG.</span>

      <h1 id="hero-title" class="home-hero__title">
        Ich arbeite weiter,<br>
        <span class="gradient-text">wo andere aufhören.</span>
      </h1>

      <p class="hero-lead">
        Websites, KI Lösungen, digitale Tools und Texte für Selbstständige, KMU und Organisationen, die online klar verstanden werden möchten. <br class="hidden-tablet">
        Durchdacht bis ins Detail, persönlich aus St. Gallen und umgesetzt mit klarer Strategie, sauberer Technik und einem Ergebnis, das nicht nach Baukasten aussieht.
      </p>

      <div class="hero-cta-group">
        <button class="btn btn-primary open-contact" title="Projekt starten">Projekt starten</button>
          <a href="/referenzen/" class="btn btn-ghost">Arbeiten ansehen</a>
      </div>
    </div>
  </section>

  <section class="section pt-compact home-values" aria-labelledby="values-title">
    <div class="container">
      <h2 id="values-title" class="visually-hidden">So arbeite ich</h2>
      <div class="grid-3">

        <article class="card value-card fade-up" style="--icon-gradient: linear-gradient(180deg, #2f7bff 0%, #00a8ff 100%); --icon-shadow: rgba(47, 123, 255, 0.36);">
          <div class="card-icon" aria-hidden="true"><div class="gradient-icon" style="-webkit-mask-image: url('/assets/icons/icon-verstaendnis.svg'); mask-image: url('/assets/icons/icon-verstaendnis.svg');"></div></div>
          <span class="cta-label">VERSTÄNDNIS</span>
          <h3>Erst verstehen. Dann veredeln.</h3>
          <p>Ich denke mich in dein Vorhaben ein, erkenne, worauf es wirklich ankommt, und entwickle daraus eine Website, KI Lösung oder digitale Anwendung mit klarer Richtung, Substanz und Wirkung.</p>
          <p>Nicht einfach schön. Nicht einfach technisch. Sondern passend zu dir, deinem Angebot und den Menschen, die du erreichen möchtest.</p>
        </article>

        <article class="card value-card fade-up delay-100" style="--icon-gradient: linear-gradient(180deg, #2f7bff 0%, #00a8ff 100%); --icon-shadow: rgba(47, 123, 255, 0.36);">
          <div class="card-icon" aria-hidden="true"><div class="gradient-icon" style="-webkit-mask-image: url('/assets/icons/icon-anspruch.svg'); mask-image: url('/assets/icons/icon-anspruch.svg');"></div></div>
          <span class="cta-label">ANSPRUCH</span>
          <h3>Gut genug ist nicht das Ziel.</h3>
          <p>Ich arbeite nicht für halbe Ergebnisse. Ich arbeite, bis Inhalt, Form, Funktion und Wirkung zusammenpassen.</p>
          <p>Damit etwas entsteht, das professionell aussieht, sauber funktioniert, schnell lädt, gefunden wird und langfristig trägt.</p>
        </article>

        <article class="card value-card fade-up delay-200" style="--icon-gradient: linear-gradient(180deg, #2f7bff 0%, #00a8ff 100%); --icon-shadow: rgba(47, 123, 255, 0.36);">
          <div class="card-icon" aria-hidden="true"><div class="gradient-icon" style="-webkit-mask-image: url('/assets/icons/icon-zusammenarbeit.svg'); mask-image: url('/assets/icons/icon-zusammenarbeit.svg');"></div></div>
          <span class="cta-label">ZUSAMMENARBEIT</span>
          <h3>Klar im Denken. Direkt im Tun.</h3>
          <p>Keine Umwege, kein leeres Theater. Ich schätze klare Abmachungen, ehrlichen Austausch, transparente Fixpreise und eine Zusammenarbeit, die unkompliziert bleibt.</p>
          <p>Du bekommst keine anonyme Agenturmaschine, sondern einen persönlichen Partner, der mitdenkt, nachfragt und Verantwortung für das Ergebnis übernimmt.</p>
        </article>

      </div>
    </div>
  </section>

  <section class="section home-final-section" aria-labelledby="cta-title">
    <div class="container">
      <div class="section-cta home-final-cta fade-up">
        <span class="cta-label">NÄCHSTER SCHRITT</span>
        <h2 id="cta-title">Erzähl mir kurz,<br><span>was du vorhast.</span></h2>
        <div class="hero-cta-group" style="justify-content: center;">
          <span class="reveal-mail btn btn-primary" role="button" tabindex="0" aria-label="E-Mail-Adresse anzeigen">Gespräch starten</span>
          <a href="/referenzen/" class="btn btn-ghost">Referenzen ansehen</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Page specific overrides if any */

  .home-hero,
  .home-values,
  .home-final-section {
    --home-a: #6f42ff;
    --home-b: #ff3f98;
    --home-c: #ffae1a;
    animation: homeCycle 90s ease-in-out infinite;
  }

  .home-hero {
    min-height: auto;
    display: flex;
    align-items: center;
    padding-top: var(--hero-offset-top-breadcrumb);
    padding-bottom: var(--hero-offset-bottom);
  }

  .home-breadcrumb-spacer {
    /* Reines CSS-Spacer: entspricht der Höhe einer Breadcrumb-Zeile (≈16px) + 26px (= 30px margin-bottom - 4px Offset) */
    height: 16px;
    margin-bottom: 26px;
    pointer-events: none;
  }

  .home-hero .badge {
    margin-bottom: 0.95rem;
    color: rgba(255, 248, 235, 0.94);
    border-color: color-mix(in srgb, var(--home-b) 44%, rgba(255, 255, 255, 0.22));
    background: transparent;
    box-shadow: none;
    transform: translateY(-6px);
  }

  .home-hero__inner {
    width: 100%;
  }

  .home-hero__title {
    max-width: 940px;
    font-size: var(--hero-title-size);
    line-height: var(--hero-title-line-height);
    letter-spacing: -0.015em;
    margin-bottom: clamp(24px, 3vw, 30px);
  }

  .home-hero .gradient-text {
    background: linear-gradient(
      90deg,
      var(--home-a) 0%,
      color-mix(in srgb, var(--home-a) 88%, var(--home-b)) 14%,
      color-mix(in srgb, var(--home-a) 60%, var(--home-b)) 32%,
      color-mix(in srgb, var(--home-a) 24%, var(--home-b)) 48%,
      color-mix(in srgb, var(--home-b) 92%, var(--home-c)) 68%,
      color-mix(in srgb, var(--home-b) 52%, var(--home-c)) 84%,
      var(--home-c) 100%
    );
    background-size: 100% auto;

    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }


  .home-hero .hero-lead {
    max-width: 620px;
    font-size: var(--lead-size);
    line-height: 1.65;
  }

  .home-hero .btn-ghost,
  .home-final-cta .btn-ghost {
    background-image:
      linear-gradient(#050505, #050505),
      linear-gradient(rgba(255, 255, 255, 0.15), rgba(255, 255, 255, 0.15));
  }

  .home-hero .btn-ghost:hover,
  .home-final-cta .btn-ghost:hover {
    animation: none;
    transform: translateY(-2px);
    background-image:
      linear-gradient(#0a0a0c, #0a0a0c),
      linear-gradient(rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0.3));
    box-shadow: 0 10px 26px rgba(255, 255, 255, 0.08);
  }

  .home-values {
    padding-top: clamp(18px, 3vw, 32px);
    padding-bottom: clamp(82px, 8vw, 108px);
  }

  .home-values .value-card:hover {
    box-shadow:
      0 15px 40px rgba(0, 0, 0, 0.4),
      inset 0 0 44px color-mix(in srgb, var(--home-b) 10%, transparent);
  }

  .home-values .value-card::before {
    background: conic-gradient(
      from calc(var(--border-angle, 0turn) + var(--start-angle, 0deg)),
      transparent 0%,
      color-mix(in srgb, var(--home-a) 20%, transparent) 10%,
      var(--home-a) 18%,
      color-mix(in srgb, var(--home-a) 26%, var(--home-b)) 28%,
      var(--home-b) 44%,
      color-mix(in srgb, var(--home-b) 24%, var(--home-c)) 62%,
      var(--home-c) 74%,
      color-mix(in srgb, var(--home-c) 18%, transparent) 82%,
      transparent 100%
    );
    filter: drop-shadow(0 0 6px color-mix(in srgb, var(--home-b) 50%, transparent));
  }

  .home-hero .hero-glow {
    background:
      radial-gradient(circle at 16% 42%, color-mix(in srgb, var(--home-a) 18%, transparent) 0%, transparent 34%),
      radial-gradient(circle at 50% 44%, color-mix(in srgb, var(--home-b) 18%, transparent) 0%, transparent 32%),
      radial-gradient(circle at 82% 28%, color-mix(in srgb, var(--home-c) 16%, transparent) 0%, transparent 28%);
  }

  .card p {
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.7;
    margin-bottom: 0;
  }

  .home-final-section {
    padding-top: 52px;
    padding-bottom: 84px;
  }

  .home-final-cta {
    max-width: 660px;
  }

  .home-final-cta .cta-label {
    color: rgba(255, 255, 255, 0.42);
  }

  .home-final-cta h2 {
    color: #f5f5f7;
    font-size: clamp(2.25rem, 4.5vw, 3.7rem);
    line-height: 1.04;
    letter-spacing: 0;
    margin-bottom: 0;
  }

  .home-final-cta h2 span {
    color: rgba(255, 255, 255, 0.62);
  }

  .home-final-cta .hero-cta-group {
    margin-top: 34px;
  }

  .home-final-cta .btn-primary:hover {
    box-shadow:
      inset 0 2px 4px rgba(255, 255, 255, 1),
      0 10px 26px rgba(255, 255, 255, 0.14);
  }

  @media (max-width: 860px) {
    .home-hero {
      min-height: auto;
      padding-top: var(--hero-offset-top-breadcrumb-mobile);
      padding-bottom: 50px;
    }

    .home-hero .badge {
      margin-top: 10px;
    }

    .home-hero__title {
      font-size: var(--hero-title-size-tablet);
      line-height: var(--hero-title-line-height-mobile);
    }
  }

  @media (max-width: 520px) {
    .home-hero .badge {
      margin-top: 14px;
    }

    .home-hero__title {
      font-size: clamp(2.12rem, 10vw, 2.55rem);
      line-height: var(--hero-title-line-height-mobile);
      max-width: 100%;
      overflow-wrap: normal;
    }

    .home-hero .hero-lead {
      font-size: var(--lead-size-mobile);
      line-height: 1.6;
      overflow-wrap: break-word;
    }

    .home-values {
      padding-top: 16px;
      padding-bottom: 72px;
    }

    .home-final-section {
      padding-top: 40px;
      padding-bottom: 72px;
    }

    .home-final-cta h2 {
      font-size: clamp(1.8rem, 11vw, 2.5rem);
    }
  }

</style>
