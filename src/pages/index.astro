---
import Layout from '../layouts/Layout.astro';
import { references } from '../data/references';

const showcase = references.slice(0, 3);

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["WebPage", "HomePage"],
      "@id": "https://www.nigredo.ch/#webpage",
      "url": "https://www.nigredo.ch/",
      "name": "Nigredo St. Gallen | Websites, KI und digitale Werkzeuge",
      "alternateName": ["Nigredo", "Nigredo.ch", "nigredo.ch", "Nigredo St. Gallen", "Nigredo Schweiz"],
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "about": { "@id": "https://www.nigredo.ch/#organization" },
      "mainEntity": { "@id": "https://www.nigredo.ch/#organization" },
      "publisher": { "@id": "https://www.nigredo.ch/#organization" },
      "primaryImageOfPage": { "@id": "https://www.nigredo.ch/#logo" },
      "significantLink": [
        "https://www.nigredo.ch/digitale-loesungen/",
        "https://www.nigredo.ch/referenzen/",
        "https://www.nigredo.ch/marco-calzavara/",
        "https://www.nigredo.ch/kontakt/",
        "https://www.nigredo.ch/haeufige-fragen/"
      ],
      "description": "Nigredo entwickelt Websites, KI-Lösungen und digitale Werkzeuge für Selbstständige, KMU und Organisationen. Persönlich umgesetzt in St. Gallen.",
      "datePublished": "2025-06-01",
      "dateModified": "2026-07-16",
      "inLanguage": "de-CH"
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.nigredo.ch/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" }
      ]
    }
  ]
});

const services = [
  {
    number: '01',
    label: 'Websites',
    title: 'Digitale Auftritte mit Substanz.',
    text: 'Individuell gestaltet, technisch sauber und so aufgebaut, dass Menschen und Suchmaschinen verstehen, worum es geht.',
  },
  {
    number: '02',
    label: 'KI-Lösungen',
    title: 'Intelligenz mit klarem Zweck.',
    text: 'Assistenten und Automatisierungen, die dein Wissen dorthin bringen, wo dir heute Zeit verloren geht.',
  },
  {
    number: '03',
    label: 'Tools & Apps',
    title: 'Software, die zur Arbeit passt.',
    text: 'Dashboards, Plattformen und Anwendungen, entwickelt für konkrete Aufgaben statt für möglichst viele Funktionen.',
  },
  {
    number: '04',
    label: 'Inhalt & Struktur',
    title: 'Komplexes klar auf den Punkt gebracht.',
    text: 'Inhalte, Informationsarchitektur und Texte, die Orientierung schaffen und eine starke Gestaltung erst möglich machen.',
  },
];
---

<Layout
  title="Nigredo St. Gallen | Websites, KI & digitale Werkzeuge"
  description="Nigredo entwickelt Websites, KI-Lösungen und digitale Werkzeuge für Selbstständige, KMU und Organisationen. Persönlich umgesetzt in St. Gallen."
  canonical="https://www.nigredo.ch/"
  ogTitle="Ich arbeite weiter, wo andere aufhören."
  ogDescription="Websites, KI-Lösungen und digitale Werkzeuge, persönlich konzipiert und präzise umgesetzt von Marco Calzavara in St. Gallen."
  ogImageAlt="Nigredo: Websites, KI-Lösungen und digitale Werkzeuge aus St. Gallen"
  twitterTitle="Nigredo | Websites, KI-Lösungen und digitale Werkzeuge"
  twitterDescription="Persönlich konzipiert in St. Gallen. Präzise umgesetzt für Selbstständige, KMU und Organisationen."
  schema={schema}
>
  <section class="home-hero" aria-labelledby="hero-title">
    <div class="container home-hero__inner">
      <p class="home-hero__intro fade-up">Digitale Produkte aus St. Gallen</p>
      <h1 id="hero-title" class="home-hero__title fade-up delay-100">
        Ich arbeite weiter,<br>
        <span class="home-gradient-text">wo andere aufhören.</span>
      </h1>
      <p class="home-hero__lead fade-up delay-200">
        Mit Nigredo entwickle ich Websites, KI-Lösungen und digitale Werkzeuge, die Komplexität verständlich machen, Arbeit erleichtern und langfristig tragen. Persönlich konzipiert und präzise umgesetzt.
      </p>
      <div class="home-actions fade-up delay-300">
        <a href="/kontakt/" class="btn btn-primary">Projekt anfragen</a>
        <a href="/referenzen/" class="section-link">Ausgewählte Arbeiten ansehen <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <section class="section section--lg home-services" aria-labelledby="services-title">
    <div class="container">
      <div class="section-head fade-up">
        <h2 id="services-title" class="section-head__title">Was ich entwickle.</h2>
        <p class="section-head__lead">Vier Disziplinen, die einzeln überzeugen und gemeinsam starke digitale Produkte möglich machen.</p>
      </div>

      <div class="numbered-rows">
        {services.map((service, index) => (
          <a
            href="/digitale-loesungen/"
            class={`numbered-row fade-up${index > 0 ? ` delay-${index * 100}` : ''}`}
          >
            <span class="numbered-row__num" aria-hidden="true">{service.number}</span>
            <div>
              <span class="numbered-row__label">{service.label}</span>
              <h3 class="numbered-row__title">{service.title}</h3>
            </div>
            <p class="numbered-row__text">{service.text}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--lg home-work" aria-labelledby="work-title">
    <div class="container">
      <div class="section-head section-head--split fade-up">
        <div>
          <h2 id="work-title" class="section-head__title">Ausgewählte Arbeiten.</h2>
          <p class="section-head__lead">Drei Projekte, drei verschiedene Ausgangslagen. Was dahintersteckt, zeigen die Referenzen.</p>
        </div>
        <a href="/referenzen/" class="section-link">Alle Referenzen <span aria-hidden="true">→</span></a>
      </div>

      <div class="showcase-grid">
        {showcase.map((reference, index) => (
          <a
            href={reference.href}
            class={`showcase-card fade-up${index === 0 ? ' showcase-card--featured' : ''}${index > 0 ? ` delay-${index * 100}` : ''}`}
            aria-label={reference.ariaLabel}
          >
            <div class={`showcase-card__media ${reference.listImgCls}`}>
              <img src={reference.imgSrc} alt={reference.imgAlt} width="1200" height="675" loading="lazy" decoding="async">
            </div>
            <div class="showcase-card__body">
              {index === 0 && <span class="showcase-card__badge badge">{reference.badge.text}</span>}
              <div class="showcase-card__header">
                <h3 class="showcase-card__title">{reference.listTitle}</h3>
                <span class="showcase-card__year">{reference.year}</span>
              </div>
              <p class="showcase-card__sub">{reference.sub}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--lg home-about" aria-labelledby="about-title">
    <div class="container about-strip fade-up">
      <div class="about-strip__portrait">
        <picture>
          <source srcset="/assets/marco-calzavara-nigredo-st-gallen-500.avif 500w, /assets/marco-calzavara-nigredo-st-gallen-750.avif 750w" sizes="(max-width: 720px) 100vw, 360px" type="image/avif">
          <source srcset="/assets/marco-calzavara-nigredo-st-gallen-500.webp 500w, /assets/marco-calzavara-nigredo-st-gallen-750.webp 750w" sizes="(max-width: 720px) 100vw, 360px" type="image/webp">
          <img
            src="/assets/marco-calzavara-nigredo-st-gallen.jpg"
            alt="Marco Calzavara, Gründer von Nigredo in St. Gallen"
            width="750"
            height="750"
            loading="lazy"
            decoding="async"
          >
        </picture>
      </div>
      <div>
        <h2 id="about-title" class="about-strip__title">Nigredo ist persönlich.</h2>
        <p class="about-strip__text"><strong>Ich bin Marco Calzavara und begleite dein Projekt vom ersten Gedanken bis zum fertigen Produkt.</strong></p>
        <p class="about-strip__text">Du sprichst immer mit der Person, die konzipiert, entscheidet und umsetzt. So bleiben Ideen erhalten, Wege angenehm kurz und die Verantwortung eindeutig.</p>
        <p class="about-strip__text">Du erhältst einen transparenten Fixpreis, direkte Antworten und ein Ergebnis, für das ich persönlich einstehe.</p>
        <a href="/marco-calzavara/" class="section-link">Mehr über mich <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <section class="final-cta-section" aria-labelledby="cta-title">
    <div class="container final-cta-content final-cta-content--centered fade-up">
      <h2 id="cta-title">
        Ein gutes Projekt beginnt<br>
        <span>mit einem klaren Gespräch.</span>
      </h2>
      <p>Beschreibe mir dein Vorhaben in wenigen Sätzen. Ich höre zu, frage nach und sage dir offen, welcher nächste Schritt sinnvoll ist.</p>
      <div class="hero-cta-group">
        <a href="/kontakt/" class="btn btn-primary">Gespräch starten</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .home-hero {
    --home-divider: rgba(255, 255, 255, 0.08);
    --home-divider-strong: rgba(255, 255, 255, 0.12);
  }

  .home-gradient-text {
    display: inline-block;
    color: #f5f5f7;
    background: var(--hero-gradient-warm);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .home-hero {
    min-height: min(860px, 92svh);
    display: flex;
    align-items: center;
    padding: clamp(168px, 18vh, 224px) 0 clamp(112px, 15vh, 176px);
    position: relative;
  }

  .home-hero::after {
    content: "";
    position: absolute;
    left: max(var(--container-gutter), calc((100vw - var(--shell-width)) / 2));
    right: max(var(--container-gutter), calc((100vw - var(--shell-width)) / 2));
    bottom: 0;
    height: 1px;
    background: var(--home-divider);
  }

  .home-hero__inner {
    width: 100%;
  }

  .home-hero__intro {
    margin: 0 0 clamp(26px, 4vw, 42px);
    color: var(--text-soft);
    font-size: 0.84rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .home-hero__title {
    max-width: 940px;
    margin: 0;
    font-size: clamp(3.4rem, 7vw, 5.9rem);
    line-height: 1.01;
    letter-spacing: -0.038em;
  }

  .home-hero__lead {
    max-width: 670px;
    margin: clamp(34px, 5vw, 54px) 0 0;
    color: var(--text-body);
    font-size: clamp(1.08rem, 1.7vw, 1.28rem);
    line-height: 1.65;
    text-wrap: pretty;
  }

  .home-actions {
    display: flex;
    align-items: center;
    gap: clamp(22px, 4vw, 38px);
    margin-top: clamp(34px, 5vw, 52px);
  }

  @media (max-width: 860px) {
    .home-hero {
      min-height: auto;
      padding-top: 164px;
      padding-bottom: 112px;
    }

    .home-hero::after {
      left: var(--container-gutter);
      right: var(--container-gutter);
    }

    .home-hero__title {
      font-size: clamp(3rem, 10vw, 4.9rem);
    }
  }

  @media (max-width: 620px) {
    .home-hero {
      padding-top: 142px;
      padding-bottom: 88px;
    }

    .home-hero__intro {
      margin-bottom: 24px;
    }

    .home-hero__title {
      font-size: clamp(2.65rem, 12vw, 3.55rem);
      line-height: 1.04;
      letter-spacing: -0.035em;
    }

    .home-hero__lead {
      margin-top: 30px;
      font-size: 1.02rem;
    }

    .home-actions {
      align-items: flex-start;
      flex-direction: column;
      gap: 24px;
      margin-top: 34px;
    }
  }
</style>
