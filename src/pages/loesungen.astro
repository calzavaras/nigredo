---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.nigredo.ch/loesungen#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Lösungen", "item": "https://www.nigredo.ch/loesungen" }
      ]
    },
    {
      "@type": "WebPage",
      "@id": "https://www.nigredo.ch/loesungen#webpage",
      "url": "https://www.nigredo.ch/loesungen",
      "name": "Websites, KI-Lösungen & Texte – Fixpreis | Nigredo Schweiz",
      "description": "Websites, die ihren Job kennen. KI, die nicht nervt. Texte und Bilder, denen Form fehlt. Alles aus einer Hand, Fixpreis, kein Baukastensystem. Marco Calzavara, St. Gallen.",
      "inLanguage": "de-CH",
      "datePublished": "2025-06-01",
      "dateModified": "2026-04-28",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": "https://www.nigredo.ch/loesungen#breadcrumb" },
      "isAccessibleForFree": true,
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", ".accordion-content p"]
      },
      "mainEntity": { "@id": "https://www.nigredo.ch/loesungen#services" }
    },
    {
      "@type": "ItemList",
      "@id": "https://www.nigredo.ch/loesungen#services",
      "name": "Leistungen",
      "description": "Digitale Lösungen aus einer Hand – Websites, KI und Content",
      "numberOfItems": 3,
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "item": {
            "@type": "Service",
            "@id": "https://www.nigredo.ch/loesungen#website",
            "name": "Websites, die wirken",
            "description": "Individuelle Websites, die klar positioniert sind, sauber funktionieren und in jedem Detail passen. Kein Baukastensystem, kein Abo-Modell. Substanz, die bleibt.",
            "serviceType": "Webentwicklung",
            "provider": { "@id": "https://www.nigredo.ch/#organization" },
            "areaServed": { "@type": "Country", "name": "Switzerland" },
            "offers": {
              "@type": "Offer",
              "priceCurrency": "CHF",
              "priceSpecification": { "@type": "UnitPriceSpecification", "description": "Fixpreis" }
            }
          }
        },
        {
          "@type": "ListItem",
          "position": 2,
          "item": {
            "@type": "Service",
            "@id": "https://www.nigredo.ch/loesungen#ki",
            "name": "KI-Lösungen für KMU",
            "description": "KI-Lösungen mit klarem Zweck, verständlicher Rolle und echtem Nutzen im Alltag. Keine Spielerei, kein Buzzword. Werkzeuge, die entlasten und verlässlich funktionieren.",
            "serviceType": "KI-Lösungen",
            "provider": { "@id": "https://www.nigredo.ch/#organization" },
            "areaServed": { "@type": "Country", "name": "Switzerland" }
          }
        },
        {
          "@type": "ListItem",
          "position": 3,
          "item": {
            "@type": "Service",
            "@id": "https://www.nigredo.ch/loesungen#content",
            "name": "Texte, Bilder und Gestaltung",
            "description": "Der richtige Text, die klare Struktur, das starke Bild. Alles, was Form braucht – präzise, passend und ohne Umwege.",
            "serviceType": "Content-Erstellung",
            "provider": { "@id": "https://www.nigredo.ch/#organization" },
            "areaServed": { "@type": "Country", "name": "Switzerland" }
          }
        }
      ]
    }
  ]
});
---

<Layout
  title="Websites, KI-Lösungen & Content-Gestaltung | Nigredo"
  description="Individuelle Websites, intelligente KI-Integrationen und exzellente Content-Gestaltung. Entdecken Sie digitale Lösungen mit Substanz aus St. Gallen. Persönlich & zum Fixpreis."
  keywords="Website erstellen lassen Schweiz, KI-Lösungen KMU, Content Erstellung Schweiz, Webdesign St. Gallen, Softwareentwicklung Freelancer, Website Fixpreis, Automatisierung"
  canonical="https://www.nigredo.ch/loesungen"
  ogTitle="Individuelle Lösungen für Ihre digitale Präsenz."
  ogDescription="Websites, KI und Content mit Charakter. Marco Calzavara entwickelt Lösungen, die wirklich zu Ihnen passen. Persönlich. Fixpreis. Ohne Baukasten."
  ogImageAlt="Nigredo – Individuelle Websites, KI & Content-Lösungen"
  twitterTitle="Websites, KI-Lösungen & Content-Gestaltung | Nigredo"
  twitterDescription="Websites, die ihren Job kennen. KI, die nicht nervt. Alles, dem Form fehlt. Fixpreis."
  schema={schema}
>
  <section class="section pt-sub solutions-hero" aria-labelledby="loesungen-title">
    <div class="hero-glow"></div>
    <div class="container solutions-hero__container">

      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Lösungen' }
      ]} />

      <div class="fade-up home-hero__inner solutions-hero__content">
        <span class="badge badge--cyan">WOMIT ES AUFHÖRT</span>

        <h1 id="loesungen-title" class="home-hero__title solutions-hero__title">
          Wenn es fertig ist, <br class="hidden-mobile">
          <span class="gradient-text">fühlt es sich richtig an.</span>
        </h1>
        <p class="hero-lead solutions-hero__lead">
          Fertig heisst hier nicht einfach abgeschlossen. Es heisst: kein Detail, das stört, kein Satz, der danebenliegt, kein Klick, der ins Leere führt. Erst wenn alles stimmt, ist ein Projekt wirklich fertig.
        </p>
      </div>

      <div class="fade-up delay-100 mt-80 solutions-accordion-wrap">

        <div class="accordion solutions-accordion" role="list">

          <div class="accordion-item solutions-accordion__item" role="listitem">
            <h3 class="accordion-h3">
              <button id="acc-btn-1" class="accordion-header" aria-expanded="false" aria-controls="acc-1">
                <div class="accordion-title-wrapper">
                  <span class="acc-icon-title" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <defs>
                        <linearGradient id="acc-grad-1" x1="0" y1="0" x2="24" y2="24" gradientUnits="userSpaceOnUse">
                          <stop stop-color="#00D2FF"/><stop offset="1" stop-color="#A64DFF"/>
                        </linearGradient>
                      </defs>
                      <rect x="3" y="4" width="18" height="15" rx="2.4" stroke="url(#acc-grad-1)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                      <line x1="3" y1="8" x2="21" y2="8" stroke="url(#acc-grad-1)" stroke-width="1.6" stroke-linecap="round"/>
                      <circle cx="6.2" cy="6.1" r="0.55" fill="url(#acc-grad-1)"/>
                      <circle cx="8.4" cy="6.1" r="0.55" fill="url(#acc-grad-1)"/>
                      <path d="M7 13.4L10.1 10.3L12.6 12.7L17.2 9.4" stroke="url(#acc-grad-1)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M15.6 9.2H17.4V11" stroke="url(#acc-grad-1)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M14.2 14.3L18.2 16.1L16.5 16.9L17.5 19L16.1 19.6L15.1 17.5L13.7 18.8L14.2 14.3Z" stroke="url(#acc-grad-1)" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  <span>Websites, die wirken.</span>
                </div>
                <span class="accordion-icon" aria-hidden="true">+</span>
              </button>
            </h3>
            <div id="acc-1" class="accordion-content" role="region" aria-labelledby="acc-btn-1" aria-hidden="true">
              <p>
                Eine Website ist nicht einfach nur da. Sie zeigt, wer du bist, bevor du etwas sagen musst. Sie schafft Vertrauen, gibt Richtung und bringt Menschen dorthin, wo sie hinfinden sollen.<br><br>
                Ich entwickle Websites, die klar positioniert sind, sauber funktionieren und in jedem Detail zu dir passen. Keine Vorlage, keine Kompromisse, kein Abo-Modell. Sondern eine Lösung, die Substanz hat und bleibt.
              </p>
            </div>
          </div>

          <div class="accordion-item solutions-accordion__item" role="listitem">
            <h3 class="accordion-h3">
              <button id="acc-btn-2" class="accordion-header" aria-expanded="false" aria-controls="acc-2">
                <div class="accordion-title-wrapper">
                  <span class="acc-icon-title" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <defs>
                        <linearGradient id="acc-grad-2" x1="0" y1="0" x2="24" y2="24" gradientUnits="userSpaceOnUse">
                          <stop stop-color="#A64DFF"/><stop offset="1" stop-color="#FF4D80"/>
                        </linearGradient>
                      </defs>
                      <circle cx="12" cy="12" r="2" stroke="url(#acc-grad-2)" stroke-width="1.8"/>
                      <circle cx="4.5" cy="8" r="1.5" stroke="url(#acc-grad-2)" stroke-width="1.5"/>
                      <circle cx="4.5" cy="16" r="1.5" stroke="url(#acc-grad-2)" stroke-width="1.5"/>
                      <circle cx="19.5" cy="8" r="1.5" stroke="url(#acc-grad-2)" stroke-width="1.5"/>
                      <circle cx="19.5" cy="16" r="1.5" stroke="url(#acc-grad-2)" stroke-width="1.5"/>
                      <circle cx="12" cy="3" r="1.5" stroke="url(#acc-grad-2)" stroke-width="1.5"/>
                      <line x1="10.3" y1="11" x2="6" y2="8.7" stroke="url(#acc-grad-2)" stroke-width="1.2"/><line x1="10.3" y1="13" x2="6" y2="15.3" stroke="url(#acc-grad-2)" stroke-width="1.2"/><line x1="13.7" y1="11" x2="18" y2="8.7" stroke="url(#acc-grad-2)" stroke-width="1.2"/><line x1="13.7" y1="13" x2="18" y2="15.3" stroke="url(#acc-grad-2)" stroke-width="1.2"/><line x1="12" y1="10" x2="12" y2="4.5" stroke="url(#acc-grad-2)" stroke-width="1.2"/>
                    </svg>
                  </span>
                  <span>KI, die nicht nervt.</span>
                </div>
                <span class="accordion-icon" aria-hidden="true">+</span>
              </button>
            </h3>
            <div id="acc-2" class="accordion-content" role="region" aria-labelledby="acc-btn-2" aria-hidden="true">
              <p>
                Viele KI-Lösungen beeindrucken kurz und verschwinden dann im Alltag. Nicht, weil die Technik zu wenig kann, sondern weil die Aufgabe nie klar war.<br><br>
                Ich entwickle KI-Lösungen, die nicht nur möglich, sondern sinnvoll sind. Mit einem klaren Zweck, einer verständlichen Rolle und einem echten Nutzen im Alltag. Keine Spielerei, kein Buzzword, kein zusätzlicher Lärm. Sondern Werkzeuge, die entlasten und verlässlich funktionieren.
              </p>
            </div>
          </div>

          <div class="accordion-item solutions-accordion__item" role="listitem">
            <h3 class="accordion-h3">
              <button id="acc-btn-3" class="accordion-header" aria-expanded="false" aria-controls="acc-3">
                <div class="accordion-title-wrapper">
                  <span class="acc-icon-title" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <defs>
                        <linearGradient id="acc-grad-3" x1="0" y1="0" x2="24" y2="24" gradientUnits="userSpaceOnUse">
                          <stop stop-color="#FF4D80"/><stop offset="1" stop-color="#FFC700"/>
                        </linearGradient>
                      </defs>
                      <path d="M4 6.4C4 5.1 5.1 4 6.4 4H17.6C18.9 4 20 5.1 20 6.4V17.6C20 18.9 18.9 20 17.6 20H6.4C5.1 20 4 18.9 4 17.6V6.4Z" stroke="url(#acc-grad-3)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M7.2 8.1H13.2" stroke="url(#acc-grad-3)" stroke-width="1.5" stroke-linecap="round"/>
                      <path d="M7.2 11.3H11.6" stroke="url(#acc-grad-3)" stroke-width="1.5" stroke-linecap="round"/>
                      <path d="M7.2 15.9L9.8 13.4L11.6 15.1L16.8 9.9" stroke="url(#acc-grad-3)" stroke-width="1.55" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M15.1 9.8H16.9V11.6" stroke="url(#acc-grad-3)" stroke-width="1.55" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  <span>Alles, was Form braucht.</span>
                </div>
                <span class="accordion-icon" aria-hidden="true">+</span>
              </button>
            </h3>
            <div id="acc-3" class="accordion-content" role="region" aria-labelledby="acc-btn-3" aria-hidden="true">
              <p>
                Nicht immer braucht es ein neues System. Manchmal braucht es einfach den richtigen Text. Eine klare Struktur. Ein starkes Bild. Oder eine Darstellung, die aus Komplexität endlich Klarheit macht.<br><br>
                Ich schaue hin, was fehlt, was stört und was klarer werden muss. Dann bringe ich es in Form. Präzise, passend und ohne Umwege.
              </p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>

  <section class="section solutions-final-section" aria-labelledby="loesungen-cta-title">
    <div class="container">
      <div class="section-cta solutions-final-cta fade-up">
        <span class="cta-label">BEREIT?</span>
        <h2 id="loesungen-cta-title">Weniger planen.<br><span>Einfach anfangen.</span></h2>
        <div class="hero-cta-group" style="justify-content: center;">
          <span class="reveal-mail btn btn-primary" role="button" tabindex="0" aria-label="Kontaktformular öffnen">Unverbindlich anfragen</span>
          <a href="/referenzen" class="btn btn-ghost">Referenzprojekte ansehen</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .solutions-hero {
    min-height: min(570px, 64vh);
    display: flex;
    align-items: center;
    padding-top: 150px;
    padding-bottom: 48px;
  }

  .solutions-hero__container {
    position: relative;
    width: 100%;
  }

  .solutions-hero__content {
    max-width: 940px;
  }

  .solutions-hero .home-hero__inner {
    width: 100%;
  }

  .solutions-hero :global(.breadcrumb) {
    margin-bottom: 28px;
  }

  .solutions-hero .badge {
    margin-bottom: 1rem;
  }

  .solutions-hero__title {
    max-width: 940px;
    font-size: clamp(2.9rem, 5.35vw, 4.85rem);
    line-height: var(--hero-title-line-height);
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }

  .solutions-hero__lead {
    max-width: 620px;
    font-size: clamp(1.03rem, 1.15vw, 1.2rem);
    line-height: 1.65;
  }

  .solutions-accordion-wrap {
    margin-top: 72px;
    max-width: 880px;
  }

  .solutions-accordion {
    position: relative;
  }

  .accordion-h3 {
    margin: 0;
  }

  .solutions-accordion__item {
    position: relative;
    border-bottom-color: rgba(255, 255, 255, 0.07);
    transition:
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.35s ease,
      box-shadow 0.35s ease,
      background-color 0.35s ease;
  }

  .solutions-accordion :global(.accordion-header) {
    position: relative;
    z-index: 1;
    padding: 28px 8px;
    color: rgba(245, 245, 247, 0.92);
    transition:
      color 0.25s ease,
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .solutions-accordion__item:hover :global(.accordion-header) {
    color: #ffffff;
  }

  .solutions-accordion__item.active :global(.accordion-header) {
    color: #f5f5f7;
  }

  .solutions-accordion :global(.accordion-title-wrapper) {
    gap: 18px;
  }

  .solutions-accordion :global(.accordion-title-wrapper > span:last-child) {
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .solutions-accordion :global(.acc-icon-title) {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    border-color: rgba(255, 255, 255, 0.1);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.024)),
      rgba(255, 255, 255, 0.02);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.045),
      0 0 14px rgba(166, 77, 255, 0.14);
    transition:
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.35s ease,
      background 0.35s ease,
      box-shadow 0.35s ease;
  }

  .solutions-accordion :global(.acc-icon-title svg) {
    opacity: 0.9;
    filter:
      brightness(1.12)
      saturate(1.18)
      drop-shadow(0 0 8px rgba(166, 77, 255, 0.26));
    transition: opacity 0.45s ease, filter 0.45s ease;
  }

  .solutions-accordion__item:hover :global(.acc-icon-title),
  .solutions-accordion__item.active :global(.acc-icon-title) {
    transform: translateY(-1px);
    border-color: rgba(255, 255, 255, 0.16);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.025)),
      rgba(255, 255, 255, 0.035);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 0 22px rgba(166, 77, 255, 0.24),
      0 0 48px rgba(0, 210, 255, 0.12);
  }

  .solutions-accordion__item:hover :global(.acc-icon-title svg),
  .solutions-accordion__item.active :global(.acc-icon-title svg) {
    opacity: 1;
    filter:
      brightness(1.18)
      saturate(1.35)
      drop-shadow(0 0 12px rgba(166, 77, 255, 0.46))
      drop-shadow(0 0 24px rgba(0, 210, 255, 0.2));
  }

  .solutions-accordion :global(.accordion-icon) {
    width: 40px;
    height: 40px;
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.46);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition:
      transform 0.3s ease,
      color 0.25s ease,
      border-color 0.25s ease,
      background-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .solutions-accordion__item:hover :global(.accordion-icon) {
    color: rgba(255, 255, 255, 0.82);
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.05);
  }

  .solutions-accordion__item.active :global(.accordion-icon) {
    color: #ff4d80;
    border-color: rgba(255, 77, 128, 0.28);
    background: rgba(255, 77, 128, 0.08);
    box-shadow: 0 0 22px rgba(255, 77, 128, 0.14);
  }

  .solutions-accordion :global(.accordion-content) {
    position: relative;
    z-index: 1;
  }

  .accordion-content p {
    padding: 0 28px 34px 70px;
    color: rgba(255, 255, 255, 0.58);
    line-height: 1.72;
    margin: 0;
  }

  .solutions-final-section {
    padding-top: 52px;
    padding-bottom: 118px;
  }

  .solutions-final-cta {
    max-width: 660px;
  }

  .solutions-final-cta .cta-label {
    color: rgba(255, 255, 255, 0.42);
  }

  .solutions-final-cta h2 {
    color: #f5f5f7;
    font-size: clamp(2.25rem, 4.5vw, 3.7rem);
    line-height: 1.04;
    letter-spacing: 0;
    margin-bottom: 0;
  }

  .solutions-final-cta h2 span {
    color: rgba(255, 255, 255, 0.62);
  }

  .solutions-final-cta .hero-cta-group {
    margin-top: 34px;
  }

  .solutions-final-cta .btn-ghost {
    background-image:
      linear-gradient(#050505, #050505),
      linear-gradient(rgba(255, 255, 255, 0.15), rgba(255, 255, 255, 0.15));
  }

  .solutions-final-cta .btn-ghost:hover {
    animation: none;
    transform: translateY(-2px);
    background-image:
      linear-gradient(#0a0a0c, #0a0a0c),
      linear-gradient(rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0.3));
    box-shadow: 0 10px 26px rgba(255, 255, 255, 0.08);
  }

  .solutions-final-cta .btn-primary:hover {
    box-shadow:
      inset 0 2px 4px rgba(255, 255, 255, 1),
      0 10px 26px rgba(255, 255, 255, 0.14);
  }

  @media (max-width: 860px) {
    .solutions-hero {
      min-height: auto;
      padding-top: 132px;
      padding-bottom: 42px;
    }

    .solutions-hero__title {
      font-size: clamp(2.55rem, 10vw, 3.8rem);
      line-height: var(--hero-title-line-height-mobile);
    }

    .solutions-accordion-wrap {
      margin-top: 52px;
      max-width: none;
    }

    .solutions-accordion :global(.accordion-header) {
      padding: 24px 0;
    }

    .accordion-content p {
      padding: 0 24px 30px 0;
    }
  }

  @media (max-width: 768px) {
    .solutions-accordion :global(.accordion-title-wrapper) {
      align-items: flex-start;
    }

    .solutions-accordion :global(.accordion-title-wrapper > span:last-child) {
      font-size: 1.14rem;
      line-height: 1.22;
    }

    .accordion-content p {
      padding: 0 20px 24px 20px;
    }
  }

  @media (max-width: 520px) {
    .solutions-hero__lead {
      font-size: 1.02rem;
      line-height: 1.6;
    }

    .solutions-hero__title {
      font-size: clamp(2.35rem, 13vw, 3.25rem);
      line-height: var(--hero-title-line-height-mobile);
    }

    .solutions-accordion-wrap {
      margin-top: 42px;
    }

    .solutions-accordion :global(.accordion-header) {
      align-items: flex-start;
      gap: 14px;
      padding: 22px 0;
    }

    .solutions-accordion :global(.accordion-title-wrapper) {
      gap: 14px;
    }

    .solutions-accordion :global(.acc-icon-title) {
      width: 46px;
      height: 46px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .solutions-accordion :global(.accordion-icon) {
      width: 36px;
