---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.nigredo.ch/loesungen#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Lösungen", "item": "https://www.nigredo.ch/loesungen" }
      ]
    },
    {
      "@type": "WebPage",
      "@id": "https://www.nigredo.ch/loesungen#webpage",
      "url": "https://www.nigredo.ch/loesungen",
      "name": "Websites, KI-Lösungen & Texte – Fixpreis | Nigredo Schweiz",
      "description": "Websites, die ihren Job kennen. KI, die nicht nervt. Texte und Bilder, denen Form fehlt. Alles aus einer Hand, Fixpreis, kein Baukastensystem. Marco Calzavara, St. Gallen.",
      "inLanguage": "de-CH",
      "datePublished": "2025-06-01",
      "dateModified": "2026-04-07",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": "https://www.nigredo.ch/loesungen#breadcrumb" },
      "isAccessibleForFree": true,
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", ".accordion-content p"]
      },
      "mainEntity": { "@id": "https://www.nigredo.ch/loesungen#services" }
    },
    {
      "@type": "ItemList",
      "@id": "https://www.nigredo.ch/loesungen#services",
      "name": "Leistungen",
      "description": "Digitale Lösungen aus einer Hand – Websites, KI und Content",
      "numberOfItems": 3,
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "item": {
            "@type": "Service",
            "@id": "https://www.nigredo.ch/loesungen#website",
            "name": "Websites, die wirken",
            "description": "Individuelle Websites, die klar positioniert sind, sauber funktionieren und in jedem Detail passen. Kein Baukastensystem, kein Abo-Modell. Substanz, die bleibt.",
            "serviceType": "Webentwicklung",
            "provider": { "@id": "https://www.nigredo.ch/#organization" },
            "areaServed": { "@type": "Country", "name": "Switzerland" },
            "offers": {
              "@type": "Offer",
              "priceCurrency": "CHF",
              "priceSpecification": { "@type": "UnitPriceSpecification", "description": "Fixpreis" }
            }
          }
        },
        {
          "@type": "ListItem",
          "position": 2,
          "item": {
            "@type": "Service",
            "@id": "https://www.nigredo.ch/loesungen#ki",
            "name": "KI-Lösungen für KMU",
            "description": "KI-Lösungen mit klarem Zweck, verständlicher Rolle und echtem Nutzen im Alltag. Keine Spielerei, kein Buzzword. Werkzeuge, die entlasten und verlässlich funktionieren.",
            "serviceType": "KI-Lösungen",
            "provider": { "@id": "https://www.nigredo.ch/#organization" },
            "areaServed": { "@type": "Country", "name": "Switzerland" }
          }
        },
        {
          "@type": "ListItem",
          "position": 3,
          "item": {
            "@type": "Service",
            "@id": "https://www.nigredo.ch/loesungen#content",
            "name": "Texte, Bilder und Gestaltung",
            "description": "Der richtige Text, die klare Struktur, das starke Bild. Alles, was Form braucht – präzise, passend und ohne Umwege.",
            "serviceType": "Content-Erstellung",
            "provider": { "@id": "https://www.nigredo.ch/#organization" },
            "areaServed": { "@type": "Country", "name": "Switzerland" }
          }
        }
      ]
    }
  ]
});
---

<Layout
  title="Websites, KI-Lösungen & Content-Gestaltung | Nigredo"
  description="Individuelle Websites, intelligente KI-Integrationen und exzellente Content-Gestaltung. Entdecken Sie digitale Lösungen mit Substanz aus St. Gallen. Persönlich & zum Fixpreis."
  keywords="Website erstellen lassen Schweiz, KI-Lösungen KMU, Content Erstellung Schweiz, Webdesign St. Gallen, Softwareentwicklung Freelancer, Website Fixpreis, Automatisierung"
  canonical="https://www.nigredo.ch/loesungen"
  ogTitle="Individuelle Lösungen für Ihre digitale Präsenz."
  ogDescription="Websites, KI und Content mit Charakter. Marco Calzavara entwickelt Lösungen, die wirklich zu Ihnen passen. Persönlich. Fixpreis. Ohne Baukasten."
  ogImageAlt="Nigredo – Individuelle Websites, KI & Content-Lösungen"
  twitterTitle="Websites, KI-Lösungen & Content-Gestaltung | Nigredo"
  twitterDescription="Websites, die ihren Job kennen. KI, die nicht nervt. Alles, dem Form fehlt. Fixpreis."
  schema={schema}
>
  <section class="section pt-sub" aria-labelledby="loesungen-title">
    <div class="hero-glow"></div>
    <div class="container">

      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Lösungen' }
      ]} />

      <div class="fade-up">
        <span class="badge badge--cyan">WOMIT ES AUFHÖRT</span>

        <h1 id="loesungen-title">
          Wenn es fertig ist,<br>
          <span class="gradient-text">fühlt es sich richtig an.</span>
        </h1>
        <p class="hero-lead">
          Fertig heisst hier nicht einfach abgeschlossen. Es heisst: kein Detail, das stört, kein Satz, der danebenliegt, kein Klick, der ins Leere führt. Erst wenn alles stimmt, ist ein Projekt wirklich fertig.
        </p>
      </div>

      <div class="fade-up delay-100 mt-80">

        <div class="accordion" role="list">

          <div class="accordion-item" role="listitem">
            <h3 class="accordion-h3">
              <button id="acc-btn-1" class="accordion-header" aria-expanded="false" aria-controls="acc-1">
                <div class="accordion-title-wrapper">
                  <span class="acc-icon-title" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <defs>
                        <linearGradient id="acc-grad-1" x1="0" y1="0" x2="24" y2="24" gradientUnits="userSpaceOnUse">
                          <stop stop-color="#00D2FF"/><stop offset="1" stop-color="#A64DFF"/>
                        </linearGradient>
                      </defs>
                      <rect x="2" y="3" width="20" height="14" rx="2" stroke="url(#acc-grad-1)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                      <line x1="8" y1="21" x2="16" y2="21" stroke="url(#acc-grad-1)" stroke-width="1.8" stroke-linecap="round"/>
                      <line x1="12" y1="17" x2="12" y2="21" stroke="url(#acc-grad-1)" stroke-width="1.8"/>
                      <line x1="7" y1="11" x2="7" y2="13" stroke="url(#acc-grad-1)" stroke-width="1.5" stroke-linecap="round"/>
                      <line x1="10" y1="9" x2="10" y2="13" stroke="url(#acc-grad-1)" stroke-width="1.5" stroke-linecap="round"/>
                      <line x1="13" y1="7" x2="13" y2="13" stroke="url(#acc-grad-1)" stroke-width="1.5" stroke-linecap="round"/>
                      <line x1="16" y1="9" x2="16" y2="13" stroke="url(#acc-grad-1)" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                  </span>
                  <span>Websites, die wirken.</span>
                </div>
                <span class="accordion-icon" aria-hidden="true">+</span>
              </button>
            </h3>
            <div id="acc-1" class="accordion-content" role="region" aria-labelledby="acc-btn-1" aria-hidden="true">
              <p>
                Eine Website ist nicht einfach nur da. Sie zeigt, wer du bist, bevor du etwas sagen musst. Sie schafft Vertrauen, gibt Richtung und bringt Menschen dorthin, wo du sie haben willst.<br><br>
                Ich entwickle Websites, die klar positioniert sind, sauber funktionieren und in jedem Detail zu dir passen. Keine Vorlage, keine Kompromisse, kein Abo-Modell. Sondern eine Lösung, die Substanz hat und bleibt.
              </p>
            </div>
          </div>

          <div class="accordion-item" role="listitem">
            <h3 class="accordion-h3">
              <button id="acc-btn-2" class="accordion-header" aria-expanded="false" aria-controls="acc-2">
                <div class="accordion-title-wrapper">
                  <span class="acc-icon-title" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <defs>
                        <linearGradient id="acc-grad-2" x1="0" y1="0" x2="24" y2="24" gradientUnits="userSpaceOnUse">
                          <stop stop-color="#A64DFF"/><stop offset="1" stop-color="#FF4D80"/>
                        </linearGradient>
                      </defs>
                      <circle cx="12" cy="12" r="2" stroke="url(#acc-grad-2)" stroke-width="1.8"/>
                      <circle cx="4.5" cy="8" r="1.5" stroke="url(#acc-grad-2)" stroke-width="1.5"/>
                      <circle cx="4.5" cy="16" r="1.5" stroke="url(#acc-grad-2)" stroke-width="1.5"/>
                      <circle cx="19.5" cy="8" r="1.5" stroke="url(#acc-grad-2)" stroke-width="1.5"/>
                      <circle cx="19.5" cy="16" r="1.5" stroke="url(#acc-grad-2)" stroke-width="1.5"/>
                      <circle cx="12" cy="3" r="1.5" stroke="url(#acc-grad-2)" stroke-width="1.5"/>
                      <line x1="10.3" y1="11" x2="6" y2="8.7" stroke="url(#acc-grad-2)" stroke-width="1.2"/><line x1="10.3" y1="13" x2="6" y2="15.3" stroke="url(#acc-grad-2)" stroke-width="1.2"/><line x1="13.7" y1="11" x2="18" y2="8.7" stroke="url(#acc-grad-2)" stroke-width="1.2"/><line x1="13.7" y1="13" x2="18" y2="15.3" stroke="url(#acc-grad-2)" stroke-width="1.2"/><line x1="12" y1="10" x2="12" y2="4.5" stroke="url(#acc-grad-2)" stroke-width="1.2"/>
                    </svg>
                  </span>
                  <span>KI, die nicht nervt.</span>
                </div>
                <span class="accordion-icon" aria-hidden="true">+</span>
              </button>
            </h3>
            <div id="acc-2" class="accordion-content" role="region" aria-labelledby="acc-btn-2" aria-hidden="true">
              <p>
                Viele KI-Lösungen beeindrucken kurz und verschwinden dann im Alltag. Nicht, weil die Technik zu wenig kann, sondern weil die Aufgabe nie klar war.<br><br>
                Ich entwickle KI-Lösungen, die nicht nur möglich, sondern sinnvoll sind. Mit einem klaren Zweck, einer verständlichen Rolle und einem echten Nutzen im Alltag. Keine Spielerei, kein Buzzword, kein zusätzlicher Lärm. Sondern Werkzeuge, die entlasten und verlässlich funktionieren.
              </p>
            </div>
          </div>

          <div class="accordion-item" role="listitem">
            <h3 class="accordion-h3">
              <button id="acc-btn-3" class="accordion-header" aria-expanded="false" aria-controls="acc-3">
                <div class="accordion-title-wrapper">
                  <span class="acc-icon-title" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <defs>
                        <linearGradient id="acc-grad-3" x1="0" y1="0" x2="24" y2="24" gradientUnits="userSpaceOnUse">
                          <stop stop-color="#FF4D80"/><stop offset="1" stop-color="#FFC700"/>
                        </linearGradient>
                      </defs>
                      <polygon points="12 2 22 8.5 12 15 2 8.5" stroke="url(#acc-grad-3)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><polyline points="2 13 12 19.5 22 13" stroke="url(#acc-grad-3)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  <span>Alles, was Form braucht.</span>
                </div>
                <span class="accordion-icon" aria-hidden="true">+</span>
              </button>
            </h3>
            <div id="acc-3" class="accordion-content" role="region" aria-labelledby="acc-btn-3" aria-hidden="true">
              <p>
                Nicht immer braucht es ein neues System. Manchmal braucht es einfach den richtigen Text. Eine klare Struktur. Ein starkes Bild. Oder eine Darstellung, die aus Komplexität endlich Klarheit macht.<br><br>
                Ich schaue hin, was fehlt, was stört und was besser werden muss. Dann bringe ich es in Form. Präzise, passend und ohne Umwege.
              </p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>

  <section class="section" aria-labelledby="loesungen-cta-title">
    <div class="container">
      <div class="section-cta fade-up">
        <span class="cta-label">BEREIT?</span>
        <h2 id="loesungen-cta-title">Weniger planen.<br><span class="gradient-text">Einfach anfangen.</span></h2>
        <div class="hero-cta-group" style="justify-content: center;">
          <span class="reveal-mail btn btn-primary" role="button" tabindex="0" aria-label="Kontaktformular öffnen">Unverbindlich anfragen</span>
          <a href="/referenzen" class="btn btn-ghost">Referenzprojekte ansehen</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .accordion-h3 {
    margin: 0;
  }
  .accordion-content p {
    padding: 0 32px 32px 92px;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }
  @media (max-width: 768px) {
    .accordion-content p {
      padding: 0 20px 24px 20px;
    }
  }
</style>
