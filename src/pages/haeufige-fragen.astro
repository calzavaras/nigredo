---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const pageUrl = 'https://www.nigredo.ch/haeufige-fragen/';

const faqEntries = [
  {
    id: 'faq-cost',
    question: 'Was kostet eine professionelle Website?',
    answer: 'Der Preis folgt der Aufgabe. Eine kompakte Website beginnt meist im unteren vierstelligen Bereich. Konzept, Text, individuelle Gestaltung und zusätzliche Funktionen erhöhen den Aufwand.',
    href: '/haeufige-fragen/was-kostet-eine-professionelle-website/'
  },
  {
    id: 'faq-timeline',
    question: 'Wie lange dauert die Erstellung einer professionellen Website?',
    answer: 'Eine kompakte Website kann in wenigen Wochen online sein. Wie schnell es geht, bestimmen vor allem vorhandene Inhalte, klare Zuständigkeiten und kurze Freigabewege.',
    href: '/haeufige-fragen/wie-lange-dauert-die-erstellung-einer-professionellen-website/'
  },
  {
    id: 'faq-maintenance',
    question: 'Kann ich meine Website später selbst bearbeiten?',
    answer: 'Ja. Texte, Bilder, Teamprofile oder Referenzen lassen sich auf Wunsch selbst pflegen. Ob dafür ein CMS sinnvoll ist, entscheidet die tatsächliche Nutzung im Alltag.',
    href: '/haeufige-fragen/kann-ich-meine-professionelle-website-selbst-bearbeiten-und-pflegen/'
  },
  {
    id: 'faq-custom-or-builder',
    question: 'Brauche ich eine individuelle Website oder reicht ein Baukasten?',
    answer: 'Ein Baukasten genügt für einfache Auftritte mit wenig Veränderung. Eine individuelle Website lohnt sich, wenn Inhalt, Gestaltung, Funktionen und künftige Erweiterungen genau zur Aufgabe passen sollen.',
    href: '/haeufige-fragen/brauche-ich-eine-individuelle-website-oder-reicht-ein-baukasten/'
  },
  {
    id: 'faq-google',
    question: 'Wird meine Website bei Google gefunden?',
    answer: 'Eine gute Platzierung entsteht nicht allein durch den Launch. Google muss die Website technisch erfassen, ihren Inhalt verstehen und für konkrete Suchanfragen als relevant einstufen können.',
    href: '/haeufige-fragen/wird-meine-website-bei-google-gefunden/'
  },
  {
    id: 'faq-running-costs',
    question: 'Welche laufenden Kosten hat eine Website?',
    answer: 'Domain und Hosting bilden die festen Grundkosten. Wartung, technische Updates und redaktionelle Pflege kommen nur hinzu, wenn Aufbau und Nutzung der Website sie erfordern.',
    href: '/haeufige-fragen/was-kostet-der-laufende-betrieb-einer-website/'
  },
  {
    id: 'faq-privacy',
    question: 'Was muss meine Website beim Datenschutz beachten?',
    answer: 'Eine Website sollte nur notwendige Daten bearbeiten und alle Datenflüsse verständlich offenlegen. Entscheidend sind eine passende Datenschutzerklärung sowie ein bewusster Umgang mit Cookies, Analyse und externen Diensten.',
    href: '/haeufige-fragen/was-muss-meine-website-beim-datenschutz-beachten/'
  }
];

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Häufige Fragen", "item": pageUrl }
      ]
    },
    {
      "@type": ["CollectionPage", "WebPage"],
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": "Häufige Fragen zu professionellen Websites | Nigredo",
      "description": "Klare Antworten zu Kosten, Dauer, Pflege, Baukasten, Google und Datenschutz für KMU und Selbstständige in der Schweiz.",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "mainEntity": { "@id": `${pageUrl}#faq` },
      "hasPart": { "@id": `${pageUrl}#faqs` },
      "about": { "@id": "https://www.nigredo.ch/#organization" },
      "inLanguage": "de-CH",
      "datePublished": "2026-05-16",
      "dateModified": "2026-07-14",
      "isAccessibleForFree": true,
      "significantLink": faqEntries.map((entry) => `https://www.nigredo.ch${entry.href}`)
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      "mainEntity": faqEntries.map((entry) => ({
        "@type": "Question",
        "name": entry.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": entry.answer
        }
      }))
    },
    {
      "@type": "ItemList",
      "@id": `${pageUrl}#faqs`,
      "name": "Häufige Fragen zu professionellen Websites",
      "numberOfItems": faqEntries.length,
      "itemListElement": faqEntries.map((entry, index) => ({
        "@type": "ListItem",
        "position": index + 1,
        "url": `https://www.nigredo.ch${entry.href}`,
        "name": entry.question,
        "description": entry.answer
      }))
    }
  ]
});
---

<Layout
  title="Häufige Fragen zu professionellen Websites | Nigredo"
  description="Klare Antworten zu Kosten, Dauer, Pflege, Baukasten, Google und Datenschutz für KMU und Selbstständige in der Schweiz."
  canonical={pageUrl}
  ogTitle="Häufige Fragen zu professionellen Websites | Nigredo"
  ogDescription="Klare Antworten zu Kosten, Dauer, Pflege, Baukasten, Google und Datenschutz für KMU und Selbstständige in der Schweiz."
  twitterTitle="Häufige Fragen zu professionellen Websites | Nigredo"
  twitterDescription="Antworten zu Kosten, Dauer, Pflege, Baukasten, Google und Datenschutz."
  schema={schema}
>
  <section class="section faq-overview" aria-labelledby="faq-title">
    <div class="hero-glow"></div>
    <div class="container faq-overview__container">
      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Häufige Fragen' }
      ]} />

      <div class="faq-overview__intro fade-up">
        <h1 id="faq-title">Häufige <span class="gradient-text">Fragen.</span></h1>
        <p>
          Von Budget und Ablauf bis Sichtbarkeit, Pflege und Datenschutz: Hier findest du verständliche Antworten, damit du fundiert entscheiden kannst, was deine Website braucht.
        </p>
      </div>

      <div class="faq-grid" aria-label="FAQ-Übersicht">
        {faqEntries.map((entry, index) => (
          <a
            class={`faq-card fade-up ${index > 0 ? `delay-${Math.min(index, 4) * 100}` : ''}`.trim()}
            href={entry.href}
            aria-labelledby={`${entry.id}-title`}
          >
            <div class="faq-card__topline">
              <span class="faq-card__number">{String(index + 1).padStart(2, '0')}</span>
            </div>

            <div class="faq-card__body">
              <h2 id={`${entry.id}-title`}>{entry.question}</h2>
              <p>{entry.answer}</p>
            </div>

            <span class="faq-card__link">
              Antwort lesen
            </span>
          </a>
        ))}
      </div>

      <div class="faq-overview__cta fade-up">
        <p>Noch etwas offen?</p>
        <a href="/kontakt/" class="btn btn-primary">Frage persönlich klären</a>
      </div>

    </div>
  </section>
</Layout>

<style>
  .faq-overview {
    --faq-a: var(--brand-blue);
    --faq-b: var(--brand-violet);
    --faq-c: var(--brand-pink);
    animation: none;
  }

  .faq-overview {
    position: relative;
    min-height: auto;
    padding-top: var(--hero-offset-top-breadcrumb);
    padding-bottom: var(--section-py-md);
    overflow: hidden;
  }

  .faq-overview__container {
    position: relative;
    width: 100%;
  }

  .faq-overview :global(.breadcrumb) {
    margin-bottom: 28px;
  }

  .faq-overview__intro {
    max-width: 780px;
    margin-bottom: clamp(44px, 6vw, 64px);
  }

  .faq-overview__intro .badge {
    min-height: 26px;
    margin-bottom: 0.9rem;
    padding: 4px 10px;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: rgba(246, 240, 255, 0.96);
    border-color: color-mix(in srgb, var(--faq-b) 36%, rgba(255, 255, 255, 0.22));
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--faq-a) 14%, rgba(255, 255, 255, 0.03)), color-mix(in srgb, var(--faq-c) 10%, rgba(255, 255, 255, 0.015)));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 0 18px color-mix(in srgb, var(--faq-b) 14%, transparent);
  }

  .faq-overview__intro .gradient-text {
    background: var(--brand-gradient-cool);
    background-size: 100% auto;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .faq-overview__intro h1 {
    margin: 0 0 clamp(22px, 3vw, 30px);
    font-size: clamp(3.45rem, 6.4vw, 5.7rem);
    line-height: 0.98;
    letter-spacing: 0;
    color: #f5f5f7;
  }

  .faq-overview .hero-glow {
    background:
      radial-gradient(circle at 18% 40%, color-mix(in srgb, var(--faq-a) 18%, transparent) 0%, transparent 36%),
      radial-gradient(circle at 56% 34%, color-mix(in srgb, var(--faq-b) 17%, transparent) 0%, transparent 32%),
      radial-gradient(circle at 84% 44%, color-mix(in srgb, var(--faq-c) 16%, transparent) 0%, transparent 28%);
  }

  .faq-overview__intro p {
    max-width: 660px;
    margin: 0;
    color: var(--text-body);
    font-size: var(--lead-size);
    line-height: 1.65;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 26px;
    align-items: stretch;
  }

  .faq-card {
    display: grid;
    grid-template-rows: auto auto auto;
    gap: 24px;
    padding: clamp(24px, 3vw, 30px);
    border-radius: var(--radius-xl);
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.015)),
      rgba(10, 10, 12, 0.92);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.03),
      0 18px 44px rgba(0, 0, 0, 0.22);
    text-decoration: none;
    transition:
      transform 0.24s ease,
      border-color 0.24s ease,
      box-shadow 0.24s ease,
      background 0.24s ease;
  }

  .faq-card:hover,
  .faq-card:focus-visible {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.14);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.02)),
      rgba(10, 10, 12, 0.94);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.045),
      0 24px 52px rgba(0, 0, 0, 0.28);
  }

  .faq-card:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--faq-b) 34%, rgba(255, 255, 255, 0.12));
    outline-offset: 4px;
  }

  .faq-card__topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
  }

  .faq-card__number {
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    line-height: 1;
  }

  .faq-card__body h2 {
    max-width: 22ch;
    margin: 0 0 0.95rem;
    color: rgba(255, 255, 255, 0.96);
    font-size: clamp(1.3rem, 2.2vw, 1.78rem);
    line-height: 1.14;
    letter-spacing: -0.01em;
  }

  .faq-card__body p {
    margin: 0;
    color: var(--text-soft);
    font-size: 1rem;
    line-height: 1.72;
  }

  .faq-card__link {
    margin-top: 2px;
    width: fit-content;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 16px;
    border-radius: var(--radius-pill);
    color: rgba(255, 255, 255, 0.94);
    font-weight: 700;
    text-decoration: none;
    background:
      linear-gradient(#050505, #050505),
      linear-gradient(rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.18));
    background-origin: border-box;
    background-clip: padding-box, border-box;
    border: 1px solid transparent;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background-image 0.2s ease;
  }

  .faq-card:hover .faq-card__link,
  .faq-card:focus-visible .faq-card__link {
    transform: translateY(-2px);
    background-image:
      linear-gradient(#0a0a0c, #0a0a0c),
      linear-gradient(
        color-mix(in srgb, var(--faq-b) 28%, transparent),
        color-mix(in srgb, var(--faq-b) 18%, transparent)
      );
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.22);
  }

  @media (max-width: 980px) {
    .faq-overview {
      padding-top: var(--hero-offset-top-breadcrumb-mobile);
      padding-bottom: 72px;
    }

    .faq-overview__intro h1 {
      font-size: clamp(2.9rem, 10.2vw, 4.3rem);
      line-height: var(--hero-title-line-height-mobile);
    }

    .faq-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .faq-overview__intro {
      margin-bottom: 38px;
    }

    .faq-overview__intro h1 {
      font-size: clamp(2.6rem, 13.6vw, 3.45rem);
    }

    .faq-overview__intro p {
      font-size: var(--lead-size-mobile);
      line-height: 1.6;
    }

    .faq-card {
      gap: 20px;
      padding: 22px 20px;
      border-radius: var(--radius-xl);
    }

    .faq-card__topline {
      align-items: flex-start;
      flex-direction: column;
      gap: 10px;
    }

    .faq-card__body h2 {
      max-width: none;
      font-size: 1.38rem;
    }

    .faq-card__body p {
      font-size: 1rem;
      line-height: 1.68;
    }

    .faq-card__link {
      width: auto;
      min-width: 148px;
      align-self: center;
    }
  }

  /* Editorialer Fragenindex statt gleichförmiger Kartenwand */
  .faq-grid {
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .faq-card {
    grid-template-columns: minmax(120px, 0.28fr) minmax(0, 1fr) auto;
    grid-template-rows: auto;
    align-items: start;
    gap: clamp(24px, 5vw, 64px);
    padding: var(--section-py-sm) 0;
    border: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  .faq-card:hover,
  .faq-card:focus-visible {
    transform: none;
    border-color: rgba(255, 255, 255, 0.2);
    background: linear-gradient(90deg, rgba(65, 101, 255, 0.045), transparent 70%);
    box-shadow: none;
  }

  .faq-card__topline {
    display: grid;
    justify-content: start;
    gap: 12px;
  }

  .faq-card__number {
    color: color-mix(in srgb, var(--faq-a) 82%, white 8%);
  }

  .faq-card__body h2 {
    max-width: 28ch;
    font-size: clamp(1.45rem, 2.7vw, 2.15rem);
  }

  .faq-card__body p {
    max-width: 62ch;
    color: var(--text-body);
  }

  .faq-card__link {
    min-height: 44px;
    margin: 0;
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: var(--text-body);
    white-space: nowrap;
  }

  .faq-card__link::after {
    content: '↗';
    margin-left: 9px;
    color: color-mix(in srgb, var(--faq-b) 78%, white 8%);
  }

  .faq-card:hover .faq-card__link,
  .faq-card:focus-visible .faq-card__link {
    transform: translateX(4px);
    background: transparent;
    box-shadow: none;
  }

  .faq-overview__cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-top: clamp(56px, 7vw, 84px);
    padding-top: 30px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .faq-overview__cta p {
    margin: 0;
    color: rgba(255, 255, 255, 0.82);
    font-size: clamp(1.2rem, 2.4vw, 1.65rem);
    font-weight: 600;
  }

  @media (max-width: 760px) {
    .faq-card {
      grid-template-columns: 70px minmax(0, 1fr);
      gap: 22px;
    }

    .faq-card__link {
      grid-column: 2;
      justify-self: start;
    }

    .faq-overview__cta {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 520px) {
    .faq-card {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 28px 0;
    }

    .faq-card__topline,
    .faq-card__link {
      grid-column: 1;
    }

    .faq-card__link {
      min-width: 0;
      align-self: start;
    }
  }
</style>
