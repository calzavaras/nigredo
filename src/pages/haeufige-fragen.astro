---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const pageUrl = 'https://www.nigredo.ch/haeufige-fragen/';

const faqEntries = [
  {
    id: 'faq-cost',
    category: 'Website-Kosten',
    question: 'Was kostet eine professionelle Website?',
    answer: 'Eine professionelle Website kostet je nach Umfang, Inhalt, Designanspruch und technischer Umsetzung unterschiedlich viel. Für KMU und Selbständige in der Schweiz beginnt eine seriös umgesetzte Website meist im unteren vierstelligen Bereich; umfangreichere Auftritte mit Konzept, Text, SEO und Funktionen liegen entsprechend höher.',
    href: '/haeufige-fragen/was-kostet-eine-professionelle-website/'
  }
];

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Häufige Fragen", "item": pageUrl }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      "mainEntity": faqEntries.map((entry) => ({
        "@type": "Question",
        "name": entry.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": entry.answer
        }
      }))
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": "Häufige Fragen | Nigredo",
      "description": "Kurze Antworten auf wichtige Fragen zu professionellen Websites, Kosten und sinnvoller Umsetzung.",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "mainEntity": { "@id": `${pageUrl}#faq` },
      "inLanguage": "de-CH",
      "datePublished": "2026-05-16",
      "dateModified": "2026-05-16",
      "isAccessibleForFree": true
    }
  ]
});
---

<Layout
  title="Häufige Fragen | Nigredo"
  description="Kurze Antworten auf wichtige Fragen zu professionellen Websites, Kosten und sinnvoller Umsetzung. Klar, direkt und ohne Verkaufsnebel."
  canonical={pageUrl}
  ogTitle="Häufige Fragen | Nigredo"
  ogDescription="Kurze Antworten auf wichtige Fragen zu professionellen Websites, Kosten und sinnvoller Umsetzung."
  twitterTitle="Häufige Fragen | Nigredo"
  twitterDescription="Kurze Antworten auf wichtige Fragen zu professionellen Websites und Kosten."
  schema={schema}
>
  <section class="section faq-overview" aria-labelledby="faq-title">
    <div class="hero-glow"></div>
    <div class="container faq-overview__container">
      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Häufige Fragen' }
      ]} />

      <div class="faq-overview__intro fade-up">
        <span class="badge badge--yellow">FAQ</span>
        <h1 id="faq-title">Häufige <span class="gradient-text">Fragen.</span></h1>
        <p>
          Kurze Antworten auf Fragen, die vor einer professionellen Website wirklich zählen. Die Übersicht bleibt bewusst knapp; ausführlichere Erklärungen stehen dort, wo sie sinnvoll sind.
        </p>
      </div>

      <div class="faq-grid" aria-label="FAQ-Übersicht">
        {faqEntries.map((entry, index) => (
          <a
            class={`faq-card fade-up ${index > 0 ? `delay-${Math.min(index, 4) * 100}` : ''}`.trim()}
            href={entry.href}
            aria-labelledby={`${entry.id}-title`}
          >
            <div class="faq-card__topline">
              <span class="faq-card__number">{String(index + 1).padStart(2, '0')}</span>
              <span class="faq-card__category">{entry.category}</span>
            </div>

            <div class="faq-card__body">
              <h2 id={`${entry.id}-title`}>{entry.question}</h2>
              <p>{entry.answer}</p>
            </div>

            <span class="faq-card__link">
              Mehr lesen
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .faq-overview {
    --faq-a: #ff7c20;
    --faq-b: #ff2e55;
    --faq-c: #cc20cc;
    animation: faqCycle 90s ease-in-out infinite;
  }

  .faq-overview {
    position: relative;
    min-height: auto;
    padding-top: var(--hero-offset-top-breadcrumb);
    padding-bottom: clamp(84px, 8vw, 112px);
    overflow: hidden;
  }

  .faq-overview__container {
    position: relative;
    width: 100%;
  }

  .faq-overview :global(.breadcrumb) {
    margin-bottom: 28px;
  }

  .faq-overview__intro {
    max-width: 780px;
    margin-bottom: clamp(44px, 6vw, 64px);
  }

  .faq-overview__intro .badge {
    min-height: 26px;
    margin-bottom: 0.9rem;
    padding: 4px 10px;
    font-size: 0.54rem;
    letter-spacing: 0.14em;
    color: rgba(255, 236, 224, 0.94);
    border-color: color-mix(in srgb, var(--faq-b) 34%, rgba(255, 255, 255, 0.22));
    background: transparent;
    box-shadow: none;
  }

  .faq-overview__intro .gradient-text {
    background: linear-gradient(
      90deg,
      var(--faq-a) 0%,
      color-mix(in srgb, var(--faq-a) 84%, var(--faq-b)) 14%,
      color-mix(in srgb, var(--faq-a) 62%, var(--faq-b)) 28%,
      color-mix(in srgb, var(--faq-a) 34%, var(--faq-b)) 42%,
      color-mix(in srgb, var(--faq-a) 12%, var(--faq-b)) 54%,
      color-mix(in srgb, var(--faq-b) 78%, var(--faq-c)) 66%,
      color-mix(in srgb, var(--faq-b) 54%, var(--faq-c)) 78%,
      color-mix(in srgb, var(--faq-b) 28%, var(--faq-c)) 90%,
      var(--faq-c) 100%
    );
    background-size: 100% auto;

    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    filter:
      drop-shadow(0 0 12px color-mix(in srgb, var(--faq-a) 22%, transparent))
      drop-shadow(0 0 18px color-mix(in srgb, var(--faq-c) 14%, transparent));
  }

  .faq-overview__intro h1 {
    margin: 0 0 clamp(22px, 3vw, 30px);
    font-size: clamp(3.45rem, 6.4vw, 5.7rem);
    line-height: 0.98;
    letter-spacing: 0;
    color: #f5f5f7;
  }

  .faq-overview .hero-glow {
    background:
      radial-gradient(circle at 18% 40%, color-mix(in srgb, var(--faq-a) 18%, transparent) 0%, transparent 36%),
      radial-gradient(circle at 56% 34%, color-mix(in srgb, var(--faq-b) 17%, transparent) 0%, transparent 32%),
      radial-gradient(circle at 84% 44%, color-mix(in srgb, var(--faq-c) 16%, transparent) 0%, transparent 28%);
  }

  .faq-overview__intro p {
    max-width: 660px;
    margin: 0;
    color: rgba(255, 255, 255, 0.66);
    font-size: var(--lead-size);
    line-height: 1.65;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 26px;
    align-items: stretch;
  }

  .faq-card {
    display: grid;
    grid-template-rows: auto auto auto;
    gap: 24px;
    padding: clamp(24px, 3vw, 30px);
    border-radius: 26px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.015)),
      rgba(10, 10, 12, 0.92);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.03),
      0 18px 44px rgba(0, 0, 0, 0.22);
    text-decoration: none;
    transition:
      transform 0.24s ease,
      border-color 0.24s ease,
      box-shadow 0.24s ease,
      background 0.24s ease;
  }

  .faq-card:hover,
  .faq-card:focus-visible {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.14);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.02)),
      rgba(10, 10, 12, 0.94);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.045),
      0 24px 52px rgba(0, 0, 0, 0.28);
  }

  .faq-card:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--faq-b) 34%, rgba(255, 255, 255, 0.12));
    outline-offset: 4px;
  }

  .faq-card__topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
  }

  .faq-card__number {
    color: color-mix(in srgb, var(--faq-b) 88%, white 10%);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    line-height: 1;
  }

  .faq-card__category {
    color: rgba(255, 255, 255, 0.46);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-align: right;
  }

  .faq-card__body h2 {
    max-width: 22ch;
    margin: 0 0 0.95rem;
    color: rgba(255, 255, 255, 0.96);
    font-size: clamp(1.3rem, 2.2vw, 1.78rem);
    line-height: 1.14;
    letter-spacing: -0.01em;
  }

  .faq-card__body p {
    margin: 0;
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.99rem;
    line-height: 1.72;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .faq-card__link {
    margin-top: 2px;
    width: fit-content;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 16px;
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.94);
    font-weight: 700;
    text-decoration: none;
    background:
      linear-gradient(#050505, #050505),
      linear-gradient(rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.18));
    background-origin: border-box;
    background-clip: padding-box, border-box;
    border: 1px solid transparent;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background-image 0.2s ease;
  }

  .faq-card:hover .faq-card__link,
  .faq-card:focus-visible .faq-card__link {
    transform: translateY(-2px);
    background-image:
      linear-gradient(#0a0a0c, #0a0a0c),
      linear-gradient(
        color-mix(in srgb, var(--faq-b) 28%, transparent),
        color-mix(in srgb, var(--faq-b) 18%, transparent)
      );
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.22);
  }

  @media (max-width: 980px) {
    .faq-overview {
      padding-top: var(--hero-offset-top-breadcrumb-mobile);
      padding-bottom: 72px;
    }

    .faq-overview__intro h1 {
      font-size: clamp(2.9rem, 10.2vw, 4.3rem);
      line-height: var(--hero-title-line-height-mobile);
    }

    .faq-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .faq-overview__intro {
      margin-bottom: 38px;
    }

    .faq-overview__intro h1 {
      font-size: clamp(2.6rem, 13.6vw, 3.45rem);
    }

    .faq-overview__intro p {
      font-size: var(--lead-size-mobile);
      line-height: 1.6;
    }

    .faq-card {
      gap: 20px;
      padding: 22px 20px;
      border-radius: 22px;
    }

    .faq-card__topline {
      align-items: flex-start;
      flex-direction: column;
      gap: 10px;
    }

    .faq-card__category {
      text-align: left;
    }

    .faq-card__body h2 {
      max-width: none;
      font-size: 1.38rem;
    }

    .faq-card__body p {
      font-size: 0.98rem;
      line-height: 1.68;
      -webkit-line-clamp: 5;
    }

    .faq-card__link {
      width: auto;
      min-width: 148px;
      align-self: center;
    }
  }
</style>
