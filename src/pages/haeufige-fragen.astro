---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const pageUrl = 'https://www.nigredo.ch/haeufige-fragen/';

const faqEntries = [
  {
    id: 'faq-cost',
    category: 'Website-Kosten',
    question: 'Was kostet eine professionelle Website?',
    answer: 'Eine professionelle Website hat keinen seriösen Einheitspreis. Für KMU und Selbständige in der Schweiz beginnt eine sauber umgesetzte Website meist im unteren vierstelligen Bereich. Entscheidend sind Umfang, Inhalt, Gestaltung, Technik und das Ziel der Website.',
    href: '/haeufige-fragen/was-kostet-eine-professionelle-website/'
  },
  {
    id: 'faq-timeline',
    category: 'Projektablauf',
    question: 'Wie lange dauert die Erstellung einer professionellen Website?',
    answer: 'Eine schlanke professionelle Website kann in wenigen Wochen online sein. Mehr Zeit braucht es, wenn Texte, Struktur, Bildmaterial, SEO oder Freigaben zuerst erarbeitet werden müssen. Der wichtigste Beschleuniger ist ein klarer Umfang.',
    href: '/haeufige-fragen/wie-lange-dauert-die-erstellung-einer-professionellen-website/'
  },
  {
    id: 'faq-maintenance',
    category: 'Pflege & CMS',
    question: 'Kann ich meine professionelle Website später selbst bearbeiten und pflegen?',
    answer: 'Ja, viele Inhalte lassen sich später selbst pflegen, wenn die Website entsprechend geplant wird. Ob ein CMS sinnvoll ist, hängt davon ab, wie oft Inhalte geändert werden und wer intern damit arbeitet. Nicht jede Website braucht dafür ein grosses System.',
    href: '/haeufige-fragen/kann-ich-meine-professionelle-website-selbst-bearbeiten-und-pflegen/'
  }
];

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Häufige Fragen", "item": pageUrl }
      ]
    },
    {
      "@type": ["CollectionPage", "WebPage"],
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": "Häufige Fragen zu professionellen Websites | Nigredo",
      "description": "Klare Antworten auf häufige Fragen zu Kosten, Dauer und späterer Pflege professioneller Websites für KMU und Selbständige in der Schweiz.",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "mainEntity": { "@id": `${pageUrl}#faq` },
      "hasPart": { "@id": `${pageUrl}#faqs` },
      "about": { "@id": "https://www.nigredo.ch/#organization" },
      "inLanguage": "de-CH",
      "datePublished": "2026-05-16",
      "dateModified": "2026-05-18",
      "isAccessibleForFree": true,
      "significantLink": faqEntries.map((entry) => `https://www.nigredo.ch${entry.href}`)
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      "mainEntity": faqEntries.map((entry) => ({
        "@type": "Question",
        "name": entry.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": entry.answer
        }
      }))
    },
    {
      "@type": "ItemList",
      "@id": `${pageUrl}#faqs`,
      "name": "Häufige Fragen zu professionellen Websites",
      "numberOfItems": faqEntries.length,
      "itemListElement": faqEntries.map((entry, index) => ({
        "@type": "ListItem",
        "position": index + 1,
        "url": `https://www.nigredo.ch${entry.href}`,
        "name": entry.question,
        "description": entry.answer
      }))
    }
  ]
});
---

<Layout
  title="Häufige Fragen zu professionellen Websites | Nigredo"
  description="Klare Antworten auf häufige Fragen zu Kosten, Dauer und späterer Pflege professioneller Websites für KMU und Selbständige in der Schweiz."
  canonical={pageUrl}
  ogTitle="Häufige Fragen zu professionellen Websites | Nigredo"
  ogDescription="Antworten zu Kosten, Dauer und Pflege professioneller Websites. Prägnant, verständlich und hilfreich für KMU und Selbständige."
  twitterTitle="Häufige Fragen zu professionellen Websites | Nigredo"
  twitterDescription="Antworten zu Kosten, Dauer und Pflege professioneller Websites."
  schema={schema}
>
  <section class="section faq-overview" aria-labelledby="faq-title">
    <div class="hero-glow"></div>
    <div class="container faq-overview__container">
      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Häufige Fragen' }
      ]} />

      <div class="faq-overview__intro fade-up">
        <span class="badge badge--yellow">FAQ</span>
        <h1 id="faq-title">Häufige <span class="gradient-text">Fragen.</span></h1>
        <p>
          Hier finden Sie klare Antworten auf häufige Fragen rund um professionelle Websites, von Aufwand und Ablauf bis zur späteren Pflege und Weiterentwicklung.
        </p>
      </div>

      <div class="faq-grid" aria-label="FAQ-Übersicht">
        {faqEntries.map((entry, index) => (
          <a
            class={`faq-card fade-up ${index > 0 ? `delay-${Math.min(index, 4) * 100}` : ''}`.trim()}
            href={entry.href}
            aria-labelledby={`${entry.id}-title`}
          >
            <div class="faq-card__topline">
              <span class="faq-card__number">{String(index + 1).padStart(2, '0')}</span>
              <span class="faq-card__category">{entry.category}</span>
            </div>

            <div class="faq-card__body">
              <h2 id={`${entry.id}-title`}>{entry.question}</h2>
              <p>{entry.answer}</p>
            </div>

            <span class="faq-card__link">
              Mehr lesen
            </span>
          </a>
        ))}
      </div>

    </div>
  </section>
</Layout>

<style>
  .faq-overview {
    --faq-a: #695cff;
    --faq-b: #a05eff;
    --faq-c: #ff83cf;
    animation: faqCycle 90s ease-in-out infinite;
  }

  .faq-overview {
    position: relative;
    min-height: auto;
    padding-top: var(--hero-offset-top-breadcrumb);
    padding-bottom: clamp(84px, 8vw, 112px);
    overflow: hidden;
  }

  .faq-overview__container {
    position: relative;
    width: 100%;
  }

  .faq-overview :global(.breadcrumb) {
    margin-bottom: 28px;
  }

  .faq-overview__intro {
    max-width: 780px;
    margin-bottom: clamp(44px, 6vw, 64px);
  }

  .faq-overview__intro .badge {
    min-height: 26px;
    margin-bottom: 0.9rem;
    padding: 4px 10px;
    font-size: 0.54rem;
    letter-spacing: 0.14em;
    color: rgba(246, 240, 255, 0.96);
    border-color: color-mix(in srgb, var(--faq-b) 36%, rgba(255, 255, 255, 0.22));
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--faq-a) 14%, rgba(255, 255, 255, 0.03)), color-mix(in srgb, var(--faq-c) 10%, rgba(255, 255, 255, 0.015)));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 0 18px color-mix(in srgb, var(--faq-b) 14%, transparent);
  }

  .faq-overview__intro .gradient-text {
    background: linear-gradient(
      90deg,
      var(--faq-a) 0%,
      color-mix(in srgb, var(--faq-a) 78%, var(--faq-b)) 18%,
      color-mix(in srgb, var(--faq-a) 34%, var(--faq-b)) 46%,
      color-mix(in srgb, var(--faq-b) 74%, var(--faq-c)) 72%,
      color-mix(in srgb, var(--faq-b) 28%, var(--faq-c)) 90%,
      var(--faq-c) 100%
    );
    background-size: 100% auto;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .faq-overview__intro h1 {
    margin: 0 0 clamp(22px, 3vw, 30px);
    font-size: clamp(3.45rem, 6.4vw, 5.7rem);
    line-height: 0.98;
    letter-spacing: 0;
    color: #f5f5f7;
  }

  .faq-overview .hero-glow {
    background:
      radial-gradient(circle at 18% 40%, color-mix(in srgb, var(--faq-a) 18%, transparent) 0%, transparent 36%),
      radial-gradient(circle at 56% 34%, color-mix(in srgb, var(--faq-b) 17%, transparent) 0%, transparent 32%),
      radial-gradient(circle at 84% 44%, color-mix(in srgb, var(--faq-c) 16%, transparent) 0%, transparent 28%);
  }

  .faq-overview__intro p {
    max-width: 660px;
    margin: 0;
    color: rgba(255, 255, 255, 0.66);
    font-size: var(--lead-size);
    line-height: 1.65;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 26px;
    align-items: stretch;
  }

  .faq-card {
    display: grid;
    grid-template-rows: auto auto auto;
    gap: 24px;
    padding: clamp(24px, 3vw, 30px);
    border-radius: 26px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.015)),
      rgba(10, 10, 12, 0.92);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.03),
      0 18px 44px rgba(0, 0, 0, 0.22);
    text-decoration: none;
    transition:
      transform 0.24s ease,
      border-color 0.24s ease,
      box-shadow 0.24s ease,
      background 0.24s ease;
  }

  .faq-card:hover,
  .faq-card:focus-visible {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.14);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.02)),
      rgba(10, 10, 12, 0.94);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.045),
      0 24px 52px rgba(0, 0, 0, 0.28);
  }

  .faq-card:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--faq-b) 34%, rgba(255, 255, 255, 0.12));
    outline-offset: 4px;
  }

  .faq-card__topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
  }

  .faq-card__number {
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    line-height: 1;
  }

  .faq-card__category {
    color: rgba(255, 255, 255, 0.46);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-align: right;
  }

  .faq-card__body h2 {
    max-width: 22ch;
    margin: 0 0 0.95rem;
    color: rgba(255, 255, 255, 0.96);
    font-size: clamp(1.3rem, 2.2vw, 1.78rem);
    line-height: 1.14;
    letter-spacing: -0.01em;
  }

  .faq-card__body p {
    margin: 0;
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.99rem;
    line-height: 1.72;
  }

  .faq-card__link {
    margin-top: 2px;
    width: fit-content;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 16px;
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.94);
    font-weight: 700;
    text-decoration: none;
    background:
      linear-gradient(#050505, #050505),
      linear-gradient(rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.18));
    background-origin: border-box;
    background-clip: padding-box, border-box;
    border: 1px solid transparent;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background-image 0.2s ease;
  }

  .faq-card:hover .faq-card__link,
  .faq-card:focus-visible .faq-card__link {
    transform: translateY(-2px);
    background-image:
      linear-gradient(#0a0a0c, #0a0a0c),
      linear-gradient(
        color-mix(in srgb, var(--faq-b) 28%, transparent),
        color-mix(in srgb, var(--faq-b) 18%, transparent)
      );
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.22);
  }

  @media (max-width: 980px) {
    .faq-overview {
      padding-top: var(--hero-offset-top-breadcrumb-mobile);
      padding-bottom: 72px;
    }

    .faq-overview__intro h1 {
      font-size: clamp(2.9rem, 10.2vw, 4.3rem);
      line-height: var(--hero-title-line-height-mobile);
    }

    .faq-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .faq-overview__intro {
      margin-bottom: 38px;
    }

    .faq-overview__intro h1 {
      font-size: clamp(2.6rem, 13.6vw, 3.45rem);
    }

    .faq-overview__intro p {
      font-size: var(--lead-size-mobile);
      line-height: 1.6;
    }

    .faq-card {
      gap: 20px;
      padding: 22px 20px;
      border-radius: 22px;
    }

    .faq-card__topline {
      align-items: flex-start;
      flex-direction: column;
      gap: 10px;
    }

    .faq-card__category {
      text-align: left;
    }

    .faq-card__body h2 {
      max-width: none;
      font-size: 1.38rem;
    }

    .faq-card__body p {
      font-size: 0.98rem;
      line-height: 1.68;
    }

    .faq-card__link {
      width: auto;
      min-width: 148px;
      align-self: center;
    }
  }
</style>
