---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const leadershipSinceYear = 2011;
const leadershipYears = new Date().getFullYear() - leadershipSinceYear;

const pageUrl = 'https://www.nigredo.ch/marco-calzavara/';
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Über mich", "item": pageUrl }
      ]
    },
    {
      "@type": "AboutPage",
      "@id": `${pageUrl}#webpage`,
      "name": "Über mich | Marco Calzavara | Nigredo",
      "url": pageUrl,
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "inLanguage": "de-CH",
      "datePublished": "2025-06-01",
      "dateModified": "2026-05-17",
      "isAccessibleForFree": true,
      "publisher": { "@id": "https://www.nigredo.ch/#organization" },
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", ".pc-name", ".belief-title"]
      },
      "mainEntity": { "@id": "https://www.nigredo.ch/#person" }
    }
  ]
});
---

<Layout
  title="Über mich | Marco Calzavara | Nigredo"
  description={`Marco Calzavara – ${leadershipYears} Jahre Führung, 3 Firmen gegründet und verkauft. KI, Gestaltung und Umsetzung direkt aus St. Gallen.`}
  canonical={pageUrl}
  ogTitle="Ein Mensch. 1001 Ideen."
  ogDescription="15 Jahre Führung. 3 Firmen gegründet & verkauft. Baut mit KI-Agenten, liefert was sonst Teams brauchen. Direkt, persönlich, aus St. Gallen."
  ogType="profile"
  ogImage="https://www.nigredo.ch/assets/marco-calzavara-portrait-nigredo-st-gallen.jpg"
  ogImageAlt="Marco Calzavara - Gründer von Nigredo"
  ogImageWidth="768"
  ogImageHeight="1024"
  twitterTitle="Ein Mensch. 1001 Ideen."
  twitterDescription="Macher, Ideengeber und Gründer aus St. Gallen. Verwaltungsexpertise, KI und ein starkes IT-Netzwerk."
  schema={schema}
  preloadImage="/assets/marco-calzavara-nigredo-st-gallen-500.avif"
  preloadImageType="image/avif"
  preloadImageSrcset="/assets/marco-calzavara-nigredo-st-gallen-500.avif 500w, /assets/marco-calzavara-nigredo-st-gallen-750.avif 750w, /assets/marco-calzavara-nigredo-st-gallen-1000.avif 1000w"
  preloadImageSizes="(max-width: 600px) 204px, 252px"
>
  <section class="section pt-sub about-hero" aria-labelledby="about-title">
    <div class="hero-glow"></div>
    <div class="container about-hero__container">

      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Über mich' }
      ]} />

      <!-- Hero -->
      <div class="fade-up home-hero__inner about-hero__intro">
        <span class="badge badge--pink">PROFIL</span>
        <h1 id="about-title" class="home-hero__title about-hero__title">
          Ein Mensch.<br>
          <span class="gradient-text">1001 Ideen.</span>
        </h1>
      </div>

      <!-- Main Profile & Intro Grid -->
      <div class="au-main-grid mt-80">
        <div class="au-profile-column fade-up delay-100">
          <div class="au-photo-container">
            <div class="au-photo-aura"></div>
            <div class="au-photo-circle-wrap">
              <picture>
                <source srcset="/assets/marco-calzavara-nigredo-st-gallen-500.avif 500w, /assets/marco-calzavara-nigredo-st-gallen-750.avif 750w, /assets/marco-calzavara-nigredo-st-gallen-1000.avif 1000w" sizes="(max-width: 600px) 204px, 252px" type="image/avif">
                <source srcset="/assets/marco-calzavara-nigredo-st-gallen-500.webp 500w, /assets/marco-calzavara-nigredo-st-gallen-750.webp 750w, /assets/marco-calzavara-nigredo-st-gallen-1000.webp 1000w" sizes="(max-width: 600px) 204px, 252px" type="image/webp">
                <img
                  src="/assets/marco-calzavara-nigredo-st-gallen.jpg"
                  alt="Marco Calzavara – Gründer und Inhaber von Nigredo, St. Gallen"
                  class="au-photo-circle"
                  width="1086"
                  height="1086"
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                />
              </picture>
            </div>
          </div>
          <div class="au-profile-info">
            <h2 class="au-name">Marco Calzavara</h2>
            <p class="au-role">Ideengeber. Vernetzer. Umsetzer.</p>
          </div>
        </div>

        <div class="au-content-column fade-up delay-150">
          <div class="au-statement">
            <blockquote class="hero-lead about-statement__quote">
              Ich habe selten nur eine Idee. Aber meistens ziemlich schnell einen Anfang.
            </blockquote>
          </div>
          
          <div class="au-bio">
            <p class="au-bio-intro">
              Ich bin ein Macher mit Ideenüberschuss: kreativ, neugierig, manchmal unkonventionell und ziemlich allergisch gegen «Das haben wir schon immer so gemacht». Mich interessieren Möglichkeiten, bevor sie fertig sortiert sind. Und noch mehr interessiert mich, was daraus werden kann.
            </p>
            
            <div class="au-bio-more" data-bio-more>
              <button
                type="button"
                class="au-bio-more__toggle"
                aria-expanded="false"
                aria-controls="au-bio-more-content"
                data-bio-more-toggle
              >
                Mehr erfahren
              </button>
              <div id="au-bio-more-content" class="au-bio-more__panel" hidden data-bio-more-panel>
                <div class="au-bio-more__content">
                  <p>
                    Hauptberuflich arbeite ich seit 2009 bei der IV Stelle und bin seit 2011 in der Führung. Heute leite ich ein Expertenteam und bin für Abteilungsentwicklung zuständig. Das hat mich geprägt: klar denken, Menschen mitnehmen, Komplexität ordnen und Lösungen so bauen, dass sie im Alltag wirklich funktionieren.
                  </p>
                  <p>
                    Daneben entstehen Unternehmen, Projekte und digitale Lösungen. Ich habe mehrere Firmen gegründet, einige verkauft, viel umgesetzt und dabei noch mehr gelernt. Mit Nigredo verbinde ich Ideen, KI, Gestaltung und starke Informatikfachleute. Mit einem Kollegen führe ich ausserdem die HappyPath GmbH, eine schweizweite Softwarelösung für Sozialversicherungen.
                  </p>
                  <p>
                    Ich muss nicht alles allein können. Aber ich muss erkennen, was möglich ist, die richtigen Menschen zusammenbringen und dafür sorgen, dass etwas passiert. Wenn ich etwas anpacke, bleibt es nicht monatelang in schönen Konzepten liegen. Kein grosses Theater. Lieber gute Arbeit, die man zeigen kann.
                  </p>
                  <button type="button" class="au-bio-more__toggle au-bio-more__toggle--close" data-bio-more-close>
                    Weniger anzeigen
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="au-stats-grid mt-80 fade-up delay-200">
        <div class="au-stat-card">
          <div class="au-stat-inner">
            <span class="au-stat-value">{leadershipYears}</span>
            <span class="au-stat-desc">Jahre Führung seit {leadershipSinceYear}</span>
          </div>
        </div>
        <div class="au-stat-card">
          <div class="au-stat-inner">
            <span class="au-stat-value">3×</span>
            <span class="au-stat-desc">Firmen gegründet, aufgebaut, verkauft</span>
          </div>
        </div>
        <div class="au-stat-card">
          <div class="au-stat-inner">
            <span class="au-stat-value">1</span>
            <span class="au-stat-desc">Ideengeber, Netzwerk, direkte Verantwortung</span>
          </div>
        </div>
        <div class="au-stat-card">
          <div class="au-stat-inner">
            <span class="au-stat-value">∞</span>
            <span class="au-stat-desc">Neugier, Initiative und Umsetzungsdrang</span>
          </div>
        </div>
      </div>

      <!-- Principles -->
      <div class="mt-80 fade-up delay-300">
        <span class="badge badge--pink">PRINZIPIEN</span>
        <h2>Woran ich glaube.</h2>
        <div class="grid-3">
          <article class="card au-principle-card">
            <div class="au-principle-number">01</div>
            <h3><span>Anpacken</span> schlägt Abwarten.</h3>
            <p class="au-principle-text">Viele gute Ideen scheitern nicht an der Technik, sondern daran, dass niemand den ersten Schritt macht.</p>
          </article>
          <article class="card au-principle-card">
            <div class="au-principle-number">02</div>
            <h3>Technik braucht <span>Richtung</span>.</h3>
            <p class="au-principle-text">KI, Software und gute Leute können viel. Entscheidend ist, wofür man sie einsetzt.</p>
          </article>
          <article class="card au-principle-card">
            <div class="au-principle-number">03</div>
            <h3>Kein Theater. <span>Ergebnis</span>.</h3>
            <p class="au-principle-text">Klar denken, schnell starten, sauber umsetzen. Am Ende soll etwas stehen, das man gern zeigt.</p>
          </article>
        </div>
      </div>

      <!-- CTA -->
      <div class="section about-final-section fade-up">
        <div class="section-cta about-final-cta">
          <span class="cta-label">Und jetzt?</span>
          <h2>Noch keine fertige Idee?<br><span>Genau richtig.</span></h2>
          <div class="hero-cta-group" style="justify-content: center;">
            <a href="/kontakt/" class="btn btn-primary">Direkt schreiben</a>
            <a href="/referenzen/" class="btn btn-ghost">Projekte ansehen</a>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<script>
  const bioMore = document.querySelector('[data-bio-more]');
  const bioMoreToggle = bioMore?.querySelector('[data-bio-more-toggle]');
  const bioMoreClose = bioMore?.querySelector('[data-bio-more-close]');
  const bioMorePanel = bioMore?.querySelector('[data-bio-more-panel]');

  if (bioMoreToggle instanceof HTMLButtonElement && bioMorePanel instanceof HTMLElement) {
    let closeTimer: number | undefined;

    const setBioMoreOpen = (shouldOpen: boolean) => {
      window.clearTimeout(closeTimer);
      bioMoreToggle.setAttribute('aria-expanded', String(shouldOpen));

      if (shouldOpen) {
        bioMorePanel.hidden = false;
        bioMoreToggle.hidden = true;
        window.requestAnimationFrame(() => {
          bioMorePanel.classList.add('is-open');
        });
        return;
      }

      bioMorePanel.classList.remove('is-open');
      bioMoreToggle.hidden = false;
      closeTimer = window.setTimeout(() => {
        if (bioMoreToggle.getAttribute('aria-expanded') !== 'true') {
          bioMorePanel.hidden = true;
        }
      }, 480);
    };

    bioMoreToggle.addEventListener('click', () => setBioMoreOpen(true));

    if (bioMoreClose instanceof HTMLButtonElement) {
      bioMoreClose.addEventListener('click', () => setBioMoreOpen(false));
    }
  }
</script>

<style>
  .about-hero {
    --about-a: #ffb830;
    --about-b: #ff5030;
    --about-c: #e0246a;
    animation: aboutCycle 90s ease-in-out infinite;
    padding-top: var(--hero-offset-top-breadcrumb);
    padding-bottom: var(--hero-offset-bottom);
  }

  .about-hero__container {
    position: relative;
    width: 100%;
  }

  .about-hero :global(.breadcrumb) {
    margin-bottom: 28px;
  }

  .about-hero .badge {
    margin-bottom: 0.95rem;
    color: rgba(255, 241, 232, 0.94);
    border-color: color-mix(in srgb, var(--about-b) 38%, rgba(255, 255, 255, 0.22));
    background: transparent;
    box-shadow: none;
  }

  .about-hero__intro {
    width: 100%;
    max-width: 940px;
  }

  .about-hero__title {
    max-width: 940px;
    font-size: var(--hero-title-size);
    line-height: var(--hero-title-line-height);
    letter-spacing: -0.02em;
    margin-bottom: 0;
  }

  .about-hero .gradient-text {
    background: linear-gradient(
      90deg,
      var(--about-a) 0%,
      color-mix(in srgb, var(--about-a) 84%, var(--about-b)) 14%,
      color-mix(in srgb, var(--about-a) 58%, var(--about-b)) 28%,
      color-mix(in srgb, var(--about-a) 24%, var(--about-b)) 44%,
      color-mix(in srgb, var(--about-b) 90%, var(--about-c)) 64%,
      color-mix(in srgb, var(--about-b) 62%, var(--about-c)) 80%,
      var(--about-c) 100%
    );
    background-size: 100% auto;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    filter:
      drop-shadow(0 0 10px color-mix(in srgb, var(--about-a) 16%, transparent))
      drop-shadow(0 0 14px color-mix(in srgb, var(--about-b) 14%, transparent))
      drop-shadow(0 0 18px color-mix(in srgb, var(--about-c) 10%, transparent));
  }

  .about-hero .hero-glow {
    background:
      radial-gradient(circle at 18% 40%, color-mix(in srgb, var(--about-a) 18%, transparent) 0%, transparent 36%),
      radial-gradient(circle at 58% 44%, color-mix(in srgb, var(--about-b) 17%, transparent) 0%, transparent 32%),
      radial-gradient(circle at 84% 28%, color-mix(in srgb, var(--about-c) 16%, transparent) 0%, transparent 28%);
  }

  /* Main Layout Grid */
  .au-main-grid {
    display: grid;
    grid-template-columns: minmax(280px, 340px) minmax(0, 1fr);
    gap: clamp(44px, 6vw, 80px);
    align-items: start;
    margin-top: clamp(64px, 7vw, 82px);
  }

  .au-content-column {
    --au-copy-max-width: 690px;
  }

  /* Profile Column */
  .au-profile-column {
    position: sticky;
    top: 132px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .au-photo-container {
    position: relative;
    width: 252px;
    height: 252px;
    margin-bottom: 26px;
  }

  .au-photo-aura {
    position: absolute;
    inset: -12px;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--about-b) 78%, white 10%) 0%,
      color-mix(in srgb, var(--about-b) 58%, black 14%) 100%
    );
    border-radius: 50%;
    filter: blur(18px);
    opacity: 0.16;
    animation: aura-pulse 8s infinite alternate ease-in-out;
  }

  @keyframes aura-pulse {
    0% { transform: scale(1); opacity: 0.15; }
    100% { transform: scale(1.1); opacity: 0.25; }
  }

  .au-photo-circle-wrap {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: #050505;
    z-index: 1;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 18px 45px rgba(0, 0, 0, 0.28);
  }

  .au-photo-circle {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
    cursor: default;
    transition: transform 0.6s cubic-bezier(0.2, 0, 0.2, 1);
  }

  .au-photo-circle:hover { transform: scale(1.02); }

  .au-name {
    font-size: clamp(1.28rem, 2vw, 1.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 7px;
    color: #fff;
  }

  .au-role {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.42);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
  }

  /* Content Column */
  .au-statement {
    max-width: var(--au-copy-max-width);
    margin-bottom: 32px;
  }

  .au-statement .about-statement__quote {
    max-width: calc(100% + 32px);
    box-sizing: border-box;
    font-size: var(--lead-size);
    line-height: 1.65;
    color: rgba(245, 245, 247, 0.92);
    font-style: italic;
    margin: 0 0 0 -32px;
    padding: 28px 32px;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.016)),
      #0a0a0c;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.035),
      0 18px 45px rgba(0, 0, 0, 0.22);
  }

  .au-bio p {
    max-width: var(--au-copy-max-width);
    font-size: var(--lead-size);
    line-height: 1.65;
    color: var(--text-secondary);
    margin-bottom: 20px;
  }

  .au-bio-intro {
    color: rgba(245, 245, 247, 0.76);
    margin-bottom: 20px;
  }

  .au-bio strong {
    color: #fff;
    font-weight: 700;
  }

  .au-bio-more {
    max-width: var(--au-copy-max-width);
    margin-top: 0;
  }

  .au-bio-more__toggle {
    appearance: none;
    display: inline-block;
    padding: 0;
    border: 0;
    background: transparent;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.92rem;
    font-weight: 700;
    line-height: 1.25;
    cursor: pointer;
    transition:
      color 0.24s ease,
      transform 0.24s ease;
  }

  .au-bio-more__toggle[hidden] {
    display: none !important;
  }

  .au-bio-more__toggle:hover,
  .au-bio-more__toggle:focus-visible {
    color: #fff;
  }

  .au-bio-more__toggle:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--about-a) 44%, transparent);
    outline-offset: 5px;
  }

  .au-bio-more__panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.48s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .au-bio-more__panel.is-open {
    grid-template-rows: 1fr;
  }

  .au-bio-more__panel[hidden] {
    display: none;
  }

  .au-bio-more__content {
    overflow: hidden;
    min-height: 0;
  }

  .au-bio-more__content p {
    max-width: 760px;
    font-size: var(--lead-size);
    line-height: 1.65;
    color: var(--text-secondary);
    margin-bottom: 20px;
  }

  .au-bio-more__toggle--close {
    margin-top: 2px;
  }

  /* Stats Grid */
  .au-stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 18px;
    margin-top: clamp(68px, 7vw, 84px);
  }

  .au-stat-card {
    padding: 0;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.016)),
      #0a0a0c;
    transition:
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.35s ease,
      box-shadow 0.35s ease,
      background 0.35s ease;
  }

  .au-stat-card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.16);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.02)),
      #0b0b0d;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 28px 60px rgba(0, 0, 0, 0.32);
  }

  .au-stat-inner {
    padding: 30px 24px;
    text-align: center;
    height: 100%;
    box-sizing: border-box;
  }

  .au-stat-value {
    font-size: clamp(2.55rem, 4.2vw, 3rem);
    font-weight: 700;
    line-height: 1;
    margin-bottom: 10px;
    display: block;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--about-b) 88%, white 10%) 0%,
      color-mix(in srgb, var(--about-b) 64%, black 16%) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .au-stat-desc {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.48);
    line-height: 1.45;
  }

  .mt-80.fade-up.delay-300 {
    margin-top: 84px;
  }

  /* Principles specific */
  .au-principle-card {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.018)),
      #0a0a0c;
    isolation: isolate;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.035),
      0 18px 45px rgba(0, 0, 0, 0.22);
    height: 100%;
    box-sizing: border-box;
  }

  .au-principle-card::before,
  .au-principle-card::after {
    display: none;
  }

  .au-principle-card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.16);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.022)),
      #0b0b0d;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 28px 60px rgba(0, 0, 0, 0.32);
  }

  .au-principle-number {
    font-size: 0.75rem;
    font-weight: 700;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--about-b) 90%, white 8%) 0%,
      color-mix(in srgb, var(--about-b) 68%, black 16%) 100%
    );
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    letter-spacing: 0.12em;
    margin-bottom: 16px;
    display: block;
  }

  .au-principle-card h3 {
    font-size: clamp(1.23rem, 2.2vw, 1.48rem);
    line-height: 1.18;
    letter-spacing: -0.01em;
    margin-bottom: 14px;
    color: rgba(245, 245, 247, 0.96);
  }

  .au-principle-card h3 span {
    background: none;
    -webkit-text-fill-color: rgba(255, 255, 255, 0.72);
    color: rgba(255, 255, 255, 0.72);
    font-style: normal;
  }

  .au-principle-text {
    font-size: 0.95rem;
    line-height: 1.62;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
  }

  .about-final-section {
    margin-top: clamp(60px, 7vw, 78px);
    padding-top: 0;
