---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const leadershipSinceYear = 2011;
const leadershipYears = new Date().getFullYear() - leadershipSinceYear;

const pageUrl = 'https://www.nigredo.ch/marco-calzavara/';
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Über mich", "item": pageUrl }
      ]
    },
    {
      "@type": "AboutPage",
      "@id": `${pageUrl}#webpage`,
      "name": "Über mich | Marco Calzavara | Nigredo",
      "url": pageUrl,
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "inLanguage": "de-CH",
      "datePublished": "2025-06-01",
      "dateModified": "2026-07-14",
      "isAccessibleForFree": true,
      "publisher": { "@id": "https://www.nigredo.ch/#organization" },
      "about": { "@id": "https://www.nigredo.ch/#person" },
      "primaryImageOfPage": {
        "@type": "ImageObject",
        "@id": `${pageUrl}#primaryimage`,
        "url": "https://www.nigredo.ch/assets/marco-calzavara-portrait-nigredo-st-gallen.jpg",
        "contentUrl": "https://www.nigredo.ch/assets/marco-calzavara-portrait-nigredo-st-gallen.jpg",
        "thumbnailUrl": "https://www.nigredo.ch/assets/marco-calzavara-nigredo-st-gallen-500.webp",
        "width": 768,
        "height": 1024,
        "caption": "Marco Calzavara, Gründer von Nigredo in St. Gallen",
        "representativeOfPage": true
      },
      "mainEntity": { "@id": "https://www.nigredo.ch/#person" }
    },
    {
      "@type": "Person",
      "@id": "https://www.nigredo.ch/#person",
      "name": "Marco Calzavara",
      "givenName": "Marco",
      "familyName": "Calzavara",
      "jobTitle": "Gründer & Full-Stack Developer",
      "description": "Marco Calzavara ist Gründer von Nigredo. Er verbindet Führungserfahrung, Gestaltung und KI mit einem belastbaren Netzwerk aus Informatikfachleuten und übernimmt persönliche Verantwortung für jedes Projekt.",
      "url": pageUrl,
      "mainEntityOfPage": { "@id": `${pageUrl}#webpage` },
      "worksFor": { "@id": "https://www.nigredo.ch/#organization" },
      "image": { "@id": `${pageUrl}#primaryimage` },
      "sameAs": [
        "https://ch.linkedin.com/in/calzavara-marco",
        "https://github.com/calza"
      ]
    }
  ]
});
---

<Layout
  title="Über mich | Marco Calzavara | Nigredo"
  description={`Marco Calzavara verbindet ${leadershipYears} Jahre Führungserfahrung, Gestaltung und KI zu digitalen Lösungen mit persönlicher Verantwortung.`}
  canonical={pageUrl}
  ogTitle="Marco Calzavara | Ideen mit Richtung"
  ogDescription="Marco Calzavara verbindet Führungserfahrung, Gestaltung und KI zu digitalen Lösungen mit persönlicher Verantwortung."
  ogType="profile"
  ogImage="https://www.nigredo.ch/assets/marco-calzavara-portrait-nigredo-st-gallen.jpg"
  ogImageAlt="Marco Calzavara, Gründer von Nigredo"
  ogImageWidth="768"
  ogImageHeight="1024"
  twitterTitle="Marco Calzavara | Ideen mit Richtung"
  twitterDescription="Führungserfahrung, Gestaltung und KI, verbunden mit persönlicher Verantwortung."
  schema={schema}
  preloadImage="/assets/marco-calzavara-nigredo-st-gallen-500.avif"
  preloadImageType="image/avif"
  preloadImageSrcset="/assets/marco-calzavara-nigredo-st-gallen-500.avif 500w, /assets/marco-calzavara-nigredo-st-gallen-750.avif 750w, /assets/marco-calzavara-nigredo-st-gallen-1000.avif 1000w"
  preloadImageSizes="(max-width: 600px) 204px, 252px"
>
  <section class="section pt-sub about-hero" aria-labelledby="about-title">
    <div class="hero-glow"></div>
    <div class="container about-hero__container">

      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Über mich' }
      ]} />

      <!-- Hero -->
      <div class="fade-up home-hero__inner about-hero__intro">
        <h1 id="about-title" class="home-hero__title about-hero__title">
          Ich sehe Möglichkeiten.<br>
          <span class="gradient-text">Und bringe sie in Form.</span>
        </h1>
      </div>

      <!-- Main Profile & Intro Grid -->
      <div class="au-main-grid mt-80">
        <div class="au-profile-column fade-up delay-100">
          <div class="au-photo-container">
            <div class="au-photo-aura"></div>
            <div class="au-photo-circle-wrap">
              <picture>
                <source srcset="/assets/marco-calzavara-nigredo-st-gallen-500.avif 500w, /assets/marco-calzavara-nigredo-st-gallen-750.avif 750w, /assets/marco-calzavara-nigredo-st-gallen-1000.avif 1000w" sizes="(max-width: 600px) 204px, 252px" type="image/avif">
                <source srcset="/assets/marco-calzavara-nigredo-st-gallen-500.webp 500w, /assets/marco-calzavara-nigredo-st-gallen-750.webp 750w, /assets/marco-calzavara-nigredo-st-gallen-1000.webp 1000w" sizes="(max-width: 600px) 204px, 252px" type="image/webp">
                <img
                  src="/assets/marco-calzavara-nigredo-st-gallen.jpg"
                  alt="Marco Calzavara, Gründer und Inhaber von Nigredo in St. Gallen"
                  class="au-photo-circle"
                  width="1086"
                  height="1086"
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                />
              </picture>
            </div>
          </div>
          <div class="au-profile-info">
            <h2 class="au-name">Marco Calzavara</h2>
            <p class="au-role">Gründer und direkter Ansprechpartner</p>
          </div>
        </div>

        <div class="au-content-column fade-up delay-150">
          <div class="au-statement">
            <blockquote class="hero-lead about-statement__quote">
              Ich erkenne schnell, wo etwas einfacher, klarer oder wirksamer werden kann. Dann bringe ich die richtigen Menschen und Werkzeuge zusammen.
            </blockquote>
          </div>
          
          <div class="au-bio">
            <p class="au-bio-intro">
              Mich interessieren digitale Lösungen, die einen spürbaren Unterschied machen. Dafür verbinde ich Führungserfahrung, Verwaltungswissen, Gestaltung und KI mit einem belastbaren Netzwerk aus Informatikfachleuten.
            </p>
            
            <div class="au-bio-more" data-bio-more>
              <button
                type="button"
                class="au-bio-more__toggle"
                aria-expanded="false"
                aria-controls="au-bio-more-content"
                data-bio-more-toggle
              >
                Mehr erfahren
              </button>
              <div id="au-bio-more-content" class="au-bio-more__panel" hidden data-bio-more-panel>
                <div class="au-bio-more__content">
                  <p>
                    Seit 2009 arbeite ich bei der IV-Stelle, seit 2011 in einer Führungsfunktion. Heute leite ich ein Expertenteam und verantworte die Weiterentwicklung einer Abteilung. Diese Arbeit hat meinen Blick geprägt: Komplexität ordnen, Menschen einbeziehen und Entscheidungen so treffen, dass sie im Alltag tragen.
                  </p>
                  <p>
                    Parallel dazu habe ich Unternehmen gegründet, aufgebaut und verkauft. Mit Nigredo verbinde ich Ideen, Gestaltung, KI und technische Umsetzung. Gemeinsam mit einem Geschäftspartner führe ich zudem die HappyPath GmbH, eine schweizweit eingesetzte Softwarelösung für Sozialversicherungen.
                  </p>
                  <p>
                    Ich arbeite bewusst mit den passenden Fachleuten zusammen. Meine Aufgabe ist es, Möglichkeiten früh zu erkennen, die richtigen Kompetenzen zu verbinden und Verantwortung für das Ergebnis zu übernehmen.
                  </p>
                  <button type="button" class="au-bio-more__toggle au-bio-more__toggle--close" data-bio-more-close>
                    Weniger anzeigen
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="au-stats-grid mt-80 fade-up delay-200">
        <div class="au-stat-card">
          <div class="au-stat-inner">
            <span class="au-stat-value">{leadershipYears}</span>
            <span class="au-stat-desc">Jahre Führungserfahrung</span>
          </div>
        </div>
        <div class="au-stat-card">
          <div class="au-stat-inner">
            <span class="au-stat-value">3×</span>
            <span class="au-stat-desc">Unternehmen gegründet, aufgebaut und verkauft</span>
          </div>
        </div>
        <div class="au-stat-card">
          <div class="au-stat-inner">
            <span class="au-stat-value">1</span>
            <span class="au-stat-desc">Direkter Ansprechpartner</span>
          </div>
        </div>
        <div class="au-stat-card">
          <div class="au-stat-inner">
            <span class="au-stat-value">∞</span>
            <span class="au-stat-desc">Neugier auf gute Lösungen</span>
          </div>
        </div>
      </div>

      <!-- Principles -->
      <div class="mt-80 fade-up delay-300">
        <h2>Woran ich glaube.</h2>
        <div class="grid-3">
          <article class="card au-principle-card">
            <div class="au-principle-number">01</div>
            <h3><span>Anpacken</span> schafft Bewegung.</h3>
            <p class="au-principle-text">Gute Ideen gewinnen erst an Wert, wenn jemand den ersten Schritt macht.</p>
          </article>
          <article class="card au-principle-card">
            <div class="au-principle-number">02</div>
            <h3>Technik braucht <span>Richtung</span>.</h3>
            <p class="au-principle-text">Entscheidend ist nicht, was möglich ist, sondern was für Menschen und Aufgabe sinnvoll ist.</p>
          </article>
          <article class="card au-principle-card">
            <div class="au-principle-number">03</div>
            <h3><span>Qualität</span> zeigt sich im Ergebnis.</h3>
            <p class="au-principle-text">Inhalt, Gestaltung und Technik müssen gemeinsam überzeugen.</p>
          </article>
        </div>
      </div>

      <!-- CTA -->
      <div class="section about-final-section fade-up">
        <div class="section-cta about-final-cta">
          <span class="cta-label">Direkter Austausch</span>
          <h2>Eine gute Idee braucht<br><span>noch keinen fertigen Plan.</span></h2>
          <div class="hero-cta-group" style="justify-content: center;">
            <a href="/kontakt/" class="btn btn-primary">Direkt schreiben</a>
            <a href="/referenzen/" class="btn btn-ghost">Projekte ansehen</a>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<script>
  const bioMore = document.querySelector('[data-bio-more]');
  const bioMoreToggle = bioMore?.querySelector('[data-bio-more-toggle]');
  const bioMoreClose = bioMore?.querySelector('[data-bio-more-close]');
  const bioMorePanel = bioMore?.querySelector('[data-bio-more-panel]');

  if (bioMoreToggle instanceof HTMLButtonElement && bioMorePanel instanceof HTMLElement) {
    let closeTimer: number | undefined;

    const setBioMoreOpen = (shouldOpen: boolean) => {
      window.clearTimeout(closeTimer);
      bioMoreToggle.setAttribute('aria-expanded', String(shouldOpen));

      if (shouldOpen) {
        bioMorePanel.hidden = false;
        bioMoreToggle.hidden = true;
        window.requestAnimationFrame(() => {
          bioMorePanel.classList.add('is-open');
        });
        return;
      }

      bioMorePanel.classList.remove('is-open');
      bioMoreToggle.hidden = false;
      closeTimer = window.setTimeout(() => {
        if (bioMoreToggle.getAttribute('aria-expanded') !== 'true') {
          bioMorePanel.hidden = true;
        }
      }, 480);
    };

    bioMoreToggle.addEventListener('click', () => setBioMoreOpen(true));

    if (bioMoreClose instanceof HTMLButtonElement) {
      bioMoreClose.addEventListener('click', () => setBioMoreOpen(false));
    }
  }
</script>

<style>
  .about-hero {
    --about-a: var(--brand-sun);
    --about-b: var(--brand-coral);
    --about-c: var(--brand-pink);
    animation: none;
    padding-top: var(--hero-offset-top-breadcrumb);
    padding-bottom: var(--hero-offset-bottom);
  }

  .about-hero__container {
    position: relative;
    width: 100%;
  }

  .about-hero :global(.breadcrumb) {
    margin-bottom: 28px;
  }

  .about-hero .badge {
    margin-bottom: 0.95rem;
    color: rgba(255, 241, 232, 0.94);
    border-color: color-mix(in srgb, var(--about-b) 38%, rgba(255, 255, 255, 0.22));
    background: transparent;
    box-shadow: none;
  }

  .about-hero__intro {
    width: 100%;
    max-width: 940px;
  }

  .about-hero__title {
    max-width: 940px;
    font-size: var(--hero-title-size);
    line-height: var(--hero-title-line-height);
    letter-spacing: -0.02em;
    margin-bottom: 0;
  }

  .about-hero .gradient-text {
    background: var(--brand-gradient-warm);
    background-size: 100% auto;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .about-hero .hero-glow {
    background:
      radial-gradient(circle at 18% 40%, color-mix(in srgb, var(--about-a) 18%, transparent) 0%, transparent 36%),
      radial-gradient(circle at 58% 44%, color-mix(in srgb, var(--about-b) 17%, transparent) 0%, transparent 32%),
      radial-gradient(circle at 84% 28%, color-mix(in srgb, var(--about-c) 16%, transparent) 0%, transparent 28%);
  }

  /* Main Layout Grid */
  .au-main-grid {
    display: grid;
    grid-template-columns: minmax(280px, 340px) minmax(0, 1fr);
    gap: clamp(44px, 6vw, 80px);
    align-items: start;
    margin-top: clamp(64px, 7vw, 82px);
  }

  .au-content-column {
    --au-copy-max-width: 690px;
  }

  /* Profile Column */
  .au-profile-column {
    position: sticky;
    top: 132px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }

  .au-photo-container {
    position: relative;
    width: min(100%, 304px);
    aspect-ratio: 4 / 5;
    height: auto;
    margin: 0 0 28px 14px;
  }

  .au-photo-aura {
    position: absolute;
    inset: 18px 14px -18px -14px;
    background: var(--brand-gradient-warm);
    border-radius: var(--radius-lg);
    filter: none;
    opacity: 0.82;
  }

  .au-photo-circle-wrap {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: #111014;
    z-index: 1;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 8px 8px rgba(0, 0, 0, 0.22);
  }

  .au-photo-circle {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
    cursor: default;
    transition: transform 0.6s cubic-bezier(0.2, 0, 0.2, 1);
  }

  .au-photo-circle:hover { transform: scale(1.02); }

  .au-name {
    font-size: clamp(1.28rem, 2vw, 1.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 7px;
    color: #fff;
  }

  .au-role {
    font-size: 0.85rem;
    color: var(--text-soft);
    letter-spacing: 0;
    text-transform: none;
    margin: 0;
  }

  /* Content Column */
  .au-statement {
    max-width: var(--au-copy-max-width);
    margin-bottom: 32px;
  }

  .au-statement .about-statement__quote {
    max-width: var(--au-copy-max-width);
    box-sizing: border-box;
    font-size: var(--lead-size);
    line-height: 1.65;
    color: rgba(245, 245, 247, 0.92);
    font-style: italic;
    margin: 0;
    padding: 0 0 28px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0;
    border-top: 0;
    border-left: 0;
    border-right: 0;
    background: transparent;
    box-shadow: none;
  }

  .au-bio p {
    max-width: var(--au-copy-max-width);
    font-size: var(--lead-size);
    line-height: 1.65;
    color: var(--text-secondary);
    margin-bottom: 20px;
  }

  .au-bio-intro {
    color: rgba(245, 245, 247, 0.76);
    margin-bottom: 20px;
  }

  .au-bio strong {
    color: #fff;
    font-weight: 700;
  }

  .au-bio-more {
    max-width: var(--au-copy-max-width);
    margin-top: 0;
  }

  .au-bio-more__toggle {
    appearance: none;
    display: inline-block;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--text-body);
    font-size: 0.92rem;
    font-weight: 700;
    line-height: 1.25;
    cursor: pointer;
    transition:
      color 0.24s ease,
      transform 0.24s ease;
  }

  .au-bio-more__toggle[hidden] {
    display: none !important;
  }

  .au-bio-more__toggle:hover,
  .au-bio-more__toggle:focus-visible {
    color: #fff;
  }

  .au-bio-more__toggle:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--about-a) 44%, transparent);
    outline-offset: 5px;
  }

  .au-bio-more__panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.48s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .au-bio-more__panel.is-open {
    grid-template-rows: 1fr;
  }

  .au-bio-more__panel[hidden] {
    display: none;
  }

  .au-bio-more__content {
    overflow: hidden;
    min-height: 0;
  }

  .au-bio-more__content p {
    max-width: 760px;
    font-size: var(--lead-size);
    line-height: 1.65;
    color: var(--text-secondary);
    margin-bottom: 20px;
  }

  .au-bio-more__toggle--close {
    margin-top: 2px;
  }

  /* Stats Grid */
  .au-stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    margin-top: clamp(68px, 7vw, 84px);
  }

  .au-stat-card {
    padding: 0;
    border-radius: 0;
    border: 0;
    border-left: 1px solid rgba(255, 255, 255, 0.08);
    background: transparent;
    transition:
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.35s ease,
      box-shadow 0.35s ease,
      background 0.35s ease;
  }

  .au-stat-card:hover {
    transform: none;
    border-color: rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.018);
    box-shadow: none;
  }

  .au-stat-card:first-child { border-left: 0; }

  .au-stat-inner {
    padding: 30px 24px;
    text-align: center;
    height: 100%;
    box-sizing: border-box;
  }

  .au-stat-value {
    font-size: clamp(2.55rem, 4.2vw, 3rem);
    font-weight: 700;
    line-height: 1;
    margin-bottom: 10px;
    display: block;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--about-b) 88%, white 10%) 0%,
      color-mix(in srgb, var(--about-b) 64%, black 16%) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .au-stat-desc {
    font-size: 0.85rem;
    color: var(--text-faint);
    line-height: 1.45;
  }

  .mt-80.fade-up.delay-300 {
    margin-top: 84px;
  }

  /* Principles specific */
  .au-principle-card {
    padding: 28px 0 0;
    border: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0;
    background: transparent;
    isolation: isolate;
    box-shadow: none;
    height: 100%;
    box-sizing: border-box;
  }

  .au-principle-card::before,
  .au-principle-card::after {
    display: none;
  }

  .au-principle-card:hover {
    transform: none;
    border-color: rgba(255, 255, 255, 0.18);
    background: transparent;
    box-shadow: none;
  }

  .au-principle-number {
    font-size: 0.75rem;
    font-weight: 700;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--about-b) 90%, white 8%) 0%,
      color-mix(in srgb, var(--about-b) 68%, black 16%) 100%
    );
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    letter-spacing: 0.12em;
    margin-bottom: 16px;
    display: block;
  }

  .au-principle-card h3 {
    font-size: clamp(1.23rem, 2.2vw, 1.48rem);
    line-height: 1.18;
    letter-spacing: -0.01em;
    margin-bottom: 14px;
    color: rgba(245, 245, 247, 0.96);
  }

  .au-principle-card h3 span {
    background: none;
    -webkit-text-fill-color: rgba(255, 255, 255, 0.72);
    color: var(--text-body);
    font-style: normal;
  }

  .au-principle-text {
    font-size: 1rem;
    line-height: 1.68;
    color: var(--text-soft);
    margin: 0;
  }

  .about-final-section {
    margin-top: clamp(60px, 7vw, 78px);
    padding-top: 0;
    padding-bottom: var(--section-py-md);
  }

  .about-final-cta {
    max-width: 660px;
  }

  .about-final-cta .cta-label {
    color: var(--text-faint);
  }

  .about-final-cta h2 {
    color: #f5f5f7;
    font-size: var(--display-title);
    line-height: 1.04;
    letter-spacing: 0;
    margin-bottom: 0;
  }

  .about-final-cta h2 span {
    color: var(--text-soft);
  }

  .about-final-cta .hero-cta-group {
    margin-top: 34px;
  }

  .about-final-cta .btn-ghost {
    background-image:
      linear-gradient(#050505, #050505),
