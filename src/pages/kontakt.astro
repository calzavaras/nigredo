---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const pageUrl = 'https://www.nigredo.ch/kontakt/';
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Kontakt", "item": pageUrl }
      ]
    },
    {
      "@type": "ContactPage",
      "@id": `${pageUrl}#webpage`,
      "name": "Kontakt und Projektanfrage | Nigredo St. Gallen",
      "url": pageUrl,
      "description": "Direkter Kontakt zu Marco Calzavara für Websites, digitale Werkzeuge und KI-Lösungen. Persönliche Ersteinschätzung innerhalb von zwei Arbeitstagen.",
      "inLanguage": "de-CH",
      "datePublished": "2025-06-01",
      "dateModified": "2026-07-14",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "publisher": { "@id": "https://www.nigredo.ch/#organization" },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "isAccessibleForFree": true,
      "mainEntity": { "@id": "https://www.nigredo.ch/#organization" }
    }
  ]
});
---

<Layout
  title="Kontakt und Projektanfrage | Nigredo St. Gallen"
  description="Direkter Kontakt zu Marco Calzavara. Persönliche Ersteinschätzung für dein digitales Projekt innerhalb von zwei Arbeitstagen."
  canonical={pageUrl}
  ogTitle="Lass uns klären, was dein Projekt braucht."
  ogDescription="Beschreibe dein Vorhaben in wenigen Sätzen und erhalte eine persönliche, klare Ersteinschätzung von Marco Calzavara."
  ogImageAlt="Nigredo Kontakt: direkter Austausch mit Marco Calzavara"
  twitterTitle="Lass uns klären, was dein Projekt braucht | Nigredo"
  twitterDescription="Direkter Kontakt und eine persönliche Ersteinschätzung innerhalb von zwei Arbeitstagen."
  schema={schema}
>
  <section class="section pt-sub contact-hero" aria-labelledby="kontakt-title">
    <div class="hero-glow"></div>
    <div class="container">

      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Kontakt' }
      ]} />

      <div class="kontakt-grid">

        <div class="fade-up contact-hero__content">
          <h1 id="kontakt-title" class="contact-hero__title">
            Lass uns klären,<br>
            <span class="gradient-text">was dein Projekt braucht.</span>
          </h1>
          <p class="hero-lead contact-hero__lead">
            Schreib mir, worum es geht, wo du heute stehst und was sich verändern soll. Ich prüfe dein Vorhaben persönlich und antworte mit einer ehrlichen ersten Einschätzung.
          </p>
          <p class="kontakt-sub">
            Wenn es fachlich und menschlich passt, erhältst du einen transparenten Vorschlag mit Umfang, Prioritäten, Fixpreis und realistischem Zeitrahmen.
          </p>
        </div>

        <div class="contact-card contact-panel fade-up delay-100">
          <div class="contact-top-stripe"></div>

          <div class="card-icon">
            <svg width="48" height="48" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="none" aria-hidden="true" focusable="false">
              <defs>
                <linearGradient id="mailGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" style="stop-color: color-mix(in srgb, var(--contact-b) 88%, white 14%)"/>
                  <stop offset="50%" style="stop-color: var(--contact-b)"/>
                  <stop offset="100%" style="stop-color: color-mix(in srgb, var(--contact-b) 72%, black 18%)"/>
                </linearGradient>
              </defs>
              <rect x="4" y="10" width="40" height="28" rx="4" stroke="url(#mailGrad)" stroke-width="2" fill="none"/>
              <path d="M4 15l20 14 20-14" stroke="url(#mailGrad)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </svg>
          </div>

          <span class="cta-label">Persönlich beantwortet</span>
          <h2>Direkt bei mir.</h2>
          <p class="contact-text">Deine Nachricht erreicht die Person, die dein Projekt später konzipiert und umsetzt. Das hält Entscheidungswege kurz und die Verantwortung eindeutig.</p>

          <button id="mailBtn" class="btn btn-primary">Projekt beschreiben</button>
          <p class="contact-response">Antwort in der Regel innerhalb von zwei Arbeitstagen.</p>
        </div>

      </div>

    </div>
  </section>
</Layout>

<style>
  .contact-hero {
    --contact-a: var(--brand-sun);
    --contact-b: var(--brand-coral);
    --contact-c: var(--brand-pink);
    animation: none;
  }

  .contact-hero {
    padding-top: var(--hero-offset-top-breadcrumb);
    padding-bottom: var(--section-py-md);
  }

  .contact-hero :global(.breadcrumb) {
    margin-bottom: 28px;
  }

  .contact-hero .badge {
    margin-bottom: 0.95rem;
    color: rgba(255, 239, 222, 0.94);
    border-color: color-mix(in srgb, var(--contact-b) 36%, rgba(255, 255, 255, 0.22));
    background: transparent;
    box-shadow: none;
  }

  .kontakt-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(340px, 0.72fr);
    gap: clamp(44px, 6vw, 80px);
    align-items: center;
  }

  .contact-hero__content {
    max-width: 940px;
  }

  .contact-hero__title {
    max-width: 940px;
    font-size: var(--hero-title-size);
    line-height: var(--hero-title-line-height);
    letter-spacing: -0.02em;
    margin-bottom: clamp(24px, 3vw, 30px);
  }

  .contact-hero .gradient-text {
    background: var(--brand-gradient-warm);
    background-size: 100% auto;

    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .contact-hero__lead {
    max-width: 620px;
    font-size: var(--lead-size);
    line-height: 1.65;
  }

  .contact-hero .hero-glow {
    background:
      radial-gradient(circle at 18% 38%, color-mix(in srgb, var(--contact-a) 18%, transparent) 0%, transparent 30%),
      radial-gradient(circle at 54% 44%, color-mix(in srgb, var(--contact-b) 18%, transparent) 0%, transparent 28%),
      radial-gradient(circle at 84% 28%, color-mix(in srgb, var(--contact-c) 16%, transparent) 0%, transparent 24%);
  }

  .kontakt-sub {
    max-width: 610px;
    margin: 22px 0 0;
    color: var(--text-faint);
    font-size: clamp(1rem, 1.08vw, 1.05rem);
    line-height: 1.65;
  }

  .contact-panel {
    position: relative;
    align-self: center;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.018)),
      #0a0a0c;
    isolation: isolate;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.035);
  }

  .contact-panel::before,
  .contact-panel::after {
    display: none;
  }

  .contact-panel:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.16);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.022)),
      #0b0b0d;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  /* Top gradient accent stripe */
  .contact-top-stripe {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--contact-b) 84%, white 10%) 0%,
      var(--contact-b) 54%,
      color-mix(in srgb, var(--contact-b) 72%, black 18%) 100%
    );
    border-radius: 2px 2px 0 0;
  }

  .contact-panel .cta-label {
    margin-bottom: 12px;
    color: var(--text-faint);
  }

  .contact-panel h2 {
    font-size: clamp(1.45rem, 2.4vw, 1.72rem);
    line-height: 1.14;
    letter-spacing: -0.02em;
    margin-bottom: 14px;
  }

  .contact-text {
    color: var(--text-soft);
    margin-bottom: 32px;
    font-size: 1rem;
    line-height: 1.68;
  }

  .contact-response {
    margin: 16px 0 0;
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.82rem;
    line-height: 1.5;
  }

  .contact-card .card-icon {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.024)),
      rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.045),
      0 0 14px color-mix(in srgb, var(--contact-b) 14%, transparent),
      0 0 20px color-mix(in srgb, var(--contact-b) 10%, transparent);
    transition:
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.35s ease,
      background 0.35s ease,
      box-shadow 0.35s ease;
  }

  .contact-card .card-icon svg {
    width: 30px;
    height: 30px;
    filter:
      brightness(1.08)
      saturate(1.08)
      drop-shadow(0 0 6px color-mix(in srgb, var(--contact-b) 18%, transparent))
      drop-shadow(0 0 12px color-mix(in srgb, var(--contact-b) 12%, transparent));
    transition: filter 0.45s ease;
  }

  .contact-card:hover .card-icon {
    transform: translateY(-1px);
    border-color: rgba(255, 255, 255, 0.16);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.025)),
      rgba(255, 255, 255, 0.035);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 0 22px color-mix(in srgb, var(--contact-b) 18%, transparent),
      0 0 36px color-mix(in srgb, var(--contact-b) 12%, transparent);
  }

  .contact-card:hover .card-icon svg {
    filter:
      brightness(1.14)
      saturate(1.12)
      drop-shadow(0 0 10px color-mix(in srgb, var(--contact-b) 22%, transparent))
      drop-shadow(0 0 18px color-mix(in srgb, var(--contact-b) 14%, transparent));
  }

  @media (max-width: 860px) {
    .contact-hero {
      padding-top: var(--hero-offset-top-breadcrumb-mobile);
      padding-bottom: 72px;
    }

    .kontakt-grid {
      grid-template-columns: 1fr;
      gap: 38px;
    }

    .contact-hero__title {
      font-size: var(--hero-title-size-tablet);
      line-height: var(--hero-title-line-height-mobile);
      letter-spacing: 0;
    }
  }

  @media (max-width: 520px) {
    .contact-hero {
      padding-top: var(--hero-offset-top-breadcrumb-mobile);
      padding-bottom: 72px;
    }

    .contact-hero__title {
      font-size: var(--hero-title-size-mobile);
      line-height: var(--hero-title-line-height-mobile);
      letter-spacing: 0;
    }

    .contact-hero__lead {
      font-size: var(--lead-size-mobile);
      line-height: 1.6;
    }

    .kontakt-sub {
      font-size: 1rem;
      line-height: 1.65;
      margin-top: 18px;
    }

    .contact-panel {
      padding: 30px 24px;
    }
  }
</style>
