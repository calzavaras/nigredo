---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.nigredo.ch/ueber-uns#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Über mich", "item": "https://www.nigredo.ch/ueber-uns" }
      ]
    },
    {
      "@type": "Person",
      "@id": "https://www.nigredo.ch/#person",
      "name": "Marco Calzavara",
      "givenName": "Marco",
      "familyName": "Calzavara",
      "jobTitle": "Gründer",
      "description": "Gründer von Nigredo. Baut mit KI-Agenten digitale Lösungen – Websites, Tools, Texte, Bilder. Einer, der liefert was sonst Teams brauchen.",
      "image": {
        "@type": "ImageObject",
        "url": "https://www.nigredo.ch/assets/marco-calzavara-gruender-nigredo-st-gallen.webp",
        "width": 768,
        "height": 1024
      },
      "url": "https://www.nigredo.ch/ueber-uns",
      "worksFor": { "@id": "https://www.nigredo.ch/#organization" },
      "knowsAbout": ["Content-Erstellung", "Bildgenerierung", "Logo-Design", "Software Development", "Web Development", "UX Design", "Datenaufbereitung", "KI-Lösungen"],
      "sameAs": [
        "https://ch.linkedin.com/in/calzavara-marco",
        "https://github.com/calza"
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "St. Gallen",
        "postalCode": "9000",
        "addressCountry": "CH"
      }
    },
    {
      "@type": "AboutPage",
      "@id": "https://www.nigredo.ch/ueber-uns#webpage",
      "name": "Über mich | Marco Calzavara | Nigredo",
      "url": "https://www.nigredo.ch/ueber-uns",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": "https://www.nigredo.ch/ueber-uns#breadcrumb" },
      "inLanguage": "de-CH",
      "datePublished": "2025-06-01",
      "dateModified": "2026-03-21",
      "isAccessibleForFree": true,
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", ".pc-name", ".belief-title"]
      },
      "mainEntity": { "@id": "https://www.nigredo.ch/#person" }
    }
  ]
});
---

<Layout
  title="Über mich | Marco Calzavara | Nigredo"
  description="Marco Calzavara – 15 Jahre Führung, 3 Firmen gegründet und verkauft. Baut mit KI-Agenten, liefert was sonst Teams brauchen. Direkt, persönlich, aus St. Gallen."
  keywords="Marco Calzavara, Nigredo Gründer, Website Freelancer St. Gallen, Webdesign Schweiz, KI-Lösungen Schweiz, persönliche Betreuung, Softwareentwicklung KMU"
  canonical="https://www.nigredo.ch/ueber-uns"
  ogTitle="Ein Mensch. 1001 Ideen."
  ogDescription="15 Jahre Sozialversicherung, 3 Firmen gegründet und verkauft. Baut heute mit KI-Agenten, was sonst Teams brauchen. Ein Mensch. 1001 Ideen."
  ogType="profile"
  ogImage="https://www.nigredo.ch/assets/marco-calzavara-gruender-nigredo-st-gallen.webp"
  ogImageAlt="Marco Calzavara - Gründer von Nigredo"
  ogImageWidth="768"
  ogImageHeight="1024"
  twitterTitle="Ein Mensch. 1001 Ideen."
  twitterDescription="15 Jahre Sozialversicherung, 3 Firmen gegründet. Baut mit KI-Agenten, was sonst Teams brauchen. Ein Mensch. 1001 Ideen."
  schema={schema}
>
  <section class="section pt-sub about-hero" aria-labelledby="about-title">
    <div class="hero-glow"></div>
    <div class="container about-hero__container">

      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Über mich' }
      ]} />

      <!-- Hero -->
      <div class="fade-up home-hero__inner about-hero__intro">
        <span class="badge badge--pink">STORY</span>
        <h1 id="about-title" class="home-hero__title about-hero__title">
          Ein Mensch.<br>
          <span class="gradient-text">1001 Ideen.</span>
        </h1>
      </div>

      <!-- Main Profile & Intro Grid -->
      <div class="au-main-grid mt-80">
        <div class="au-profile-column fade-up delay-100">
          <div class="au-photo-container">
            <div class="au-photo-aura"></div>
            <div class="au-photo-circle-wrap">
              <img
                src="/assets/marco-calzavara-gruender-nigredo-st-gallen.webp"
                alt="Marco Calzavara"
                class="au-photo-circle lightbox-trigger"
                width="768"
                height="1024"
                loading="lazy"
              >
            </div>
          </div>
          <div class="au-profile-info">
            <h2 class="au-name">Marco Calzavara</h2>
            <p class="au-role">Gründer. Designer. Möglichmacher.</p>
          </div>
        </div>

        <div class="au-content-column fade-up delay-150">
          <div class="au-statement">
            <blockquote class="hero-lead about-statement__quote">
              «Ich liebe Ideen. Noch mehr liebe ich den Moment, in dem aus einer verrückten Idee etwas wird, das wirklich funktioniert.»
            </blockquote>
          </div>
          
          <div class="au-bio">
            <p>
              Ich bin ein Macher. Einer, der Möglichkeiten sieht, wo andere zuerst Grenzen sehen. Kreativ, neugierig, manchmal unkonventionell – und ziemlich schlecht darin, eine gute Idee einfach liegen zu lassen.
            </p>
            <p>
              Mich reizt das Neue. Die Aufgabe, bei der noch niemand genau weiss, wie sie gelöst werden soll. Der Moment, in dem aus «das geht nicht» langsam ein «doch, so könnte es gehen» wird. Genau dort fängt es für mich an, spannend zu werden.
            </p>
            <p>
              Heute kann ich diese Energie digital umsetzen: mit KI-Agenten, einem klaren Blick für Gestaltung und einem breiten Netzwerk aus erfahrenen Informatikfachleuten. Ich verbinde Idee, Konzept, Design, Technik und Umsetzung so, dass am Ende nicht nur etwas Schönes entsteht, sondern etwas, das funktioniert.
            </p>
            <p>
              Dazu kommen <strong>15 Jahre Führungserfahrung</strong>, drei aufgebaute und verkaufte Firmen und ein gutes Gespür dafür, was Menschen im Alltag wirklich brauchen. Ich muss nicht alles selbst sein. Aber ich weiss, was es braucht, damit aus einer Idee ein Ergebnis wird.
            </p>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="au-stats-grid mt-80 fade-up delay-200">
        <div class="au-stat-card">
          <div class="au-stat-inner">
            <span class="au-stat-value">15</span>
            <span class="au-stat-desc">Jahre Fachwissen, Führung und Praxis</span>
          </div>
        </div>
        <div class="au-stat-card">
          <div class="au-stat-inner">
            <span class="au-stat-value">3×</span>
            <span class="au-stat-desc">Aufgebaut, verkauft, weitergedacht</span>
          </div>
        </div>
        <div class="au-stat-card">
          <div class="au-stat-inner">
            <span class="au-stat-value">1</span>
            <span class="au-stat-desc">Ansprechpartner statt Projekt-Pingpong</span>
          </div>
        </div>
        <div class="au-stat-card">
          <div class="au-stat-inner">
            <span class="au-stat-value">∞</span>
            <span class="au-stat-desc">Neugier, leider nicht abstellbar</span>
          </div>
        </div>
      </div>

      <!-- Principles -->
      <div class="mt-80 fade-up delay-300">
        <span class="badge badge--pink">PRINZIPIEN</span>
        <h2>Woran ich glaube.</h2>
        <div class="grid-3">
          <article class="card au-principle-card">
            <div class="au-principle-number">01</div>
            <h3><em>Fertig</em> ist kein Datum.</h3>
            <p class="au-principle-text">Fertig ist der Moment, in dem nichts mehr stört. Deadlines respektiere ich. Halbe Lösungen nicht.</p>
          </article>
          <article class="card au-principle-card">
            <div class="au-principle-number">02</div>
            <h3>Weniger ist <em>Substanz</em>.</h3>
            <p class="au-principle-text">Ich baue keine Systeme, die sich wichtiger nehmen als das Problem. Was keinen Nutzen hat, fliegt raus.</p>
          </article>
          <article class="card au-principle-card">
            <div class="au-principle-number">03</div>
            <h3>Ehrlichkeit <em>spart Nerven</em>.</h3>
            <p class="au-principle-text">Wenn eine Idee nicht trägt, sage ich das. Freundlich, aber früh. Ein klares Nein ist oft der Anfang einer besseren Lösung.</p>
          </article>
        </div>
      </div>

      <!-- CTA -->
      <div class="section about-final-section fade-up">
        <div class="section-cta about-final-cta">
          <span class="cta-label">Und jetzt?</span>
          <h2>Noch keine fertige Idee?<br><span>Perfekter Zeitpunkt.</span></h2>
          <div class="hero-cta-group" style="justify-content: center;">
            <a href="/kontakt" class="btn btn-primary">Direkt schreiben</a>
            <a href="/referenzen" class="btn btn-ghost">Projekte ansehen</a>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  .about-hero {
    padding-top: 150px;
    padding-bottom: 48px;
  }

  .about-hero__container {
    position: relative;
    width: 100%;
  }

  .about-hero :global(.breadcrumb) {
    margin-bottom: 28px;
  }

  .about-hero .badge {
    margin-bottom: 1rem;
  }

  .about-hero__intro {
    width: 100%;
    max-width: 940px;
  }

  .about-hero__title {
    max-width: 940px;
    font-size: clamp(2.9rem, 5.35vw, 4.85rem);
    line-height: var(--hero-title-line-height);
    letter-spacing: -0.02em;
    margin-bottom: 0;
  }

  .about-hero .gradient-text {
    background: linear-gradient(to right, #ff4d80, #a64dff, #ff4d80);
    background-size: 200% auto;
    animation: gradientPan 24s linear infinite;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  /* Main Layout Grid */
  .au-main-grid {
    display: grid;
    grid-template-columns: minmax(280px, 340px) minmax(0, 1fr);
    gap: clamp(44px, 6vw, 80px);
    align-items: start;
    margin-top: 72px;
  }

  /* Profile Column */
  .au-profile-column {
    position: sticky;
    top: 132px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .au-photo-container {
    position: relative;
    width: 252px;
    height: 252px;
    margin-bottom: 26px;
  }

  .au-photo-aura {
    position: absolute;
    inset: -12px;
    background: linear-gradient(135deg, #FF4D80, #A64DFF);
    border-radius: 50%;
    filter: blur(24px);
    opacity: 0.16;
    animation: aura-pulse 8s infinite alternate ease-in-out;
  }

  @keyframes aura-pulse {
    0% { transform: scale(1); opacity: 0.15; }
    100% { transform: scale(1.1); opacity: 0.25; }
  }

  .au-photo-circle-wrap {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: #050505;
    z-index: 1;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 18px 45px rgba(0, 0, 0, 0.28);
  }

  .au-photo-circle {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    display: block;
    cursor: zoom-in;
    transition: transform 0.6s cubic-bezier(0.2, 0, 0.2, 1);
  }

  .au-photo-circle:hover { transform: scale(1.055); }

  .au-name {
    font-size: clamp(1.28rem, 2vw, 1.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 7px;
    color: #fff;
  }

  .au-role {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.42);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
  }

  /* Content Column */
  .au-statement {
    margin-bottom: 34px;
  }

  .au-statement .about-statement__quote {
    max-width: 760px;
    font-size: clamp(1.18rem, 2.05vw, 1.44rem);
    line-height: 1.46;
    color: rgba(245, 245, 247, 0.92);
    font-style: italic;
    margin: 0;
    padding: 28px 30px;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.016)),
      #0a0a0c;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.035),
      0 18px 45px rgba(0, 0, 0, 0.22);
  }

  .au-bio p {
    max-width: 760px;
    font-size: clamp(1rem, 1.2vw, 1.06rem);
    line-height: 1.72;
    color: var(--text-secondary);
    margin-bottom: 22px;
  }

  .au-bio strong {
    color: #fff;
    font-weight: 700;
  }

  /* Stats Grid */
  .au-stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-top: 80px;
  }

  .au-stat-card {
    padding: 0;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.016)),
      #0a0a0c;
    transition:
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.35s ease,
      box-shadow 0.35s ease,
      background 0.35s ease;
  }

  .au-stat-card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.16);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.02)),
      #0b0b0d;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 24px 56px rgba(0, 0, 0, 0.28),
      0 0 28px rgba(255, 77, 128, 0.08);
  }

  .au-stat-inner {
    padding: 32px 24px;
    text-align: center;
    height: 100%;
    box-sizing: border-box;
  }

  .au-stat-value {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 10px;
    display: block;
    background: linear-gradient(135deg, #FF4D80, #A64DFF);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .au-stat-desc {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.48);
    line-height: 1.45;
  }

  .mt-80.fade-up.delay-300 {
    margin-top: 86px;
  }

  /* Principles specific */
  .au-principle-card {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.018)),
      #0a0a0c;
    isolation: isolate;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.035),
      0 18px 45px rgba(0, 0, 0, 0.22);
  }

  .au-principle-card::before,
  .au-principle-card::after {
    display: none;
  }

  .au-principle-card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.16);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.022)),
      #0b0b0d;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 28px 60px rgba(0, 0, 0, 0.32);
  }

  .au-principle-number {
    font-size: 0.75rem;
    font-weight: 800;
    color: rgba(255, 77, 128, 0.86);
    letter-spacing: 0.12em;
    margin-bottom: 18px;
    display: block;
  }

  .au-principle-card h3 {
    line-height: 1.16;
    letter-spacing: -0.02em;
  }

  .au-principle-card h3 em {
    color: #FF4D80;
    font-style: italic;
  }

  .au-principle-text {
    font-size: 0.95rem;
    line-height: 1.68;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
  }

  .about-final-section {
    padding-top: 52px;
    padding-bottom: 118px;
  }

  .about-final-cta {
    max-width: 660px;
  }

  .about-final-cta .cta-label {
    color: rgba(255, 255, 255, 0.42);
  }

  .about-final-cta h2 {
    color: #f5f5f7;
    font-size: clamp(2.25rem, 4.5vw, 3.7rem);
    line-height: 1.04;
    letter-spacing: 0;
    margin-bottom: 0;
  }

  .about-final-cta h2 span {
    color: rgba(255, 255, 255, 0.62);
  }

  .about-final-cta .hero-cta-group {
    margin-top: 34px;
  }

  .about-final-cta .btn-ghost {
    background-image:
      linear-gradient(#050505, #050505),
      linear-gradient(rgba(255, 255, 255, 0.15), rgba(255, 255, 255, 0.15));
  }

  .about-final-cta .btn-ghost:hover {
    animation: none;
    transform: translateY(-2px);
    background-image:
      linear-gradient(#0a0a0c, #0a0a0c),
      linear-gradient(rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0.3));
    box-shadow: 0 10px 26px rgba(255, 255, 255, 0.08);
  }

  .about-final-cta .btn-primary:hover {
    box-shadow:
      inset 0 2px 4px rgba(255, 255, 255, 1),
      0 10px 26px rgba(255, 255, 255, 0.14);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .au-main-grid {
      grid-template-columns: 1fr;
      gap: 44px;
    }

    .au-profile-column {
      position: static;
    }
  }

  @media (max-width: 860px) {
    .about-hero {
      padding-top: 132px;
      padding-bottom: 42px;
    }

    .about-hero__title {
      font-size: clamp(2.55rem, 10vw, 3.8rem);
      line-height: var(--hero-title-line-height-mobile);
    }

    .au-main-grid {
      margin-top: 52px;
    }

    .au-stats-grid {
      margin-top: 64px;
    }

    .mt-80.fade-up.delay-300 {
      margin-top: 70px;
    }
  }

  @media (max-width: 600px) {
    .about-hero__title {
      font-size: clamp(2.35rem, 13vw, 3.25rem);
      line-height: var(--hero-title-line-height-mobile);
    }

    .au-photo-container {
      width: 204px;
      height: 204px;
    }

    .au-statement .about-statement__quote {
      padding: 24px;
      font-size: 1.08rem;
      line-height: 1.5;
    }

    .au-stat-value {
      font-size: 2.5rem;
    }

    .about-final-section {
      padding-top: 40px;
      padding-bottom: 88px;
    }

    .about-final-cta h2 {
      font-size: clamp(1.8rem, 11vw, 2.5rem);
    }
  }
</style>
