---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.nigredo.ch/ueber-uns#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Über mich", "item": "https://www.nigredo.ch/ueber-uns" }
      ]
    },
    {
      "@type": "Person",
      "@id": "https://www.nigredo.ch/#person",
      "name": "Marco Calzavara",
      "givenName": "Marco",
      "familyName": "Calzavara",
      "jobTitle": "Gründer",
      "description": "Gründer von Nigredo. Baut mit KI-Agenten digitale Lösungen – Websites, Tools, Texte, Bilder. Einer, der liefert was sonst Teams brauchen.",
      "image": {
        "@type": "ImageObject",
        "url": "https://www.nigredo.ch/assets/marco-calzavara-gruender-nigredo-st-gallen.webp",
        "width": 768,
        "height": 1024
      },
      "url": "https://www.nigredo.ch/ueber-uns",
      "worksFor": { "@id": "https://www.nigredo.ch/#organization" },
      "knowsAbout": ["Content-Erstellung", "Bildgenerierung", "Logo-Design", "Software Development", "Web Development", "UX Design", "Datenaufbereitung", "KI-Lösungen"],
      "sameAs": [
        "https://ch.linkedin.com/in/calzavara-marco",
        "https://github.com/calza"
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "St. Gallen",
        "postalCode": "9000",
        "addressCountry": "CH"
      }
    },
    {
      "@type": "AboutPage",
      "@id": "https://www.nigredo.ch/ueber-uns#webpage",
      "name": "Über mich | Marco Calzavara | Nigredo",
      "url": "https://www.nigredo.ch/ueber-uns",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": "https://www.nigredo.ch/ueber-uns#breadcrumb" },
      "inLanguage": "de-CH",
      "datePublished": "2025-06-01",
      "dateModified": "2026-03-21",
      "isAccessibleForFree": true,
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", ".pc-name", ".belief-title"]
      },
      "mainEntity": { "@id": "https://www.nigredo.ch/#person" }
    }
  ]
});
---

<Layout
  title="Über mich | Marco Calzavara | Nigredo"
  description="Marco Calzavara – 15 Jahre Führung, 3 Firmen gegründet und verkauft. Baut mit KI-Agenten, liefert was sonst Teams brauchen. Direkt, persönlich, aus St. Gallen."
  keywords="Marco Calzavara, Nigredo Gründer, Website Freelancer St. Gallen, Webdesign Schweiz, KI-Lösungen Schweiz, persönliche Betreuung, Softwareentwicklung KMU"
  canonical="https://www.nigredo.ch/ueber-uns"
  ogTitle="Ein Mensch. 1001 Ideen."
  ogDescription="15 Jahre Sozialversicherung, 3 Firmen gegründet und verkauft. Baut heute mit KI-Agenten, was sonst Teams brauchen. Ein Mensch. 1001 Ideen."
  ogType="profile"
  ogImage="https://www.nigredo.ch/assets/marco-calzavara-gruender-nigredo-st-gallen.webp"
  ogImageAlt="Marco Calzavara - Gründer von Nigredo"
  ogImageWidth="768"
  ogImageHeight="1024"
  twitterTitle="Ein Mensch. 1001 Ideen."
  twitterDescription="15 Jahre Sozialversicherung, 3 Firmen gegründet. Baut mit KI-Agenten, was sonst Teams brauchen. Ein Mensch. 1001 Ideen."
  schema={schema}
>
  <section class="section pt-hero">
    <div class="hero-glow"></div>
    <div class="container">

      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Über mich' }
      ]} />

      <!-- Hero -->
      <div class="fade-up">
        <span class="badge badge--pink">STORY</span>
        <h1>
          Ein Mensch.<br>
          <span class="gradient-text">1001 Ideen.</span>
        </h1>
      </div>

      <!-- Main Profile & Intro Grid -->
      <div class="au-main-grid mt-80">
        <div class="au-profile-column fade-up delay-100">
          <div class="au-photo-container">
            <div class="au-photo-aura"></div>
            <div class="au-photo-circle-wrap">
              <img
                src="/assets/marco-calzavara-gruender-nigredo-st-gallen.webp"
                alt="Marco Calzavara"
                class="au-photo-circle lightbox-trigger"
                width="768"
                height="1024"
                loading="lazy"
              >
            </div>
          </div>
          <div class="au-profile-info">
            <h2 class="au-name">Marco Calzavara</h2>
            <p class="au-role">Gründer & Architekt</p>
          </div>
        </div>

        <div class="au-content-column fade-up delay-150">
          <div class="au-statement">
            <blockquote class="hero-lead">
              «Ideen interessieren mich erst, wenn sie irgendwo in der Welt landen. Ich lasse erst los, wenn das Ergebnis wirklich glänzt.»
            </blockquote>
          </div>
          
          <div class="au-bio">
            <p>
              Technik und das Umsetzen von Ideen haben mich fasziniert, solange ich denken kann. Geblieben bin ich in der Sozialversicherung, weil echtes Fachwissen zählt – und weil das Naheliegende irgendwann unausweichlich wurde: beides verbinden.
            </p>
            <p>
              Seit 2021 entwickle und lizenziere ich Software, die Sozialversicherungen täglich einsetzen. Kein Prototyp. Ein echtes Produkt, das seinen Job kennt.
            </p>
            <p>
              <strong>15 Jahre Führungserfahrung</strong>, drei Firmen gegründet und verkauft, und eine Ader für Perfektion. Mit KI-Agenten kann ich heute allein liefern, wofür früher ein ganzes Team gebraucht wurde.
            </p>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="au-stats-grid mt-80 fade-up delay-200">
        <div class="au-stat-card">
          <div class="au-stat-inner">
            <span class="au-stat-value">15</span>
            <span class="au-stat-desc">Jahre Führung & Expertise</span>
          </div>
        </div>
        <div class="au-stat-card">
          <div class="au-stat-inner">
            <span class="au-stat-value">3×</span>
            <span class="au-stat-desc">Exit nach Firmenaufbau</span>
          </div>
        </div>
        <div class="au-stat-card">
          <div class="au-stat-inner">
            <span class="au-stat-value">1</span>
            <span class="au-stat-desc">Fokus ohne stille Post</span>
          </div>
        </div>
        <div class="au-stat-card">
          <div class="au-stat-inner">
            <span class="au-stat-value">∞</span>
            <span class="au-stat-desc">Neugier auf Neues</span>
          </div>
        </div>
      </div>

      <!-- Principles -->
      <div class="mt-80 fade-up delay-300">
        <span class="badge badge--pink">PRINZIPIEN</span>
        <h2>Woran ich glaube.</h2>
        <div class="grid-3">
          <article class="card">
            <div class="au-principle-number">01</div>
            <h3><em>Fertig</em> ist kein Datum.</h3>
            <p class="au-principle-text">Sondern der Moment, in dem das Ergebnis für sich spricht. Deadlines respektiere ich. «Gut genug» nicht.</p>
          </article>
          <article class="card">
            <div class="au-principle-number">02</div>
            <h3>Weniger ist <em>Substanz</em>.</h3>
            <p class="au-principle-text">Ich baue keine Denkmäler, die nach einem Jahr niemand mehr versteht. Was nicht gebraucht wird, kommt nicht rein.</p>
          </article>
          <article class="card">
            <div class="au-principle-number">03</div>
            <h3>Ehrlichkeit <em>spart Nerven</em>.</h3>
            <p class="au-principle-text">Wenn eine Idee keinen Sinn ergibt, sage ich das. Ein klares «Nein» zur richtigen Zeit ist mehr wert als jedes «Ja».</p>
          </article>
        </div>
      </div>

      <!-- CTA -->
      <div class="section pt-hero fade-up">
        <div class="section-cta">
          <span class="cta-label">Und jetzt?</span>
          <h2>Noch kein Plan?<br><span class="gradient-text">Perfekter Zeitpunkt.</span></h2>
          <div class="hero-cta-group" style="justify-content: center;">
            <a href="/kontakt" class="btn btn-primary">Direkt schreiben</a>
            <a href="/referenzen" class="btn btn-ghost">Projekte ansehen</a>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  /* Main Layout Grid */
  .au-main-grid {
    display: grid;
    grid-template-columns: minmax(280px, 340px) minmax(0, 1fr);
    gap: clamp(40px, 5vw, 72px);
    align-items: start;
  }

  /* Profile Column */
  .au-profile-column {
    position: sticky;
    top: 120px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .au-photo-container {
    position: relative;
    width: 240px;
    height: 240px;
    margin-bottom: 24px;
  }

  .au-photo-aura {
    position: absolute;
    inset: -10px;
    background: linear-gradient(135deg, #FF4D80, #A64DFF);
    border-radius: 50%;
    filter: blur(20px);
    opacity: 0.15;
    animation: aura-pulse 8s infinite alternate ease-in-out;
  }

  @keyframes aura-pulse {
    0% { transform: scale(1); opacity: 0.15; }
    100% { transform: scale(1.1); opacity: 0.25; }
  }

  .au-photo-circle-wrap {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: #000;
    z-index: 1;
  }

  .au-photo-circle {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    display: block;
    cursor: zoom-in;
    transition: transform 0.6s cubic-bezier(0.2, 0, 0.2, 1);
  }

  .au-photo-circle:hover { transform: scale(1.08); }

  .au-name {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 4px;
    color: #fff;
  }

  .au-role {
    font-size: 0.85rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  /* Content Column */
  .au-statement {
    margin-bottom: 40px;
  }

  .au-statement .hero-lead {
    font-size: clamp(1.2rem, 3vw, 1.5rem);
    line-height: 1.4;
    color: #fff;
    font-style: italic;
    margin: 0;
    max-width: 100%;
  }

  .au-bio p {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 24px;
  }

  .au-bio strong { color: #fff; }

  /* Stats Grid */
  .au-stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
  }

  .au-stat-card {
    padding: 1px;
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(255,255,255,0.08), transparent);
  }

  .au-stat-inner {
    background: rgba(15, 15, 17, 0.6);
    padding: 32px 24px;
    border-radius: 15px;
    text-align: center;
    height: 100%;
  }

  .au-stat-value {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 8px;
    background: linear-gradient(135deg, #FFC700, #FF4D80);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .au-stat-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.4;
  }

  /* Principles specific */
  .au-principle-number {
    font-size: 0.75rem;
    font-weight: 800;
    color: #FF4D80;
    margin-bottom: 16px;
    display: block;
  }

  .card h3 em { color: #FF4D80; font-style: italic; }
  .au-principle-text { font-size: 0.95rem; line-height: 1.6; color: var(--text-muted); margin: 0; }

  /* Responsive */
  @media (max-width: 1024px) {
    .au-main-grid { grid-template-columns: 1fr; gap: 40px; }
    .au-profile-column { position: static; }
  }

  @media (max-width: 600px) {
    .au-photo-container { width: 200px; height: 200px; }
    .au-stat-value { font-size: 2.5rem; }
  }
</style>
