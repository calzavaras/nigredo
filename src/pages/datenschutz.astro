---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.nigredo.ch/datenschutz#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Datenschutz", "item": "https://www.nigredo.ch/datenschutz" }
      ]
    },
    {
      "@type": "WebPage",
      "@id": "https://www.nigredo.ch/datenschutz#webpage",
      "name": "Datenschutz | Nigredo",
      "description": "Datenschutzerklärung von Nigredo – transparente Information über Datenerhebung und -nutzung.",
      "url": "https://www.nigredo.ch/datenschutz",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": "https://www.nigredo.ch/datenschutz#breadcrumb" },
      "publisher": { "@type": "Organization", "name": "Nigredo", "url": "https://www.nigredo.ch" },
      "inLanguage": "de-CH",
      "datePublished": "2025-06-01",
      "dateModified": "2026-03-21"
    }
  ]
});
---

<Layout
  title="Datenschutz | Nigredo"
  description="Datenschutzerklärung von Nigredo. Transparente Information über die Erhebung und Nutzung deiner Daten."
  keywords="Datenschutz Nigredo, Schweizer Hosting, Datensicherheit, Privatsphäre, DSG konform"
  canonical="https://www.nigredo.ch/datenschutz"
  robots="noindex, follow"
  schema={schema}
>
  <section class="section pt-sub">
    <div class="hero-glow"></div>
    <div class="container container--narrow">

      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Datenschutz' }
      ]} />

      <div class="fade-up legal-container">
        <span class="badge badge--cyan">DATENSCHUTZ</span>
        <h1>Datenschutz</h1>
        <p class="hero-lead">Kurz und klar: was gesammelt wird, warum und wer dafür verantwortlich ist.</p>

        <div class="mt-80 legal-text-block">
          <div class="legal-item">
            <span class="legal-num">01</span>
            <div>
              <h3>Verantwortliche Stelle</h3>
              <p>Verantwortlich für die Datenverarbeitung auf dieser Website:</p>
              <div class="legal-address">
                <strong>Nigredo</strong><br>
                Marco Calzavara<br>
                Wildeggstrasse 37<br>
                9000 St. Gallen, Schweiz
              </div>
              <span class="reveal-mail btn btn-ghost legal-btn" role="button" tabindex="0">Nachricht schreiben →</span>
            </div>
          </div>

          <div class="legal-item mt-80">
            <span class="legal-num">02</span>
            <div>
              <h3>Hosting</h3>
              <p>Diese Website wird bei <strong>Hosttech</strong> in der Schweiz gehostet. Der Hosting-Provider speichert automatisch Server-Logs (IP-Adresse, Browsertyp, Betriebssystem, Datum und Uhrzeit). Diese Daten werden ausschliesslich zu technischen Zwecken erhoben und unterliegen dem schweizerischen Datenschutzgesetz (DSG).</p>
            </div>
          </div>

          <div class="legal-item mt-80">
            <span class="legal-num">03</span>
            <div>
              <h3>Analyse-Tools & Cookies</h3>
              <p>Diese Website nutzt <strong>Umami Analytics</strong>, ein datenschutzfreundliches, cookiefreies Analyse-Tool. Umami erfasst anonymisierte Nutzungsdaten (z.B. besuchte Seiten, Verweildauer) ohne persönlich identifizierbare Informationen zu speichern. Es werden keine Cookies gesetzt und keine Daten an Dritte weitergegeben. Die Verarbeitung erfolgt in Übereinstimmung mit dem Schweizer Datenschutzgesetz (DSG).</p>
            </div>
          </div>

          <div class="legal-item mt-80">
            <span class="legal-num">04</span>
            <div>
              <h3>Kontaktaufnahme</h3>
              <p>Wenn du mich per E-Mail kontaktierst, werden deine Angaben (E-Mail-Adresse, Name, Nachricht) gespeichert, um deine Anfrage zu bearbeiten. Diese Daten werden nicht ohne deine Einwilligung weitergegeben.</p>
            </div>
          </div>

          <div class="legal-item mt-80">
            <span class="legal-num">05</span>
            <div>
              <h3>Deine Rechte</h3>
              <p>Du hast das Recht auf Auskunft, Berichtigung, Löschung und Einschränkung der Verarbeitung deiner personenbezogenen Daten. Kontaktiere mich dafür einfach per E-Mail.</p>
            </div>
          </div>

          <div class="legal-item mt-80">
            <span class="legal-num">06</span>
            <div>
              <h3>SSL-Verschlüsselung</h3>
              <p>Diese Website nutzt SSL-Verschlüsselung für die sichere Übertragung von Daten. Verschlüsselte Seiten erkennst du am «https://» in der Adresszeile und am Schloss-Symbol im Browser.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .legal-container {
    max-width: 100%;
  }
  .legal-text-block p {
    color: var(--text-muted);
    max-width: var(--reading-width);
    margin-bottom: 24px;
  }
  .legal-item {
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }
  .legal-num {
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--quaternary-accent);
    padding-top: 6px;
    flex-shrink: 0;
  }
  .legal-address {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 24px;
  }
  .legal-btn {
    padding: 10px 20px;
    font-size: 0.85rem;
  }
  @media (max-width: 600px) {
    .legal-item {
      flex-direction: column;
      gap: 12px;
    }
  }
</style>
