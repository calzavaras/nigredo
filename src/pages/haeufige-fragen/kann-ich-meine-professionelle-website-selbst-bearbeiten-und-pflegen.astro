---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const pageUrl = 'https://www.nigredo.ch/haeufige-fragen/kann-ich-meine-professionelle-website-selbst-bearbeiten-und-pflegen/';
const question = 'Kann ich meine Website später selbst bearbeiten?';
const answer = 'Ja. Welche Inhalte du selbst pflegen kannst, wird bereits bei der Planung festgelegt. Für regelmässige Änderungen kann ein passendes CMS sinnvoll sein. Bei seltenen Anpassungen ist eine schlankere Lösung oft einfacher und wirtschaftlicher.';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Häufige Fragen", "item": "https://www.nigredo.ch/haeufige-fragen/" },
        { "@type": "ListItem", "position": 3, "name": question, "item": pageUrl }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": answer
          }
        }
      ]
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": "Kann ich meine Website später selbst bearbeiten? | Nigredo",
      "description": "Welche Inhalte du selbst pflegen kannst, wann ein CMS sinnvoll ist und wie Nigredo eine verständliche Übergabe mit eindeutigen Zuständigkeiten gestaltet.",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "mainEntity": { "@id": `${pageUrl}#faq` },
      "about": { "@id": "https://www.nigredo.ch/#organization" },
      "inLanguage": "de-CH",
      "datePublished": "2026-05-18",
      "dateModified": "2026-07-14",
      "isAccessibleForFree": true
    }
  ]
});
---

<Layout
  title="Kann ich meine Website später selbst bearbeiten? | Nigredo"
  description="Welche Inhalte du selbst pflegen kannst, wann ein CMS sinnvoll ist und wie Nigredo eine verständliche Übergabe mit eindeutigen Zuständigkeiten gestaltet."
  canonical={pageUrl}
  ogTitle="Kann ich meine Website später selbst bearbeiten? | Nigredo"
  ogDescription="Wann ein CMS sinnvoll ist, welche Inhalte sich selbst pflegen lassen und wie viel Eigenständigkeit nach dem Launch realistisch bleibt."
  twitterTitle="Kann ich meine Website später selbst bearbeiten? | Nigredo"
  twitterDescription="Wann eine Website selbst gepflegt werden kann und ob ein CMS wirklich nötig ist."
  schema={schema}
>
  <article class="section faq-article" aria-labelledby="article-title">
    <div class="hero-glow"></div>
    <div class="container faq-article__container">
      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Häufige Fragen', href: '/haeufige-fragen/' },
        { label: question }
      ]} />

      <header class="faq-article__header fade-up">
        <h1 id="article-title">{question}</h1>
        <p>{answer}</p>
      </header>

      <nav class="faq-article__nav fade-up delay-100" aria-label="Inhaltsübersicht">
        <a href="#selbst-pflegen">Welche Inhalte sich gut pflegen lassen</a>
        <a href="#cms">Wann ein CMS sinnvoll ist</a>
        <a href="#eigenstaendigkeit">Wann weniger Technik besser ist</a>
        <a href="#grenzen">Welche Änderungen besser begleitet bleiben</a>
        <a href="#uebergabe">Wie Nigredo die Übergabe gestaltet</a>
      </nav>

      <div class="faq-article__content fade-up delay-100">
        <h2 id="selbst-pflegen">Welche Inhalte sich gut pflegen lassen</h2>
        <p>
          Texte, Bilder, Teamprofile, Referenzen und ähnliche Inhalte können so aufgebaut werden, dass du sie sicher selbst aktualisierst. Welche Bereiche bearbeitbar sein sollen, richtet sich nach deinem Alltag und deinen internen Abläufen.
        </p>

        <h2 id="cms">Wann ein CMS sinnvoll ist</h2>
        <p>
          Ein CMS lohnt sich, wenn Inhalte häufig wechseln, mehrere Personen daran arbeiten oder regelmässig neue Seiten entstehen. Es sollte genau die Funktionen bieten, die tatsächlich gebraucht werden, und in der Bedienung verständlich bleiben.
        </p>

        <h2 id="eigenstaendigkeit">Wann weniger Technik besser ist</h2>
        <p>
          Ändern sich Inhalte nur selten, kann ein grosses Redaktionssystem mehr Aufwand als Nutzen verursachen. Eine schlanke Website bleibt einfacher, sicherer und günstiger im Betrieb. Anpassungen können bei Bedarf gezielt vorgenommen werden.
        </p>

        <h2 id="grenzen">Welche Änderungen besser professionell begleitet bleiben</h2>
        <p>
          Redaktionelle Änderungen sind etwas anderes als Eingriffe in Navigation, Formulare, Analyse oder technische Integrationen. Solche Anpassungen betreffen oft mehrere Bereiche und sollten deshalb fachlich geprüft werden.
        </p>

        <h2 id="uebergabe">Wie Nigredo die Übergabe gestaltet</h2>
        <p>
          Nigredo klärt früh, wie viel Eigenständigkeit gewünscht ist, und richtet die Website darauf aus. Du erhältst eine verständliche Lösung mit eindeutigen Zuständigkeiten, damit die Pflege im Alltag leicht bleibt.
        </p>

        <section class="related-faqs" aria-labelledby="related-faqs-title">
          <h2 id="related-faqs-title">Verwandte Fragen</h2>
          <div class="related-faqs__grid">
            <a href="/haeufige-fragen/was-kostet-eine-professionelle-website/">
              <strong>Was kostet eine professionelle Website?</strong>
              <span>Welche Faktoren den Preis beeinflussen und wie Zusatzaufwand sauber eingeordnet wird.</span>
            </a>
            <a href="/haeufige-fragen/was-kostet-der-laufende-betrieb-einer-website/">
              <strong>Welche laufenden Kosten hat eine Website?</strong>
              <span>Welche laufenden Kosten nach dem Launch entstehen, von Hosting bis Wartung.</span>
            </a>
            <a href="/haeufige-fragen/brauche-ich-eine-individuelle-website-oder-reicht-ein-baukasten/">
              <strong>Brauche ich eine individuelle Website oder reicht ein Baukasten?</strong>
              <span>Wann eine Vorlage genügt und wann eine massgeschneiderte Lösung sinnvoller ist.</span>
            </a>
            <a href="/haeufige-fragen/was-muss-meine-website-beim-datenschutz-beachten/">
              <strong>Was muss meine Website beim Datenschutz beachten?</strong>
              <span>Was das Schweizer Datenschutzgesetz für deine Website bedeutet, von Cookies bis Analyse.</span>
            </a>
          </div>
        </section>

        <div class="article-links">
          <a href="/haeufige-fragen/">Zurück zu den häufigen Fragen</a>
          <a href="/kontakt/">Passende Pflegeform klären</a>
        </div>
      </div>
    </div>
  </article>
</Layout>

<style>
  .faq-article {
    --faq-a: var(--brand-sun);
    --faq-b: var(--brand-coral);
    --faq-c: var(--brand-pink);
  }
</style>
