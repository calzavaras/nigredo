---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const pageUrl = 'https://www.nigredo.ch/haeufige-fragen/was-kostet-der-laufende-betrieb-einer-website/';
const question = 'Was kostet der laufende Betrieb einer Website?';
const answer = 'Der laufende Betrieb einer Website kostet meist deutlich weniger als die Erstellung. Grundlegend fallen Domain und Hosting an, oft im Bereich von wenigen Franken pro Monat. Dazu kommen je nach Technik Updates, Sicherheit und inhaltliche Pflege. Eine schlank gebaute Website verursacht im Betrieb sehr geringe Fixkosten.';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Häufige Fragen", "item": "https://www.nigredo.ch/haeufige-fragen/" },
        { "@type": "ListItem", "position": 3, "name": question, "item": pageUrl }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": answer
          }
        },
        {
          "@type": "Question",
          "name": "Welche laufenden Kosten hat eine Website mindestens?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Mindestens fallen Domain und Hosting an. Eine Domain kostet in der Schweiz meist rund zehn bis zwanzig Franken pro Jahr, einfaches Hosting wenige Franken pro Monat. Alles Weitere wie Wartung oder inhaltliche Pflege hängt von Technik und Anspruch ab."
          }
        },
        {
          "@type": "Question",
          "name": "Braucht eine Website einen monatlichen Wartungsvertrag?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Nicht zwingend. Eine schlank und sicher gebaute Website kann ohne festen Wartungsvertrag laufen. Sinnvoll wird laufende Wartung dort, wo ein System mit vielen Erweiterungen, regelmässigen Updates oder häufig wechselnden Inhalten im Einsatz ist."
          }
        }
      ]
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": "Was kostet der laufende Betrieb einer Website? | Nigredo",
      "description": "Welche laufenden Kosten eine Website nach dem Launch verursacht: Domain, Hosting, Wartung und Pflege, klar erklärt für KMU und Selbständige in der Schweiz.",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "mainEntity": { "@id": `${pageUrl}#faq` },
      "about": { "@id": "https://www.nigredo.ch/#organization" },
      "inLanguage": "de-CH",
      "datePublished": "2026-06-17",
      "dateModified": "2026-06-17",
      "isAccessibleForFree": true
    }
  ]
});
---

<Layout
  title="Was kostet der laufende Betrieb einer Website? | Nigredo"
  description="Welche laufenden Kosten eine Website nach dem Launch verursacht: Domain, Hosting, Wartung und Pflege, klar erklärt für KMU und Selbständige in der Schweiz."
  canonical={pageUrl}
  ogTitle="Was kostet der laufende Betrieb einer Website? | Nigredo"
  ogDescription="Domain, Hosting, Wartung und Pflege: Was eine Website nach dem Launch wirklich kostet und wie sich der laufende Aufwand schlank halten lässt."
  twitterTitle="Was kostet der laufende Betrieb einer Website? | Nigredo"
  twitterDescription="Welche laufenden Kosten eine Website nach dem Launch verursacht und wie man sie tief hält."
  schema={schema}
>
  <article class="section faq-article" aria-labelledby="article-title">
    <div class="hero-glow"></div>
    <div class="container faq-article__container">
      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Häufige Fragen', href: '/haeufige-fragen/' },
        { label: question }
      ]} />

      <header class="faq-article__header fade-up">
        <span class="badge badge--cyan">Betrieb & Unterhalt</span>
        <h1 id="article-title">{question}</h1>
        <p>
          Eine Website ist mit dem Launch nicht fertig bezahlt, aber der laufende Betrieb ist meist überschaubar. Grundlegend braucht es eine Domain und Hosting. Was darüber hinaus anfällt, hängt von Technik, Sicherheit und davon ab, wie oft Inhalte gepflegt werden.
        </p>
      </header>

      <nav class="faq-article__nav fade-up delay-100" aria-label="Inhaltsübersicht">
        <a href="#bestandteile">Woraus sich Betriebskosten zusammensetzen</a>
        <a href="#hosting-domain">Hosting und Domain</a>
        <a href="#wartung">Wartung, Updates und Sicherheit</a>
        <a href="#pflege">Inhaltliche Pflege</a>
        <a href="#nigredo">Wie Nigredo den Betrieb schlank hält</a>
      </nav>

      <div class="faq-article__content fade-up delay-100">
        <p class="lead-answer">
          Als Orientierung gilt: Die laufenden Fixkosten einer schlanken Website liegen oft bei wenigen Franken pro Monat für Hosting plus einer kleinen Jahresgebühr für die Domain. Grösser wird der laufende Aufwand erst, wenn ein umfangreiches System gepflegt, regelmässig aktualisiert oder inhaltlich häufig erweitert werden muss.
        </p>

        <h2 id="bestandteile">Woraus sich die Betriebskosten zusammensetzen</h2>
        <p>
          Der laufende Betrieb besteht aus zwei Teilen: den technischen Fixkosten und dem optionalen Aufwand für Pflege und Wartung. Fix sind vor allem Domain und Hosting. Optional sind regelmässige Updates, Sicherheits- und Backup-Massnahmen sowie inhaltliche Anpassungen, wenn sich etwas am Angebot ändert.
        </p>
        <p>
          Wie hoch der Betrieb am Ende ausfällt, entscheidet sich oft schon beim Bauen. Eine technisch schlanke Website mit wenig beweglichen Teilen verursacht im Betrieb kaum Aufwand. Ein grosses System mit vielen Erweiterungen muss dagegen laufend gepflegt werden, sonst entstehen Sicherheits- oder Funktionslücken.
        </p>

        <h2 id="hosting-domain">Hosting und Domain</h2>
        <p>
          Die Domain ist die Adresse deiner Website, etwa eine .ch-Adresse, und kostet in der Schweiz meist rund zehn bis zwanzig Franken pro Jahr. Das Hosting ist der Speicherplatz, auf dem die Website läuft. Für eine klassische KMU-Website reichen oft schon günstige Pakete im Bereich weniger Franken pro Monat.
        </p>
        <p>
          Entscheidend ist nicht der billigste Tarif, sondern eine zuverlässige, schnelle und gut erreichbare Grundlage. Eine schnell ausgelieferte Website wirkt sich positiv auf Besucher und Suchmaschinen aus. Wer eine statisch gebaute Website betreibt, kommt technisch mit sehr wenig aus und hat entsprechend tiefe laufende Kosten.
        </p>

        <h2 id="wartung">Wartung, Updates und Sicherheit</h2>
        <p>
          Wartung bedeutet, eine Website sicher und funktionsfähig zu halten. Bei Systemen mit vielen Bausteinen gehören regelmässige Updates, Backups und Sicherheitsprüfungen dazu. Wird das vernachlässigt, steigt das Risiko für Ausfälle oder Sicherheitsprobleme. Genau hier entstehen bei manchen Lösungen die eigentlichen laufenden Kosten.
        </p>
        <p>
          Nicht jede Website braucht aber einen festen Wartungsvertrag. Je schlanker und stabiler die technische Basis ist, desto weniger muss laufend nachgezogen werden. Sinnvoll ist Wartung vor allem dort, wo viel Technik im Spiel ist, sensible Daten verarbeitet werden oder Inhalte ständig wechseln.
        </p>

        <h2 id="pflege">Inhaltliche Pflege</h2>
        <p>
          Neben der Technik gibt es die inhaltliche Seite: neue Texte, aktualisierte Angebote, frische Bilder oder zusätzliche Seiten. Dieser Aufwand fällt nicht regelmässig an, sondern dann, wenn sich etwas ändert. Ob du das selbst übernimmst oder begleiten lässt, hängt davon ab, wie die Website aufgebaut ist und wer intern damit arbeitet.
        </p>
        <p>
          Wer Inhalte selbst pflegen möchte, sollte das bereits bei der Planung berücksichtigen. Wie viel Eigenständigkeit dabei realistisch bleibt und wann ein CMS sinnvoll ist, ist in <a href="/haeufige-fragen/kann-ich-meine-professionelle-website-selbst-bearbeiten-und-pflegen/">der Frage zur Pflege einer Website</a> ausführlicher erklärt.
        </p>

        <h2 id="nigredo">Wie Nigredo den Betrieb schlank hält</h2>
        <p>
          Nigredo baut Websites bewusst technisch schlank, damit der laufende Betrieb günstig und unkompliziert bleibt. Statt grosser Systeme mit vielen Abhängigkeiten entstehen schnelle, stabile Websites, die wenig Wartung brauchen und auf einfachem Hosting laufen. So bleiben die Fixkosten nach dem Launch tief.
        </p>
        <p>
          Vor dem Projekt wird klar besprochen, welche laufenden Kosten realistisch entstehen und wo Aufwand wirklich nötig ist. Wer zuerst wissen will, was die Erstellung selbst kostet, findet die Antwort bei <a href="/haeufige-fragen/was-kostet-eine-professionelle-website/">der Frage zu den Website-Kosten</a>.
        </p>

        <section class="related-faqs" aria-labelledby="related-faqs-title">
          <h2 id="related-faqs-title">Verwandte Fragen</h2>
          <div class="related-faqs__grid">
            <a href="/haeufige-fragen/was-kostet-eine-professionelle-website/">
              <strong>Was kostet eine professionelle Website?</strong>
              <span>Wovon der Preis abhängt und wie sich die Kosten für die Erstellung seriös einschätzen lassen.</span>
            </a>
            <a href="/haeufige-fragen/kann-ich-meine-professionelle-website-selbst-bearbeiten-und-pflegen/">
              <strong>Kann ich meine professionelle Website später selbst bearbeiten und pflegen?</strong>
              <span>Wann ein CMS sinnvoll ist und wie viel Eigenständigkeit realistisch bleibt.</span>
            </a>
            <a href="/haeufige-fragen/was-muss-meine-website-beim-datenschutz-beachten/">
              <strong>Was muss meine Website beim Datenschutz beachten?</strong>
              <span>Was das Schweizer Datenschutzgesetz für deine Website bedeutet, von Cookies bis Analyse.</span>
            </a>
            <a href="/haeufige-fragen/wird-meine-website-bei-google-gefunden/">
              <strong>Wird meine Website bei Google gefunden?</strong>
              <span>Warum eine Website nicht automatisch sichtbar ist und wovon die Auffindbarkeit abhängt.</span>
            </a>
          </div>
        </section>

        <div class="article-links">
          <a href="/haeufige-fragen/">Zurück zu den häufigen Fragen</a>
          <a href="/kontakt/">Betriebskosten für meine Website klären</a>
        </div>
      </div>
    </div>
  </article>
</Layout>

<style>
  .faq-article {
    --faq-a: #00b4d8;
    --faq-b: #2d9cdb;
    --faq-c: #4cc9a0;
    animation: faqCycle 90s ease-in-out infinite;
    position: relative;
    padding-top: var(--hero-offset-top-breadcrumb);
    padding-bottom: clamp(84px, 8vw, 112px);
    overflow: hidden;
  }

  .faq-article__container {
    position: relative;
  }

  .faq-article :global(.breadcrumb) {
    margin-bottom: 28px;
  }

  .faq-article__header {
    max-width: 880px;
  }

  .faq-article__header .badge {
    min-height: 26px;
    margin-bottom: 0.9rem;
    padding: 4px 10px;
    font-size: 0.54rem;
    letter-spacing: 0.14em;
    color: rgba(224, 248, 255, 0.94);
    border-color: color-mix(in srgb, var(--faq-b) 34%, rgba(255, 255, 255, 0.22));
    background: transparent;
    box-shadow: none;
  }

  .faq-article .hero-glow {
    background:
      radial-gradient(circle at 18% 40%, color-mix(in srgb, var(--faq-a) 16%, transparent) 0%, transparent 36%),
      radial-gradient(circle at 56% 34%, color-mix(in srgb, var(--faq-b) 14%, transparent) 0%, transparent 32%),
      radial-gradient(circle at 84% 44%, color-mix(in srgb, var(--faq-c) 13%, transparent) 0%, transparent 28%);
  }

  .faq-article__header h1 {
    max-width: 920px;
    margin: 0 0 clamp(24px, 3vw, 32px);
    color: #f5f5f7;
    font-size: clamp(2.95rem, 5.2vw, 4.55rem);
    line-height: 0.99;
    letter-spacing: 0;
  }

  .faq-article__header p {
    max-width: 720px;
    margin: 0;
    color: rgba(255, 255, 255, 0.68);
    font-size: var(--lead-size);
    line-height: 1.65;
  }

  .faq-article__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    max-width: 760px;
    margin-top: 30px;
  }

  .faq-article__nav a,
  .related-faqs__grid a,
  .article-links a {
    text-decoration: none;
  }

  .faq-article__nav a {
    min-height: 40px;
    display: inline-flex;
    align-items: center;
    padding: 0 14px;
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.92rem;
    border: 1px solid rgba(255, 255, 255, 0.11);
    background: rgba(255, 255, 255, 0.03);
    transition: border-color 0.2s ease, transform 0.2s ease, color 0.2s ease;
  }

  .faq-article__nav a:hover {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.24);
    transform: translateY(-2px);
  }

  .faq-article__content {
    max-width: 760px;
    margin-top: clamp(46px, 6vw, 72px);
  }

  .faq-article__content p {
    margin: 0 0 1.25rem;
    color: rgba(255, 255, 255, 0.68);
    font-size: 1.04rem;
    line-height: 1.78;
  }

  .faq-article__content .lead-answer {
    color: rgba(255, 255, 255, 0.82);
    font-size: clamp(1.12rem, 2vw, 1.28rem);
    line-height: 1.72;
    padding-bottom: clamp(22px, 4vw, 34px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .faq-article__content h2 {
    margin: clamp(42px, 6vw, 62px) 0 1rem;
    color: rgba(255, 255, 255, 0.95);
    font-size: clamp(1.46rem, 2.8vw, 2rem);
    line-height: 1.16;
    letter-spacing: 0;
  }

  .faq-article__content a {
    color: rgba(255, 255, 255, 0.9);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  .related-faqs {
    margin-top: clamp(42px, 6vw, 62px);
    padding-top: 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .related-faqs__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .related-faqs__grid a {
    display: grid;
    gap: 10px;
    padding: 20px;
    border-radius: 22px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .related-faqs__grid a:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .related-faqs__grid strong {
    color: rgba(255, 255, 255, 0.95);
    font-size: 1rem;
    line-height: 1.4;
  }

  .related-faqs__grid span {
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.96rem;
    line-height: 1.6;
  }

  .article-links {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: clamp(42px, 6vw, 62px);
    padding-top: 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .article-links a {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 18px;
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.13);
    background: rgba(255, 255, 255, 0.035);
    transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .article-links a:hover {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.28);
    transform: translateY(-2px);
  }

  @media (max-width: 860px) {
    .faq-article {
      padding-top: var(--hero-offset-top-breadcrumb-mobile);
      padding-bottom: 72px;
    }

    .faq-article__header h1 {
      font-size: clamp(2.5rem, 8vw, 3.5rem);
      line-height: var(--hero-title-line-height-mobile);
    }

    .related-faqs__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .faq-article__header h1 {
      font-size: clamp(2.2rem, 10.8vw, 2.95rem);
    }

    .faq-article__header p {
      font-size: var(--lead-size-mobile);
      line-height: 1.6;
    }

    .faq-article__nav {
      display: grid;
      grid-template-columns: 1fr;
    }

    .faq-article__nav a {
      justify-content: center;
      text-align: center;
    }

    .faq-article__content {
      margin-top: 48px;
    }

    .faq-article__content p {
      font-size: 1rem;
      line-height: 1.72;
    }

    .article-links {
      display: grid;
      grid-template-columns: 1fr;
    }
  }
</style>
