---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const pageUrl = 'https://www.nigredo.ch/haeufige-fragen/was-kostet-der-laufende-betrieb-einer-website/';
const question = 'Welche laufenden Kosten hat eine Website?';
const answer = 'Zu den festen Grundkosten gehören Domain und Hosting. Wartung, technische Updates, Sicherungen und redaktionelle Pflege kommen je nach System und Nutzung hinzu. Eine schlank gebaute Website hält diesen Aufwand dauerhaft überschaubar.';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Häufige Fragen", "item": "https://www.nigredo.ch/haeufige-fragen/" },
        { "@type": "ListItem", "position": 3, "name": question, "item": pageUrl }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": answer
          }
        }
      ]
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": "Welche laufenden Kosten hat eine Website? | Nigredo",
      "description": "Welche Kosten nach dem Start für Domain, Hosting, Wartung und Pflege entstehen und wie eine schlanke technische Basis den Aufwand tief hält.",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "mainEntity": { "@id": `${pageUrl}#faq` },
      "about": { "@id": "https://www.nigredo.ch/#organization" },
      "inLanguage": "de-CH",
      "datePublished": "2026-06-17",
      "dateModified": "2026-07-14",
      "isAccessibleForFree": true
    }
  ]
});
---

<Layout
  title="Welche laufenden Kosten hat eine Website? | Nigredo"
  description="Welche Kosten nach dem Start für Domain, Hosting, Wartung und Pflege entstehen und wie eine schlanke technische Basis den Aufwand tief hält."
  canonical={pageUrl}
  ogTitle="Welche laufenden Kosten hat eine Website? | Nigredo"
  ogDescription="Domain, Hosting, Wartung und Pflege: Welche Kosten nach dem Start anfallen und wie sich der Aufwand dauerhaft klein halten lässt."
  twitterTitle="Welche laufenden Kosten hat eine Website? | Nigredo"
  twitterDescription="Welche laufenden Kosten eine Website nach dem Launch verursacht und wie man sie tief hält."
  schema={schema}
>
  <article class="section faq-article" aria-labelledby="article-title">
    <div class="hero-glow"></div>
    <div class="container faq-article__container">
      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Häufige Fragen', href: '/haeufige-fragen/' },
        { label: question }
      ]} />

      <header class="faq-article__header fade-up">
        <h1 id="article-title">{question}</h1>
        <p>{answer}</p>
      </header>

      <nav class="faq-article__nav fade-up delay-100" aria-label="Inhaltsübersicht">
        <a href="#bestandteile">Welche Kosten fest anfallen</a>
        <a href="#hosting-domain">Was Hosting leisten muss</a>
        <a href="#wartung">Wann Wartung nötig ist</a>
        <a href="#pflege">Was redaktionelle Pflege kostet</a>
        <a href="#nigredo">Wie Nigredo Folgekosten klein hält</a>
      </nav>

      <div class="faq-article__content fade-up delay-100">
        <h2 id="bestandteile">Welche Kosten fest anfallen</h2>
        <p>
          Jede Website braucht eine Domain und einen Ort, an dem sie betrieben wird. Diese Grundkosten lassen sich gut planen und bleiben bei einer klassischen KMU-Website meist überschaubar.
        </p>

        <h2 id="hosting-domain">Was Hosting leisten muss</h2>
        <p>
          Ein passendes Hosting sorgt dafür, dass die Website schnell, zuverlässig und sicher erreichbar ist. Nicht der tiefste Tarif entscheidet, sondern eine Lösung, die zur Technik und zum erwarteten Besuchsvolumen passt.
        </p>

        <h2 id="wartung">Wann Wartung nötig ist</h2>
        <p>
          Systeme mit Erweiterungen, Datenbanken oder regelmässigen Updates brauchen laufende Kontrolle. Eine statisch gebaute Website hat weniger bewegliche Teile und verursacht deshalb meist weniger technischen Unterhalt.
        </p>

        <h2 id="pflege">Was redaktionelle Pflege kostet</h2>
        <p>
          Neue Texte, Bilder oder Seiten sind keine festen Betriebskosten. Der Aufwand entsteht nur, wenn sich Inhalte ändern. Ob diese Pflege intern oder durch Nigredo erfolgt, wird passend zum gewünschten Mass an Eigenständigkeit festgelegt.
        </p>

        <h2 id="nigredo">Wie Nigredo Folgekosten klein hält</h2>
        <p>
          Nigredo wählt Technik nicht nach Funktionsmenge, sondern nach Aufgabe. Wenige Abhängigkeiten, zuverlässiges Hosting und ein verständlicher Pflegeprozess halten die Website stabil und die laufenden Kosten transparent.
        </p>

        <section class="related-faqs" aria-labelledby="related-faqs-title">
          <h2 id="related-faqs-title">Verwandte Fragen</h2>
          <div class="related-faqs__grid">
            <a href="/haeufige-fragen/was-kostet-eine-professionelle-website/">
              <strong>Was kostet eine professionelle Website?</strong>
              <span>Wovon der Preis abhängt und wie sich die Kosten für die Erstellung seriös einschätzen lassen.</span>
            </a>
            <a href="/haeufige-fragen/kann-ich-meine-professionelle-website-selbst-bearbeiten-und-pflegen/">
              <strong>Kann ich meine Website später selbst bearbeiten?</strong>
              <span>Wann ein CMS sinnvoll ist und wie viel Eigenständigkeit realistisch bleibt.</span>
            </a>
            <a href="/haeufige-fragen/was-muss-meine-website-beim-datenschutz-beachten/">
              <strong>Was muss meine Website beim Datenschutz beachten?</strong>
              <span>Was das Schweizer Datenschutzgesetz für deine Website bedeutet, von Cookies bis Analyse.</span>
            </a>
            <a href="/haeufige-fragen/wird-meine-website-bei-google-gefunden/">
              <strong>Wird meine Website bei Google gefunden?</strong>
              <span>Warum eine Website nicht automatisch sichtbar ist und wovon die Auffindbarkeit abhängt.</span>
            </a>
          </div>
        </section>

        <div class="article-links">
          <a href="/haeufige-fragen/">Zurück zu den häufigen Fragen</a>
          <a href="/kontakt/">Laufende Kosten meiner Website klären</a>
        </div>
      </div>
    </div>
  </article>
</Layout>

<style>
  .faq-article {
    --faq-a: var(--brand-cyan);
    --faq-b: var(--brand-blue);
    --faq-c: var(--brand-violet);
  }
</style>
