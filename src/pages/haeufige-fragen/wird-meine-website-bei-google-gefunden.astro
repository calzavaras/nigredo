---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const pageUrl = 'https://www.nigredo.ch/haeufige-fragen/wird-meine-website-bei-google-gefunden/';
const question = 'Wird meine Website bei Google gefunden?';
const answer = 'Google kann eine Website finden, wenn sie technisch erreichbar, verständlich gegliedert und inhaltlich relevant ist. Gute Platzierungen brauchen zusätzlich passende Suchanfragen, überzeugende Inhalte und Zeit. Eine seriöse Umsetzung schafft die Grundlage, garantiert aber keine feste Position.';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Häufige Fragen", "item": "https://www.nigredo.ch/haeufige-fragen/" },
        { "@type": "ListItem", "position": 3, "name": question, "item": pageUrl }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": answer
          }
        }
      ]
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": "Wird meine Website bei Google gefunden? | Nigredo",
      "description": "Was Google braucht, um eine Website zu finden und einzuordnen, wie gute Platzierungen entstehen und welche Grundlagen Nigredo dafür schafft.",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "mainEntity": { "@id": `${pageUrl}#faq` },
      "about": { "@id": "https://www.nigredo.ch/#organization" },
      "inLanguage": "de-CH",
      "datePublished": "2026-06-04",
      "dateModified": "2026-07-14",
      "isAccessibleForFree": true
    }
  ]
});
---

<Layout
  title="Wird meine Website bei Google gefunden? | Nigredo"
  description="Was Google braucht, um eine Website zu finden und einzuordnen, wie gute Platzierungen entstehen und welche Grundlagen Nigredo dafür schafft."
  canonical={pageUrl}
  ogTitle="Wird meine Website bei Google gefunden? | Nigredo"
  ogDescription="Wovon es abhängt, ob eine Website bei Google gefunden wird, und was KMU und Selbstständige in der Schweiz dafür brauchen."
  twitterTitle="Wird meine Website bei Google gefunden? | Nigredo"
  twitterDescription="Warum eine Website nicht von allein sichtbar ist und was wirklich zählt."
  schema={schema}
>
  <article class="section faq-article" aria-labelledby="article-title">
    <div class="hero-glow"></div>
    <div class="container faq-article__container">
      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Häufige Fragen', href: '/haeufige-fragen/' },
        { label: question }
      ]} />

      <header class="faq-article__header fade-up">
        <h1 id="article-title">{question}</h1>
        <p>{answer}</p>
      </header>

      <nav class="faq-article__nav fade-up delay-100" aria-label="Inhaltsübersicht">
        <a href="#nicht-automatisch">Gefunden werden und gut platziert sein</a>
        <a href="#faktoren">Was Google einordnen muss</a>
        <a href="#inhalt">Warum Suchabsicht wichtiger ist als Wortmenge</a>
        <a href="#dauer">Wann Ergebnisse sichtbar werden</a>
        <a href="#nigredo">Wie Nigredo Sichtbarkeit vorbereitet</a>
      </nav>

      <div class="faq-article__content fade-up delay-100">
        <h2 id="nicht-automatisch">Gefunden werden und gut platziert sein</h2>
        <p>
          Zuerst muss Google eine Seite aufrufen und in den Suchindex aufnehmen können. Danach wird bewertet, für welche Suchanfragen der Inhalt relevant ist. Eine indexierte Website ist deshalb nicht automatisch auf den vorderen Plätzen sichtbar.
        </p>

        <h2 id="faktoren">Was Google einordnen muss</h2>
        <p>
          Aussagekräftige Seitentitel, eindeutige Überschriften, schnelle Ladezeiten und eine verständliche Struktur helfen bei der Einordnung. Ebenso wichtig ist, dass jede Seite ein konkretes Thema behandelt und die dazugehörigen Fragen vollständig beantwortet.
        </p>

        <h2 id="inhalt">Warum Suchabsicht wichtiger ist als Wortmenge</h2>
        <p>
          Gute Inhalte verwenden die Sprache der Zielgruppe und lösen ein konkretes Informationsbedürfnis. Entscheidend ist nicht, einen Begriff möglichst oft zu wiederholen, sondern die beste verständliche Antwort auf eine reale Suche zu geben.
        </p>

        <h2 id="dauer">Wann Ergebnisse sichtbar werden</h2>
        <p>
          Technische Verbesserungen können rasch erfasst werden. Neue Platzierungen entwickeln sich meist über Wochen oder Monate, besonders bei umkämpften Suchbegriffen. Verlässliche Sichtbarkeit entsteht durch Qualität, Relevanz und kontinuierliche Weiterentwicklung.
        </p>

        <h2 id="nigredo">Wie Nigredo Sichtbarkeit vorbereitet</h2>
        <p>
          Nigredo verbindet technische Suchmaschinenoptimierung mit präziser Inhaltsarbeit. Jede Seite erhält eine eindeutige Funktion, passende Metadaten und eine Struktur, die Menschen wie Suchmaschinen gut verstehen können.
        </p>

        <section class="related-faqs" aria-labelledby="related-faqs-title">
          <h2 id="related-faqs-title">Verwandte Fragen</h2>
          <div class="related-faqs__grid">
            <a href="/haeufige-fragen/was-kostet-eine-professionelle-website/">
              <strong>Was kostet eine professionelle Website?</strong>
              <span>Wovon der Preis abhängt und warum es keinen seriösen Einheitspreis gibt.</span>
            </a>
            <a href="/haeufige-fragen/brauche-ich-eine-individuelle-website-oder-reicht-ein-baukasten/">
              <strong>Brauche ich eine individuelle Website oder reicht ein Baukasten?</strong>
              <span>Wann eine Vorlage genügt und wann eine massgeschneiderte Lösung sinnvoller ist.</span>
            </a>
            <a href="/haeufige-fragen/was-muss-meine-website-beim-datenschutz-beachten/">
              <strong>Was muss meine Website beim Datenschutz beachten?</strong>
              <span>Was das Schweizer Datenschutzgesetz für deine Website bedeutet, von Cookies bis Analyse.</span>
            </a>
            <a href="/haeufige-fragen/was-kostet-der-laufende-betrieb-einer-website/">
              <strong>Welche laufenden Kosten hat eine Website?</strong>
              <span>Welche laufenden Kosten nach dem Launch entstehen, von Hosting bis Wartung.</span>
            </a>
          </div>
        </section>

        <div class="article-links">
          <a href="/haeufige-fragen/">Zurück zu den häufigen Fragen</a>
          <a href="/kontakt/">Sichtbarkeit meiner Website klären</a>
        </div>
      </div>
    </div>
  </article>
</Layout>

<style>
  .faq-article {
    --faq-a: var(--brand-sun);
    --faq-b: var(--brand-coral);
    --faq-c: var(--brand-pink);
  }
</style>
