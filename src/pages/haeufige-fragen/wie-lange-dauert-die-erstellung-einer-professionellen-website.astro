---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const pageUrl = 'https://www.nigredo.ch/haeufige-fragen/wie-lange-dauert-die-erstellung-einer-professionellen-website/';
const question = 'Wie lange dauert die Erstellung einer professionellen Website?';
const answer = 'Die Erstellung einer professionellen Website dauert je nach Umfang, Inhalt und Abstimmung unterschiedlich lang. Eine schlanke Website kann in wenigen Wochen realistisch umgesetzt werden, während ein umfangreicherer Auftritt mit Textarbeit, Suchmaschinenoptimierung und mehreren Freigaben entsprechend mehr Zeit braucht.';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Häufige Fragen", "item": "https://www.nigredo.ch/haeufige-fragen/" },
        { "@type": "ListItem", "position": 3, "name": question, "item": pageUrl }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": answer
          }
        }
      ]
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": "Wie lange dauert die Erstellung einer professionellen Website? | Nigredo",
      "description": "Wie lange eine professionelle Website realistisch dauert, welche Projektphasen Zeit brauchen und wodurch sich ein Launch beschleunigen oder verzögern kann.",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "mainEntity": { "@id": `${pageUrl}#faq` },
      "about": { "@id": "https://www.nigredo.ch/#organization" },
      "inLanguage": "de-CH",
      "datePublished": "2026-05-18",
      "dateModified": "2026-05-18",
      "isAccessibleForFree": true
    }
  ]
});
---

<Layout
  title="Wie lange dauert die Erstellung einer professionellen Website? | Nigredo"
  description="Wie lange eine professionelle Website realistisch dauert, welche Projektphasen Zeit brauchen und wodurch sich ein Launch beschleunigen oder verzögern kann."
  canonical={pageUrl}
  ogTitle="Wie lange dauert die Erstellung einer professionellen Website? | Nigredo"
  ogDescription="Realistische Zeitrahmen, typische Projektphasen und die wichtigsten Verzögerungsfaktoren bei professionellen Websites."
  twitterTitle="Wie lange dauert die Erstellung einer professionellen Website? | Nigredo"
  twitterDescription="Wie lange eine professionelle Website dauert und wovon der Zeitrahmen abhängt."
  schema={schema}
>
  <article class="section faq-article" aria-labelledby="article-title">
    <div class="hero-glow"></div>
    <div class="container faq-article__container">
      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Häufige Fragen', href: '/haeufige-fragen/' },
        { label: question }
      ]} />

      <header class="faq-article__header fade-up">
        <span class="badge badge--purple">Projektablauf</span>
        <h1 id="article-title">{question}</h1>
        <p>
          Die Dauer hängt nicht nur von der Seitenzahl ab. Entscheidend sind vor allem Klarheit im Ziel, verfügbare Inhalte, Abstimmungswege und technische Anforderungen. Eine schlanke Website kann deutlich schneller online gehen als ein Auftritt mit viel Textarbeit, mehreren Freigaben und zusätzlichen Funktionen.
        </p>
      </header>

      <nav class="faq-article__nav fade-up delay-100" aria-label="Inhaltsübersicht">
        <a href="#abhaengigkeit">Wovon die Dauer abhängt</a>
        <a href="#ablauf">Typischer Projektablauf</a>
        <a href="#verzoegerung">Was Projekte verzögert</a>
        <a href="#schneller">Wann es schneller geht</a>
        <a href="#einschaetzung">Wie Nigredo den Zeitrahmen einschätzt</a>
      </nav>

      <div class="faq-article__content fade-up delay-100">
        <p class="lead-answer">
          Als grobe Orientierung gilt: Je klarer Ziele, Inhalte und Zuständigkeiten sind, desto schneller lässt sich eine Website umsetzen. Nicht die Technik allein kostet Zeit, sondern oft die inhaltliche Abstimmung davor.
        </p>

        <h2 id="abhaengigkeit">Wovon die Dauer einer Website wirklich abhängt</h2>
        <p>
          Eine professionelle Website dauert unterschiedlich lang, weil nicht jedes Projekt dieselbe Ausgangslage hat. Gibt es bereits gute Texte, Bilder und eine klare Struktur, verkürzt das den Weg deutlich. Müssen Positionierung, Inhalt und Seitenaufbau zuerst gemeinsam entwickelt werden, braucht das entsprechend mehr Zeit.
        </p>
        <p>
          Auch technische Anforderungen spielen hinein. Ein einfacher Auftritt mit wenigen Seiten ist schneller umgesetzt als eine Website mit komplexen Formularen, speziellen Integrationen oder mehreren Entscheidungsschlaufen im Unternehmen.
        </p>

        <h2 id="ablauf">Wie ein typischer Projektablauf aussieht</h2>
        <p>
          Meist beginnt ein Website-Projekt mit der Klärung von Ziel, Umfang und Prioritäten. Danach folgen Struktur, Inhalt, Gestaltung und Umsetzung. Zum Schluss kommen Feinschliff, Prüfung auf verschiedenen Geräten und der Launch.
        </p>
        <p>
          Diese Phasen müssen nicht kompliziert sein, aber sie brauchen klare Entscheidungen. Wer früh weiss, was die Website leisten soll, spart oft mehr Zeit als jemand, der erst während der Umsetzung grundlegende Fragen klärt.
        </p>

        <h2 id="verzoegerung">Was Projekte am häufigsten verzögert</h2>
        <p>
          Die grössten Verzögerungen entstehen selten im Code. Häufig bremsen fehlende Inhalte, unklare Freigaben, lange Rückmeldeschlaufen oder nachträgliche Richtungswechsel. Wenn Texte, Bilder oder Zuständigkeiten erst spät geklärt werden, verschiebt sich der Zeitplan schnell.
        </p>
        <p>
          Auch zu viele gleichzeitige Wünsche können ein Projekt strecken. Deshalb ist es oft sinnvoller, zuerst die klare Kernversion online zu bringen und zusätzliche Ausbaustufen später sauber nachzuziehen.
        </p>

        <h2 id="schneller">Wann eine Website schneller online sein kann</h2>
        <p>
          Schneller geht es, wenn Ziel, Inhalte und Entscheidungswege früh stehen. Wer weiss, welche Seiten wirklich nötig sind, vorhandenes Material geordnet bereitstellt und Feedback gebündelt gibt, schafft eine deutlich bessere Taktung im Projekt.
        </p>
        <p>
          Das heisst nicht, dass Qualität geopfert werden muss. Im Gegenteil: Ein fokussierter Umfang macht die Umsetzung oft nicht nur schneller, sondern auch klarer und wirksamer.
        </p>

        <h2 id="einschaetzung">Wie Nigredo den Zeitrahmen realistisch einschätzt</h2>
        <p>
          Nigredo schaut zuerst auf Aufgabe, Umfang und Abhängigkeiten. Welche Inhalte sind vorhanden? Wer entscheidet mit? Gibt es feste Termine oder saisonale Gründe für einen Launch? Daraus entsteht ein realistischer Zeitrahmen statt eines schönen, aber unbrauchbaren Wunschdatums.
        </p>
        <p>
          Wer zuerst die Kosten einordnen will, findet die passende Antwort bei <a href="/haeufige-fragen/was-kostet-eine-professionelle-website/">der Frage zu den Website-Kosten</a>. Wer wissen will, wie viel später selbst gepflegt werden kann, findet die Einordnung bei <a href="/haeufige-fragen/kann-ich-meine-professionelle-website-selbst-bearbeiten-und-pflegen/">der Frage zur Website-Pflege</a>.
        </p>

        <section class="related-faqs" aria-labelledby="related-faqs-title">
          <h2 id="related-faqs-title">Verwandte Fragen</h2>
          <div class="related-faqs__grid">
            <a href="/haeufige-fragen/was-kostet-eine-professionelle-website/">
              <strong>Was kostet eine professionelle Website?</strong>
              <span>Welche Faktoren den Preis beeinflussen und wie sich Kosten seriös einschätzen lassen.</span>
            </a>
            <a href="/haeufige-fragen/kann-ich-meine-professionelle-website-selbst-bearbeiten-und-pflegen/">
              <strong>Kann ich meine professionelle Website später selbst bearbeiten und pflegen?</strong>
              <span>Wann ein CMS sinnvoll ist und wie viel Eigenständigkeit nach dem Launch bleibt.</span>
            </a>
          </div>
        </section>

        <div class="article-links">
          <a href="/haeufige-fragen/">Zurück zu den häufigen Fragen</a>
          <a href="/kontakt/">Projekt und Zeitrahmen besprechen</a>
        </div>
      </div>
    </div>
  </article>
</Layout>

<style>
  .faq-article {
    --faq-a: #ff7c20;
    --faq-b: #ff2e55;
    --faq-c: #cc20cc;
    animation: faqCycle 90s ease-in-out infinite;
    position: relative;
    padding-top: var(--hero-offset-top-breadcrumb);
    padding-bottom: clamp(84px, 8vw, 112px);
    overflow: hidden;
  }

  .faq-article__container {
    position: relative;
  }

  .faq-article :global(.breadcrumb) {
    margin-bottom: 28px;
  }

  .faq-article__header {
    max-width: 880px;
  }

  .faq-article__header .badge {
    min-height: 26px;
    margin-bottom: 0.9rem;
    padding: 4px 10px;
    font-size: 0.54rem;
    letter-spacing: 0.14em;
    color: rgba(255, 236, 224, 0.94);
    border-color: color-mix(in srgb, var(--faq-b) 34%, rgba(255, 255, 255, 0.22));
    background: transparent;
    box-shadow: none;
  }

  .faq-article .hero-glow {
    background:
      radial-gradient(circle at 18% 40%, color-mix(in srgb, var(--faq-a) 16%, transparent) 0%, transparent 36%),
      radial-gradient(circle at 56% 34%, color-mix(in srgb, var(--faq-b) 14%, transparent) 0%, transparent 32%),
      radial-gradient(circle at 84% 44%, color-mix(in srgb, var(--faq-c) 13%, transparent) 0%, transparent 28%);
  }

  .faq-article__header h1 {
    max-width: 920px;
    margin: 0 0 clamp(24px, 3vw, 32px);
    color: #f5f5f7;
    font-size: clamp(2.95rem, 5.2vw, 4.55rem);
    line-height: 0.99;
    letter-spacing: 0;
  }

  .faq-article__header p {
    max-width: 720px;
    margin: 0;
    color: rgba(255, 255, 255, 0.68);
    font-size: var(--lead-size);
    line-height: 1.65;
  }

  .faq-article__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    max-width: 760px;
    margin-top: 30px;
  }

  .faq-article__nav a,
  .related-faqs__grid a,
  .article-links a {
    text-decoration: none;
  }

  .faq-article__nav a {
    min-height: 40px;
    display: inline-flex;
    align-items: center;
    padding: 0 14px;
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.92rem;
    border: 1px solid rgba(255, 255, 255, 0.11);
    background: rgba(255, 255, 255, 0.03);
    transition: border-color 0.2s ease, transform 0.2s ease, color 0.2s ease;
  }

  .faq-article__nav a:hover {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.24);
    transform: translateY(-2px);
  }

  .faq-article__content {
    max-width: 760px;
    margin-top: clamp(46px, 6vw, 72px);
  }

  .faq-article__content p {
    margin: 0 0 1.25rem;
    color: rgba(255, 255, 255, 0.68);
    font-size: 1.04rem;
    line-height: 1.78;
  }

  .faq-article__content .lead-answer {
    color: rgba(255, 255, 255, 0.82);
    font-size: clamp(1.12rem, 2vw, 1.28rem);
    line-height: 1.72;
    padding-bottom: clamp(22px, 4vw, 34px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .faq-article__content h2 {
    margin: clamp(42px, 6vw, 62px) 0 1rem;
    color: rgba(255, 255, 255, 0.95);
    font-size: clamp(1.46rem, 2.8vw, 2rem);
    line-height: 1.16;
    letter-spacing: 0;
  }

  .faq-article__content a {
    color: rgba(255, 255, 255, 0.9);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  .related-faqs {
    margin-top: clamp(42px, 6vw, 62px);
    padding-top: 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .related-faqs__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .related-faqs__grid a {
    display: grid;
    gap: 10px;
    padding: 20px;
    border-radius: 22px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .related-faqs__grid a:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .related-faqs__grid strong {
    color: rgba(255, 255, 255, 0.95);
    font-size: 1rem;
    line-height: 1.4;
  }

  .related-faqs__grid span {
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.96rem;
    line-height: 1.6;
  }

  .article-links {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: clamp(42px, 6vw, 62px);
    padding-top: 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .article-links a {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 18px;
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.13);
    background: rgba(255, 255, 255, 0.035);
    transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .article-links a:hover {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.28);
    transform: translateY(-2px);
  }

  @media (max-width: 860px) {
    .faq-article {
      padding-top: var(--hero-offset-top-breadcrumb-mobile);
      padding-bottom: 72px;
    }

    .faq-article__header h1 {
      font-size: clamp(2.5rem, 8vw, 3.5rem);
      line-height: var(--hero-title-line-height-mobile);
    }

    .related-faqs__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .faq-article__header h1 {
      font-size: clamp(2.2rem, 10.8vw, 2.95rem);
    }

    .faq-article__header p {
      font-size: var(--lead-size-mobile);
      line-height: 1.6;
    }

    .faq-article__nav {
      display: grid;
      grid-template-columns: 1fr;
    }

    .faq-article__nav a {
      justify-content: center;
      text-align: center;
    }

    .faq-article__content {
      margin-top: 48px;
    }

    .faq-article__content p {
      font-size: 1rem;
      line-height: 1.72;
    }

    .article-links {
      display: grid;
      grid-template-columns: 1fr;
    }
  }
</style>
