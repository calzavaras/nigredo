---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const pageUrl = 'https://www.nigredo.ch/haeufige-fragen/wie-lange-dauert-die-erstellung-einer-professionellen-website/';
const question = 'Wie lange dauert die Erstellung einer professionellen Website?';
const answer = 'Eine kompakte Website kann in wenigen Wochen online sein. Umfang, vorhandene Inhalte, Entscheidungswege und technische Anforderungen bestimmen den Zeitrahmen. Nigredo plant diese Faktoren vor dem Start und nennt einen realistischen Termin.';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Häufige Fragen", "item": "https://www.nigredo.ch/haeufige-fragen/" },
        { "@type": "ListItem", "position": 3, "name": question, "item": pageUrl }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": answer
          }
        }
      ]
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": "Wie lange dauert eine Website-Erstellung? | Nigredo",
      "description": "Wie lange eine professionelle Website dauert, welche Projektphasen Zeit brauchen und wie gute Inhalte und kurze Entscheidungswege den Start beschleunigen.",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "mainEntity": { "@id": `${pageUrl}#faq` },
      "about": { "@id": "https://www.nigredo.ch/#organization" },
      "inLanguage": "de-CH",
      "datePublished": "2026-05-18",
      "dateModified": "2026-07-14",
      "isAccessibleForFree": true
    }
  ]
});
---

<Layout
  title="Wie lange dauert eine Website-Erstellung? | Nigredo"
  description="Wie lange eine professionelle Website dauert, welche Projektphasen Zeit brauchen und wie gute Inhalte und kurze Entscheidungswege den Start beschleunigen."
  canonical={pageUrl}
  ogTitle="Wie lange dauert eine Website-Erstellung? | Nigredo"
  ogDescription="Realistische Zeitrahmen, typische Projektphasen und die wichtigsten Verzögerungsfaktoren bei professionellen Websites."
  twitterTitle="Wie lange dauert eine Website-Erstellung? | Nigredo"
  twitterDescription="Wie lange eine professionelle Website dauert und wovon der Zeitrahmen abhängt."
  schema={schema}
>
  <article class="section faq-article" aria-labelledby="article-title">
    <div class="hero-glow"></div>
    <div class="container faq-article__container">
      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Häufige Fragen', href: '/haeufige-fragen/' },
        { label: question }
      ]} />

      <header class="faq-article__header fade-up">
        <h1 id="article-title">{question}</h1>
        <p>{answer}</p>
      </header>

      <nav class="faq-article__nav fade-up delay-100" aria-label="Inhaltsübersicht">
        <a href="#abhaengigkeit">Was den Zeitrahmen bestimmt</a>
        <a href="#ablauf">Wie das Projekt abläuft</a>
        <a href="#verzoegerung">Was Projekte verzögert</a>
        <a href="#schneller">Was den Ablauf beschleunigt</a>
        <a href="#einschaetzung">Wie Nigredo den Termin plant</a>
      </nav>

      <div class="faq-article__content fade-up delay-100">
        <h2 id="abhaengigkeit">Was den Zeitrahmen bestimmt</h2>
        <p>
          Gute Texte, passendes Bildmaterial und ein geklärtes Ziel verkürzen den Weg deutlich. Wenn Positionierung, Inhalte und Struktur erst entwickelt werden, braucht das mehr Zeit, schafft aber auch eine tragfähigere Grundlage.
        </p>

        <h2 id="ablauf">Wie das Projekt abläuft</h2>
        <p>
          Nach der Klärung von Ziel und Umfang folgen Struktur, Inhalt, Gestaltung und technische Umsetzung. Danach wird die Website auf verschiedenen Geräten geprüft, verfeinert und für den Start vorbereitet.
        </p>

        <h2 id="verzoegerung">Was Projekte am häufigsten verzögert</h2>
        <p>
          Verzögerungen entstehen meist durch fehlende Inhalte, verstreutes Feedback oder offene Zuständigkeiten. Auch grundlegende Richtungswechsel während der Umsetzung verschieben den Termin, weil bereits abgestimmte Arbeit neu aufgebaut werden muss.
        </p>

        <h2 id="schneller">Was den Ablauf beschleunigt</h2>
        <p>
          Ein definierter Umfang, gebündelte Rückmeldungen und eine Person mit Entscheidungskompetenz schaffen Tempo. Zusätzliche Wünsche können als spätere Ausbaustufe geplant werden, damit die starke Kernversion pünktlich online geht.
        </p>

        <h2 id="einschaetzung">Wie Nigredo den Termin plant</h2>
        <p>
          Nigredo macht Abhängigkeiten früh sichtbar und stimmt die einzelnen Schritte verbindlich ab. So entsteht ein Zeitplan, der zur tatsächlichen Ausgangslage passt und nicht nur auf dem Papier gut aussieht.
        </p>

        <section class="related-faqs" aria-labelledby="related-faqs-title">
          <h2 id="related-faqs-title">Verwandte Fragen</h2>
          <div class="related-faqs__grid">
            <a href="/haeufige-fragen/was-kostet-eine-professionelle-website/">
              <strong>Was kostet eine professionelle Website?</strong>
              <span>Welche Faktoren den Preis beeinflussen und wie sich Kosten seriös einschätzen lassen.</span>
            </a>
            <a href="/haeufige-fragen/was-kostet-der-laufende-betrieb-einer-website/">
              <strong>Welche laufenden Kosten hat eine Website?</strong>
              <span>Welche laufenden Kosten nach dem Launch entstehen, von Hosting bis Wartung.</span>
            </a>
            <a href="/haeufige-fragen/brauche-ich-eine-individuelle-website-oder-reicht-ein-baukasten/">
              <strong>Brauche ich eine individuelle Website oder reicht ein Baukasten?</strong>
              <span>Wann eine Vorlage genügt und wann eine massgeschneiderte Lösung sinnvoller ist.</span>
            </a>
            <a href="/haeufige-fragen/wird-meine-website-bei-google-gefunden/">
              <strong>Wird meine Website bei Google gefunden?</strong>
              <span>Warum eine Website nicht automatisch sichtbar ist und wovon die Auffindbarkeit abhängt.</span>
            </a>
          </div>
        </section>

        <div class="article-links">
          <a href="/haeufige-fragen/">Zurück zu den häufigen Fragen</a>
          <a href="/kontakt/">Zeitrahmen für mein Projekt klären</a>
        </div>
      </div>
    </div>
  </article>
</Layout>

<style>
  .faq-article {
    --faq-a: var(--brand-sun);
    --faq-b: var(--brand-coral);
    --faq-c: var(--brand-pink);
  }
</style>
