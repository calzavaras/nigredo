---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const pageUrl = 'https://www.nigredo.ch/haeufige-fragen/was-muss-meine-website-beim-datenschutz-beachten/';
const question = 'Was muss meine Website beim Datenschutz beachten?';
const answer = 'Eine Website sollte nur notwendige Personendaten bearbeiten und transparent erklären, wofür sie verwendet werden. Dazu gehören eine passende Datenschutzerklärung sowie ein bewusster Umgang mit Cookies, Analyse und externen Diensten. Welche Regeln gelten, hängt vom Angebot, der Zielgruppe und den eingesetzten Technologien ab.';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Häufige Fragen", "item": "https://www.nigredo.ch/haeufige-fragen/" },
        { "@type": "ListItem", "position": 3, "name": question, "item": pageUrl }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": answer
          }
        }
      ]
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": "Was muss meine Website beim Datenschutz beachten? | Nigredo",
      "description": "Was Schweizer Websites bei Datenschutzerklärung, Cookies, Analyse und externen Diensten beachten sollten und wann die DSGVO zusätzlich relevant wird.",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "mainEntity": { "@id": `${pageUrl}#faq` },
      "about": { "@id": "https://www.nigredo.ch/#organization" },
      "inLanguage": "de-CH",
      "datePublished": "2026-06-17",
      "dateModified": "2026-07-14",
      "isAccessibleForFree": true
    }
  ]
});
---

<Layout
  title="Was muss meine Website beim Datenschutz beachten? | Nigredo"
  description="Was Schweizer Websites bei Datenschutzerklärung, Cookies, Analyse und externen Diensten beachten sollten und wann die DSGVO zusätzlich relevant wird."
  canonical={pageUrl}
  ogTitle="Was muss meine Website beim Datenschutz beachten? | Nigredo"
  ogDescription="Datenschutzerklärung, Schweizer DSG, Cookies und schonende Analyse: Was beim Datenschutz einer Website wirklich zählt und wie man es schlank löst."
  twitterTitle="Was muss meine Website beim Datenschutz beachten? | Nigredo"
  twitterDescription="Datenschutz für Websites in der Schweiz, verständlich erklärt: DSG, Cookies, Tracking und datensparsame Analyse."
  schema={schema}
>
  <article class="section faq-article" aria-labelledby="article-title">
    <div class="hero-glow"></div>
    <div class="container faq-article__container">
      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Häufige Fragen', href: '/haeufige-fragen/' },
        { label: question }
      ]} />

      <header class="faq-article__header fade-up">
        <h1 id="article-title">{question}</h1>
        <p>{answer}</p>
      </header>

      <nav class="faq-article__nav fade-up delay-100" aria-label="Inhaltsübersicht">
        <a href="#grundlagen">Was Datenschutz auf einer Website bedeutet</a>
        <a href="#datenschutzerklaerung">Was in die Datenschutzerklärung gehört</a>
        <a href="#cookies">Wann die DSGVO zusätzlich relevant wird</a>
        <a href="#analyse">Cookies, Analyse und externe Dienste</a>
        <a href="#nigredo">Wie Nigredo Datenschutz berücksichtigt</a>
      </nav>

      <div class="faq-article__content fade-up delay-100">
        <h2 id="grundlagen">Was Datenschutz auf einer Website bedeutet</h2>
        <p>
          Personendaten entstehen nicht nur in Kontaktformularen. Auch IP-Adressen, Serverprotokolle und Daten aus Analysewerkzeugen können betroffen sein. Deshalb sollten alle Datenflüsse bekannt, begründet und angemessen geschützt sein.
        </p>

        <h2 id="datenschutzerklaerung">Was in die Datenschutzerklärung gehört</h2>
        <p>
          Die Erklärung muss zur tatsächlichen Website passen. Sie nennt die verantwortliche Stelle, bearbeitete Daten, Zwecke, mögliche Empfänger, Übermittlungen ins Ausland und die Rechte betroffener Personen. Allgemeine Vorlagen ohne Bezug zur eingesetzten Technik reichen dafür nicht.
        </p>

        <h2 id="cookies">Wann die DSGVO zusätzlich relevant wird</h2>
        <p>
          Für Schweizer Anbieter bildet das Schweizer Datenschutzgesetz die Grundlage. Die DSGVO kann zusätzlich gelten, wenn sich ein Angebot gezielt an Personen in der EU richtet oder deren Verhalten beobachtet wird. Ein gelegentlicher Besuch aus der EU allein ist deshalb keine präzise Abgrenzung.
        </p>

        <h2 id="analyse">Cookies, Analyse und externe Dienste</h2>
        <p>
          Ob eine Einwilligung oder ein Banner nötig ist, hängt von Zweck und Funktionsweise der eingesetzten Technologie ab. Besonders sorgfältig zu prüfen sind Profiling, personalisierte Werbung und Dienste, die Daten an Dritte oder ins Ausland übertragen. Datensparsame Lösungen reduzieren rechtliche und technische Komplexität.
        </p>

        <h2 id="nigredo">Wie Nigredo Datenschutz berücksichtigt</h2>
        <p>
          Nigredo setzt externe Dienste zurückhaltend ein und gestaltet Datenflüsse so sparsam wie möglich. Die technische Umsetzung ersetzt keine Rechtsberatung, schafft aber eine nachvollziehbare Grundlage für eine passende rechtliche Prüfung.
        </p>

        <section class="related-faqs" aria-labelledby="related-faqs-title">
          <h2 id="related-faqs-title">Verwandte Fragen</h2>
          <div class="related-faqs__grid">
            <a href="/haeufige-fragen/wird-meine-website-bei-google-gefunden/">
              <strong>Wird meine Website bei Google gefunden?</strong>
              <span>Warum eine Website nicht automatisch sichtbar ist und wovon die Auffindbarkeit abhängt.</span>
            </a>
            <a href="/haeufige-fragen/was-kostet-der-laufende-betrieb-einer-website/">
              <strong>Welche laufenden Kosten hat eine Website?</strong>
              <span>Welche laufenden Kosten nach dem Launch entstehen, von Hosting bis Wartung.</span>
            </a>
            <a href="/haeufige-fragen/brauche-ich-eine-individuelle-website-oder-reicht-ein-baukasten/">
              <strong>Brauche ich eine individuelle Website oder reicht ein Baukasten?</strong>
              <span>Wann eine Vorlage genügt und wann eine massgeschneiderte Lösung sinnvoller ist.</span>
            </a>
            <a href="/haeufige-fragen/kann-ich-meine-professionelle-website-selbst-bearbeiten-und-pflegen/">
              <strong>Kann ich meine Website später selbst bearbeiten?</strong>
              <span>Wann ein CMS sinnvoll ist und wie viel Eigenständigkeit realistisch bleibt.</span>
            </a>
          </div>
        </section>

        <div class="article-links">
          <a href="/haeufige-fragen/">Zurück zu den häufigen Fragen</a>
          <a href="/kontakt/">Datenschutz meiner Website technisch klären</a>
        </div>
      </div>
    </div>
  </article>
</Layout>

<style>
  .faq-article {
    --faq-a: var(--brand-violet);
    --faq-b: var(--brand-blue);
    --faq-c: var(--brand-cyan);
  }
</style>
