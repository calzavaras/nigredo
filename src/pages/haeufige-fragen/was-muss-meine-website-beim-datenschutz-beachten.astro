---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const pageUrl = 'https://www.nigredo.ch/haeufige-fragen/was-muss-meine-website-beim-datenschutz-beachten/';
const question = 'Was muss meine Website beim Datenschutz beachten?';
const answer = 'Eine Website in der Schweiz muss transparent machen, welche Daten sie bearbeitet. Dazu gehören in der Regel eine verständliche Datenschutzerklärung, klare Angaben zum Anbieter und ein bewusster Umgang mit Cookies, Tracking und externen Diensten. Massgeblich ist das Schweizer Datenschutzgesetz, bei Besuchern aus der EU zusätzlich die DSGVO.';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Häufige Fragen", "item": "https://www.nigredo.ch/haeufige-fragen/" },
        { "@type": "ListItem", "position": 3, "name": question, "item": pageUrl }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": answer
          }
        },
        {
          "@type": "Question",
          "name": "Braucht jede Website eine Datenschutzerklärung?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sobald eine Website Personendaten bearbeitet, also etwa über ein Kontaktformular, Server-Logs oder Analyse-Werkzeuge, gehört eine verständliche Datenschutzerklärung dazu. In der Praxis trifft das auf nahezu jede Website zu, weshalb eine Datenschutzerklärung Standard sein sollte."
          }
        },
        {
          "@type": "Question",
          "name": "Brauche ich für meine Website ein Cookie-Banner?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ein Cookie-Banner ist kein Selbstzweck. Nötig wird eine Einwilligung vor allem dann, wenn nicht zwingend erforderliche Cookies oder Tracking-Dienste eingesetzt werden. Wer auf datensparsame Technik und schonende Analyse setzt, kann den Bedarf für Banner oft deutlich reduzieren."
          }
        }
      ]
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": "Was muss meine Website beim Datenschutz beachten? | Nigredo",
      "description": "Was beim Datenschutz einer Website in der Schweiz wichtig ist: Datenschutzerklärung, Schweizer DSG, Cookies und datensparsame Analyse, klar erklärt für KMU.",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "mainEntity": { "@id": `${pageUrl}#faq` },
      "about": { "@id": "https://www.nigredo.ch/#organization" },
      "inLanguage": "de-CH",
      "datePublished": "2026-06-17",
      "dateModified": "2026-06-17",
      "isAccessibleForFree": true
    }
  ]
});
---

<Layout
  title="Was muss meine Website beim Datenschutz beachten? | Nigredo"
  description="Was beim Datenschutz einer Website in der Schweiz wichtig ist: Datenschutzerklärung, Schweizer DSG, Cookies und datensparsame Analyse, klar erklärt für KMU."
  canonical={pageUrl}
  ogTitle="Was muss meine Website beim Datenschutz beachten? | Nigredo"
  ogDescription="Datenschutzerklärung, Schweizer DSG, Cookies und schonende Analyse: Was beim Datenschutz einer Website wirklich zählt und wie man es schlank löst."
  twitterTitle="Was muss meine Website beim Datenschutz beachten? | Nigredo"
  twitterDescription="Datenschutz für Websites in der Schweiz, verständlich erklärt: DSG, Cookies, Tracking und datensparsame Analyse."
  schema={schema}
>
  <article class="section faq-article" aria-labelledby="article-title">
    <div class="hero-glow"></div>
    <div class="container faq-article__container">
      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Häufige Fragen', href: '/haeufige-fragen/' },
        { label: question }
      ]} />

      <header class="faq-article__header fade-up">
        <span class="badge badge--pink">Datenschutz & Recht</span>
        <h1 id="article-title">{question}</h1>
        <p>
          Datenschutz wirkt schnell kompliziert, lässt sich aber gut handhaben, wenn man ihn von Anfang an mitdenkt. Im Kern geht es darum, transparent zu sein, sparsam mit Daten umzugehen und Besuchern verständlich zu erklären, was mit ihren Daten passiert.
        </p>
      </header>

      <nav class="faq-article__nav fade-up delay-100" aria-label="Inhaltsübersicht">
        <a href="#grundlagen">Worum es beim Datenschutz geht</a>
        <a href="#datenschutzerklaerung">Datenschutzerklärung und Anbieterangaben</a>
        <a href="#cookies">Cookies, Tracking und externe Dienste</a>
        <a href="#analyse">Datensparsame Website-Analyse</a>
        <a href="#nigredo">Wie Nigredo Datenschutz mitdenkt</a>
      </nav>

      <div class="faq-article__content fade-up delay-100">
        <p class="lead-answer">
          Als Orientierung gilt: Eine Website muss nachvollziehbar machen, welche Daten sie warum bearbeitet. In der Schweiz ist dafür das revidierte Datenschutzgesetz massgeblich, bei Besuchern aus der EU zusätzlich die DSGVO. Wer datensparsam baut, hat es deutlich einfacher, weil weniger Datenflüsse auch weniger erklärt und abgesichert werden müssen.
        </p>

        <h2 id="grundlagen">Worum es beim Datenschutz wirklich geht</h2>
        <p>
          Datenschutz bedeutet, sorgfältig mit den Personendaten der Besucher umzugehen. Personendaten sind nicht nur Name und E-Mail aus einem Formular, sondern zum Beispiel auch IP-Adressen in Server-Logs oder Informationen, die Analyse- und Tracking-Werkzeuge sammeln. Sobald solche Daten bearbeitet werden, greifen die Datenschutzregeln.
        </p>
        <p>
          Massgeblich ist in der Schweiz das Datenschutzgesetz. Richtet sich eine Website auch an Personen in der EU, kommt die DSGVO dazu. Beide verlangen vor allem Transparenz, einen klaren Zweck und Sparsamkeit. Wer von vornherein nur das erhebt, was wirklich nötig ist, erfüllt den grössten Teil der Anforderungen fast automatisch.
        </p>

        <h2 id="datenschutzerklaerung">Datenschutzerklärung und Anbieterangaben</h2>
        <p>
          Eine verständliche Datenschutzerklärung gehört auf praktisch jede Website. Sie erklärt, welche Daten zu welchem Zweck bearbeitet werden, wer dafür verantwortlich ist und welche Rechte Besucher haben. Wichtig ist, dass sie zur tatsächlichen Website passt und nicht ungeprüft aus einer Vorlage übernommen wird, die ganz andere Dienste beschreibt.
        </p>
        <p>
          Dazu kommen klare Angaben zum Anbieter, damit erkennbar ist, wer hinter der Website steht. Diese Informationen schaffen nicht nur Rechtssicherheit, sondern auch Vertrauen. Besucher sehen auf einen Blick, mit wem sie es zu tun haben und wie sie Kontakt aufnehmen können.
        </p>

        <h2 id="cookies">Cookies, Tracking und externe Dienste</h2>
        <p>
          Heikel wird es meist nicht bei der Website selbst, sondern bei dem, was sie zusätzlich einbindet: externe Schriftarten, Karten, Videos, Werbe- oder Analyse-Dienste. Solche Einbindungen können Daten an Dritte übertragen, oft schon beim blossen Aufruf der Seite. Für nicht zwingend nötige Cookies oder Tracking-Dienste braucht es in der Regel eine bewusste Einwilligung.
        </p>
        <p>
          Genau hier lohnt sich Zurückhaltung. Jeder externe Dienst, der eingespart oder datenschonend eingebunden wird, reduziert den Aufwand für Einwilligungen und Banner. Eine Website, die mit wenigen, bewusst gewählten externen Diensten auskommt, ist nicht nur einfacher abzusichern, sondern lädt meist auch schneller.
        </p>

        <h2 id="analyse">Datensparsame Website-Analyse</h2>
        <p>
          Auch ohne umfangreiches Tracking lässt sich verstehen, wie eine Website genutzt wird. Datensparsame Analyse-Werkzeuge kommen ohne aufdringliches Profiling aus und verzichten darauf, Besucher über Seiten hinweg zu verfolgen. So bleiben aussagekräftige Erkenntnisse möglich, ohne dass mehr Daten gesammelt werden als nötig.
        </p>
        <p>
          Dieser Ansatz ist nicht nur datenschutzfreundlich, sondern oft auch praktischer. Weniger Datenflüsse bedeuten weniger Einwilligungen, schlankere Technik und einen klareren Überblick. Wer Sichtbarkeit und Wirkung der Website messen will, muss dafür nicht zwingend die Privatsphäre der Besucher belasten.
        </p>

        <h2 id="nigredo">Wie Nigredo Datenschutz mitdenkt</h2>
        <p>
          Nigredo plant Datenschutz nicht als nachträgliche Pflichtübung, sondern als Teil einer sauberen Umsetzung. Websites werden so gebaut, dass möglichst wenige Daten anfallen, externe Dienste bewusst und sparsam eingesetzt werden und die Analyse datenschonend bleibt. Das reduziert Aufwand und schafft gleichzeitig Vertrauen.
        </p>
        <p>
          Wichtig ist dabei die Ehrlichkeit: Nigredo ersetzt keine Rechtsberatung, sorgt aber für eine technisch saubere und datensparsame Grundlage, auf der sich Datenschutz gut umsetzen lässt. Wie eine datenschonende Analyse mit der Sichtbarkeit zusammenhängt, zeigt <a href="/haeufige-fragen/wird-meine-website-bei-google-gefunden/">die Frage zur Auffindbarkeit bei Google</a>.
        </p>

        <section class="related-faqs" aria-labelledby="related-faqs-title">
          <h2 id="related-faqs-title">Verwandte Fragen</h2>
          <div class="related-faqs__grid">
            <a href="/haeufige-fragen/wird-meine-website-bei-google-gefunden/">
              <strong>Wird meine Website bei Google gefunden?</strong>
              <span>Warum eine Website nicht automatisch sichtbar ist und wovon die Auffindbarkeit abhängt.</span>
            </a>
            <a href="/haeufige-fragen/was-kostet-der-laufende-betrieb-einer-website/">
              <strong>Was kostet der laufende Betrieb einer Website?</strong>
              <span>Welche laufenden Kosten nach dem Launch entstehen, von Hosting bis Wartung.</span>
            </a>
            <a href="/haeufige-fragen/brauche-ich-eine-individuelle-website-oder-reicht-ein-baukasten/">
              <strong>Brauche ich eine individuelle Website oder reicht ein Baukasten?</strong>
              <span>Wann eine Vorlage genügt und wann eine massgeschneiderte Lösung sinnvoller ist.</span>
            </a>
            <a href="/haeufige-fragen/kann-ich-meine-professionelle-website-selbst-bearbeiten-und-pflegen/">
              <strong>Kann ich meine professionelle Website später selbst bearbeiten und pflegen?</strong>
              <span>Wann ein CMS sinnvoll ist und wie viel Eigenständigkeit realistisch bleibt.</span>
            </a>
          </div>
        </section>

        <div class="article-links">
          <a href="/haeufige-fragen/">Zurück zu den häufigen Fragen</a>
          <a href="/kontakt/">Datenschutz für meine Website besprechen</a>
        </div>
      </div>
    </div>
  </article>
</Layout>

<style>
  .faq-article {
    --faq-a: #6c5cff;
    --faq-b: #3a86ff;
    --faq-c: #00c2a8;
    animation: faqCycle 90s ease-in-out infinite;
    position: relative;
    padding-top: var(--hero-offset-top-breadcrumb);
    padding-bottom: clamp(84px, 8vw, 112px);
    overflow: hidden;
  }

  .faq-article__container {
    position: relative;
  }

  .faq-article :global(.breadcrumb) {
    margin-bottom: 28px;
  }

  .faq-article__header {
    max-width: 880px;
  }

  .faq-article__header .badge {
    min-height: 26px;
    margin-bottom: 0.9rem;
    padding: 4px 10px;
    font-size: 0.54rem;
    letter-spacing: 0.14em;
    color: rgba(226, 232, 255, 0.94);
    border-color: color-mix(in srgb, var(--faq-b) 34%, rgba(255, 255, 255, 0.22));
    background: transparent;
    box-shadow: none;
  }

  .faq-article .hero-glow {
    background:
      radial-gradient(circle at 18% 40%, color-mix(in srgb, var(--faq-a) 16%, transparent) 0%, transparent 36%),
      radial-gradient(circle at 56% 34%, color-mix(in srgb, var(--faq-b) 14%, transparent) 0%, transparent 32%),
      radial-gradient(circle at 84% 44%, color-mix(in srgb, var(--faq-c) 13%, transparent) 0%, transparent 28%);
  }

  .faq-article__header h1 {
    max-width: 920px;
    margin: 0 0 clamp(24px, 3vw, 32px);
    color: #f5f5f7;
    font-size: clamp(2.95rem, 5.2vw, 4.55rem);
    line-height: 0.99;
    letter-spacing: 0;
  }

  .faq-article__header p {
    max-width: 720px;
    margin: 0;
    color: rgba(255, 255, 255, 0.68);
    font-size: var(--lead-size);
    line-height: 1.65;
  }

  .faq-article__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    max-width: 760px;
    margin-top: 30px;
  }

  .faq-article__nav a,
  .related-faqs__grid a,
  .article-links a {
    text-decoration: none;
  }

  .faq-article__nav a {
    min-height: 40px;
    display: inline-flex;
    align-items: center;
    padding: 0 14px;
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.92rem;
    border: 1px solid rgba(255, 255, 255, 0.11);
    background: rgba(255, 255, 255, 0.03);
    transition: border-color 0.2s ease, transform 0.2s ease, color 0.2s ease;
  }

  .faq-article__nav a:hover {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.24);
    transform: translateY(-2px);
  }

  .faq-article__content {
    max-width: 760px;
    margin-top: clamp(46px, 6vw, 72px);
  }

  .faq-article__content p {
    margin: 0 0 1.25rem;
    color: rgba(255, 255, 255, 0.68);
    font-size: 1.04rem;
    line-height: 1.78;
  }

  .faq-article__content .lead-answer {
    color: rgba(255, 255, 255, 0.82);
    font-size: clamp(1.12rem, 2vw, 1.28rem);
    line-height: 1.72;
    padding-bottom: clamp(22px, 4vw, 34px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .faq-article__content h2 {
    margin: clamp(42px, 6vw, 62px) 0 1rem;
    color: rgba(255, 255, 255, 0.95);
    font-size: clamp(1.46rem, 2.8vw, 2rem);
    line-height: 1.16;
    letter-spacing: 0;
  }

  .faq-article__content a {
    color: rgba(255, 255, 255, 0.9);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  .related-faqs {
    margin-top: clamp(42px, 6vw, 62px);
    padding-top: 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .related-faqs__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .related-faqs__grid a {
    display: grid;
    gap: 10px;
    padding: 20px;
    border-radius: 22px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .related-faqs__grid a:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .related-faqs__grid strong {
    color: rgba(255, 255, 255, 0.95);
    font-size: 1rem;
    line-height: 1.4;
  }

  .related-faqs__grid span {
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.96rem;
    line-height: 1.6;
  }

  .article-links {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: clamp(42px, 6vw, 62px);
    padding-top: 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .article-links a {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 18px;
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.13);
    background: rgba(255, 255, 255, 0.035);
    transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .article-links a:hover {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.28);
    transform: translateY(-2px);
  }

  @media (max-width: 860px) {
    .faq-article {
      padding-top: var(--hero-offset-top-breadcrumb-mobile);
      padding-bottom: 72px;
    }

    .faq-article__header h1 {
      font-size: clamp(2.5rem, 8vw, 3.5rem);
      line-height: var(--hero-title-line-height-mobile);
    }

    .related-faqs__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .faq-article__header h1 {
      font-size: clamp(2.2rem, 10.8vw, 2.95rem);
    }

    .faq-article__header p {
      font-size: var(--lead-size-mobile);
      line-height: 1.6;
    }

    .faq-article__nav {
      display: grid;
      grid-template-columns: 1fr;
    }

    .faq-article__nav a {
      justify-content: center;
      text-align: center;
    }

    .faq-article__content {
      margin-top: 48px;
    }

    .faq-article__content p {
      font-size: 1rem;
      line-height: 1.72;
    }

    .article-links {
      display: grid;
      grid-template-columns: 1fr;
    }
  }
</style>
