---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const pageUrl = 'https://www.nigredo.ch/haeufige-fragen/brauche-ich-eine-individuelle-website-oder-reicht-ein-baukasten/';
const question = 'Brauche ich eine individuelle Website oder reicht ein Baukasten?';
const answer = 'Ein Baukasten reicht für eine einfache Präsenz mit wenigen Anforderungen. Eine individuelle Website ist sinnvoll, wenn Inhalt, Gestaltung, Funktionen und spätere Erweiterungen genau zur Aufgabe passen sollen. Entscheidend ist nicht das Werkzeug, sondern was der Auftritt leisten muss.';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Häufige Fragen", "item": "https://www.nigredo.ch/haeufige-fragen/" },
        { "@type": "ListItem", "position": 3, "name": question, "item": pageUrl }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": answer
          }
        }
      ]
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": "Individuelle Website oder Baukasten? | Nigredo",
      "description": "Wann ein Website-Baukasten genügt, wann eine individuelle Lösung sinnvoll ist und welche Entscheidung zu Aufgabe, Marke und Wachstum passt.",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "mainEntity": { "@id": `${pageUrl}#faq` },
      "about": { "@id": "https://www.nigredo.ch/#organization" },
      "inLanguage": "de-CH",
      "datePublished": "2026-05-27",
      "dateModified": "2026-07-14",
      "isAccessibleForFree": true
    }
  ]
});
---

<Layout
  title="Individuelle Website oder Baukasten? | Nigredo"
  description="Wann ein Website-Baukasten genügt, wann eine individuelle Lösung sinnvoll ist und welche Entscheidung zu Aufgabe, Marke und Wachstum passt."
  canonical={pageUrl}
  ogTitle="Individuelle Website oder Baukasten? | Nigredo"
  ogDescription="Eine klare Einordnung, wann ein Baukasten genügt und wann eine individuell entwickelte Website die bessere Grundlage ist."
  twitterTitle="Individuelle Website oder Baukasten? | Nigredo"
  twitterDescription="Wann ein Baukasten reicht und wann eine individuelle Website sinnvoll ist."
  schema={schema}
>
  <article class="section faq-article" aria-labelledby="article-title">
    <div class="hero-glow"></div>
    <div class="container faq-article__container">
      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Häufige Fragen', href: '/haeufige-fragen/' },
        { label: question }
      ]} />

      <header class="faq-article__header fade-up">
        <h1 id="article-title">{question}</h1>
        <p>{answer}</p>
      </header>

      <nav class="faq-article__nav fade-up delay-100" aria-label="Inhaltsübersicht">
        <a href="#baukasten">Wann ein Baukasten genügt</a>
        <a href="#grenzen">Wo die Grenzen liegen</a>
        <a href="#individuell">Was eine individuelle Lösung verändert</a>
        <a href="#inhalt">Warum der Inhalt entscheidet</a>
        <a href="#einschaetzung">Wie Nigredo entscheidet</a>
      </nav>

      <div class="faq-article__content fade-up delay-100">
        <h2 id="baukasten">Wann ein Baukasten genügt</h2>
        <p>
          Für eine kleine Informationsseite, eine Übergangslösung oder ein Vorhaben mit knappem Umfang kann ein Baukasten zweckmässig sein. Voraussetzung ist, dass die vorhandenen Vorlagen zur Aufgabe passen und keine besonderen Funktionen nötig sind.
        </p>

        <h2 id="grenzen">Wo die Grenzen liegen</h2>
        <p>
          Standardvorlagen werden unflexibel, wenn Inhalte eine eigene Dramaturgie brauchen, Gestaltung eindeutig zur Marke passen soll oder technische Anforderungen wachsen. Auch Ladezeit, Datenschutz und Erweiterbarkeit hängen stark vom gewählten System ab.
        </p>

        <h2 id="individuell">Was eine individuelle Lösung verändert</h2>
        <p>
          Eine individuelle Website beginnt bei Zielgruppe, Angebot und gewünschter Handlung. Struktur, Texte, Gestaltung und Technik werden darauf abgestimmt. Das schafft einen Auftritt, der eigenständig wirkt und nicht gegen die Grenzen einer Vorlage arbeitet.
        </p>

        <h2 id="inhalt">Warum der Inhalt entscheidet</h2>
        <p>
          Auch die beste technische Plattform ersetzt keine eindeutige Aussage. Besucher müssen rasch verstehen, was angeboten wird, für wen es gedacht ist und wie der nächste Schritt aussieht. Erst daraus entsteht eine überzeugende Website.
        </p>

        <h2 id="einschaetzung">Wie Nigredo entscheidet</h2>
        <p>
          Nigredo empfiehlt keine grössere Lösung als nötig. Wenn ein Baukasten die Aufgabe erfüllt, darf die Lösung klein bleiben. Wenn Profil, Qualität oder Wachstum mehr Freiheit verlangen, wird eine individuelle Grundlage entwickelt.
        </p>

        <section class="related-faqs" aria-labelledby="related-faqs-title">
          <h2 id="related-faqs-title">Verwandte Fragen</h2>
          <div class="related-faqs__grid">
            <a href="/haeufige-fragen/was-kostet-eine-professionelle-website/">
              <strong>Was kostet eine professionelle Website?</strong>
              <span>Welche Faktoren den Preis beeinflussen und wie sich Kosten seriös einschätzen lassen.</span>
            </a>
            <a href="/haeufige-fragen/was-kostet-der-laufende-betrieb-einer-website/">
              <strong>Welche laufenden Kosten hat eine Website?</strong>
              <span>Welche laufenden Kosten nach dem Launch entstehen, von Hosting bis Wartung.</span>
            </a>
            <a href="/haeufige-fragen/was-muss-meine-website-beim-datenschutz-beachten/">
              <strong>Was muss meine Website beim Datenschutz beachten?</strong>
              <span>Was das Schweizer Datenschutzgesetz für deine Website bedeutet, von Cookies bis Analyse.</span>
            </a>
            <a href="/haeufige-fragen/wird-meine-website-bei-google-gefunden/">
              <strong>Wird meine Website bei Google gefunden?</strong>
              <span>Warum eine Website nicht automatisch sichtbar ist und wovon die Auffindbarkeit abhängt.</span>
            </a>
          </div>
        </section>

        <div class="article-links">
          <a href="/haeufige-fragen/">Zurück zu den häufigen Fragen</a>
          <a href="/kontakt/">Passende Lösung für mein Vorhaben klären</a>
        </div>
      </div>
    </div>
  </article>
</Layout>

<style>
  .faq-article {
    --faq-a: var(--brand-sun);
    --faq-b: var(--brand-coral);
    --faq-c: var(--brand-pink);
  }
</style>
