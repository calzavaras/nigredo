---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const pageUrl = 'https://www.nigredo.ch/haeufige-fragen/was-kostet-eine-professionelle-website/';
const question = 'Was kostet eine professionelle Website?';
const answer = 'Eine professionelle Website hat keinen seriösen Einheitspreis. Für KMU und Selbständige in der Schweiz beginnt eine sauber umgesetzte Website meist im unteren vierstelligen Bereich. Der genaue Preis hängt vor allem von Ziel, Umfang, Inhalt, Gestaltung und technischen Anforderungen ab.';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Häufige Fragen", "item": "https://www.nigredo.ch/haeufige-fragen/" },
        { "@type": "ListItem", "position": 3, "name": question, "item": pageUrl }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": answer
          }
        }
      ]
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": "Was kostet eine professionelle Website? | Nigredo",
      "description": "Was eine professionelle Website in der Schweiz kostet, wovon der Preis abhängt und wie sich Website-Kosten für KMU und Selbständige seriös einschätzen lassen.",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "mainEntity": { "@id": `${pageUrl}#faq` },
      "about": { "@id": "https://www.nigredo.ch/#organization" },
      "inLanguage": "de-CH",
      "datePublished": "2026-05-16",
      "dateModified": "2026-06-04",
      "isAccessibleForFree": true
    }
  ]
});
---

<Layout
  title="Was kostet eine professionelle Website? | Nigredo"
  description="Was eine professionelle Website in der Schweiz kostet, wovon der Preis abhängt und wie sich Website-Kosten für KMU und Selbständige seriös einschätzen lassen."
  canonical={pageUrl}
  ogTitle="Was kostet eine professionelle Website? | Nigredo"
  ogDescription="Eine klare Antwort darauf, wovon Website-Kosten für KMU und Selbständige in der Schweiz abhängen."
  twitterTitle="Was kostet eine professionelle Website? | Nigredo"
  twitterDescription="Was eine professionelle Website kostet und wovon der Preis wirklich abhängt."
  schema={schema}
>
  <article class="section faq-article" aria-labelledby="article-title">
    <div class="hero-glow"></div>
    <div class="container faq-article__container">
      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Häufige Fragen', href: '/haeufige-fragen/' },
        { label: question }
      ]} />

      <header class="faq-article__header fade-up">
        <span class="badge badge--purple">Website-Kosten</span>
        <h1 id="article-title">{question}</h1>
        <p>
          Eine professionelle Website hat keinen seriösen Einheitspreis. Für KMU und Selbständige in der Schweiz beginnt eine sauber umgesetzte Website meist im unteren vierstelligen Bereich. Ob es dabei bleibt, hängt von Ziel, Umfang, Inhalt, Gestaltung und Technik ab.
        </p>
      </header>

      <nav class="faq-article__nav fade-up delay-100" aria-label="Inhaltsübersicht">
        <a href="#einheitspreis">Warum es keinen Einheitspreis gibt</a>
        <a href="#kostentreiber">Welche Faktoren den Preis beeinflussen</a>
        <a href="#enthalten">Was enthalten sein sollte</a>
        <a href="#schnellloesung">Wann eine günstige Lösung reicht</a>
        <a href="#einschaetzung">Wie Nigredo Kosten einschätzt</a>
      </nav>

      <div class="faq-article__content fade-up delay-100">
        <p class="lead-answer">
          Als Orientierung gilt: Eine schlanke Website mit wenigen klaren Seiten kostet weniger als ein Auftritt mit Konzept, neuen Texten, Suchmaschinenoptimierung und besonderen Funktionen. Je klarer Ziel und Umfang sind, desto genauer lässt sich der Preis seriös einschätzen.
        </p>

        <h2 id="einheitspreis">Warum es keinen seriösen Einheitspreis gibt</h2>
        <p>
          Die Seitenzahl allein sagt wenig aus. Eine einfache Präsenz braucht weniger Konzeption, Inhalt und Technik als eine Website für ein KMU mit mehreren Leistungsseiten, klarer Positionierung, Textarbeit oder individueller Gestaltung.
        </p>
        <p>
          Ein fixer Preis ohne Blick auf Ziel, Inhalt und Aufgabe klingt bequem, ist aber oft ungenau. Entweder werden unnötige Leistungen mitverkauft oder wichtige Arbeit fehlt und muss später aufwändig nachgeholt werden.
        </p>

        <h2 id="kostentreiber">Welche Faktoren den Preis beeinflussen</h2>
        <p>
          Entscheidend sind vor allem Umfang, Inhaltsarbeit, Designanspruch, technische Anforderungen und Sichtbarkeit. Müssen Texte neu entwickelt werden? Gibt es bereits gutes Bildmaterial? Soll die Website nur informieren oder aktiv Anfragen führen? Braucht es Formulare, Schnittstellen oder spezielle Funktionen?
        </p>
        <p>
          Auch Suchmaschinenoptimierung ist kein Zusatzknopf am Ende. Gute Titel, klare Seitenstruktur, sauber formulierte Inhalte und schnelle Ladezeiten gehören zur Umsetzung selbst. Genau das beeinflusst den Aufwand und damit auch den Preis.
        </p>

        <h2 id="enthalten">Was bei einer professionellen Website enthalten sein sollte</h2>
        <p>
          Eine professionelle Website sollte auf Smartphone, Tablet und Desktop sauber funktionieren, schnell laden und eine klare Führung haben. Besucher müssen rasch verstehen, worum es geht, für wen das Angebot geeignet ist und was der nächste sinnvolle Schritt ist.
        </p>
        <p>
          Wichtig ist zudem, dass die Website nicht nur gut aussieht, sondern inhaltlich trägt. Verständliche Texte, eine nachvollziehbare Struktur und eine saubere technische Basis sind oft wertvoller als oberflächliche Effekte.
        </p>

        <h2 id="schnellloesung">Wann eine günstige Lösung reicht und wann nicht</h2>
        <p>
          Eine günstige Lösung kann sinnvoll sein, wenn nur eine sehr einfache Präsenz gebraucht wird und keine besonderen Anforderungen bestehen. Für ein kleines Projekt oder eine bewusst reduzierte Website muss nicht automatisch ein grosser Aufbau entstehen.
        </p>
        <p>
          Wenn die Website aber Vertrauen tragen, in Google gefunden werden oder echte Anfragen bringen soll, reicht eine reine Schnelllösung oft nicht. Dann lohnt sich eine saubere Grundlage, weil spätere Korrekturen meist teurer sind als eine klare Umsetzung von Anfang an.
        </p>

        <h2 id="einschaetzung">Wie Nigredo die Kosten einschätzt</h2>
        <p>
          Nigredo startet nicht mit einer langen Preisliste, sondern mit einer kurzen Klärung: Was soll die Website leisten? Welche Inhalte gibt es schon? Was muss neu entstehen? Welche Funktionen sind wirklich nötig? Daraus ergibt sich ein konkreter Umfang und damit eine saubere Kosteneinschätzung.
        </p>
        <p>
          Wer vor allem wissen will, wann ein Projekt realistisch online gehen kann, findet die Antwort bei <a href="/haeufige-fragen/wie-lange-dauert-die-erstellung-einer-professionellen-website/">der Frage zur Projektdauer</a>. Wer noch zwischen Vorlage und individueller Umsetzung abwägt, findet die passende Einordnung bei <a href="/haeufige-fragen/brauche-ich-eine-individuelle-website-oder-reicht-ein-baukasten/">der Frage zu Baukasten oder individueller Website</a>.
        </p>

        <section class="related-faqs" aria-labelledby="related-faqs-title">
          <h2 id="related-faqs-title">Verwandte Fragen</h2>
          <div class="related-faqs__grid">
            <a href="/haeufige-fragen/wie-lange-dauert-die-erstellung-einer-professionellen-website/">
              <strong>Wie lange dauert die Erstellung einer professionellen Website?</strong>
              <span>Realistische Zeitrahmen, Projektphasen und typische Verzögerungen.</span>
            </a>
            <a href="/haeufige-fragen/was-kostet-der-laufende-betrieb-einer-website/">
              <strong>Was kostet der laufende Betrieb einer Website?</strong>
              <span>Welche laufenden Kosten nach dem Launch entstehen, von Hosting bis Wartung.</span>
            </a>
            <a href="/haeufige-fragen/brauche-ich-eine-individuelle-website-oder-reicht-ein-baukasten/">
              <strong>Brauche ich eine individuelle Website oder reicht ein Baukasten?</strong>
              <span>Wann eine Vorlage genügt und wann eine massgeschneiderte Lösung sinnvoller ist.</span>
            </a>
            <a href="/haeufige-fragen/wird-meine-website-bei-google-gefunden/">
              <strong>Wird meine Website bei Google gefunden?</strong>
              <span>Warum eine Website nicht automatisch sichtbar ist und wovon die Auffindbarkeit abhängt.</span>
            </a>
          </div>
        </section>

        <div class="article-links">
          <a href="/haeufige-fragen/">Zurück zu den häufigen Fragen</a>
          <a href="/kontakt/">Kosten für meine Website einschätzen lassen</a>
        </div>
      </div>
    </div>
  </article>
</Layout>

<style>
  .faq-article {
    --faq-a: #ff7c20;
    --faq-b: #ff2e55;
    --faq-c: #cc20cc;
    animation: faqCycle 90s ease-in-out infinite;
    position: relative;
    padding-top: var(--hero-offset-top-breadcrumb);
    padding-bottom: clamp(84px, 8vw, 112px);
    overflow: hidden;
  }

  .faq-article__container {
    position: relative;
  }

  .faq-article :global(.breadcrumb) {
    margin-bottom: 28px;
  }

  .faq-article__header {
    max-width: 880px;
  }

  .faq-article__header .badge {
    min-height: 26px;
    margin-bottom: 0.9rem;
    padding: 4px 10px;
    font-size: 0.54rem;
    letter-spacing: 0.14em;
    color: rgba(255, 236, 224, 0.94);
    border-color: color-mix(in srgb, var(--faq-b) 34%, rgba(255, 255, 255, 0.22));
    background: transparent;
    box-shadow: none;
  }

  .faq-article .hero-glow {
    background:
      radial-gradient(circle at 18% 40%, color-mix(in srgb, var(--faq-a) 16%, transparent) 0%, transparent 36%),
      radial-gradient(circle at 56% 34%, color-mix(in srgb, var(--faq-b) 14%, transparent) 0%, transparent 32%),
      radial-gradient(circle at 84% 44%, color-mix(in srgb, var(--faq-c) 13%, transparent) 0%, transparent 28%);
  }

  .faq-article__header h1 {
    max-width: 920px;
    margin: 0 0 clamp(24px, 3vw, 32px);
    color: #f5f5f7;
    font-size: clamp(2.95rem, 5.2vw, 4.55rem);
    line-height: 0.99;
    letter-spacing: 0;
  }

  .faq-article__header p {
    max-width: 720px;
    margin: 0;
    color: rgba(255, 255, 255, 0.68);
    font-size: var(--lead-size);
    line-height: 1.65;
  }

  .faq-article__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    max-width: 760px;
    margin-top: 30px;
  }

  .faq-article__nav a,
  .related-faqs__grid a,
  .article-links a {
    text-decoration: none;
  }

  .faq-article__nav a {
    min-height: 40px;
    display: inline-flex;
    align-items: center;
    padding: 0 14px;
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.92rem;
    border: 1px solid rgba(255, 255, 255, 0.11);
    background: rgba(255, 255, 255, 0.03);
    transition: border-color 0.2s ease, transform 0.2s ease, color 0.2s ease;
  }

  .faq-article__nav a:hover {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.24);
    transform: translateY(-2px);
  }

  .faq-article__content {
    max-width: 760px;
    margin-top: clamp(46px, 6vw, 72px);
  }

  .faq-article__content p {
    margin: 0 0 1.25rem;
    color: rgba(255, 255, 255, 0.68);
    font-size: 1.04rem;
    line-height: 1.78;
  }

  .faq-article__content .lead-answer {
    color: rgba(255, 255, 255, 0.82);
    font-size: clamp(1.12rem, 2vw, 1.28rem);
    line-height: 1.72;
    padding-bottom: clamp(22px, 4vw, 34px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .faq-article__content h2 {
    margin: clamp(42px, 6vw, 62px) 0 1rem;
    color: rgba(255, 255, 255, 0.95);
    font-size: clamp(1.46rem, 2.8vw, 2rem);
    line-height: 1.16;
    letter-spacing: 0;
  }

  .faq-article__content a {
    color: rgba(255, 255, 255, 0.9);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  .related-faqs {
    margin-top: clamp(42px, 6vw, 62px);
    padding-top: 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .related-faqs__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .related-faqs__grid a {
    display: grid;
    gap: 10px;
    padding: 20px;
    border-radius: 22px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .related-faqs__grid a:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .related-faqs__grid strong {
    color: rgba(255, 255, 255, 0.95);
    font-size: 1rem;
    line-height: 1.4;
  }

  .related-faqs__grid span {
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.96rem;
    line-height: 1.6;
  }

  .article-links {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: clamp(42px, 6vw, 62px);
    padding-top: 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .article-links a {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 18px;
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.13);
    background: rgba(255, 255, 255, 0.035);
    transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .article-links a:hover {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.28);
    transform: translateY(-2px);
  }

  @media (max-width: 860px) {
    .faq-article {
      padding-top: var(--hero-offset-top-breadcrumb-mobile);
      padding-bottom: 72px;
    }

    .faq-article__header h1 {
      font-size: clamp(2.5rem, 8vw, 3.5rem);
      line-height: var(--hero-title-line-height-mobile);
    }

    .related-faqs__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .faq-article__header h1 {
      font-size: clamp(2.2rem, 10.8vw, 2.95rem);
    }

    .faq-article__header p {
      font-size: var(--lead-size-mobile);
      line-height: 1.6;
    }

    .faq-article__nav {
      display: grid;
      grid-template-columns: 1fr;
    }

    .faq-article__nav a {
      justify-content: center;
      text-align: center;
    }

    .faq-article__content {
      margin-top: 48px;
    }

    .faq-article__content p {
      font-size: 1rem;
      line-height: 1.72;
    }

    .article-links {
      display: grid;
      grid-template-columns: 1fr;
    }
  }
</style>
