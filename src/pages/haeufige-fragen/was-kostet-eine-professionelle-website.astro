---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const pageUrl = 'https://www.nigredo.ch/haeufige-fragen/was-kostet-eine-professionelle-website/';
const question = 'Was kostet eine professionelle Website?';
const answer = 'Eine kompakte, professionell umgesetzte Website beginnt meist im unteren vierstelligen Bereich. Der konkrete Fixpreis richtet sich nach Ziel, Inhalt, Gestaltung und Funktionen. Je genauer der Umfang definiert ist, desto verlässlicher lässt sich das Budget planen.';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Häufige Fragen", "item": "https://www.nigredo.ch/haeufige-fragen/" },
        { "@type": "ListItem", "position": 3, "name": question, "item": pageUrl }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": answer
          }
        }
      ]
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": "Was kostet eine professionelle Website? | Nigredo",
      "description": "Was eine professionelle Website in der Schweiz kostet, welche Leistungen den Preis bestimmen und wie Nigredo einen transparenten Fixpreis entwickelt.",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "mainEntity": { "@id": `${pageUrl}#faq` },
      "about": { "@id": "https://www.nigredo.ch/#organization" },
      "inLanguage": "de-CH",
      "datePublished": "2026-05-16",
      "dateModified": "2026-07-14",
      "isAccessibleForFree": true
    }
  ]
});
---

<Layout
  title="Was kostet eine professionelle Website? | Nigredo"
  description="Was eine professionelle Website in der Schweiz kostet, welche Leistungen den Preis bestimmen und wie Nigredo einen transparenten Fixpreis entwickelt."
  canonical={pageUrl}
  ogTitle="Was kostet eine professionelle Website? | Nigredo"
  ogDescription="Eine klare Antwort darauf, wovon Website-Kosten für KMU und Selbstständige in der Schweiz abhängen."
  twitterTitle="Was kostet eine professionelle Website? | Nigredo"
  twitterDescription="Was eine professionelle Website kostet und wovon der Preis wirklich abhängt."
  schema={schema}
>
  <article class="section faq-article" aria-labelledby="article-title">
    <div class="hero-glow"></div>
    <div class="container faq-article__container">
      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Häufige Fragen', href: '/haeufige-fragen/' },
        { label: question }
      ]} />

      <header class="faq-article__header fade-up">
        <h1 id="article-title">{question}</h1>
        <p>{answer}</p>
      </header>

      <nav class="faq-article__nav fade-up delay-100" aria-label="Inhaltsübersicht">
        <a href="#einheitspreis">Warum Seitenzahlen allein wenig sagen</a>
        <a href="#kostentreiber">Was den Preis bestimmt</a>
        <a href="#enthalten">Was im Angebot enthalten sein sollte</a>
        <a href="#schnellloesung">Wann eine einfache Lösung genügt</a>
        <a href="#einschaetzung">Wie Nigredo kalkuliert</a>
      </nav>

      <div class="faq-article__content fade-up delay-100">
        <h2 id="einheitspreis">Warum Seitenzahlen allein wenig sagen</h2>
        <p>
          Zwei Websites mit derselben Anzahl Seiten können sehr unterschiedlich aufwendig sein. Entscheidend ist, ob Struktur, Texte und Bilder bereits stehen oder gemeinsam entwickelt werden. Auch individuelle Gestaltung, Formulare und besondere Funktionen prägen den Umfang.
        </p>

        <h2 id="kostentreiber">Was den Preis bestimmt</h2>
        <p>
          Den grössten Einfluss haben Konzept, Inhaltsarbeit, Designanspruch und technische Anforderungen. Suchmaschinenoptimierung gehört zur inhaltlichen und technischen Umsetzung. Sie ist kein später Zusatz, sondern Teil einer Website, die gefunden und verstanden werden soll.
        </p>

        <h2 id="enthalten">Was im Angebot enthalten sein sollte</h2>
        <p>
          Ein seriöses Angebot benennt Leistungen, Zuständigkeiten und Grenzen eindeutig. Dazu gehören die Darstellung auf allen Geräten, schnelle Ladezeiten, verständliche Inhalte, technische Qualität sowie eine sorgfältige Prüfung vor dem Start.
        </p>

        <h2 id="schnellloesung">Wann eine einfache Lösung genügt</h2>
        <p>
          Für eine kleine Präsenz mit wenigen Inhalten kann ein reduzierter Aufbau vollkommen richtig sein. Mehr Aufwand lohnt sich dort, wo die Website ein Angebot erklären, Vertrauen aufbauen, Anfragen gewinnen oder später erweitert werden soll.
        </p>

        <h2 id="einschaetzung">Wie Nigredo kalkuliert</h2>
        <p>
          Nigredo klärt zuerst, was die Website leisten muss und welche Grundlagen bereits vorhanden sind. Daraus entstehen ein definierter Umfang, nachvollziehbare Prioritäten und ein transparenter Fixpreis. Bezahlt wird für eine passende Lösung, nicht für unnötige Komplexität.
        </p>

        <section class="related-faqs" aria-labelledby="related-faqs-title">
          <h2 id="related-faqs-title">Verwandte Fragen</h2>
          <div class="related-faqs__grid">
            <a href="/haeufige-fragen/wie-lange-dauert-die-erstellung-einer-professionellen-website/">
              <strong>Wie lange dauert die Erstellung einer professionellen Website?</strong>
              <span>Realistische Zeitrahmen, Projektphasen und typische Verzögerungen.</span>
            </a>
            <a href="/haeufige-fragen/was-kostet-der-laufende-betrieb-einer-website/">
              <strong>Welche laufenden Kosten hat eine Website?</strong>
              <span>Welche laufenden Kosten nach dem Launch entstehen, von Hosting bis Wartung.</span>
            </a>
            <a href="/haeufige-fragen/brauche-ich-eine-individuelle-website-oder-reicht-ein-baukasten/">
              <strong>Brauche ich eine individuelle Website oder reicht ein Baukasten?</strong>
              <span>Wann eine Vorlage genügt und wann eine massgeschneiderte Lösung sinnvoller ist.</span>
            </a>
            <a href="/haeufige-fragen/wird-meine-website-bei-google-gefunden/">
              <strong>Wird meine Website bei Google gefunden?</strong>
              <span>Warum eine Website nicht automatisch sichtbar ist und wovon die Auffindbarkeit abhängt.</span>
            </a>
          </div>
        </section>

        <div class="article-links">
          <a href="/haeufige-fragen/">Zurück zu den häufigen Fragen</a>
          <a href="/kontakt/">Fixpreis für meine Website klären</a>
        </div>
      </div>
    </div>
  </article>
</Layout>

<style>
  .faq-article {
    --faq-a: var(--brand-sun);
    --faq-b: var(--brand-coral);
    --faq-c: var(--brand-pink);
  }
</style>
