---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CaseMoreReferences from '../../../components/CaseMoreReferences.astro';

const pageUrl = 'https://www.nigredo.ch/referenzen/dashboard-kantonsverwaltung/';
const detailImage = '/referenzen/dashboard-kantonsverwaltung/dashboard-kantonsverwaltung-verwaltungsdashboard-screenshot-2160.webp';
const detailImageAvif = '/referenzen/dashboard-kantonsverwaltung/dashboard-kantonsverwaltung-verwaltungsdashboard-screenshot-2160.avif';
const ogImage = 'https://www.nigredo.ch/referenzen/dashboard-kantonsverwaltung/dashboard-kantonsverwaltung-verwaltungsdashboard-screenshot-og.jpg';
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Referenzen", "item": "https://www.nigredo.ch/referenzen/" },
        { "@type": "ListItem", "position": 3, "name": "Dashboard für Verwaltung", "item": pageUrl }
      ]
    },
    {
      "@type": "SoftwareApplication",
      "@id": `${pageUrl}#software`,
      "name": "Dashboard für Verwaltung",
      "url": pageUrl,
      "description": "Lokales Excel Dashboard für eine Schweizer Kantonsverwaltung. Import, Kennzahlen, Diagramme, Anonymisierung und PDF Export laufen vollständig im Browser. Sämtliche Daten bleiben auf dem Rechner.",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web Browser",
      "inLanguage": "de",
      "dateCreated": "2025-04-01",
      "datePublished": "2026-02-28",
      "featureList": [
        "Drag & Drop Excel-Import",
        "KPI-Auswertung",
        "Interaktive Diagramme",
        "Anonymisierung per Knopfdruck",
        "PDF-Export",
        "100% lokal im Browser"
      ],
      "screenshot": [
        {
          "@type": "ImageObject",
          "url": ogImage,
          "caption": "Lokales Verwaltungs-Dashboard mit anonymisierten Kennzahlen, Statusübersicht und Auswertung"
        }
      ],
      "creator": { "@id": "https://www.nigredo.ch/#organization" }
    },
    {
      "@type": "ImageObject",
      "@id": `${pageUrl}#primaryimage`,
      "url": ogImage,
      "contentUrl": ogImage,
      "width": 1200,
      "height": 630,
      "caption": "Lokales Verwaltungs Dashboard mit anonymisierten Kennzahlen, Statusübersicht und Auswertung"
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "name": "Dashboard für Verwaltung | Nigredo Referenzen",
      "url": pageUrl,
      "description": "Lokales Excel Dashboard für eine Schweizer Kantonsverwaltung mit Import, Kennzahlen, Diagrammen, Anonymisierung und PDF Export.",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "inLanguage": "de-CH",
      "datePublished": "2025-06-01",
      "dateModified": "2026-07-17",
      "about": { "@id": `${pageUrl}#software` },
      "mainEntity": { "@id": `${pageUrl}#software` },
      "primaryImageOfPage": { "@id": `${pageUrl}#primaryimage` },
      "publisher": { "@id": "https://www.nigredo.ch/#organization" },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "isAccessibleForFree": true
    }
  ]
});
---

<Layout
  title="Dashboard für Verwaltung | Nigredo Referenzen"
  description="Lokales Excel Dashboard für eine Schweizer Kantonsverwaltung: Import, Kennzahlen, Diagramme, Anonymisierung und PDF Export. Daten bleiben lokal."
  canonical={pageUrl}
  ogTitle="Dashboard für Verwaltung"
  ogDescription="Excel Import, Kennzahlen, Diagramme, Anonymisierung und PDF Export. Sensible Personaldaten bleiben vollständig lokal im Browser."
  ogImage={ogImage}
  ogImageAlt="Lokales Verwaltungs-Dashboard mit anonymisierten Kennzahlen, Statusübersicht und Auswertung"
  ogImageWidth="1200"
  ogImageHeight="630"
  twitterTitle="Dashboard für Verwaltung"
  twitterDescription="Excel Auswertung ohne Cloud mit Kennzahlen, Diagrammen und Anonymisierung. Sämtliche Daten bleiben lokal im Browser."
  schema={schema}
  preloadImage={detailImageAvif}
  preloadImageType="image/avif"
>
  <section class="section pt-sub case-page case-page--app" aria-labelledby="dashboard-kantonsverwaltung-title">
    <div class="hero-glow"></div>
    <div class="container case-page__container">

      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Referenzen', href: '/referenzen/' },
        { label: 'Dashboard' }
      ]} />

      <a href="/referenzen/" class="case-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
        Alle Referenzen
      </a>

      <!-- Hero: Split Layout -->
      <div class="case-hero fade-up">
        <div class="case-hero-content">
          <h1 id="dashboard-kantonsverwaltung-title" class="home-hero__title case-hero-title">Excel Dashboard<br><span class="gradient-text">für Verwaltung</span></h1>
          <p class="hero-lead case-hero-lead">
            Dieses lokale Dashboard wertet sensible Personaldaten direkt im Browser aus. Excel-Dateien werden importiert, anonymisiert, visualisiert und als PDF ausgegeben, ohne Server, Cloud oder externe Datenübertragung.
          </p>
        </div>

        <div class="case-hero-visual">
          <div class="case-hero-canvas case-hero-canvas--cyan">
            <button
              type="button"
              class="case-hero-float lightbox-trigger"
              data-gallery={`["${detailImage}"]`}
              data-gallery-index="0"
              aria-label="Screenshot vergrössern"
            >
              <picture>
                <source
                  srcset={detailImageAvif}
                  type="image/avif"
                >
              <img
                src={detailImage}
                alt="Lokales Verwaltungs-Dashboard mit anonymisierten Kennzahlen, Statusübersicht und Auswertung"
                width="1440" height="810"
                loading="eager"
                decoding="async"
                fetchpriority="high"
              >
              </picture>
            </button>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="case-stats fade-up delay-100" style="--stats-cols: 4;">
        <div class="case-stat">
          <strong class="stat-tool">100%</strong>
          <span>Lokal</span>
        </div>
        <div class="case-stat">
          <strong class="stat-tool">0</strong>
          <span>Cloud-Uploads</span>
        </div>
        <div class="case-stat">
          <strong class="stat-tool">1 Klick</strong>
          <span>Anonymisierung</span>
        </div>
        <div class="case-stat">
          <strong class="stat-tool">PDF</strong>
          <span>Berichtsexport</span>
        </div>
      </div>

      <!-- Lösung -->
      <div class="case-section fade-up delay-100">
        <div class="case-section-hd">
          <span class="case-eyebrow">Ergebnis im Detail</span>
          <h2 class="case-section-title">Lokale Excel-Auswertung für die Kantonsverwaltung</h2>
        </div>
        <div class="case-features">
          <div class="case-feature">
            <div class="case-feature-body">
              <div class="case-feature-icon case-feature-icon--cyan">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="url(#dashboard-feature-grad-1)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><defs><linearGradient id="dashboard-feature-grad-1" x1="3" y1="3" x2="21" y2="21" gradientUnits="userSpaceOnUse"><stop stop-color="var(--brand-cyan)"/><stop offset="0.52" stop-color="var(--brand-violet)"/><stop offset="1" stop-color="var(--brand-blue)"/></linearGradient></defs><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              </div>
              <div class="case-feature-text">
                <h3>Drag-and-Drop-Import</h3>
                <p>Die Excel-Datei wird direkt in den Browser gezogen und ohne Installation verarbeitet. Kein Upload, kein externes System und kein Umweg über die Cloud.</p>
              </div>
            </div>
          </div>
          <div class="case-feature">
            <div class="case-feature-body">
              <div class="case-feature-icon case-feature-icon--cyan">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="url(#dashboard-feature-grad-2)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><defs><linearGradient id="dashboard-feature-grad-2" x1="4" y1="2" x2="20" y2="22" gradientUnits="userSpaceOnUse"><stop stop-color="var(--brand-cyan)"/><stop offset="0.52" stop-color="var(--brand-violet)"/><stop offset="1" stop-color="var(--brand-blue)"/></linearGradient></defs><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              </div>
              <div class="case-feature-text">
                <h3>Anonymisierung auf Knopfdruck</h3>
                <p>Kennzahlen und Diagramme gehen in die Präsentation, Echtnamen bleiben im Büro. Datenschutz ist hier kein Zusatz, sondern Teil der Lösung.</p>
              </div>
            </div>
          </div>
          <div class="case-feature">
            <div class="case-feature-body">
              <div class="case-feature-icon case-feature-icon--cyan">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="url(#dashboard-feature-grad-3)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><defs><linearGradient id="dashboard-feature-grad-3" x1="4" y1="2" x2="20" y2="22" gradientUnits="userSpaceOnUse"><stop stop-color="var(--brand-cyan)"/><stop offset="0.52" stop-color="var(--brand-violet)"/><stop offset="1" stop-color="var(--brand-blue)"/></linearGradient></defs><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="12" x2="12" y2="18"/><polyline points="9 15 12 18 15 15"/></svg>
              </div>
              <div class="case-feature-text">
                <h3>Export als PDF</h3>
                <p>Ein Klick erstellt einen druckfertigen Bericht mit Diagrammen, Kennzahlen und einem aufgeräumten Layout.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <span class="case-date fade-up">Abgeschlossen: Juni 2025</span>

      <!-- Weitere Projekte -->
      <div class="fade-up case-more-section">
        <span class="case-more-label">Weitere Projekte</span>
        <CaseMoreReferences />
      </div>

      <!-- CTA -->
      <div class="section case-final-section fade-up">
        <div class="section-cta case-final-cta">
          <span class="cta-label">Der nächste Schritt</span>
          <h2>Soll es lokal<br><span>bleiben?</span></h2>
          <div class="hero-cta-group" style="justify-content: center;">
            <a href="/kontakt/" class="btn btn-primary">Kontakt aufnehmen</a>
            <a href="/referenzen/" class="btn btn-ghost">Alle Projekte</a>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style is:global>
  .case-page--app {
    --case-accent: var(--brand-cyan);
    --case-accent-2: var(--brand-blue);
    --case-accent-3: var(--brand-violet);
    --case-title-gradient: linear-gradient(96deg, var(--brand-cyan) 0%, var(--brand-violet) 52%, var(--brand-sun) 100%);
    --case-accent-soft: color-mix(in srgb, var(--case-accent) 14%, transparent);
    --case-accent-glow: color-mix(in srgb, var(--case-accent) 24%, transparent);
  }

  .case-page--app .gradient-text {
    background: var(--case-title-gradient);
    background-size: 100% auto;

    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .stat-tool {
    background: var(--case-title-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .case-page--app .case-hero-canvas--cyan {
    background:
      radial-gradient(ellipse at 50% 50%, rgba(0, 210, 255, 0.24) 0%, rgba(0, 210, 255, 0.08) 48%, rgba(255, 255, 255, 0.02) 100%),
      #0a0a0c;
    border-color: rgba(0, 210, 255, 0.16);
  }

  .case-page--app .case-feature:hover {
    border-color: rgba(255, 255, 255, 0.16);
    box-shadow: var(--shadow-card-hover),
      0 0 28px rgba(0, 210, 255, 0.08);
  }
</style>
