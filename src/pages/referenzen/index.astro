---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.nigredo.ch/referenzen#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Referenzen", "item": "https://www.nigredo.ch/referenzen" }
      ]
    },
    {
      "@type": "CollectionPage",
      "@id": "https://www.nigredo.ch/referenzen#webpage",
      "url": "https://www.nigredo.ch/referenzen",
      "name": "Referenzprojekte – KI & Software für Schweizer KMU | Nigredo",
      "description": "Echte Projekte: KI Voice Agent für IV-Stellen, lokales Excel-Dashboard für Kantonsverwaltung. Massgeschneiderte digitale Lösungen von Nigredo, St. Gallen.",
      "inLanguage": "de-CH",
      "datePublished": "2025-06-01",
      "dateModified": "2026-03-21",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": "https://www.nigredo.ch/referenzen#breadcrumb" },
      "isAccessibleForFree": true,
      "mainEntity": {
        "@type": "ItemList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "url": "https://www.nigredo.ch/referenzen/ki-voice-agent", "name": "KI Voice Agent für IV-Stellen" },
          { "@type": "ListItem", "position": 2, "url": "https://www.nigredo.ch/referenzen/dashboard-kantonsverwaltung", "name": "Dashboard für Kantonsverwaltung" }
        ]
      }
    }
  ]
});
---

<Layout
  title="Referenzprojekte – KI & Software für Schweizer KMU | Nigredo"
  description="Echte Projekte: KI Voice Agent für IV-Stellen, lokales Excel-Dashboard für Kantonsverwaltung. Massgeschneiderte digitale Lösungen von Nigredo, St. Gallen."
  keywords="Referenzen Nigredo, KI Voice Agent Schweiz, Excel Dashboard Kantonsverwaltung, digitale Lösungen Schweiz, Softwareentwicklung Referenzen, KI-Projekte St. Gallen, Website Referenzen KMU"
  canonical="https://www.nigredo.ch/referenzen"
  ogTitle="Gebaut. Nicht gepitcht. | Nigredo"
  ogDescription="Keine Demos, keine Konzeptpapiere. Projekte, die raus sind und arbeiten. KI Voice Agent, Excel-Dashboard und mehr."
  ogImageAlt="Nigredo Referenzen – Echte Projekte, keine Demos"
  twitterTitle="Gebaut. Nicht gepitcht. | Nigredo"
  twitterDescription="Keine Demos, keine Konzeptpapiere. Projekte, die raus sind und arbeiten."
  schema={schema}
>
  <section class="section pt-sub">
    <div class="hero-glow"></div>
    <div class="container">

      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Referenzen' }
      ]} />

      <div class="fade-up refs-intro">
        <span class="badge badge--purple">GEBAUT. NICHT GEPITCHT.</span>

        <h1 id="referenzen-title">
          Echte Aufgaben.<br>
          <span class="gradient-text">Echte Ergebnisse.</span>
        </h1>
        <p class="hero-lead">
          Jedes Projekt hier hatte einen konkreten Auftrag, einen echten Kontext und ein Problem, das gelöst werden musste. Keine Showpieces, keine Vorführprojekte. Sondern Arbeit, die Substanz braucht und im Alltag bestehen muss.
        </p>
      </div>

      <div id="refs-grid" class="refs-grid" aria-live="polite"></div>

      <div class="refs-nav" id="refs-nav">
        <button class="refs-nav-btn" id="refs-prev" aria-label="Vorherige Projekte">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
        </button>
        <span class="refs-nav-count" id="refs-nav-count"></span>
        <button class="refs-nav-btn" id="refs-next" aria-label="Nächste Projekte">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
        </button>
      </div>

      <div class="section">
        <div class="section-cta fade-up">
          <span class="cta-label">Der nächste Schritt</span>
          <h2>Nächstes Projekt?<br><span class="gradient-text">Erzähl mir davon.</span></h2>
          <div class="hero-cta-group" style="justify-content: center;">
            <a href="/kontakt" class="btn btn-primary">Kontakt aufnehmen</a>
            <a href="/ueber-uns" class="btn btn-ghost">Über mich</a>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style is:global>
  /* Main Grid */
  .refs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-bottom: 64px;
  }

  .refs-intro {
    max-width: 920px;
    margin-bottom: 64px;
  }

  /* Card */
  .ref-main-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-xl);
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(10, 10, 12, 0.75);
    background-clip: padding-box;
    overflow: hidden;
    text-decoration: none;
    color: #fff;
    position: relative;
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1),
                border-color 0.4s ease,
                box-shadow 0.4s ease;
  }

  @media (hover: hover) {
    .ref-main-card:hover {
      transform: translateY(-5px);
      border-color: rgba(255, 255, 255, 0.2);
      box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    }
    .ref-main-card:hover .ref-main-card-img img {
      transform: scale(1.04);
    }
  }

  /* Image Area */
  .ref-main-card-img {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    flex-shrink: 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .ref-main-card-img--purple {
    background: radial-gradient(ellipse at 25% 35%, rgba(166,77,255,0.45) 0%, transparent 55%), #0c0814;
  }
  .ref-main-card-img--cyan {
    background: radial-gradient(ellipse at 25% 35%, rgba(0,210,255,0.35) 0%, transparent 55%), #030d14;
  }
  .ref-main-card-img img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: top center;
    display: block;
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .ref-main-badge {
    position: absolute;
    top: 16px; left: 16px;
    z-index: 1;
  }

  /* Card Body */
  .ref-main-card-body {
    padding: 32px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .ref-main-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
  }
  .ref-main-card-year {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.3);
    white-space: nowrap;
    padding-top: 4px;
  }
  .ref-main-card-title {
    font-size: 1.35rem;
    font-weight: 700;
    margin: 0;
    color: #fff;
  }
  .ref-main-card-sub {
    font-size: 0.85rem;
    color: var(--secondary-accent);
    margin-bottom: 16px;
    font-weight: 500;
  }
  .ref-main-card-desc {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  /* Footer */
  .ref-main-card-footer {
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .ref-main-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
    transition: color 0.3s ease, gap 0.3s ease;
  }
  .ref-main-card:hover .ref-main-link {
    color: #fff;
    gap: 12px;
  }

  /* Navigation */
  .refs-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 80px;
  }
  .refs-nav-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.1);
    background: transparent;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }
  .refs-nav-btn:hover:not(:disabled) {
    border-color: #fff;
    background: rgba(255,255,255,0.05);
  }
  .refs-nav-btn:disabled {
    opacity: 0.2;
    cursor: default;
  }
  .refs-nav-count {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.4);
  }

  /* Responsive */
  @media (max-width: 860px) {
    .refs-grid { grid-template-columns: 1fr; gap: 24px; }
    .refs-intro { margin-bottom: 48px; }
  }
</style>

<script>
  const REFS = [
    {
      href: '/referenzen/ki-voice-agent',
      imgSrc: '/referenzen/ki-voice-agent/ki-voice-agent-ahv-hilfsmittel-sprachassistent.svg',
      imgAlt: 'KI Voice Agent für IV-Stellen – AHV Hilfsmittel Sprachassistent von Nigredo',
      imgCls: 'ref-main-card-img--purple',
      badge: { text: 'KI-Agent', cls: 'accent-purple' },
      linkCls: 'ref-main-link--ki',
      year: 'Feb 2026',
      title: 'KI Agent für IV-Stellen',
      sub: 'Sprachassistent für AHV-Hilfsmittel',
      desc: 'Dieser Agent ist aktuell noch nicht im Einsatz. Er zeigt als Prototyp, wie Anfragen künftig schneller, klarer und mehrsprachig beantwortet werden können. Vier Sprachen, keine Wartezeiten und ein System, das Wissen zuverlässig verfügbar macht.',
      ariaLabel: 'KI Agent für IV-Stellen – Details ansehen'
    },
    {
      href: '/referenzen/dashboard-kantonsverwaltung',
      imgSrc: '/referenzen/dashboard-kantonsverwaltung/dashboard-kantonsverwaltung-excel-kpi-browser.svg',
      imgAlt: 'Dashboard für Kantonsverwaltung – Excel KPI-Auswertung im Browser ohne Cloud',
      imgCls: 'ref-main-card-img--cyan',
      badge: { text: 'App', cls: 'accent-cyan' },
      linkCls: '',
      year: 'Jun 2025',
      title: 'Dashboard für Kantonsverwaltung',
      sub: 'Excel KPI-Auswertung im Browser, ohne Cloud',
      desc: 'Sensible Daten bleiben dort, wo sie hingehören. Auf dem eigenen Rechner. Berichte entstehen mit einem Klick, ganz ohne Cloud-Upload, ohne IT-Ticket und ohne unnötige Umwege.',
      ariaLabel: 'Dashboard für Kantonsverwaltung – Details ansehen'
    }
    // Weitere Referenzen hier einfach anhängen
  ];

  const ARROW_SVG = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>';

  function shuffle(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function cardHTML(ref) {
    return `
      <a href="${ref.href}" class="ref-main-card" aria-label="${ref.ariaLabel}">
        <div class="ref-main-card-img ${ref.imgCls}">
          <img src="${ref.imgSrc}" alt="${ref.imgAlt}" width="800" height="450" loading="lazy">
          <span class="tech-badge ${ref.badge.cls} ref-main-badge">${ref.badge.text}</span>
        </div>
        <div class="ref-main-card-body">
          <div class="ref-main-card-header">
            <h2 class="ref-main-card-title">${ref.title}</h2>
            <span class="ref-main-card-year">${ref.year}</span>
          </div>
          ${ref.sub ? `<p class="ref-main-card-sub">${ref.sub}</p>` : ''}
          <p class="ref-main-card-desc">${ref.desc}</p>
          <div class="ref-main-card-footer">
            <span class="ref-main-link ${ref.linkCls}">Details ${ARROW_SVG}</span>
          </div>
        </div>
      </a>`;
  }

  const PER_PAGE = 2;
  const shuffled = shuffle(REFS);
  const totalPages = Math.ceil(shuffled.length / PER_PAGE);
  let page = 0;

  const grid    = document.getElementById('refs-grid');
  const nav     = document.getElementById('refs-nav');
  const prevBtn = document.getElementById('refs-prev');
  const nextBtn = document.getElementById('refs-next');
  const counter = document.getElementById('refs-nav-count');

  // Nav nur zeigen wenn mehr als 1 Seite
  nav.style.display = totalPages > 1 ? 'flex' : 'none';

  function render() {
    const visible = shuffled.slice(page * PER_PAGE, (page + 1) * PER_PAGE);
    grid.innerHTML = visible.map(cardHTML).join('');
    prevBtn.disabled = page === 0;
    nextBtn.disabled = page >= totalPages - 1;
    if (totalPages > 1) counter.textContent = `${page + 1} / ${totalPages}`;
  }

  prevBtn.addEventListener('click', () => { if (page > 0) { page--; render(); } });
  nextBtn.addEventListener('click', () => { if (page < totalPages - 1) { page++; render(); } });

  render();
</script>
