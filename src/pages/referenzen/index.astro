---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { references } from '../../data/references';
const referencesJson = JSON.stringify(references);

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.nigredo.ch/referenzen#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Referenzen", "item": "https://www.nigredo.ch/referenzen" }
      ]
    },
    {
      "@type": "CollectionPage",
      "@id": "https://www.nigredo.ch/referenzen#webpage",
      "url": "https://www.nigredo.ch/referenzen",
      "name": "Referenzprojekte – KI, Websites & Software für Schweizer KMU | Nigredo",
      "description": "Echte Projekte: KI Voice Agent für IV-Stellen, lokales Excel-Dashboard für Verwaltung und die Website von Therapie Ost. Massgeschneiderte digitale Lösungen von Nigredo, St. Gallen.",
      "inLanguage": "de-CH",
      "datePublished": "2025-06-01",
      "dateModified": "2026-05-03",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "breadcrumb": { "@id": "https://www.nigredo.ch/referenzen#breadcrumb" },
      "isAccessibleForFree": true,
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", ".hero-lead"]
      },
      "mainEntity": {
        "@type": "ItemList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "url": "https://www.nigredo.ch/referenzen/ki-voice-agent", "name": "KI Voice Agent für IV-Stellen" },
          { "@type": "ListItem", "position": 2, "url": "https://www.nigredo.ch/referenzen/dashboard-kantonsverwaltung", "name": "Dashboard für Verwaltung" },
          { "@type": "ListItem", "position": 3, "url": "https://www.nigredo.ch/referenzen/therapie-ost", "name": "Website für Therapie Ost" }
        ]
      }
    }
  ]
});
---

<Layout
  title="Referenzprojekte – KI, Websites & Software für Schweizer KMU | Nigredo"
  description="Referenzen von Nigredo: KI Voice Agent, lokales Excel-Dashboard und Website für Therapie Ost. Digitale Lösungen aus St. Gallen."
  canonical="https://www.nigredo.ch/referenzen"
  ogTitle="Gebaut. Nicht versprochen. | Nigredo"
  ogDescription="Keine Demos, keine Konzeptpapiere. Projekte, die raus sind und arbeiten. KI Voice Agent, Excel-Dashboard und mehr."
  ogImageAlt="Nigredo Referenzen – Echte Projekte, keine Demos"
  twitterTitle="Gebaut. Nicht versprochen. | Nigredo"
  twitterDescription="Keine Demos, keine Konzeptpapiere. Projekte, die raus sind und arbeiten."
  schema={schema}
>
  <section class="section pt-sub refs-hero" aria-labelledby="referenzen-title">
    <div class="hero-glow"></div>
    <div class="container refs-hero__container">

      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Referenzen' }
      ]} />

      <div class="fade-up home-hero__inner refs-intro">
        <span class="badge badge--purple">GEBAUT. NICHT VERSPROCHEN.</span>

        <h1 id="referenzen-title" class="home-hero__title refs-hero__title">
          Echte Aufgaben.<br>
          <span class="gradient-text">Echte Ergebnisse.</span>
        </h1>
        <p class="hero-lead refs-hero__lead">
          Hier stehen keine Demos und keine hübschen Attrappen. Hier stehen Projekte mit Auftrag, Kontext und Reibung. Dinge, die nicht nur gut aussehen mussten, sondern im Alltag funktionieren.
        </p>
      </div>

      <div id="refs-grid" class="refs-grid" aria-live="polite" data-references={referencesJson}>
        {references.map((ref) => (
          <a href={ref.href} class="ref-main-card" aria-label={ref.ariaLabel}>
            <div class={`ref-main-card-img ${ref.listImgCls}`}>
              <img src={ref.imgSrc} alt={ref.imgAlt} width="800" height="450" loading="lazy" decoding="async">
              <span class={`tech-badge ${ref.badge.cls} ref-main-badge`}>{ref.badge.text}</span>
            </div>
            <div class="ref-main-card-body">
              <div class="ref-main-card-header">
                <h2 class="ref-main-card-title">{ref.listTitle}</h2>
                <span class="ref-main-card-year">{ref.year}</span>
              </div>
              {ref.sub && <p class="ref-main-card-sub">{ref.sub}</p>}
              <p class="ref-main-card-desc">{ref.listDesc}</p>
              <div class="ref-main-card-footer">
                <span class={`ref-main-link ${ref.linkCls || ''}`}>Details <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="refs-controls" aria-label="Referenzen Navigation">
        <button
          id="refs-load-more"
          class="refs-load-more"
          type="button"
          hidden
        >
          Weitere Projekte
        </button>

        <nav id="refs-pagination" class="refs-pagination" aria-label="Seiten blättern" hidden></nav>
      </div>

      <div class="section refs-final-section">
        <div class="section-cta refs-final-cta fade-up">
          <span class="cta-label">Der nächste Schritt</span>
          <h2>Dein Projekt soll hier stehen?<br><span>Erzähl mir davon.</span></h2>
          <div class="hero-cta-group" style="justify-content: center;">
            <a href="/kontakt" class="btn btn-primary">Kontakt aufnehmen</a>
            <a href="/ueber-uns" class="btn btn-ghost">Über mich</a>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style is:global>
  .refs-hero {
    min-height: min(570px, 64vh);
    display: flex;
    align-items: center;
    padding-top: 150px;
    padding-bottom: 48px;
  }

  .refs-hero__container {
    position: relative;
    width: 100%;
  }

  .refs-hero .home-hero__inner {
    width: 100%;
  }

  .refs-hero .breadcrumb {
    margin-bottom: 28px;
  }

  .refs-hero .badge {
    margin-bottom: 1rem;
  }

  .refs-hero__title {
    max-width: 940px;
    font-size: clamp(2.9rem, 5.35vw, 4.85rem);
    line-height: var(--hero-title-line-height);
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }

  .refs-hero__lead {
    max-width: 620px;
    font-size: clamp(1.03rem, 1.15vw, 1.2rem);
    line-height: 1.65;
    color: rgba(245, 245, 247, 0.68);
  }

  /* Main Grid */
  .refs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 1080px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 0;
  }

  .refs-intro {
    max-width: 940px;
    margin-bottom: 64px;
  }

  .refs-controls {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    margin-top: 36px;
    margin-bottom: 64px;
  }

  .refs-load-more {
    appearance: none;
    border: 0;
    background: transparent;
    color: rgba(255, 255, 255, 0.5);
    border-radius: 0;
    padding: 0 0 4px;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    cursor: pointer;
    border-bottom: 1px solid rgba(255, 255, 255, 0.16);
    transition: color 0.25s ease, border-color 0.25s ease;
  }

  .refs-load-more:hover {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.38);
    color: #fff;
  }

  .refs-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    width: 100%;
  }

  .refs-page-list {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .refs-page-btn,
  .refs-page-arrow {
    appearance: none;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.03);
    color: rgba(245,245,247,0.86);
    min-width: 46px;
    height: 46px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font: inherit;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.25s ease, border-color 0.25s ease, color 0.25s ease, transform 0.25s ease;
  }

  .refs-page-btn:hover,
  .refs-page-arrow:hover {
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.22);
    color: #fff;
    transform: translateY(-1px);
  }

  .refs-page-btn.is-active {
    background: linear-gradient(135deg, rgba(255,255,255,0.18), rgba(255,255,255,0.08));
    border-color: rgba(255,255,255,0.28);
    color: #fff;
  }

  .refs-page-arrow:disabled {
    opacity: 0.36;
    cursor: not-allowed;
    transform: none;
  }

  /* Card */
  .ref-main-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(10, 10, 12, 0.75);
    background-clip: padding-box;
    overflow: hidden;
    text-decoration: none;
    color: #fff;
    position: relative;
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1),
                border-color 0.4s ease,
                box-shadow 0.4s ease;
  }

  @media (hover: hover) {
    .ref-main-card:hover {
      transform: translateY(-4px);
      border-color: rgba(255, 255, 255, 0.16);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.05),
        0 28px 60px rgba(0, 0, 0, 0.32);
    }
    .ref-main-card:hover .ref-main-card-img img {
      transform: scale(1.04);
    }
  }

  /* Image Area */
  .ref-main-card-img {
    position: relative;
    aspect-ratio: 16 / 8.5;
    overflow: hidden;
    flex-shrink: 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .ref-main-card-img--purple {
    background: radial-gradient(ellipse at 25% 35%, rgba(166,77,255,0.45) 0%, transparent 55%), #0c0814;
  }
  .ref-main-card-img--cyan {
    background: radial-gradient(ellipse at 25% 35%, rgba(0,210,255,0.35) 0%, transparent 55%), #030d14;
  }
  .ref-main-card-img--coral {
    background: radial-gradient(ellipse at 25% 35%, rgba(255,92,168,0.36) 0%, transparent 55%), #140812;
  }
  .ref-main-card-img img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: top center;
    display: block;
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .ref-main-badge {
    position: absolute;
    top: 16px; left: 16px;
    z-index: 1;
  }

  /* Card Body */
  .ref-main-card-body {
    padding: 34px 28px 30px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .ref-main-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 10px;
  }
  .ref-main-card-year {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.3);
    white-space: nowrap;
    padding-top: 4px;
  }
  .ref-main-card-title {
    font-size: 1.28rem;
    font-weight: 700;
    margin: 0;
    color: #fff;
    line-height: 1.14;
  }
  .ref-main-card-sub {
    font-size: 0.85rem;
    color: var(--secondary-accent);
    margin-bottom: 14px;
    font-weight: 500;
  }
  .ref-main-card-desc {
    font-size: 0.92rem;
    color: var(--text-muted);
    line-height: 1.58;
    margin: 0;
    flex: 1;
  }

  /* Footer */
  .ref-main-card-footer {
    margin-top: 22px;
    padding-top: 18px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .ref-main-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
    transition: color 0.3s ease, gap 0.3s ease;
  }
  .ref-main-card:hover .ref-main-link {
    color: #fff;
    gap: 12px;
  }

  .refs-final-section {
    padding-top: 52px;
    padding-bottom: 118px;
  }

  .refs-final-cta {
    max-width: 660px;
  }

  .refs-final-cta .cta-label {
    color: rgba(255, 255, 255, 0.42);
  }

  .refs-final-cta h2 {
    color: #f5f5f7;
    font-size: clamp(2.25rem, 4.5vw, 3.7rem);
    line-height: 1.04;
    letter-spacing: 0;
    margin-bottom: 0;
  }

  .refs-final-cta h2 span {
    color: rgba(255, 255, 255, 0.62);
  }

  .refs-final-cta .hero-cta-group {
    margin-top: 34px;
  }

  .refs-final-cta .btn-primary:hover {
    box-shadow:
      inset 0 2px 4px rgba(255, 255, 255, 1),
      0 10px 26px rgba(255, 255, 255, 0.14);
  }

  /* Responsive */
  @media (max-width: 860px) {
    .refs-hero {
      min-height: auto;
      padding-top: 136px;
      padding-bottom: 44px;
    }

    .refs-hero__title {
      font-size: clamp(2.55rem, 10vw, 3.8rem);
      line-height: var(--hero-title-line-height-mobile);
    }

    .refs-grid {
      grid-template-columns: 1fr;
      gap: 24px;
      max-width: none;
      margin-left: 0;
      margin-right: 0;
    }

    .refs-intro {
      margin-bottom: 52px;
    }

    .refs-controls {
      margin-top: 30px;
      margin-bottom: 56px;
      gap: 18px;
    }
  }

  @media (max-width: 520px) {
    .refs-hero .breadcrumb {
      margin-bottom: 22px;
    }

    .refs-hero__lead {
      font-size: 1.02rem;
      line-height: 1.6;
    }

    .refs-hero__title {
      font-size: clamp(2.35rem, 13vw, 3.25rem);
      line-height: var(--hero-title-line-height-mobile);
      margin-bottom: 20px;
    }

    .refs-intro {
      margin-bottom: 38px;
    }

    .refs-controls {
      margin-top: 24px;
      margin-bottom: 44px;
      gap: 14px;
    }

    .refs-load-more {
      max-width: 100%;
      min-height: 0;
      padding: 0 0 4px;
    }

    .refs-pagination {
      gap: 10px;
    }

    .refs-page-list {
      gap: 8px;
    }

    .refs-page-btn,
    .refs-page-arrow {
      min-width: 42px;
      height: 42px;
      font-size: 0.9rem;
    }

    .ref-main-card-body {
      padding: 30px 22px 26px;
    }

    .ref-main-card-img {
      aspect-ratio: 16 / 9;
    }

    .ref-main-card-title {
      font-size: 1.22rem;
      line-height: 1.18;
    }

    .refs-final-section {
      padding-top: 40px;
      padding-bottom: 88px;
    }

    .refs-final-cta h2 {
      font-size: clamp(1.8rem, 11vw, 2.5rem);
    }
  }
</style>
