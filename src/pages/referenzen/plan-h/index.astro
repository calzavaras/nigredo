---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CaseMoreReferences from '../../../components/CaseMoreReferences.astro';

const liveUrl = 'https://www.plan-h.ch';
const pageUrl = 'https://www.nigredo.ch/referenzen/plan-h/';
const detailImage = '/referenzen/plan-h/plan-h-hypnosetherapie-website-startseite-screenshot.png';
const ogImage = 'https://www.nigredo.ch/referenzen/plan-h/plan-h-hypnosetherapie-website-startseite-screenshot-og.jpg';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Referenzen", "item": "https://www.nigredo.ch/referenzen/" },
        { "@type": "ListItem", "position": 3, "name": "Website für Plan H", "item": pageUrl }
      ]
    },
    {
      "@type": ["WebSite", "CreativeWork"],
      "@id": `${pageUrl}#website-project`,
      "name": "Plan H Hypnosetherapie",
      "url": liveUrl,
      "description": "Website für Plan H Hypnosetherapie in Bernhardzell bei St. Gallen mit lokaler Google-Ausrichtung, WhatsApp-Kontakt, sortierbaren Stimmen, strukturierter SEO-Basis und klarer Angebotsführung.",
      "keywords": [
        "Hypnosetherapie Website",
        "Website für Hypnosetherapie",
        "Plan H",
        "Local SEO St. Gallen",
        "Google Integration",
        "WhatsApp Kontakt",
        "strukturierte Daten",
        "Kundenstimmen Website"
      ],
      "featureList": [
        "Responsive Astro-Website mit statischer Auslieferung",
        "Lokale Suchmaschinenoptimierung für Bernhardzell und St. Gallen",
        "Google-relevante Metadaten, Sitemap, robots.txt und strukturierte Daten",
        "Direkte Kontaktwege mit E-Mail, Telefon und WhatsApp",
        "Stimmen-Seite mit sortierbarer Darstellung",
        "Angebotsseite mit klarem Ablauf, Preisen und Service-Schema",
        "LLM-Dateien für KI-Crawler und maschinenlesbare Inhalte"
      ],
      "inLanguage": "de-CH",
      "dateCreated": "2026-06-01",
      "creator": { "@id": "https://www.nigredo.ch/#person" },
      "author": { "@id": "https://www.nigredo.ch/#person" },
      "publisher": { "@id": "https://www.nigredo.ch/#organization" },
      "maintainer": { "@id": "https://www.nigredo.ch/#organization" },
      "isPartOf": { "@id": "https://www.nigredo.ch/referenzen/#webpage" },
      "about": {
        "@type": "LocalBusiness",
        "name": "Plan H Hypnosetherapie",
        "url": liveUrl,
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Lee 1021",
          "postalCode": "9304",
          "addressLocality": "Bernhardzell",
          "addressRegion": "St. Gallen",
          "addressCountry": "CH"
        }
      },
      "hasPart": [
        {
          "@type": "WebPage",
          "name": "Plan H Startseite",
          "url": `${liveUrl}/`
        },
        {
          "@type": "WebPage",
          "name": "Plan H Angebot",
          "url": `${liveUrl}/angebot/`
        },
        {
          "@type": "WebPage",
          "name": "Plan H Stimmen",
          "url": `${liveUrl}/stimmen/`
        },
        {
          "@type": "ContactPage",
          "name": "Plan H Kontakt",
          "url": `${liveUrl}/kontakt/`
        }
      ],
      "potentialAction": {
        "@type": "ContactAction",
        "target": `${liveUrl}/kontakt/`,
        "name": "Termin bei Plan H anfragen"
      },
      "image": ogImage
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "name": "Website für Plan H Hypnosetherapie | Nigredo Referenzen",
      "url": pageUrl,
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "inLanguage": "de-CH",
      "datePublished": "2026-06-17",
      "dateModified": "2026-06-17",
      "about": { "@id": `${pageUrl}#website-project` },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "isAccessibleForFree": true,
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", ".case-hero-lead", ".case-feature-body h3"]
      }
    }
  ]
});
---

<Layout
  title="Website für Plan H Hypnosetherapie | Nigredo Referenzen"
  description="Plan-H-Website mit Local SEO, WhatsApp-Kontakt, Google-Struktur, sortierbaren Stimmen und klarer Angebotsführung für Hypnosetherapie."
  canonical={pageUrl}
  ogTitle="Website für Plan H Hypnosetherapie"
  ogDescription="Ein ruhiger Webauftritt mit Local SEO, WhatsApp-Kontakt, Google-Struktur und sortierbaren Stimmen."
  ogImage={ogImage}
  ogImageAlt="Screenshot der Plan-H-Hypnosetherapie-Website mit Hero-Bereich, Navigation und türkisfarbener Illustration"
  ogImageWidth="1200"
  ogImageHeight="831"
  twitterTitle="Website für Plan H Hypnosetherapie"
  twitterDescription="Praxis-Website mit Local SEO, WhatsApp-Kontakt, Google-Struktur und klarer Anfrageführung."
  schema={schema}
  preloadImage={detailImage}
  preloadImageType="image/png"
>
  <section class="section pt-sub case-page case-page--plan-h" aria-labelledby="plan-h-title">
    <div class="hero-glow"></div>
    <div class="container case-page__container">
      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Referenzen', href: '/referenzen/' },
        { label: 'Plan H' }
      ]} />

      <a href="/referenzen/" class="case-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
        Alle Referenzen
      </a>

      <div class="case-hero fade-up">
        <div class="case-hero-content">
          <span class="tech-badge accent-coral case-hero-badge">Website</span>
          <h1 id="plan-h-title" class="home-hero__title case-hero-title case-hero-title--plan-h"><span class="case-hero-title-line">Website für</span> <span class="gradient-text">Plan H</span></h1>
          <p class="hero-lead case-hero-lead">
            Für Plan H entstand ein ruhiger Praxisauftritt, der Vertrauen aufbaut und technisch sauber arbeitet: lokale Google-Ausrichtung, strukturierte Daten, klare Angebotsseiten, sortierbare Stimmen und direkte Kontaktwege bis hin zum WhatsApp-Chat.
          </p>
          <div class="hero-cta-group">
            <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">Website besuchen</a>
          </div>
        </div>

        <div class="case-hero-visual">
          <div class="case-hero-canvas case-hero-canvas--coral">
            <button
              type="button"
              class="case-hero-float case-hero-float--wide lightbox-trigger"
              data-gallery={`["${detailImage}"]`}
              data-gallery-index="0"
              aria-label="Website-Vorschau vergrössern"
            >
              <img
                src={detailImage}
                alt="Screenshot der Plan H Hypnosetherapie Website mit Hero Bereich und ruhiger türkisfarbener Gestaltung"
                width="1696" height="1174"
                loading="eager"
                decoding="async"
                fetchpriority="high"
              >
            </button>
          </div>
        </div>
      </div>

      <div class="case-stats fade-up delay-100" style="--stats-cols: 5;">
        <div class="case-stat">
          <strong class="stat-website">Website</strong>
          <span>statisch schnell</span>
        </div>
        <div class="case-stat">
          <strong class="stat-website">Google</strong>
          <span>lokal ausgerichtet</span>
        </div>
        <div class="case-stat">
          <strong class="stat-website">WhatsApp</strong>
          <span>direkt verlinkt</span>
        </div>
        <div class="case-stat">
          <strong class="stat-website">Stimmen</strong>
          <span>sortierbar</span>
        </div>
        <div class="case-stat">
          <strong class="stat-website">Schema</strong>
          <span>maschinenlesbar</span>
        </div>
      </div>

      <div class="case-section fade-up delay-100">
        <div class="case-section-hd">
          <span class="case-eyebrow">Was wurde gebaut</span>
          <h2 class="case-section-title">Praxiswebsite mit Kontaktlogik, Local SEO und Vertrauenselementen</h2>
        </div>
        <div class="case-features">
          <div class="case-feature">
            <div class="case-feature-body">
              <div class="case-feature-icon case-feature-icon--coral">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#therapie-feature-grad-1)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><defs><linearGradient id="therapie-feature-grad-1" x1="4" y1="3" x2="20" y2="21" gradientUnits="userSpaceOnUse"><stop stop-color="#FF2E63"/><stop offset="0.48" stop-color="#FF4D80"/><stop offset="1" stop-color="#A64DFF"/></linearGradient></defs><path d="M12 4.5c3.8 0 6.8 3.2 8.2 7.5-1.4 4.3-4.4 7.5-8.2 7.5S5.2 16.3 3.8 12C5.2 7.7 8.2 4.5 12 4.5z"/><path d="M12 9.1a2.9 2.9 0 1 1 0 5.8 2.9 2.9 0 0 1 0-5.8z"/><path d="M18.5 4.5l.8 1.7 1.7.8-1.7.8-.8 1.7-.8-1.7-1.7-.8 1.7-.8.8-1.7z"/></svg>
              </div>
              <div class="case-feature-text">
                <h3>Ruhige Marke, klare technische Grundlage</h3>
                <p>Die Startseite übersetzt das Plan-H-Thema in eine klare digitale Dramaturgie: ein ruhiger Einstieg, verständliche Nutzenführung und ein statischer Astro-Aufbau, der schnell lädt, stabil ausliefert und ohne unnötige Systemabhängigkeiten funktioniert.</p>
              </div>
            </div>
          </div>
          <div class="case-feature">
            <div class="case-feature-body">
              <div class="case-feature-icon case-feature-icon--coral">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#therapie-feature-grad-2)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><defs><linearGradient id="therapie-feature-grad-2" x1="3" y1="3" x2="21" y2="21" gradientUnits="userSpaceOnUse"><stop stop-color="#FF2E63"/><stop offset="0.48" stop-color="#FF4D80"/><stop offset="1" stop-color="#A64DFF"/></linearGradient></defs><path d="M5 7h6"/><path d="M5 12h10"/><path d="M5 17h7"/><path d="M16.5 6.5l2 2 2-2"/><path d="M18.5 8.5v7"/><path d="M16.5 17.5l2-2 2 2"/></svg>
              </div>
              <div class="case-feature-text">
                <h3>Google-Integration und lokale Auffindbarkeit</h3>
                <p>Die Website ist auf Hypnosetherapie in Bernhardzell, St. Gallen und Umgebung ausgerichtet. Seitentitel, Beschreibungen, Sitemap, robots.txt, LocalBusiness-Daten und Angebots-Schema geben Google klare Signale, worum es geht, wo Plan H tätig ist und welche Leistungen angeboten werden.</p>
              </div>
            </div>
          </div>
          <div class="case-feature">
            <div class="case-feature-body">
              <div class="case-feature-icon case-feature-icon--coral">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#therapie-feature-grad-3)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><defs><linearGradient id="therapie-feature-grad-3" x1="4" y1="2" x2="20" y2="22" gradientUnits="userSpaceOnUse"><stop stop-color="#FF2E63"/><stop offset="0.48" stop-color="#FF4D80"/><stop offset="1" stop-color="#A64DFF"/></linearGradient></defs><path d="M5 12h11"/><path d="M12 6l6 6-6 6"/><path d="M5 7.5h4"/><path d="M5 16.5h4"/><path d="M18.5 4.5l.7 1.5 1.5.7-1.5.7-.7 1.5-.7-1.5-1.5-.7 1.5-.7.7-1.5z"/></svg>
              </div>
              <div class="case-feature-text">
                <h3>Kontakt ohne Reibung: Formular, Telefon und WhatsApp</h3>
                <p>Wer bereit ist, soll nicht suchen müssen. Die Kontaktseite bündelt E-Mail, Telefon und WhatsApp-Chat so, dass eine Anfrage direkt aus der Situation heraus möglich ist. Das senkt die Hürde für ein erstes Gespräch und macht den nächsten Schritt spürbar einfacher.</p>
              </div>
            </div>
          </div>
          <div class="case-feature">
            <div class="case-feature-body">
              <div class="case-feature-icon case-feature-icon--coral">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#therapie-feature-grad-4)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><defs><linearGradient id="therapie-feature-grad-4" x1="3" y1="3" x2="21" y2="21" gradientUnits="userSpaceOnUse"><stop stop-color="#FF2E63"/><stop offset="0.48" stop-color="#FF4D80"/><stop offset="1" stop-color="#A64DFF"/></linearGradient></defs><path d="M6 18l7.8-7.8 2.7 2.7L8.7 20H6v-2z"/><path d="M15.7 8.3l1.2-1.2a1.9 1.9 0 0 1 2.7 2.7l-1.2 1.2"/><path d="M5 6.5h7"/><path d="M5 10h5"/><path d="M5 13.5h3"/></svg>
              </div>
              <div class="case-feature-text">
                <h3>Stimmen, Angebot und Inhalte sauber strukturiert</h3>
                <p>Die Stimmen-Seite macht Erfahrungsberichte gezielt zugänglich und erlaubt eine sortierbare Darstellung. Angebot, Ablauf und Kosten sind getrennt aufgebaut, maschinenlesbar ergänzt und so formuliert, dass Menschen und Suchmaschinen den Inhalt schnell einordnen können.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <span class="case-date fade-up">Abgeschlossen: Juni 2026</span>

      <div class="fade-up case-more-section">
        <span class="case-more-label">Weitere Projekte</span>
        <CaseMoreReferences />
      </div>

      <div class="section case-final-section fade-up">
        <div class="section-cta case-final-cta">
          <span class="cta-label">Der nächste Schritt</span>
          <h2>Braucht deine Website<br><span>mehr Klarheit?</span></h2>
          <div class="hero-cta-group" style="justify-content: center;">
            <a href="/kontakt/" class="btn btn-primary">Kontakt aufnehmen</a>
            <a href="/referenzen/" class="btn btn-ghost">Alle Projekte</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  .case-page--plan-h {
    --case-accent: #ff2e63;
    --case-accent-2: #ff2e63;
    --case-accent-3: #ff2e63;
    --case-accent-soft: rgba(255, 46, 99, 0.16);
    --case-accent-glow: rgba(255, 46, 99, 0.22);
  }

  .case-page--plan-h .gradient-text {
    background: linear-gradient(180deg, color-mix(in srgb, var(--case-accent) 92%, white 10%) 0%, color-mix(in srgb, var(--case-accent) 72%, black 16%) 100%);
    background-size: 260% auto;

    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .case-page--plan-h .case-hero-title-line {
    display: block;
  }

  .case-page--plan-h .case-hero-canvas--coral {
    background:
      radial-gradient(ellipse at 50% 50%, rgba(255, 46, 99, 0.24) 0%, rgba(255, 46, 99, 0.08) 48%, rgba(255, 255, 255, 0.02) 100%),
      #0a0a0c;
    border-color: rgba(255, 46, 99, 0.18);
  }

  .case-page--plan-h .case-feature:hover {
    border-color: rgba(255, 255, 255, 0.16);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 28px 60px rgba(0, 0, 0, 0.32),
      0 0 28px rgba(255, 46, 99, 0.08);
  }

  .case-page--plan-h .case-feature-icon svg {
    filter:
      brightness(1.14)
      saturate(1.18)
      drop-shadow(0 0 8px rgba(255, 46, 99, 0.18));
  }

  .case-page--plan-h .case-feature:hover .case-feature-icon svg {
    filter:
      brightness(1.2)
      saturate(1.32)
      drop-shadow(0 0 12px rgba(255, 46, 99, 0.2))
      drop-shadow(0 0 22px rgba(255, 46, 99, 0.14));
  }

  .case-feature-text p + p {
    margin-top: 12px;
  }

  .stat-website {
    background: linear-gradient(180deg, color-mix(in srgb, var(--case-accent) 90%, white 10%) 0%, color-mix(in srgb, var(--case-accent) 68%, black 18%) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .case-page--plan-h .case-hero-float--wide {
    width: 82%;
  }

  @media (max-width: 860px) {
    .case-page--plan-h .case-hero-float--wide { width: 100%; }
  }
</style>
