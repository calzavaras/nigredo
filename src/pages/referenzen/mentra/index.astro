---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CaseMoreReferences from '../../../components/CaseMoreReferences.astro';

const pageUrl = 'https://www.nigredo.ch/referenzen/mentra/';
const detailImage = '/referenzen/mentra/mentra-video-wissenssystem-app-screenshot-2160.webp';
const detailImageAvif = '/referenzen/mentra/mentra-video-wissenssystem-app-screenshot-2160.avif';
const ogImage = 'https://www.nigredo.ch/referenzen/mentra/mentra-video-wissenssystem-app-screenshot-og.jpg';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Referenzen", "item": "https://www.nigredo.ch/referenzen/" },
        { "@type": "ListItem", "position": 3, "name": "Mentra Video-Wissenssystem", "item": pageUrl }
      ]
    },
    {
      "@type": "SoftwareApplication",
      "@id": `${pageUrl}#software`,
      "name": "Mentra Video-Wissenssystem",
      "url": pageUrl,
      "description": "Privates KI Video Wissenssystem für den lokalen Betrieb. Es erschliesst Videos mit Archiv, semantischer Suche, quellengestütztem KI Chat, Reviews, Quizfragen und Exporten.",
      "applicationCategory": "BusinessApplication",
      "applicationSubCategory": "Knowledge Management",
      "operatingSystem": "Web Browser",
      "inLanguage": "de-CH",
      "dateCreated": "2026-05-20",
      "datePublished": "2026-06-06",
      "featureList": [
        "Video-Archiv mit Kategorien, Plattformen, Tags und Favoriten",
        "Providerunabhängige KI-Verarbeitung mit OpenAI, Anthropic, Gemini oder lokalen Modellen",
        "Semantische Suche und KI-Chat mit Quellenbezug",
        "Reviews nach FSRS-Logik, Highlights, Quizfragen und Lernblöcke",
        "Exportpfade für Markdown, Anki, JSON und PDF-nahe Ausgaben",
        "Lokaler Betrieb auf dem Rechner des Kunden",
        "Private Authentifizierung, verschlüsselte API-Keys, Rate-Limits und Audit-Logs"
      ],
      "screenshot": [
        {
          "@type": "ImageObject",
          "url": ogImage,
          "caption": "Mentra Video-Wissenssystem mit Archiv, KI-Chat, Suche, Reviews und Exporten"
        }
      ],
      "creator": { "@id": "https://www.nigredo.ch/#organization" }
    },
    {
      "@type": "ImageObject",
      "@id": `${pageUrl}#primaryimage`,
      "url": ogImage,
      "contentUrl": ogImage,
      "width": 1200,
      "height": 630,
      "caption": "Mentra Video Wissenssystem mit Archiv, KI Chat, Suche, Reviews und Exporten"
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "name": "Mentra Video-Wissenssystem | Nigredo Referenzen",
      "url": pageUrl,
      "description": "Lokales KI Video Wissenssystem mit Archiv, semantischer Suche, Quellen, Reviews und Exporten.",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "inLanguage": "de-CH",
      "datePublished": "2026-06-06",
      "dateModified": "2026-07-17",
      "about": { "@id": `${pageUrl}#software` },
      "mainEntity": { "@id": `${pageUrl}#software` },
      "primaryImageOfPage": { "@id": `${pageUrl}#primaryimage` },
      "publisher": { "@id": "https://www.nigredo.ch/#organization" },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "isAccessibleForFree": true
    }
  ]
});
---

<Layout
  title="Mentra Video-Wissenssystem | Nigredo Referenzen"
  description="Lokales KI Video Wissenssystem mit Archiv, semantischer Suche, Quellen, Reviews und Exporten. Daten und Modelle bleiben beim Kunden."
  canonical={pageUrl}
  ogTitle="Mentra Video-Wissenssystem"
  ogDescription="Lokales Wissenssystem für Videos mit KI Auswertung, semantischer Suche, Quellen, Reviews, Quiz und Exporten."
  ogImage={ogImage}
  ogImageAlt="Oberfläche der lokalen Mentra-App mit KI-gestützter Suche im Video-Wissensarchiv"
  ogImageWidth="1200"
  ogImageHeight="630"
  twitterTitle="Mentra Video-Wissenssystem"
  twitterDescription="Lokales KI Video Wissenssystem mit Archiv, semantischer Suche, Quellen, Reviews und Exporten."
  schema={schema}
  preloadImage={detailImageAvif}
  preloadImageType="image/avif"
>
  <section class="section pt-sub case-page case-page--mentra" aria-labelledby="mentra-title">
    <div class="hero-glow"></div>
    <div class="container case-page__container">
      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Referenzen', href: '/referenzen/' },
        { label: 'Mentra' }
      ]} />

      <a href="/referenzen/" class="case-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
        Alle Referenzen
      </a>

      <div class="case-hero fade-up">
        <div class="case-hero-content">
          <h1 id="mentra-title" class="home-hero__title case-hero-title">Mentra <span class="gradient-text">Wissen aus Videos.</span></h1>
          <p class="hero-lead case-hero-lead">
            Mentra verwandelt Videos in nutzbares Wissen. Die lokale Anwendung erfasst Inhalte, ordnet wichtige Stellen, beantwortet Fragen mit Quellen und plant Wiederholungen. Daten und Modelle bleiben dabei unter der Kontrolle des Kunden.
          </p>
        </div>

        <div class="case-hero-visual">
          <div class="case-hero-canvas case-hero-canvas--mentra">
            <button
              type="button"
              class="case-hero-float case-hero-float--wide lightbox-trigger"
              data-gallery={`["${detailImage}"]`}
              data-gallery-index="0"
              aria-label="Mentra Produktvisual vergrössern"
            >
              <picture>
                <source
                  srcset={detailImageAvif}
                  type="image/avif"
                >
                <img
                  src={detailImage}
                  alt="Oberfläche der lokalen Mentra-App mit KI-gestützter Suche im Video-Wissensarchiv"
                  width="2160"
                  height="1215"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                >
              </picture>
            </button>
          </div>
        </div>
      </div>

      <div class="case-stats fade-up delay-100" style="--stats-cols: 4;">
        <div class="case-stat">
          <strong class="stat-tool">KI</strong>
          <span>Provider frei</span>
        </div>
        <div class="case-stat">
          <strong class="stat-tool">Suche</strong>
          <span>Semantisch</span>
        </div>
        <div class="case-stat">
          <strong class="stat-tool">FSRS</strong>
          <span>Reviews</span>
        </div>
        <div class="case-stat">
          <strong class="stat-tool">Next</strong>
          <span>Prisma + MySQL</span>
        </div>
      </div>

      <div class="case-section fade-up delay-100">
        <div class="case-section-hd">
          <span class="case-eyebrow">Ergebnis im Detail</span>
          <h2 class="case-section-title">Video Wissen, das im Alltag nutzbar bleibt</h2>
        </div>
        <div class="case-features">
          <div class="case-feature">
            <div class="case-feature-body">
              <div class="case-feature-icon case-feature-icon--purple">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#mentra-feature-grad-1)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><defs><linearGradient id="mentra-feature-grad-1" x1="3" y1="3" x2="21" y2="21" gradientUnits="userSpaceOnUse"><stop stop-color="var(--brand-violet)"/><stop offset="0.5" stop-color="var(--brand-pink)"/><stop offset="1" stop-color="var(--brand-cyan)"/></linearGradient></defs><path d="M4 6h16"/><path d="M4 12h10"/><path d="M4 18h7"/><path d="m16 15 4 3-4 3v-6Z"/></svg>
              </div>
              <div class="case-feature-text">
                <h3>Ein Archiv statt verstreuter Links</h3>
                <p>Jedes Video wird zu einem klaren Eintrag mit Kategorien, Tags, Status und eigenen Notizen. So bleiben Themen auffindbar und ihr Kontext erhalten.</p>
              </div>
            </div>
          </div>
          <div class="case-feature">
            <div class="case-feature-body">
              <div class="case-feature-icon case-feature-icon--purple">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#mentra-feature-grad-2)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><defs><linearGradient id="mentra-feature-grad-2" x1="4" y1="2" x2="20" y2="22" gradientUnits="userSpaceOnUse"><stop stop-color="var(--brand-violet)"/><stop offset="0.5" stop-color="var(--brand-pink)"/><stop offset="1" stop-color="var(--brand-cyan)"/></linearGradient></defs><circle cx="11" cy="11" r="6"/><path d="m20 20-3.5-3.5"/><path d="M8.5 10.5h7"/><path d="M8.5 13.5h4"/></svg>
              </div>
              <div class="case-feature-text">
                <h3>Semantische Suche und Chat mit Quellen</h3>
                <p>Statt lange zu suchen, stellst du eine Frage. Die Suche durchsucht Transkripte, Zusammenfassungen und Notizen. Der KI Chat greift nur auf dein eigenes Wissen zu, zeigt die Quellen und macht Antworten überprüfbar.</p>
              </div>
            </div>
          </div>
          <div class="case-feature">
            <div class="case-feature-body">
              <div class="case-feature-icon case-feature-icon--purple">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#mentra-feature-grad-3)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><defs><linearGradient id="mentra-feature-grad-3" x1="3" y1="3" x2="21" y2="21" gradientUnits="userSpaceOnUse"><stop stop-color="var(--brand-violet)"/><stop offset="0.5" stop-color="var(--brand-pink)"/><stop offset="1" stop-color="var(--brand-cyan)"/></linearGradient></defs><path d="M12 3v4"/><path d="M12 17v4"/><path d="M5 8h14"/><path d="M5 16h14"/><path d="m8 12 2 2 4-5"/><path d="M17 12h1"/></svg>
              </div>
              <div class="case-feature-text">
                <h3>Lernen mit Reviews, Highlights und Quiz</h3>
                <p>Wichtige Stellen lassen sich markieren und nach der FSRS-Logik im passenden Moment wiederholen. Quizfragen und Lernblöcke unterstützen dabei, Inhalte nicht nur abzulegen, sondern sicher zu erinnern.</p>
              </div>
            </div>
          </div>
          <div class="case-feature">
            <div class="case-feature-body">
              <div class="case-feature-icon case-feature-icon--purple">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="url(#mentra-feature-grad-4)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><defs><linearGradient id="mentra-feature-grad-4" x1="4" y1="2" x2="20" y2="22" gradientUnits="userSpaceOnUse"><stop stop-color="var(--brand-violet)"/><stop offset="0.5" stop-color="var(--brand-pink)"/><stop offset="1" stop-color="var(--brand-cyan)"/></linearGradient></defs><path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><path d="M14 3v6h6"/><path d="M8 13h8"/><path d="M8 17h5"/></svg>
              </div>
              <div class="case-feature-text">
                <h3>Lokal, privat und exportierbar</h3>
                <p>Die App läuft lokal, mit verschlüsselten Zugängen, klaren Limits und nachvollziehbaren Protokollen. OpenAI, Anthropic, Gemini oder ein lokales Modell sind frei wählbar; Exporte stehen als Markdown, Anki oder JSON bereit.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <span class="case-date fade-up">Abgeschlossen: Juni 2026</span>

      <div class="fade-up case-more-section">
        <span class="case-more-label">Weitere Projekte</span>
        <CaseMoreReferences />
      </div>

      <div class="section case-final-section fade-up">
        <div class="section-cta case-final-cta">
          <span class="cta-label">Der nächste Schritt</span>
          <h2>Soll dein Wissen<br><span>auffindbar und nutzbar werden?</span></h2>
          <div class="hero-cta-group" style="justify-content: center;">
            <a href="/kontakt/" class="btn btn-primary">Kontakt aufnehmen</a>
            <a href="/referenzen/" class="btn btn-ghost">Alle Projekte</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  .case-page--mentra {
    --case-accent: var(--brand-violet);
    --case-accent-2: var(--brand-pink);
    --case-accent-3: var(--brand-blue);
    --case-title-gradient: var(--brand-gradient-cool);
    --case-accent-soft: color-mix(in srgb, var(--case-accent) 14%, transparent);
    --case-accent-glow: color-mix(in srgb, var(--case-accent) 26%, transparent);
  }

  .case-page--mentra .case-hero-float--wide {
    width: 100%;
  }

  .case-page--mentra .gradient-text {
    background: var(--case-title-gradient);
    background-size: 100% auto;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .case-page--mentra .stat-tool {
    background: var(--case-title-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .case-page--mentra .case-hero-canvas--mentra {
    background:
      radial-gradient(ellipse at 46% 42%, rgba(166, 77, 255, 0.28) 0%, rgba(214, 63, 255, 0.1) 50%, rgba(255, 255, 255, 0.02) 100%),
      #080a0e;
    border-color: rgba(166, 77, 255, 0.18);
  }

  .case-page--mentra .case-feature:hover {
    border-color: rgba(255, 255, 255, 0.16);
    box-shadow: var(--shadow-card-hover),
      0 0 28px rgba(166, 77, 255, 0.09);
  }

  .case-page--mentra .case-feature-icon svg {
    filter:
      brightness(1.14)
      saturate(1.18)
      drop-shadow(0 0 8px rgba(166, 77, 255, 0.2));
  }

</style>
