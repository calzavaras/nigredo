---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CaseMoreReferences from '../../../components/CaseMoreReferences.astro';

const pageUrl = 'https://www.nigredo.ch/referenzen/ki-voice-agent/';
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Referenzen", "item": "https://www.nigredo.ch/referenzen/" },
        { "@type": "ListItem", "position": 3, "name": "KI Voice Agent für IV-Stellen", "item": pageUrl }
      ]
    },
    {
      "@type": "SoftwareApplication",
      "@id": `${pageUrl}#software`,
      "name": "KI Voice Agent für IV-Stellen",
      "url": pageUrl,
      "description": "KI-gestützter Sprachassistent, der autonom Anrufe zu AHV-Hilfsmitteln beantwortet. Echtzeit-Sprachverarbeitung mit Google Gemini 2.5 Flash, vier Sprachen, 24/7 verfügbar.",
      "applicationCategory": "BusinessApplication",
      "applicationSubCategory": "Artificial Intelligence",
      "operatingSystem": "Web Browser",
      "inLanguage": ["de", "fr", "it", "en"],
      "dateCreated": "2026-01-01",
      "datePublished": "2026-02-28",
      "featureList": [
        "Echtzeit-Sprachverarbeitung",
        "Google Gemini 2.5 Flash",
        "Fachwissen AHV-Hilfsmittel",
        "Mehrsprachig (DE/FR/IT/EN)",
        "24/7 autonom erreichbar",
        "Live-Transkript"
      ],
      "screenshot": [
        {
          "@type": "ImageObject",
          "url": "https://www.nigredo.ch/referenzen/ki-voice-agent/ki-voice-agent-ahv-hilfsmittel-sprachassistent-og.jpg",
          "caption": "KI Voice Agent im aktiven Gespräch mit Audio-Visualizer und Live-Transkript"
        }
      ],
      "creator": { "@id": "https://www.nigredo.ch/#organization" }
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "name": "KI Voice Agent für IV-Stellen | Nigredo Referenzen",
      "url": pageUrl,
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "inLanguage": "de-CH",
      "datePublished": "2026-02-28",
      "dateModified": "2026-07-14",
      "about": { "@id": `${pageUrl}#software` },
      "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
      "isAccessibleForFree": true
    }
  ]
});
---

<Layout
  title="KI Voice Agent für IV-Stellen | Nigredo Referenzen"
  description="KI-Sprachassistent für AHV-Hilfsmittel: Echtzeit-Verarbeitung, vier Sprachen und 24/7 erreichbar. Prototyp für Schweizer IV-Stellen."
  canonical={pageUrl}
  ogTitle="KI Voice Agent für IV-Stellen"
  ogDescription="Sprachassistent mit Google Gemini 2.5 Flash: 24/7 autonom, vier Sprachen (DE/FR/IT/EN), echtes Fachwissen zu AHV-Hilfsmitteln. Prototyp für Schweizer IV-Stellen."
  ogImage="https://www.nigredo.ch/referenzen/ki-voice-agent/ki-voice-agent-ahv-hilfsmittel-sprachassistent-og.jpg"
  ogImageAlt="KI Voice Agent für IV-Stellen mit Echtzeit-Transkript von Nigredo"
  ogImageWidth="587"
  ogImageHeight="793"
  twitterTitle="KI Voice Agent für IV-Stellen"
  twitterDescription="24/7 autonom, vier Sprachen, echtes Fachwissen zu AHV-Hilfsmitteln. KI-Sprachassistent von Nigredo."
  schema={schema}
  preloadImage="/referenzen/ki-voice-agent/ki-voice-agent-ahv-hilfsmittel-sprachassistent.webp"
  preloadImageType="image/webp"
>
  <section class="section pt-sub case-page case-page--ki" aria-labelledby="ki-voice-agent-title">
    <div class="hero-glow"></div>
    <div class="container case-page__container">

      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Referenzen', href: '/referenzen/' },
        { label: 'KI Voice Agent' }
      ]} />

      <a href="/referenzen/" class="case-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
        Alle Referenzen
      </a>

      <!-- Hero: Split Layout -->
      <div class="case-hero fade-up">
        <div class="case-hero-content">
          <span class="tech-badge accent-purple case-hero-badge">KI-Lösung</span>
          <h1 id="ki-voice-agent-title" class="home-hero__title case-hero-title">KI Voice Agent <span class="gradient-text">für IV-Stellen</span></h1>
          <p class="hero-lead case-hero-lead">
            Dieser Prototyp beantwortet wiederkehrende Fachfragen ohne Warteschleife. Der Agent ist rund um die Uhr erreichbar, spricht vier Sprachen und greift gezielt auf hinterlegtes Wissen zu AHV-Hilfsmitteln zu.
          </p>
        </div>

        <div class="case-hero-visual">
          <div class="case-hero-canvas case-hero-canvas--purple">
            <button
              type="button"
              class="case-hero-float lightbox-trigger"
              data-gallery='["/referenzen/ki-voice-agent/ki-voice-agent-ahv-hilfsmittel-sprachassistent.webp"]'
              data-gallery-index="0"
              aria-label="Screenshot vergrössern"
            >
              <img
                src="/referenzen/ki-voice-agent/ki-voice-agent-ahv-hilfsmittel-sprachassistent.webp"
                alt="Screenshot KI Voice Agent Sprachassistent für AHV-Hilfsmittel der IV-Stellen, entwickelt von Nigredo"
                width="587" height="793"
                loading="eager"
                decoding="async"
                fetchpriority="high"
              >
            </button>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="case-stats fade-up delay-100" style="--stats-cols: 4;">
        <div class="case-stat">
          <strong class="stat-ki">4</strong>
          <span>Sprachen</span>
        </div>
        <div class="case-stat">
          <strong class="stat-ki">24/7</strong>
          <span>Erreichbar</span>
        </div>
        <div class="case-stat">
          <strong class="stat-ki">0s</strong>
          <span>Wartezeit</span>
        </div>
        <div class="case-stat">
          <strong class="stat-ki">AHV</strong>
          <span>Fachwissen</span>
        </div>
      </div>

      <!-- Lösung -->
      <div class="case-section fade-up delay-100">
        <div class="case-section-hd">
          <span class="case-eyebrow">Ergebnis im Detail</span>
          <h2 class="case-section-title">Sprachassistent mit KI für IV-Stellen</h2>
        </div>
        <div class="case-features">
          <div class="case-feature">
            <div class="case-feature-body">
              <div class="case-feature-icon case-feature-icon--purple">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="url(#voice-feature-grad-1)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><defs><linearGradient id="voice-feature-grad-1" x1="3" y1="2" x2="21" y2="23" gradientUnits="userSpaceOnUse"><stop stop-color="var(--brand-violet)"/><stop offset="0.52" stop-color="var(--brand-pink)"/><stop offset="1" stop-color="var(--brand-cyan)"/></linearGradient></defs><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
              </div>
              <div class="case-feature-text">
                <h3>Gespräch in Echtzeit</h3>
                <p>Keine Menüs, kein «Drücken Sie 1». Der Agent führt ein echtes Gespräch, versteht das Anliegen und antwortet in Echtzeit, getragen von Google Gemini 2.5 Flash mit nativem Audio.</p>
              </div>
            </div>
          </div>
          <div class="case-feature">
            <div class="case-feature-body">
              <div class="case-feature-icon case-feature-icon--purple">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="url(#voice-feature-grad-2)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><defs><linearGradient id="voice-feature-grad-2" x1="4" y1="2" x2="20" y2="22" gradientUnits="userSpaceOnUse"><stop stop-color="var(--brand-violet)"/><stop offset="0.52" stop-color="var(--brand-pink)"/><stop offset="1" stop-color="var(--brand-cyan)"/></linearGradient></defs><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
              </div>
              <div class="case-feature-text">
                <h3>Tiefes Fachwissen</h3>
                <p>Der Agent beantwortet komplexe Fragen zu AHV-Hilfsmitteln auf Basis des hinterlegten Fachwissens und des Kreisschreibens KSHA. So entstehen nachvollziehbare Antworten mit fachlicher Substanz.</p>
              </div>
            </div>
          </div>
          <div class="case-feature">
            <div class="case-feature-body">
              <div class="case-feature-icon case-feature-icon--purple">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="url(#voice-feature-grad-3)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><defs><linearGradient id="voice-feature-grad-3" x1="2" y1="2" x2="22" y2="22" gradientUnits="userSpaceOnUse"><stop stop-color="var(--brand-violet)"/><stop offset="0.52" stop-color="var(--brand-pink)"/><stop offset="1" stop-color="var(--brand-cyan)"/></linearGradient></defs><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              </div>
              <div class="case-feature-text">
                <h3>Vier Sprachen, ein Gesprächsfluss</h3>
                <p>Deutsch, Französisch, Italienisch und Englisch sind direkt verfügbar. Der Agent erkennt die Sprache, bleibt im Kontext und verarbeitet auch Anliegen, die nicht in einen Standardsatz passen.</p>
              </div>
            </div>
          </div>
          <div class="case-feature">
            <div class="case-feature-body">
              <div class="case-feature-icon case-feature-icon--purple">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="url(#voice-feature-grad-4)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><defs><linearGradient id="voice-feature-grad-4" x1="2" y1="2" x2="22" y2="22" gradientUnits="userSpaceOnUse"><stop stop-color="var(--brand-violet)"/><stop offset="0.52" stop-color="var(--brand-pink)"/><stop offset="1" stop-color="var(--brand-cyan)"/></linearGradient></defs><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div class="case-feature-text">
                <h3>Verlässlich erreichbar</h3>
                <p>Der Prototyp zeigt, wie wiederkehrende Auskünfte unabhängig von Öffnungszeiten verfügbar werden und Fachpersonen bei Standardfragen entlasten können.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <span class="case-date fade-up">Abgeschlossen: Februar 2026</span>

      <!-- Weitere Projekte -->
      <div class="fade-up case-more-section">
        <span class="case-more-label">Weitere Projekte</span>
        <CaseMoreReferences />
      </div>

      <!-- CTA -->
      <div class="section case-final-section fade-up">
        <div class="section-cta case-final-cta">
          <span class="cta-label">Der nächste Schritt</span>
          <h2>Noch zu viele<br><span>Warteschleifen?</span></h2>
          <div class="hero-cta-group" style="justify-content: center;">
            <a href="/kontakt/" class="btn btn-primary">Gespräch starten</a>
            <a href="/referenzen/" class="btn btn-ghost">Alle Projekte</a>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style is:global>
  .case-page--ki {
    --case-accent: var(--brand-violet);
    --case-accent-2: var(--brand-pink);
    --case-accent-3: var(--brand-blue);
    --case-accent-soft: color-mix(in srgb, var(--case-accent) 14%, transparent);
    --case-accent-glow: color-mix(in srgb, var(--case-accent) 26%, transparent);
  }

  .case-page--ki .gradient-text {
    background: var(--case-gradient-ki);
    background-size: 100% auto;

    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .stat-ki {
    background: var(--case-gradient-ki);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .case-page--ki .case-hero-canvas--purple {
    background:
      radial-gradient(ellipse at 50% 50%, rgba(166, 77, 255, 0.28) 0%, rgba(214, 63, 255, 0.1) 52%, rgba(255, 255, 255, 0.02) 100%),
      #0a0a0c;
    border-color: rgba(166, 77, 255, 0.16);
  }

  .case-page--ki .case-feature:hover {
    border-color: rgba(255, 255, 255, 0.16);
    box-shadow: var(--shadow-card-hover),
      0 0 28px rgba(166, 77, 255, 0.08);
  }
</style>

<style>
  .case-hero-float { width: 54%; }
</style>
