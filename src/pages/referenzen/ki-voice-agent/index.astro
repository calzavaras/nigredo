---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.nigredo.ch/referenzen/ki-voice-agent#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.nigredo.ch/" },
        { "@type": "ListItem", "position": 2, "name": "Referenzen", "item": "https://www.nigredo.ch/referenzen" },
        { "@type": "ListItem", "position": 3, "name": "KI Voice Agent für IV-Stellen", "item": "https://www.nigredo.ch/referenzen/ki-voice-agent" }
      ]
    },
    {
      "@type": "SoftwareApplication",
      "@id": "https://www.nigredo.ch/referenzen/ki-voice-agent#software",
      "name": "KI Voice Agent für IV-Stellen",
      "url": "https://www.nigredo.ch/referenzen/ki-voice-agent",
      "description": "KI-gestützter Sprachassistent, der autonom Anrufe zu AHV-Hilfsmitteln beantwortet. Echtzeit-Sprachverarbeitung mit Google Gemini 2.5 Flash, vier Sprachen, 24/7 verfügbar.",
      "applicationCategory": "BusinessApplication",
      "applicationSubCategory": "Artificial Intelligence",
      "operatingSystem": "Web Browser",
      "inLanguage": ["de", "fr", "it", "en"],
      "dateCreated": "2026-01-01",
      "datePublished": "2026-02-28",
      "featureList": [
        "Echtzeit-Sprachverarbeitung",
        "Google Gemini 2.5 Flash",
        "Fachwissen AHV-Hilfsmittel",
        "Mehrsprachig (DE/FR/IT/EN)",
        "24/7 autonom erreichbar",
        "Live-Transkript"
      ],
      "screenshot": [
        {
          "@type": "ImageObject",
          "url": "https://www.nigredo.ch/referenzen/ki-voice-agent/ki-voice-agent-ahv-hilfsmittel-sprachassistent.png",
          "caption": "KI Voice Agent im aktiven Gespräch mit Audio-Visualizer und Live-Transkript"
        }
      ],
      "creator": { "@id": "https://www.nigredo.ch/#organization" }
    },
    {
      "@type": "WebPage",
      "@id": "https://www.nigredo.ch/referenzen/ki-voice-agent#webpage",
      "name": "KI Voice Agent für IV-Stellen | Nigredo Referenzen",
      "url": "https://www.nigredo.ch/referenzen/ki-voice-agent",
      "isPartOf": { "@id": "https://www.nigredo.ch/#website" },
      "inLanguage": "de-CH",
      "datePublished": "2026-02-28",
      "dateModified": "2026-03-21",
      "about": { "@id": "https://www.nigredo.ch/referenzen/ki-voice-agent#software" },
      "breadcrumb": { "@id": "https://www.nigredo.ch/referenzen/ki-voice-agent#breadcrumb" },
      "isAccessibleForFree": true,
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", ".case-hero-lead", ".case-feature-body h3"]
      }
    }
  ]
});
---

<Layout
  title="KI Voice Agent für IV-Stellen | Nigredo Referenzen"
  description="KI-gestützter Sprachassistent für AHV-Hilfsmittel: Echtzeit-Sprachverarbeitung mit Google Gemini 2.5 Flash, vier Sprachen (DE/FR/IT/EN), 24/7 autonom erreichbar. Prototyp für Schweizer IV-Stellen von Nigredo."
  keywords="KI Voice Agent, Sprachassistent AHV, IV-Stellen Schweiz, Google Gemini 2.5 Flash, Echtzeit-Sprachverarbeitung, 24/7 Telefonsupport, KI Telefonie, automatischer Kundenservice"
  canonical="https://www.nigredo.ch/referenzen/ki-voice-agent"
  ogTitle="KI Voice Agent für IV-Stellen"
  ogDescription="24/7 autonom, vier Sprachen, echtes Fachwissen zu AHV-Hilfsmitteln. KI-Sprachassistent von Nigredo für Schweizer IV-Stellen."
  ogImage="https://www.nigredo.ch/referenzen/ki-voice-agent/ki-voice-agent-ahv-hilfsmittel-sprachassistent.png"
  ogImageAlt="KI Voice Agent für IV-Stellen – Sprachassistent mit Echtzeit-Transkript von Nigredo"
  ogImageWidth="1456"
  ogImageHeight="816"
  twitterTitle="KI Voice Agent für IV-Stellen"
  twitterDescription="24/7 autonom, vier Sprachen, echtes Fachwissen zu AHV-Hilfsmitteln. KI-Sprachassistent von Nigredo."
  schema={schema}
>
  <section class="section pt-sub case-page case-page--ki" aria-labelledby="ki-voice-agent-title">
    <div class="hero-glow"></div>
    <div class="container case-page__container">

      <Breadcrumb items={[
        { label: 'Start', href: '/' },
        { label: 'Referenzen', href: '/referenzen' },
        { label: 'KI Voice Agent' }
      ]} />

      <a href="/referenzen" class="case-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
        Alle Referenzen
      </a>

      <!-- Hero: Split Layout -->
      <div class="case-hero fade-up">
        <div class="case-hero-content">
          <span class="tech-badge accent-purple case-hero-badge">KI-Agent</span>
          <h1 id="ki-voice-agent-title" class="home-hero__title case-hero-title">KI Voice Agent <span class="gradient-text">für IV-Stellen</span></h1>
          <p class="hero-lead case-hero-lead">
            Niemand wartet gerne in der Leitung. Dieser Agent auch nicht. Er antwortet sofort, spricht vier Sprachen und hat das Fachwissen zu AHV-Hilfsmitteln griffbereit. Ohne Kaffeepause, Rückfrage oder Warteschleife.
          </p>
        </div>

        <div class="case-hero-visual">
          <div class="case-hero-canvas case-hero-canvas--purple">
            <button
              type="button"
              class="case-hero-float lightbox-trigger"
              data-gallery='["/referenzen/ki-voice-agent/ki-voice-agent-ahv-hilfsmittel-sprachassistent.png"]'
              data-gallery-index="0"
              aria-label="Screenshot vergrössern"
            >
              <img
                src="/referenzen/ki-voice-agent/ki-voice-agent-ahv-hilfsmittel-sprachassistent.png"
                alt="KI Voice Agent – Lio, Fachmitarbeiter Hilfsmittel AHV"
                width="1456" height="816"
              >
            </button>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="case-stats fade-up delay-100" style="--stats-cols: 4;">
        <div class="case-stat">
          <strong class="stat-purple-cyan">4</strong>
          <span>Sprachen</span>
        </div>
        <div class="case-stat">
          <strong class="stat-purple-cyan">24/7</strong>
          <span>Erreichbar</span>
        </div>
        <div class="case-stat">
          <strong class="stat-purple-cyan">0s</strong>
          <span>Wartezeit</span>
        </div>
        <div class="case-stat">
          <strong class="stat-purple-cyan">AHV</strong>
          <span>Fachwissen</span>
        </div>
      </div>

      <!-- Lösung -->
      <div class="case-section fade-up delay-100">
        <div class="case-section-hd">
          <span class="case-eyebrow">Was wurde gebaut</span>
          <h2 class="case-section-title">Die Lösung</h2>
        </div>
        <div class="case-features">
          <div class="case-feature">
            <div class="case-feature-body">
              <div class="case-feature-icon case-feature-icon--purple">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="url(#voice-feature-grad-1)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><defs><linearGradient id="voice-feature-grad-1" x1="3" y1="2" x2="21" y2="23" gradientUnits="userSpaceOnUse"><stop stop-color="#A64DFF"/><stop offset="1" stop-color="#FF4D80"/></linearGradient></defs><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
              </div>
              <div class="case-feature-text">
                <h3>Echtzeit-Gespräch</h3>
                <p>Keine Menüs, kein «Drücken Sie 1». Der Agent führt ein natürliches Gespräch, versteht das Anliegen und antwortet in Echtzeit über Google Gemini 2.5 Flash mit nativem Audio.</p>
              </div>
            </div>
          </div>
          <div class="case-feature">
            <div class="case-feature-body">
              <div class="case-feature-icon case-feature-icon--purple">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="url(#voice-feature-grad-2)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><defs><linearGradient id="voice-feature-grad-2" x1="4" y1="2" x2="20" y2="22" gradientUnits="userSpaceOnUse"><stop stop-color="#A64DFF"/><stop offset="1" stop-color="#FF4D80"/></linearGradient></defs><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
              </div>
              <div class="case-feature-text">
                <h3>Tiefes Fachwissen</h3>
                <p>Fachwissen zu AHV-Hilfsmitteln, Hörgeräten und dem Kreisschreiben KSHA. Damit entstehen Antworten mit Substanz statt freundliche Sätze ohne Inhalt.</p>
              </div>
            </div>
          </div>
          <div class="case-feature">
            <div class="case-feature-body">
              <div class="case-feature-icon case-feature-icon--purple">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="url(#voice-feature-grad-3)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><defs><linearGradient id="voice-feature-grad-3" x1="2" y1="2" x2="22" y2="22" gradientUnits="userSpaceOnUse"><stop stop-color="#A64DFF"/><stop offset="1" stop-color="#FF4D80"/></linearGradient></defs><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              </div>
              <div class="case-feature-text">
                <h3>Vier Sprachen, null Geduldsproben</h3>
                <p>Deutsch, Französisch, Italienisch und Englisch. Der Agent bleibt geduldig, auch wenn das Anliegen nicht in einen Standardsatz passt.</p>
              </div>
            </div>
          </div>
          <div class="case-feature">
            <div class="case-feature-body">
              <div class="case-feature-icon case-feature-icon--purple">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="url(#voice-feature-grad-4)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><defs><linearGradient id="voice-feature-grad-4" x1="2" y1="2" x2="22" y2="22" gradientUnits="userSpaceOnUse"><stop stop-color="#A64DFF"/><stop offset="1" stop-color="#FF4D80"/></linearGradient></defs><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div class="case-feature-text">
                <h3>Immer da</h3>
                <p>Feiertag, Nachtschicht, Personalengpass. Der Agent nimmt es nicht persönlich. Er ist einfach erreichbar.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <span class="case-date fade-up">Abgeschlossen: Februar 2026</span>

      <!-- Weitere Projekte -->
      <div class="fade-up case-more-section">
        <span class="case-more-label">Weitere Projekte</span>
        <div id="case-more-grid" class="case-more-grid"></div>
      </div>

      <!-- CTA -->
      <div class="section case-final-section fade-up">
        <div class="section-cta case-final-cta">
          <span class="cta-label">Der nächste Schritt</span>
          <h2>Noch zu viele<br><span>Warteschleifen?</span></h2>
          <div class="hero-cta-group" style="justify-content: center;">
            <a href="/kontakt" class="btn btn-primary">Gespräch starten</a>
            <a href="/referenzen" class="btn btn-ghost">Alle Projekte</a>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style is:global>
  /* Case Specific overrides */
  .case-page--ki {
    --case-accent: #a64dff;
    --case-accent-2: #ff4d80;
    --case-accent-soft: rgba(166, 77, 255, 0.14);
    --case-accent-glow: rgba(166, 77, 255, 0.26);
  }

  .case-page {
    padding-top: 150px;
    padding-bottom: 48px;
  }

  .case-page__container {
    position: relative;
    width: 100%;
  }

  .case-page .breadcrumb {
    margin-bottom: 28px;
  }

  .case-page .case-back {
    margin-bottom: 44px;
  }

  .case-page .case-back:hover {
    color: var(--case-accent);
  }

  .case-page .case-hero {
    margin-bottom: 72px;
  }

  .case-page .case-hero-badge {
    margin-bottom: 1rem;
  }

  .case-page .case-hero-title {
    max-width: 940px;
    font-size: clamp(2.9rem, 5.35vw, 4.85rem);
    line-height: var(--hero-title-line-height);
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }

  .case-page--ki .gradient-text {
    background: linear-gradient(to right, #a64dff, #ff4d80, #a64dff);
    background-size: 200% auto;
    animation: gradientPan 24s linear infinite;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .case-page .case-hero-lead {
    max-width: 620px;
    font-size: clamp(1.03rem, 1.15vw, 1.2rem);
    line-height: 1.65;
    color: var(--text-secondary);
    margin-bottom: 0;
  }

  .case-hero-float { width: 54%; }

  .stat-purple-cyan {
    background: linear-gradient(135deg, var(--case-accent) 0%, var(--case-accent-2) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .case-page--ki .case-hero-canvas--purple {
    background:
      radial-gradient(ellipse at 50% 50%, rgba(166, 77, 255, 0.26) 0%, rgba(255, 255, 255, 0.02) 100%),
      #0a0a0c;
    border-color: rgba(166, 77, 255, 0.16);
  }

  .case-feature-body {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 22px;
  }
  .case-feature-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.045),
      0 0 14px rgba(166, 77, 255, 0.14);
    transition:
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.35s ease,
      background 0.35s ease,
      box-shadow 0.35s ease;
  }
  .case-feature-icon--purple { background: rgba(166,77,255,0.08); border: 1px solid rgba(166,77,255,0.2); color: #A64DFF; }
  .case-feature-icon--cyan { background: rgba(0,210,255,0.08); border: 1px solid rgba(0,210,255,0.2); color: #00D2FF; }
  .case-page--ki .case-feature {
    background-image:
      linear-gradient(#0a0a0c, #0a0a0c),
      conic-gradient(from var(--border-angle, 0turn), rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.05) 24%, rgba(166, 77, 255, 0.2) 42%, rgba(255, 77, 128, 0.26) 58%, rgba(255, 255, 255, 0.05) 78%, rgba(255, 255, 255, 0.05) 100%);
  }
  .case-page--ki .case-feature:hover {
    box-shadow: 0 10px 30px rgba(166, 77, 255, 0.12);
    background-image:
      linear-gradient(#0a0a0c, #0a0a0c),
      conic-gradient(from var(--border-angle, 0turn), rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.08) 22%, rgba(166, 77, 255, 0.52) 42%, rgba(255, 77, 128, 0.48) 58%, rgba(255, 255, 255, 0.08) 80%, rgba(255, 255, 255, 0.08) 100%);
  }
  .case-feature-icon svg {
    filter:
      brightness(1.12)
      saturate(1.18)
      drop-shadow(0 0 8px var(--case-accent-glow));
    transition: filter 0.45s ease;
  }
  .case-feature:hover .case-feature-icon {
    transform: translateY(-1px);
    border-color: rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.04);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 0 22px var(--case-accent-glow),
      0 0 48px var(--case-accent-soft);
  }
  .case-feature:hover .case-feature-icon svg {
    filter:
      brightness(1.18)
      saturate(1.35)
      drop-shadow(0 0 12px var(--case-accent-glow))
      drop-shadow(0 0 24px var(--case-accent-soft));
  }
  
  .case-feature-text h3 { font-size: 1rem; margin-bottom: 6px; }
  .case-feature-text p { font-size: 0.875rem; line-height: 1.65; margin: 0; color: var(--text-muted); }

  .case-final-section {
    padding-top: 52px;
    padding-bottom: 118px;
  }

  .case-final-cta {
    max-width: 660px;
  }

  .case-final-cta .cta-label {
    color: rgba(255, 255, 255, 0.42);
  }

  .case-final-cta h2 {
    color: #f5f5f7;
    font-size: clamp(2.25rem, 4.5vw, 3.7rem);
    line-height: 1.04;
    letter-spacing: 0;
    margin-bottom: 0;
  }

  .case-final-cta h2 span {
    color: rgba(255, 255, 255, 0.62);
  }

  .case-final-cta .hero-cta-group {
    margin-top: 34px;
  }

  .case-final-cta .btn-ghost {
    background-image:
      linear-gradient(#050505, #050505),
      linear-gradient(rgba(255, 255, 255, 0.15), rgba(255, 255, 255, 0.15));
  }

  .case-final-cta .btn-ghost:hover {
    animation: none;
    transform: translateY(-2px);
    background-image:
      linear-gradient(#0a0a0c, #0a0a0c),
      linear-gradient(rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0.3));
    box-shadow: 0 10px 26px rgba(255, 255, 255, 0.08);
  }

  .case-final-cta .btn-primary:hover {
    box-shadow:
      inset 0 2px 4px rgba(255, 255, 255, 1),
      0 10px 26px rgba(255, 255, 255, 0.14);
  }

  @media (max-width: 768px) {
    .case-feature-body { flex-direction: column; gap: 16px; }
  }

  @media (max-width: 860px) {
    .case-page {
      padding-top: 132px;
      padding-bottom: 42px;
    }

    .case-page .case-hero-title {
      font-size: clamp(2.55rem, 10vw, 3.8rem);
      line-height: var(--hero-title-line-height-mobile);
    }
  }

  @media (max-width: 520px) {
    .case-page .case-hero-title {
      font-size: clamp(2.35rem, 13vw, 3.25rem);
      line-height: var(--hero-title-line-height-mobile);
    }

    .case-page .case-hero-lead {
      font-size: 1.02rem;
      line-height: 1.6;
    }

    .case-final-section {
      padding-top: 40px;
      padding-bottom: 88px;
    }

    .case-final-cta h2 {
      font-size: clamp(1.8rem, 11vw, 2.5rem);
    }
  }
</style>

<script>
  const REFS_ALL = [
    {
      href: '/referenzen/ki-voice-agent',
      imgSrc: '/referenzen/ki-voice-agent/ki-voice-agent-ahv-hilfsmittel-sprachassistent.svg',
      imgAlt: 'KI Voice Agent für IV-Stellen – AHV Hilfsmittel Sprachassistent von Nigredo',
      imgCls: 'case-more-card-img--purple',
      badge: { text: 'KI-Agent', cls: 'accent-purple' },
      title: 'KI Voice Agent für IV-Stellen',
      desc: 'Beantwortet Anfragen zu AHV-Hilfsmitteln sofort, mehrsprachig und ohne Warteschleife.'
    },
    {
      href: '/referenzen/dashboard-kantonsverwaltung',
      imgSrc: '/referenzen/dashboard-kantonsverwaltung/dashboard-kantonsverwaltung-excel-kpi-browser.svg',
      imgAlt: 'Dashboard für Verwaltung – Excel KPI-Auswertung im Browser von Nigredo',
      imgCls: 'case-more-card-img--cyan',
      badge: { text: 'App', cls: 'accent-cyan' },
      title: 'Dashboard für Verwaltung',
      desc: 'Wertet Excel-Daten lokal aus, anonymisiert sensible Angaben und erstellt klare Berichte.'
    }
  ];

  const ARROW = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>';

  function shuffle(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  const current = window.location.pathname.replace(/\/$/, '');
  const others = shuffle(REFS_ALL.filter(r => r.href !== current)).slice(0, 4);
  const grid = document.getElementById('case-more-grid');
  if (grid && others.length > 0) {
    grid.innerHTML = others.map(r => `
      <a href="${r.href}" class="case-more-card">
        <div class="case-more-card-img ${r.imgCls}">
          <img src="${r.imgSrc}" alt="${r.imgAlt}" loading="lazy" width="800" height="450">
        </div>
        <div class="case-more-card-body">
          <span class="tech-badge ${r.badge.cls}">${r.badge.text}</span>
          <p class="case-more-card-title">${r.title}</p>
          <p class="case-more-card-desc">${r.desc}</p>
          <span class="case-more-card-arrow">Details ansehen ${ARROW}</span>
        </div>
      </a>`).join('');
  }
</script>
