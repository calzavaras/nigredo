---
import Layout from '../../../layouts/Layout.astro';
import ReferencesArchiveSection from '../../../components/ReferencesArchiveSection.astro';
import { getReferencePage, getReferencePageCount, getReferencePageHref } from '../../../data/references';

export function getStaticPaths() {
  const pageCount = getReferencePageCount();
  return Array.from({ length: Math.max(0, pageCount - 1) }, (_, index) => {
    const pageNumber = index + 2;
    return {
      params: { page: String(pageNumber) },
      props: {
        pageNumber,
        pageItems: getReferencePage(pageNumber),
      },
    };
  });
}

const { pageNumber, pageItems } = Astro.props;
const pageCount = getReferencePageCount();

const rawHref = getReferencePageHref(pageNumber);
const pageHref = rawHref.endsWith('/') ? rawHref : `${rawHref}/`;
const pageUrl = `https://www.nigredo.ch${pageHref}`;
const referenceArchiveModified = '2026-07-14';
const rawPrevHref = getReferencePageHref(pageNumber - 1);
const prevHref = rawPrevHref.endsWith('/') ? rawPrevHref : `${rawPrevHref}/`;
const rawNextHref = pageNumber < pageCount ? getReferencePageHref(pageNumber + 1) : undefined;
const nextHref = rawNextHref ? (rawNextHref.endsWith('/') ? rawNextHref : `${rawNextHref}/`) : undefined;
const prevUrl = `https://www.nigredo.ch${prevHref}`;
const nextUrl = nextHref ? `https://www.nigredo.ch${nextHref}` : undefined;

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Start', item: 'https://www.nigredo.ch/' },
        { '@type': 'ListItem', position: 2, name: 'Referenzen', item: 'https://www.nigredo.ch/referenzen/' },
        { '@type': 'ListItem', position: 3, name: `Seite ${pageNumber}`, item: pageUrl },
      ],
    },
    {
      '@type': 'CollectionPage',
      '@id': `${pageUrl}#webpage`,
      url: pageUrl,
      name: `Referenzprojekte, Seite ${pageNumber} | Nigredo`,
      description: 'Weitere Referenzprojekte von Nigredo. KI, Websites, Wissensplattformen und Software für Schweizer KMU und Verwaltungen.',
      inLanguage: 'de-CH',
      datePublished: '2025-06-01',
      dateModified: referenceArchiveModified,
      isPartOf: { '@id': 'https://www.nigredo.ch/#website' },
      breadcrumb: { '@id': `${pageUrl}#breadcrumb` },
      isAccessibleForFree: true,
      mainEntity: {
        '@type': 'ItemList',
        itemListElement: pageItems.map((item, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          url: `https://www.nigredo.ch${item.href}`,
          name: item.listTitle,
        })),
      },
    },
  ],
});
---

<Layout
  title={`Referenzprojekte, Seite ${pageNumber} | Nigredo`}
  description="Weitere Referenzprojekte von Nigredo. KI, Websites, Wissensplattformen und Software für Schweizer KMU und Verwaltungen."
  canonical={pageUrl}
  ogTitle={`Referenzen, Seite ${pageNumber} | Nigredo`}
  ogDescription="Weitere Referenzen von Nigredo."
  ogImageAlt="Nigredo Referenzen mit weiteren Projekten"
  twitterTitle={`Referenzen, Seite ${pageNumber} | Nigredo`}
  twitterDescription="Weitere Referenzen von Nigredo."
  schema={schema}
  prevUrl={prevUrl}
  nextUrl={nextUrl}
>
  <ReferencesArchiveSection pageNumber={pageNumber} pageCount={pageCount} pageItems={pageItems} />
</Layout>
